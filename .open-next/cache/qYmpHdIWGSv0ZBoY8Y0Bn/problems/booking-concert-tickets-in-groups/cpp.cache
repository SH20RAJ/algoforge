c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nc:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nd:[\"$\",\"$1\",\"c\",{\"children\":[\"$L15\",[[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0a2gmow1_jiq0.js\",\"async\":true,\"nonce\":\"$undefined\"}]],[\"$\",\"$L16\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@18\"}]}]]}]\n19:[]\ne:\"$W19\"\nf:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1a\",null,{\"children\":\"$L1b\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1d\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n11:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/340fxer6uczx7.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n1e:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n1f:T192b,// Time:  ctor:    O(n)\n//        gather:  O(logn)\n//        scatter: O(logn), amortized\n// Space: O(n)\n\n// design, segment tree, binary search, optimized from bookmyshow2\nclass BookMyShow {\npublic:\n    BookMyShow(int n, int m)\n      : st_(n, m)\n      , m_(m)\n      , i_(0) {\n    }\n    \n    vector<int> gather(int k, int maxRow) {\n        int i = 1;\n        if (k > st_.tree[i][0]) {\n            return {};\n        }\n        while (i < st_.base) {\n            i = 2 * i + static_cast<int>(st_.tree[2 * i][0] < k);\n        }\n        if (i - st_.base > maxRow) {\n            return {};\n        }\n        int cnt = st_.tree[i][0];\n        int c = m_ - cnt;\n        i -= st_.base;\n        st_.update(i, vector<int64_t>(2, cnt - k));\n        return {i, c};\n    }\n    \n    bool scatter(int k, int maxRow) {\n        if (k > st_.query(i_, maxRow)) {\n            return false;\n        }\n        for (int i = i_; i <= maxRow && k; ++i) {\n            int cnt = st_.tree[st_.base + i][1];\n            int c = min(cnt, k);\n            cnt -= c;\n            if (!cnt) {\n                ++i_;\n            }\n            st_.update(i, vector<int64_t>(2, cnt));\n            k -= c;\n        }\n        return true;\n    }\n\nprivate:\n    // Template:\n    // https://github.com/kamyu104/LeetCode-Solutions/blob/master/C++/longest-substring-of-one-repeating-character.cpp\n    class SegmentTree {\n     public:\n        explicit SegmentTree(int N, int m)\n          : tree(N > 1 ? 1 << (__lg(N - 1) + 2) : 2, vector<int64_t>(2)),\n            base(N > 1 ? 1 << (__lg(N - 1) + 1) : 1) {\n\n            for (int i = base; i < base + N; ++i) {\n                tree[i][0] = tree[i][1] = m;\n            }\n            for (int i = base - 1; i >= 1; --i) {\n                tree[i][0] = max(tree[i * 2][0], tree[i * 2 + 1][0]);\n                tree[i][1] = tree[i * 2][1] + tree[i * 2 + 1][1];\n            }\n        }\n\n        void update(int i, const vector<int64_t>& h) {\n            int x = base + i;\n            tree[x] = h;\n            while (x > 1) {\n                x /= 2;\n                tree[x][0] = max(tree[x * 2][0], tree[x * 2 + 1][0]);\n                tree[x][1] = tree[x * 2][1] + tree[x * 2 + 1][1];\n            }\n        }\n\n        int64_t query(int L, int R) {\n            L += base;\n            R += base;\n            int64_t result = 0;\n            for (; L <= R; L /= 2, R /= 2) {\n                if (L & 1) {\n                    result += tree[L][1];\n                    ++L;\n                }\n                if ((R & 1) == 0) {\n                    result += tree[R][1];\n                    --R;\n                }\n            }\n            return result;\n        }\n\n        vector<vector<int64_t>> tree;\n        int base;\n    };\n\n    SegmentTree st_;\n    int m_;\n    int i_;\n};\n\n// Time:  ctor:    O(n)\n//        gather:  O(logn)\n//        scatter: O(logn), amortized\n// Space: O(n)\n// design, segment tree, binary search\nclass BookMyShow2 {\npublic:\n    BookMyShow2(int n, int m)\n      : m_(m)\n      , i_(0) {\n\n        const auto& build = [&m] (const auto& i) {\n            return vector<int64_t>({m, m});\n        };\n        const auto& update = [] (const auto& c) {\n            return c;\n        };\n        const auto& query = [] (const auto& x, const auto& y) {\n            if (empty(x)) {\n                return y;\n            }\n            if (empty(y)) {\n                return x;\n            }\n            return vector<int64_t>({max(x[0], y[0]), x[1] + y[1]});\n        };\n\n        st_ = make_unique<SegmentTree<vector<int64_t>>>(n, build, update, query);\n    }\n    \n    vector<int> gather(int k, int maxRow) {\n        int i = 1;\n        if (k > st_->tree[i][0]) {\n            return {};\n        }\n        while (i < st_->base) {\n            i = 2 * i + static_cast<int>(st_->tree[2 * i][0] < k);\n        }\n        if (i - st_->base > maxRow) {\n            return {};\n        }\n        int cnt = st_->tree[i][0];\n        int c = m_ - cnt;\n        i -= st_->base;\n        st_->update(i, vector<int64_t>(2, cnt - k));\n        return {i, c};\n    }\n    \n    bool scatter(int k, int maxRow) {\n        const auto cnt = st_->query(i_, maxRow);\n        if (empty(cnt) || cnt[1] < k) {\n            return false;\n        }\n        for (int i = i_; i <= maxRow && k; ++i) {\n            int cnt = st_->tree[st_->base + i][1];\n            int c = min(cnt, k);\n            cnt -= c;\n            if (!cnt) {\n                ++i_;\n            }\n            st_->update(i, vector<int64_t>(2, cnt));\n            k -= c;\n        }\n        return true;\n    }\n\nprivate:\n    // Template:\n    // https://github.com/kamyu104/LeetCode-Solutions/blob/master/C++/longest-substring-of-one-repeating-character.cpp\n    template <typename T>\n    class SegmentTree {\n     public:\n        explicit SegmentTree(\n            int N,\n            const function<T(const int&)>& build_fn,\n            const function<T(const T&)>& update_fn,\n            const function<T(const T&, const T&)>& query_fn)\n          : tree(N > 1 ? 1 << (__lg(N - 1) + 2) : 2),\n            base(N > 1 ? 1 << (__lg(N - 1) + 1) : 1),\n            build_fn_(build_fn),\n            query_fn_(query_fn),\n            update_fn_(update_fn) {\n\n            for (int i = base; i < base + N; ++i) {\n                tree[i] = build_fn_(i - base);\n            }\n            for (int i = base - 1; i >= 1; --i) {\n                tree[i] = query_fn_(tree[2 * i], tree[2 * i + 1]);\n            }\n        }\n\n        void update(int i, const T& h) {\n            int x = base + i;\n            tree[x] = update_fn_(h);\n            while (x > 1) {\n                x /= 2;\n                tree[x] = query_fn_(tree[x * 2], tree[x * 2 + 1]);\n            }\n        }\n\n        T query(int L, int R) {\n            L += base;\n            R += base;\n            T left, right;\n            for (; L <= R; L /= 2, R /= 2) {\n                if (L & 1) {\n                    left = query_fn_(left, tree[L]);\n                    ++L;\n                }\n                if ((R & 1) == 0) {\n                    right = query_fn_(tree[R], right);\n                    --R;\n                }\n            }\n            return query_fn_(left, right);\n        }\n\n        vector<T> tree;\n        int base;\n\n    private:\n        const function<T(const int&)> build_fn_;\n        const function<T(const T&)> update_fn_;\n        const function<T(const T&, const T&)> query_fn_;\n    };\n\n    unique_ptr<SegmentTree<vector<int64_t>>> st_;\n    int m_;\n    int i_;\n};\n20:Tb85,# Time:  ctor:    O(n)\n#        gather:  O(logn)\n#        scatter: O(logn), amortized\n# Space: O(n)\n\n# Template:\n# https://github.com/kamyu104/LeetCode-Solutions/blob/master/Python/longest-substring-of-one-repeating-character.py\nclass SegmentTree(object):\n    def __init__(self, N,\n                 build_fn=lambda _: float(\"inf\"),\n                 query_fn=lambda x, y: y if x is None else x if y is None else min(x, y),\n                 update_fn=lambda x: x):\n        self.tree = [None]*(2*2**((N-1).bit_length()))\n        self.base = len(self.tree)//2\n        self.query_fn = query_fn\n        self.update_fn = update_fn\n        for i in xrange(self.base, self.base+N):\n            self.tree[i] = build_fn(i-self.base)\n        for i in reversed(xrange(1, self.base)):\n            self.tree[i] = query_fn(self.tree[2*i], self.tree[2*i+1])\n\n    def update(self, i, h):\n        x = self.base+i\n        self.tree[x] = self.update_fn(h)\n        while x > 1:\n            x //= 2\n            self.tree[x] = self.query_fn(self.tree[x*2], self.tree[x*2+1])\n\n    def query(self, L, R):\n        L += self.base\n        R += self.base\n        left = right = None\n        while L <= R:\n            if L & 1:\n                left = self.query_fn(left, self.tree[L])\n                L += 1\n            if R & 1 == 0:\n                right = self.query_fn(self.tree[R], right)\n                R -= 1\n            L //= 2\n            R //= 2\n        return self.query_fn(left, right)\n\n\n# design, segment tree, binary search\nclass BookMyShow(object):\n\n    def __init__(self, n, m):\n        \"\"\"\n        :type n: int\n        :type m: int\n        \"\"\"\n        self.__st = SegmentTree(n,\n                                build_fn=lambda _: [m]*2,\n                                query_fn=lambda x, y: y if x is None else x if y is None else [max(x[0], y[0]), x[1]+y[1]])\n        self.__m = m\n        self.__i = 0\n\n    def gather(self, k, maxRow):\n        \"\"\"\n        :type k: int\n        :type maxRow: int\n        :rtype: List[int]\n        \"\"\"\n        i = 1\n        if k > self.__st.tree[i][0]:\n            return []\n        while i < self.__st.base:\n            i = 2*i+int(self.__st.tree[2*i][0] < k)\n        if i-self.__st.base > maxRow:\n            return []\n        cnt = self.__st.tree[i][0]\n        c = self.__m-cnt\n        i -= self.__st.base\n        self.__st.update(i, [cnt-k]*2)\n        return [i, c]\n\n    def scatter(self, k, maxRow):\n        \"\"\"\n        :type k: int\n        :type maxRow: int\n        :rtype: bool\n        \"\"\"\n        cnt = self.__st.query(self.__i, maxRow)\n        if not cnt or cnt[1] < k:\n            return False\n        for i in xrange(self.__i, maxRow+1):\n            cnt = self.__st.tree[self.__st.base+i][1]\n            c = min(cnt, k)\n            cnt -= c\n            if not cnt:\n                self.__i += 1\n            self.__st.update(i, [cnt]*2)\n            k -= c\n            if not k:\n                break\n        return True\n15:[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Booking Concert Tickets in Groups\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/booking-concert-tickets-in-groups\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"C++\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/booking-concert-tickets-in-groups/cpp\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/booking-concert-tickets-in-groups\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems/booking-concert-tickets-in-groups\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Booking Concert Tickets in Groups\"}]]}],[\"$\",\"li\",\"/problems/booking-concert-tickets-in-groups/cpp\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"C++\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 flex flex-wrap items-center gap-2\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\",\"children\":\"Hard\"}]}],[\"$\",\"h1\",null,{\"className\":\"mt-3 text-3xl font-bold tracking-tight\",\"children\":[\"Booking Concert Tickets in Groups\",\" — \",\"C++\"]}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-muted-foreground\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/problems/booking-concert-tickets-in-groups\",\"className\":\"text-primary hover:underline\",\"children\":\"Full explanation\"}],\" · \",\"Time \",\"ctor: O(n) gather: O(logn) scatter: O(logn), amortized\",\" · Space \",\"O(n)\"]}],[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L1e\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"booking-concert-tickets-in-groups.cpp\",\"code\":\"$1f\",\"sourcePath\":\"C++/booking-concert-tickets-in-groups.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"booking-concert-tickets-in-groups.py\",\"code\":\"$20\",\"sourcePath\":\"Python/booking-concert-tickets-in-groups.py\"}},\"defaultLang\":\"cpp\"}]}]]}]\n1b:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n21:I[27201,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"IconMark\"]\n18:null\n1d:[[\"$\",\"title\",\"0\",{\"children\":\"Booking Concert Tickets in Groups C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"C++ solution for Booking Concert Tickets in Groups (LeetCode #2286). Time ctor: O(n) gather: O(logn) scatter: O(logn), amortized, space O(n).\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"Booking Concert Tickets in Groups cpp,Booking Concert Tickets in Groups C++,cpp leetcode\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://algoforge.dev/problems/booking-concert-tickets-in-groups/cpp\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"Booking Concert Tickets in Groups C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"C++ solution for Booking Concert Tickets in Groups (LeetCode #2286). Time ctor: O(n) gather: O(logn) scatter: O(logn), amortized, space O(n).\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:url\",\"content\":\"https://algoforge.dev/problems/booking-concert-tickets-in-groups/cpp\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:site_name\",\"content\":\"AlgoForge\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:image:alt\",\"content\":\"Booking Concert Tickets in Groups C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"13\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:title\",\"content\":\"Booking Concert Tickets in Groups C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"15\",{\"name\":\"twitter:description\",\"content\":\"C++ solution for Booking Concert Tickets in Groups (LeetCode #2286). Time ctor: O(n) gather: O(logn) scatter: O(logn), amortized, space O(n).\"}],[\"$\",\"meta\",\"16\",{\"name\":\"twitter:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"link\",\"17\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.2vob68tjqpejf.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"link\",\"18\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\"}],[\"$\",\"$L21\",\"19\",{}]]\n","/problems/$d$slug/$d$lang/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[522016,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"\"]\n3:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n8:I[897367,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"OutletBoundary\"]\n9:\"$Sreact.suspense\"\n4:T192b,// Time:  ctor:    O(n)\n//        gather:  O(logn)\n//        scatter: O(logn), amortized\n// Space: O(n)\n\n// design, segment tree, binary search, optimized from bookmyshow2\nclass BookMyShow {\npublic:\n    BookMyShow(int n, int m)\n      : st_(n, m)\n      , m_(m)\n      , i_(0) {\n    }\n    \n    vector<int> gather(int k, int maxRow) {\n        int i = 1;\n        if (k > st_.tree[i][0]) {\n            return {};\n        }\n        while (i < st_.base) {\n            i = 2 * i + static_cast<int>(st_.tree[2 * i][0] < k);\n        }\n        if (i - st_.base > maxRow) {\n            return {};\n        }\n        int cnt = st_.tree[i][0];\n        int c = m_ - cnt;\n        i -= st_.base;\n        st_.update(i, vector<int64_t>(2, cnt - k));\n        return {i, c};\n    }\n    \n    bool scatter(int k, int maxRow) {\n        if (k > st_.query(i_, maxRow)) {\n            return false;\n        }\n        for (int i = i_; i <= maxRow && k; ++i) {\n            int cnt = st_.tree[st_.base + i][1];\n            int c = min(cnt, k);\n            cnt -= c;\n            if (!cnt) {\n                ++i_;\n            }\n            st_.update(i, vector<int64_t>(2, cnt));\n            k -= c;\n        }\n        return true;\n    }\n\nprivate:\n    // Template:\n    // https://github.com/kamyu104/LeetCode-Solutions/blob/master/C++/longest-substring-of-one-repeating-character.cpp\n    class SegmentTree {\n     public:\n        explicit SegmentTree(int N, int m)\n          : tree(N > 1 ? 1 << (__lg(N - 1) + 2) : 2, vector<int64_t>(2)),\n            base(N > 1 ? 1 << (__lg(N - 1) + 1) : 1) {\n\n            for (int i = base; i < base + N; ++i) {\n                tree[i][0] = tree[i][1] = m;\n            }\n            for (int i = base - 1; i >= 1; --i) {\n                tree[i][0] = max(tree[i * 2][0], tree[i * 2 + 1][0]);\n                tree[i][1] = tree[i * 2][1] + tree[i * 2 + 1][1];\n            }\n        }\n\n        void update(int i, const vector<int64_t>& h) {\n            int x = base + i;\n            tree[x] = h;\n            while (x > 1) {\n                x /= 2;\n                tree[x][0] = max(tree[x * 2][0], tree[x * 2 + 1][0]);\n                tree[x][1] = tree[x * 2][1] + tree[x * 2 + 1][1];\n            }\n        }\n\n        int64_t query(int L, int R) {\n            L += base;\n            R += base;\n            int64_t result = 0;\n            for (; L <= R; L /= 2, R /= 2) {\n                if (L & 1) {\n                    result += tree[L][1];\n                    ++L;\n                }\n                if ((R & 1) == 0) {\n                    result += tree[R][1];\n                    --R;\n                }\n            }\n            return result;\n        }\n\n        vector<vector<int64_t>> tree;\n        int base;\n    };\n\n    SegmentTree st_;\n    int m_;\n    int i_;\n};\n\n// Time:  ctor:    O(n)\n//        gather:  O(logn)\n//        scatter: O(logn), amortized\n// Space: O(n)\n// design, segment tree, binary search\nclass BookMyShow2 {\npublic:\n    BookMyShow2(int n, int m)\n      : m_(m)\n      , i_(0) {\n\n        const auto& build = [&m] (const auto& i) {\n            return vector<int64_t>({m, m});\n        };\n        const auto& update = [] (const auto& c) {\n            return c;\n        };\n        const auto& query = [] (const auto& x, const auto& y) {\n            if (empty(x)) {\n                return y;\n            }\n            if (empty(y)) {\n                return x;\n            }\n            return vector<int64_t>({max(x[0], y[0]), x[1] + y[1]});\n        };\n\n        st_ = make_unique<SegmentTree<vector<int64_t>>>(n, build, update, query);\n    }\n    \n    vector<int> gather(int k, int maxRow) {\n        int i = 1;\n        if (k > st_->tree[i][0]) {\n            return {};\n        }\n        while (i < st_->base) {\n            i = 2 * i + static_cast<int>(st_->tree[2 * i][0] < k);\n        }\n        if (i - st_->base > maxRow) {\n            return {};\n        }\n        int cnt = st_->tree[i][0];\n        int c = m_ - cnt;\n        i -= st_->base;\n        st_->update(i, vector<int64_t>(2, cnt - k));\n        return {i, c};\n    }\n    \n    bool scatter(int k, int maxRow) {\n        const auto cnt = st_->query(i_, maxRow);\n        if (empty(cnt) || cnt[1] < k) {\n            return false;\n        }\n        for (int i = i_; i <= maxRow && k; ++i) {\n            int cnt = st_->tree[st_->base + i][1];\n            int c = min(cnt, k);\n            cnt -= c;\n            if (!cnt) {\n                ++i_;\n            }\n            st_->update(i, vector<int64_t>(2, cnt));\n            k -= c;\n        }\n        return true;\n    }\n\nprivate:\n    // Template:\n    // https://github.com/kamyu104/LeetCode-Solutions/blob/master/C++/longest-substring-of-one-repeating-character.cpp\n    template <typename T>\n    class SegmentTree {\n     public:\n        explicit SegmentTree(\n            int N,\n            const function<T(const int&)>& build_fn,\n            const function<T(const T&)>& update_fn,\n            const function<T(const T&, const T&)>& query_fn)\n          : tree(N > 1 ? 1 << (__lg(N - 1) + 2) : 2),\n            base(N > 1 ? 1 << (__lg(N - 1) + 1) : 1),\n            build_fn_(build_fn),\n            query_fn_(query_fn),\n            update_fn_(update_fn) {\n\n            for (int i = base; i < base + N; ++i) {\n                tree[i] = build_fn_(i - base);\n            }\n            for (int i = base - 1; i >= 1; --i) {\n                tree[i] = query_fn_(tree[2 * i], tree[2 * i + 1]);\n            }\n        }\n\n        void update(int i, const T& h) {\n            int x = base + i;\n            tree[x] = update_fn_(h);\n            while (x > 1) {\n                x /= 2;\n                tree[x] = query_fn_(tree[x * 2], tree[x * 2 + 1]);\n            }\n        }\n\n        T query(int L, int R) {\n            L += base;\n            R += base;\n            T left, right;\n            for (; L <= R; L /= 2, R /= 2) {\n                if (L & 1) {\n                    left = query_fn_(left, tree[L]);\n                    ++L;\n                }\n                if ((R & 1) == 0) {\n                    right = query_fn_(tree[R], right);\n                    --R;\n                }\n            }\n            return query_fn_(left, right);\n        }\n\n        vector<T> tree;\n        int base;\n\n    private:\n        const function<T(const int&)> build_fn_;\n        const function<T(const T&)> update_fn_;\n        const function<T(const T&, const T&)> query_fn_;\n    };\n\n    unique_ptr<SegmentTree<vector<int64_t>>> st_;\n    int m_;\n    int i_;\n};\n5:Tb85,# Time:  ctor:    O(n)\n#        gather:  O(logn)\n#        scatter: O(logn), amortized\n# Space: O(n)\n\n# Template:\n# https://github.com/kamyu104/LeetCode-Solutions/blob/master/Python/longest-substring-of-one-repeating-character.py\nclass SegmentTree(object):\n    def __init__(self, N,\n                 build_fn=lambda _: float(\"inf\"),\n                 query_fn=lambda x, y: y if x is None else x if y is None else min(x, y),\n                 update_fn=lambda x: x):\n        self.tree = [None]*(2*2**((N-1).bit_length()))\n        self.base = len(self.tree)//2\n        self.query_fn = query_fn\n        self.update_fn = update_fn\n        for i in xrange(self.base, self.base+N):\n            self.tree[i] = build_fn(i-self.base)\n        for i in reversed(xrange(1, self.base)):\n            self.tree[i] = query_fn(self.tree[2*i], self.tree[2*i+1])\n\n    def update(self, i, h):\n        x = self.base+i\n        self.tree[x] = self.update_fn(h)\n        while x > 1:\n            x //= 2\n            self.tree[x] = self.query_fn(self.tree[x*2], self.tree[x*2+1])\n\n    def query(self, L, R):\n        L += self.base\n        R += self.base\n        left = right = None\n        while L <= R:\n            if L & 1:\n                left = self.query_fn(left, self.tree[L])\n                L += 1\n            if R & 1 == 0:\n                right = self.query_fn(self.tree[R], right)\n                R -= 1\n            L //= 2\n            R //= 2\n        return self.query_fn(left, right)\n\n\n# design, segment tree, binary search\nclass BookMyShow(object):\n\n    def __init__(self, n, m):\n        \"\"\"\n        :type n: int\n        :type m: int\n        \"\"\"\n        self.__st = SegmentTree(n,\n                                build_fn=lambda _: [m]*2,\n                                query_fn=lambda x, y: y if x is None else x if y is None else [max(x[0], y[0]), x[1]+y[1]])\n        self.__m = m\n        self.__i = 0\n\n    def gather(self, k, maxRow):\n        \"\"\"\n        :type k: int\n        :type maxRow: int\n        :rtype: List[int]\n        \"\"\"\n        i = 1\n        if k > self.__st.tree[i][0]:\n            return []\n        while i < self.__st.base:\n            i = 2*i+int(self.__st.tree[2*i][0] < k)\n        if i-self.__st.base > maxRow:\n            return []\n        cnt = self.__st.tree[i][0]\n        c = self.__m-cnt\n        i -= self.__st.base\n        self.__st.update(i, [cnt-k]*2)\n        return [i, c]\n\n    def scatter(self, k, maxRow):\n        \"\"\"\n        :type k: int\n        :type maxRow: int\n        :rtype: bool\n        \"\"\"\n        cnt = self.__st.query(self.__i, maxRow)\n        if not cnt or cnt[1] < k:\n            return False\n        for i in xrange(self.__i, maxRow+1):\n            cnt = self.__st.tree[self.__st.base+i][1]\n            c = min(cnt, k)\n            cnt -= c\n            if not cnt:\n                self.__i += 1\n            self.__st.update(i, [cnt]*2)\n            k -= c\n            if not k:\n                break\n        return True\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Booking Concert Tickets in Groups\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/booking-concert-tickets-in-groups\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"C++\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/booking-concert-tickets-in-groups/cpp\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L2\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L2\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/booking-concert-tickets-in-groups\",{