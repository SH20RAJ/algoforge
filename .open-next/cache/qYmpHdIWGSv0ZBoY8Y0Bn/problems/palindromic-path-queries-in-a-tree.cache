ing-wide bg-primary/15 text-primary\\\",\\\"children\\\":\\\"tree\\\"}]}]],[[\\\"$\\\",\\\"$L3\\\",\\\"dfs-backtracking\\\",{\\\"href\\\":\\\"/patterns/dfs-backtracking\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":\\\"dfs backtracking\\\"}]}],[\\\"$\\\",\\\"$L3\\\",\\\"fenwick-tree\\\",{\\\"href\\\":\\\"/patterns/fenwick-tree\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":\\\"fenwick tree\\\"}]}]],[]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap gap-2 pt-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L20\\\",null,{\\\"slug\\\":\\\"palindromic-path-queries-in-a-tree\\\"}],[[\\\"$\\\",\\\"$L3\\\",\\\"cpp\\\",{\\\"href\\\":\\\"/problems/palindromic-path-queries-in-a-tree/cpp\\\",\\\"className\\\":\\\"text-sm text-primary hover:underline\\\",\\\"children\\\":\\\"cpp\\\"}],[\\\"$\\\",\\\"$L3\\\",\\\"python\\\",{\\\"href\\\":\\\"/problems/palindromic-path-queries-in-a-tree/python\\\",\\\"className\\\":\\\"text-sm text-primary hover:underline\\\",\\\"children\\\":\\\"python\\\"}]]]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mt-10\\\",\\\"id\\\":\\\"solutions\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold mb-3\\\",\\\"children\\\":\\\"Solutions\\\"}],[\\\"$\\\",\\\"$L21\\\",null,{\\\"solutions\\\":{\\\"cpp\\\":{\\\"language\\\":\\\"C++\\\",\\\"languageSlug\\\":\\\"cpp\\\",\\\"filename\\\":\\\"palindromic-path-queries-in-a-tree.cpp\\\",\\\"code\\\":\\\"$22\\\",\\\"sourcePath\\\":\\\"C++/palindromic-path-queries-in-a-tree.cpp\\\"},\\\"python\\\":{\\\"language\\\":\\\"Python\\\",\\\"languageSlug\\\":\\\"python\\\",\\\"filename\\\":\\\"palindromic-path