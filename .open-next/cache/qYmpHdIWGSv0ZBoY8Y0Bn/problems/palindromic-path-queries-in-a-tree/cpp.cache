dren\":\"Product\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/pricing\",\"className\":\"hover:text-primary\",\"children\":\"Pricing\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/about\",\"className\":\"hover:text-primary\",\"children\":\"About\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/about/attribution\",\"className\":\"hover:text-primary\",\"children\":\"Attribution\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/sitemap-html\",\"className\":\"hover:text-primary\",\"children\":\"Sitemap\"}]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"border-t border-border\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-af py-4 flex flex-col sm:flex-row gap-2 justify-between text-xs text-muted-foreground\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"© \",2026,\" \",\"AlgoForge\",\". Educational use only.\"]}],[\"$\",\"p\",null,{\"children\":[\"Solution code sourced under MIT from\",\" \",[\"$\",\"a\",null,{\"href\":\"https://github.com/kamyu104/LeetCode-Solutions\",\"className\":\"underline hover:text-primary\",\"rel\":\"noopener noreferrer\",\"target\":\"_blank\",\"children\":\"kamyu104/LeetCode-Solutions\"}],\". Explanations are original AlgoForge content.\"]}]]}]}]]}]\na:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nb:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nc:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nd:[\"$\",\"$1\",\"c\",{\"children\":[\"$L15\",[[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0a2gmow1_jiq0.js\",\"async\":true,\"nonce\":\"$undefined\"}]],[\"$\",\"$L16\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@18\"}]}]]}]\n19:[]\ne:\"$W19\"\nf:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1a\",null,{\"children\":\"$L1b\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1d\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n11:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/340fxer6uczx7.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n1e:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n1f:T23b2,// Time:  O((n + q) * logn)\n// Space: O(n)\n\n// hld, lca, fenwick tree\nclass Solution {\npublic:\n    vector<bool> palindromePath(int n, vector<vector<int>>& edges, string s, vector<string>& queries) {\n        const auto& build_hld = [](const auto& adj, const auto& cb) {\n            vector<int> parent(size(adj), -1), depth(size(adj), 0), sz(size(adj), 1), heavy(size(adj), -1), head(size(adj));\n            iota(begin(head), end(head), 0);\n            vector<tuple<int, int, int>> stk = {{1, 0, -1}};\n            while (!empty(stk)) {\n                const auto [step, u, p] = stk.back(); stk.pop_back();\n                if (step == 1) {\n                    cb(u, p);\n                    parent[u] = p;\n                    depth[u] = (p == -1 ? 0 : depth[p] + 1);\n                    stk.emplace_back(2, u, p);\n                    for (const auto& v : adj[u]) {\n                        if (v == p) {\n                            continue;\n                        }\n                        stk.emplace_back(1, v, u);\n                    }\n                } else if (step == 2) {\n                    for (const auto& v : adj[u]) {\n                        if (v == parent[u]) {\n                            continue;\n                        }\n                        sz[u] += sz[v];\n                        if (heavy[u] == -1 || sz[v] > sz[heavy[u]]) {\n                            heavy[u] = v;\n                        }\n                    }\n                }\n            }\n            int idx = -1;\n            vector<int> left(size(adj), -1), right(size(adj), -1);\n            stk = {{1, 0, 0}};\n            while (!empty(stk)) {\n                const auto [step, u, h] = stk.back(); stk.pop_back();\n                if (step == 1) {\n                    head[u] = h;\n                    left[u] = ++idx;\n                    stk.emplace_back(2, u, h);\n                    for (const auto& v : adj[u]) {\n                        if (v == parent[u] || v == heavy[u]) {\n                            continue;\n                        }\n                        stk.emplace_back(1, v, v);\n                    }\n                    if (heavy[u] != -1) {\n                        stk.emplace_back(1, heavy[u], h);\n                    }\n                } else if (step == 2) {\n                    right[u] = idx;\n                }\n            }\n            return tuple(parent, depth, head, left, right);\n        };\n\n        vector<int> prefix(n);\n        const auto& callback = [&](int u, int p) {\n            prefix[u] = (p != -1 ? prefix[p] : 0) ^ (1 << (s[u] - 'a'));\n        };\n\n        vector<vector<int>> adj(n);\n        for (const auto& e : edges) {\n            adj[e[0]].emplace_back(e[1]);\n            adj[e[1]].emplace_back(e[0]);\n        }\n        const auto& [parent, depth, head, left, right] = build_hld(adj, callback);\n        const auto& lca = [&](int u, int v) {\n            while (head[u] != head[v]) {\n                if (depth[head[u]] < depth[head[v]]) {\n                    swap(u, v);\n                }\n                u = parent[head[u]];\n            }\n            return depth[u] < depth[v] ? u : v;\n        };\n\n        BIT bit(n + 1);\n        vector<bool> result;\n        for (const auto& q : queries) {\n            istringstream iss(q);\n            string op;\n            int u;\n            iss >> op >> u;\n            if (op == \"update\") {\n                char c;\n                iss >> c;\n                const auto& diff = (1 << (s[u] - 'a')) ^ (1 << (c - 'a'));\n                if (!diff) {\n                    continue;\n                }\n                s[u] = c;\n                bit.add(left[u], diff);\n                bit.add(right[u] + 1, diff);\n            } else {\n                int v;\n                iss >> v;\n                const auto& l = lca(u, v);\n                const auto& mask = (prefix[u] ^ bit.query(left[u])) ^ (prefix[v] ^ bit.query(left[v])) ^ (1 << (s[l] - 'a'));\n                result.emplace_back((mask & (mask - 1)) == 0);\n            }\n        }\n        return result;\n    }\n\nprivate:\n    class BIT {\n    public:\n        BIT(int n) : bit_(n + 1) {  // 0-indexed\n        }\n        \n        void add(int i, int val) {\n            ++i;\n            for (; i < size(bit_); i += lower_bit(i)) {\n                bit_[i] ^= val;\n            }\n        }\n\n        int query(int i) const {\n            ++i;\n            int total = 0;\n            for (; i > 0; i -= lower_bit(i)) {\n                total ^= bit_[i];\n            }\n            return total;\n        }\n\n    private:\n        inline int lower_bit(int i) const {\n            return i & -i;\n        }\n        \n        vector<int> bit_;\n    };\n};\n\n// Time:  O((n + q) * logn)\n// Space: O(nlogn)\n// dfs, lca, binary lifting, fenwick tree\nclass Solution2 {\npublic:\n    vector<bool> palindromePath(int n, vector<vector<int>>& edges, string s, vector<string>& queries) {\n        vector<vector<int>> adj(n);\n        for (const auto& e : edges) {\n            adj[e[0]].emplace_back(e[1]);\n            adj[e[1]].emplace_back(e[0]);\n        }\n        TreeInfos tree_infos(adj);\n        BIT bit(n + 1);\n        for (int u = 0; u < n; ++u) {\n            const auto& diff = 1 << (s[u] - 'a');\n            bit.add(tree_infos.left(u), diff);\n            bit.add(tree_infos.right(u) + 1, diff);\n        }\n        vector<bool> result;\n        for (const auto& q : queries) {\n            istringstream iss(q);\n            string op;\n            int u;\n            iss >> op >> u;\n            if (op == \"update\") {\n                char c;\n                iss >> c;\n                const auto& diff = (1 << (s[u] - 'a')) ^ (1 << (c - 'a'));\n                if (!diff) {\n                    continue;\n                }\n                s[u] = c;\n                bit.add(tree_infos.left(u), diff);\n                bit.add(tree_infos.right(u) + 1, diff);\n            } else {\n                int v;\n                iss >> v;\n                const auto& l = tree_infos.lca(u, v);\n                const auto& mask = bit.query(tree_infos.left(u)) ^ bit.query(tree_infos.left(v)) ^ (1 << (s[l] - 'a'));\n                result.emplace_back(mask == 0 || (mask & (mask - 1)) == 0);\n            }\n        }\n        return result;\n    }\n\nprivate:\n    class BIT {\n    public:\n        BIT(int n) : bit_(n + 1) {  // 0-indexed\n        }\n        \n        void add(int i, int val) {\n            ++i;\n            for (; i < size(bit_); i += lower_bit(i)) {\n                bit_[i] ^= val;\n            }\n        }\n\n        int query(int i) const {\n            ++i;\n            int total = 0;\n            for (; i > 0; i -= lower_bit(i)) {\n                total ^= bit_[i];\n            }\n            return total;\n        }\n\n    private:\n        inline int lower_bit(int i) const {\n            return i & -i;\n        }\n        \n        vector<int> bit_;\n    };\n\n    class TreeInfos {\n    public:\n        TreeInfos(const vector<vector<int>>& adj)\n         : L_(size(adj))\n         , R_(size(adj))\n         , D_(size(adj))\n         , P_(size(adj)) {\n\n             const int N = size(adj);\n             int idx = -1;\n             vector<tuple<int, int, int>> stk = {{1, 0, -1}};\n             while (!empty(stk)) {\n                const auto [step, u, p] = stk.back(); stk.pop_back();\n                if (step == 1) {\n                    D_[u] = (p == -1) ? 1 : D_[p] + 1;\n                    if (p != -1) {\n                        P_[u].emplace_back(p);  // ancestors of the node i\n                    }\n                    for (int i = 0; i < size(P_[u]); ++i) {\n                        if (i >= size(P_[P_[u][i]])) {\n                            break;\n                        }\n                        P_[u].emplace_back(P_[P_[u][i]][i]);\n                    }\n                    L_[u] = ++idx; \n                    stk.emplace_back(2, u, -1);\n                    for (int i = size(adj[u]) -1; i >= 0; --i) {\n                        const auto& v = adj[u][i];\n                        if (v == p) {\n                            continue;\n                        }\n                        stk.emplace_back(1, v, u);\n                    }\n                } else if (step == 2) {\n                    R_[u] = idx;\n                }\n            }\n            assert(idx == N - 1);\n        }\n        \n        bool is_ancestor(int a, int b) const {\n            return L_[a] <= L_[b] && R_[b] <= R_[a];\n        }\n\n        int lca(int a, int b) const {\n            if (D_[a] > D_[b]) {\n                swap(a, b);\n            }\n            if (is_ancestor(a, b)) {\n                return a;\n            }\n            for (int i = size(P_[a]) - 1; i >= 0; --i) {  // O(logN)\n                if (i < size(P_[a]) && !is_ancestor(P_[a][i], b)) {\n                    a = P_[a][i];\n                }\n            }\n            return P_[a][0];\n        }\n\n        int left(int a) const {\n            return L_[a];\n        }\n\n        int right(int a) const {\n            return R_[a];\n        }\n        \n        int depth(int a) const {\n            return D_[a];\n        }\n    \n    private:\n        vector<int> L_;\n        vector<int> R_;\n        vector<int> D_;\n        vector<vector<int>> P_;\n    };\n};\n20:T1e9d,# Time:  O((n + q) * logn)\n# Space: O(n)\n\n# hld, lca, fenwick tree\nclass Solution(object):\n    def palindromePath(self, n, edges, s, queries):\n        \"\"\"\n        :type n: int\n        :type edges: List[List[int]]\n        :type s: str\n        :type queries: List[str]\n        :rtype: List[bool]\n        \"\"\"\n        class BIT(object):  # 0-indexed.\n            def __init__(self, n):\n                self.__bit = [0]*(n+1)  # Extra one for dummy node.\n\n            def add(self, i, val):\n                i += 1  # Extra one for dummy node.\n                while i < len(self.__bit):\n                    self.__bit[i] ^= val  # modified\n                    i += (i & -i)\n\n            def query(self, i):\n                i += 1  # Extra one for dummy node.\n                ret = 0\n                while i > 0:\n                    ret ^= self.__bit[i]  # modified\n                    i -= (i & -i)\n                return ret\n\n\n        def build_hld(adj, cb):\n            parent, depth, size, heavy, head = [-1]*len(adj), [0]*len(adj), [1]*len(adj), [-1]*len(adj), list(range(len(adj)))\n            stk = [(1, 0, -1)]\n            while stk:\n                step, u, p = stk.pop()\n                if step == 1:\n                    cb(u, p)\n                    parent[u], depth[u] = p, (depth[p]+1 if p != -1 else 0)\n                    stk.append((2, u, p))\n                    for v in adj[u]:\n                        if v == p:\n                            continue\n                        stk.append((1, v, u))\n                elif step == 2:\n                    for v in adj[u]:\n                        if v == parent[u]:\n                            continue\n                        size[u] += size[v]\n                        if heavy[u] == -1 or size[v] > size[heavy[u]]:\n                            heavy[u] = v\n            idx = -1\n            left, right = [-1]*len(adj), [-1]*len(adj)\n            stk = [(1, 0, 0)]\n            while stk:\n                step, u, h = stk.pop()\n                if step == 1:\n                    idx += 1\n                    head[u], left[u] = h, idx\n                    stk.append((2, u, h))\n                    for v in adj[u]:\n                        if v == parent[u] or v == heavy[u]:\n                            continue\n                        stk.append((1, v, v))\n                    if heavy[u] != -1:\n                        stk.append((1, heavy[u], h))\n                elif step == 2:\n                    right[u] = idx\n            return parent, depth, head, left, right\n    \n        def lca(u, v):\n            while head[u] != head[v]:\n                if depth[head[u]] < depth[head[v]]:\n                    u, v = v, u\n                u = parent[head[u]]\n            return u if depth[u] < depth[v] else v\n\n        def callback(u, p):\n            prefix[u] = (prefix[p] if p != -1 else 0)^(1<<(ord(s[u])-ord('a')))\n\n        s = list(s)\n        adj = [[] for _ in xrange(n)]\n        for u, v in edges:\n            adj[u].append(v)\n            adj[v].append(u)\n        prefix = [0]*n\n        parent, depth, head, left, right = build_hld(adj, callback)\n        bit = BIT(n+1)\n        result = []\n        for q in queries:\n            args = q.split()\n            op = args[0]\n            u = int(args[1])\n            if op == \"update\":\n                c = args[2]\n                diff = (1<<(ord(s[u])-ord('a')))^(1<<(ord(c)-ord('a')))\n                if not diff:\n                    continue\n                s[u] = c\n                bit.add(left[u], diff)\n                bit.add(right[u]+1, diff)\n            else:\n                v = int(args[2])\n                l = lca(u, v)\n                mask = (prefix[u]^bit.query(left[u]))^(prefix[v]^bit.query(left[v]))^(1<<(ord(s[l])-ord('a')))\n                result.append((mask&(mask-1)) == 0)\n        return result\n\n\n# Time:  O((n + q) * logn)\n# Space: O(nlogn)\n# dfs, lca, binary lifting, fenwick tree\nclass Solution2(object):\n    def palindromePath(self, n, edges, s, queries):\n        \"\"\"\n        :type n: int\n        :type edges: List[List[int]]\n        :type s: str\n        :type queries: List[str]\n        :rtype: List[bool]\n        \"\"\"\n        class BIT(object):  # 0-indexed.\n            def __init__(self, n):\n                self.__bit = [0]*(n+1)  # Extra one for dummy node.\n\n            def add(self, i, val):\n                i += 1  # Extra one for dummy node.\n                while i < len(self.__bit):\n                    self.__bit[i] ^= val  # modified\n                    i += (i & -i)\n\n            def query(self, i):\n                i += 1  # Extra one for dummy node.\n                ret = 0\n                while i > 0:\n                    ret ^= self.__bit[i]  # modified\n                    i -= (i & -i)\n                return ret\n\n\n        class TreeInfos(object):  # Time: O(NlogN), Space: O(NlogN), N is the number of nodes\n            def __init__(self, adj):\n                N = len(adj)\n                L, R, D, P = [0]*N, [0]*N, [0]*N, [[] for _ in xrange(N)]\n                idx = -1\n                stk = [(1, (0, -1))]\n                while stk:\n                    step, args = stk.pop()\n                    if step == 1:\n                        u, p = args\n                        D[u] = 1 if p == -1 else D[p]+1\n                        if p != -1:\n                            P[u].append(p)\n                        i = 0\n                        while i < len(P[u]) and i < len(P[P[u][i]]):\n                            P[u].append(P[P[u][i]][i])\n                            i += 1\n                        idx += 1\n                        L[u] = idx\n                        stk.append((2, (u,)))\n                        for i in reversed(xrange(len(adj[u]))):\n                            v = adj[u][i]\n                            if v == p:\n                                continue\n                            stk.append((1, (v, u)))\n                    elif step == 2:\n                        u = args[0]\n                        R[u] = idx\n                assert(idx == N-1)\n                self.L, self.R, self.D, self.P = L, R, D, P\n\n            # Template:\n            # https://github.com/kamyu104/FacebookHackerCup-2019/blob/master/Final%20Round/little_boat_on_the_sea.py\n            def is_ancestor(self, a, b):  # includes itself\n                return self.L[a] <= self.L[b] <= self.R[b] <= self.R[a]\n\n            def lca(self, a, b):\n                if self.D[a] > self.D[b]:\n                    a, b = b, a\n                if self.is_ancestor(a, b):\n                    return a\n                for i in reversed(xrange(len(self.P[a]))):  # O(logN)\n                    if i < len(self.P[a]) and not self.is_ancestor(self.P[a][i], b):\n                        a = self.P[a][i]\n                return self.P[a][0]\n\n        s = list(s)\n        adj = [[] for _ in xrange(n)]\n        for u, v in edges:\n            adj[u].append(v)\n            adj[v].append(u)\n        tree_infos = TreeInfos(adj)\n        bit = BIT(n+1)\n        for u in xrange(n):\n            diff = 1<<(ord(s[u])-ord('a'))\n            bit.add(tree_infos.L[u], diff)\n            bit.add(tree_infos.R[u]+1, diff)\n        result = []\n        for q in queries:\n            args = q.split()\n            op = args[0]\n            u = int(args[1])\n            if op == \"update\":\n                c = args[2]\n                diff = (1<<(ord(s[u])-ord('a')))^(1<<(ord(c)-ord('a')))\n                if not diff:\n                    continue\n                s[u] = c\n                bit.add(tree_infos.L[u], diff)\n                bit.add(tree_infos.R[u]+1, diff)\n            else:\n                v = int(args[2])\n                l = tree_infos.lca(u, v)\n                mask = bit.query(tree_infos.L[u])^bit.query(tree_infos.L[v])^(1<<(ord(s[l])-ord('a')))\n                result.append(mask == 0 or (mask&(mask-1)) == 0)\n        return result\n15:[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Palindromic Path Queries in a Tree\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/palindromic-path-queries-in-a-tree\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"C++\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/palindromic-path-queries-in-a-tree/cpp\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/palindromic-path-queries-in-a-tree\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems/palindromic-path-queries-in-a-tree\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Palindromic Path Queries in a Tree\"}]]}],[\"$\",\"li\",\"/problems/palindromic-path-queries-in-a-tree/cpp\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"C++\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 flex flex-wrap items-center gap-2\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\",\"children\":\"Hard\"}]}],[\"$\",\"h1\",null,{\"className\":\"mt-3 text-3xl font-bold tracking-tight\",\"children\":[\"Palindromic Path Queries in a Tree\",\" — \",\"C++\"]}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-muted-foreground\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\