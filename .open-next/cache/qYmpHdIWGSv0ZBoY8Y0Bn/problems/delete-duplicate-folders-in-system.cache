"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Delete Duplicate Folders in System\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/delete-duplicate-folders-in-system\\\"}]}\"}}],\"$L3\"]}],\"$L4\"]}],[\"$L5\"],\"$L6\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"qYmpHdIWGSv0ZBoY8Y0Bn\"}\n3:[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L7\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L7\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/delete-duplicate-folders-in-system\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"Delete Duplicate Folders in System\"}]]}]]}]\na:T18d1,// Time:  O(n * m * l + tlogt + l * t), m is the max number of folders in a path,\n//                                    , n is the number of paths\n//                                    , l is the max length of folder name\n//                                    , t is the size of trie\n// Space: O(l * t)\n\nclass Solution {\nprivate:\n    template <typename T>\n    struct PairHash {\n        size_t operator()(const pair<T, T>& p) const {\n            size_t seed = 0;\n            seed ^= std::hash<T>{}(p.first)  + 0x9e3779b9 + (seed<<6) + (seed>>2);\n            seed ^= std::hash<T>{}(p.second) + 0x9e3779b9 + (seed<<6) + (seed>>2);\n            return seed;\n        }\n    };\n\n    template<typename T>\n    struct VectorPairHash {\n        size_t operator()(const std::vector<pair<T, T>>& v) const {\n            size_t seed = 0;\n            for (const auto& i : v) {\n                seed ^= PairHash<T>{}(i)  + 0x9e3779b9 + (seed<<6) + (seed>>2);\n            }\n            return seed;\n        }\n    };\n\n    class TrieNode { \n    public:\n        void Insert(const vector<string>& s,\n                    unordered_map<string, int> *folder_ids,\n                    unordered_map<int, string> *id_folders) {\n            auto p = this;\n            for (const auto& c : s) {\n                if (!folder_ids->count(c)) {\n                    (*folder_ids)[c] = size(*folder_ids);\n                    (*id_folders)[(*folder_ids)[c]] = c;\n                }\n                const auto folder_id = (*folder_ids)[c];\n                if (!p->leaves.count(folder_id)) {\n                    p->leaves[folder_id] = make_unique<TrieNode>();\n                }\n                p = p->leaves[folder_id].get();\n            }\n        }\n\n        bool deleted = false;\n        unordered_map<int, unique_ptr<TrieNode>> leaves;\n    };\n  \npublic:\n    vector<vector<string>> deleteDuplicateFolder(vector<vector<string>>& paths) {\n        auto trie = make_unique<TrieNode>();\n        unordered_map<string, int> folder_ids;\n        unordered_map<int, string> id_folders;\n        for (const auto& path : paths) {\n            trie->Insert(path, &folder_ids, &id_folders);\n        }\n        unordered_map<int, TrieNode*> lookup;\n        unordered_map<vector<pair<int, int>>, int, VectorPairHash<int>> node_ids;\n        mark(trie.get(), &lookup, &node_ids);\n        vector<vector<string>> result;\n        vector<int> path;\n        sweep(trie.get(), id_folders, &path, &result);\n        return result;\n    }\n\nprivate:\n    int mark(TrieNode *node,\n             unordered_map<int, TrieNode*> *lookup,\n             unordered_map<vector<pair<int, int>>, int, VectorPairHash<int>> *node_ids) {\n        vector<pair<int, int>> id_pairs;\n        for (const auto& [subfolder_id, child] : node->leaves) {\n            id_pairs.emplace_back(subfolder_id, mark(child.get(), lookup, node_ids));\n        }\n        sort(begin(id_pairs), end(id_pairs));\n        if (!node_ids->count(id_pairs)) {\n            (*node_ids)[id_pairs] = size(*node_ids);\n        }\n        int node_id = (*node_ids)[id_pairs];\n        if (node_id) {\n            if (lookup->count(node_id)) {\n                (*lookup)[node_id]->deleted = true;\n                node->deleted = true;\n            } else {\n                (*lookup)[node_id] = node;\n            }\n        }\n        return node_id;\n    }\n\n    void sweep(TrieNode *node,\n               const unordered_map<int, string>& id_folders,\n               vector<int> *path,\n               vector<vector<string>> *result) {\n        if (!empty(*path)) {\n            result->emplace_back();\n            transform(cbegin(*path), cend(*path), back_inserter(result->back()),\n                      [&id_folders](const auto& i) {\n                          return id_folders.at(i);\n                      });\n        }\n        for (const auto& [subfolder_id, child] : node->leaves) {\n            if (child->deleted) {\n                continue;\n            }\n            path->emplace_back(subfolder_id);\n            sweep(child.get(), id_folders, path, result);\n            path->pop_back();\n        }\n    }\n};\n\n// Time:  O(n * m * l + l * tlogt + l * t^2), m is the max number of folders in a path,\n//                                          , n is the number of paths\n//                                          , l is the max length of folder name\n//                                          , t is the size of trie\n// Space: O(l * t^2)\nclass Solution2 {\nprivate:\n    class TrieNode { \n    public:\n        void Insert(const vector<string>& s) {\n            auto p = this;\n            for (const auto& c : s) {\n                if (!p->leaves.count(c)) {\n                    p->leaves[c] = make_unique<TrieNode>();\n                }\n                p = p->leaves[c].get();\n            }\n        }\n\n        bool deleted = false;\n        map<string, unique_ptr<TrieNode>> leaves;\n    };\n  \npublic:\n    vector<vector<string>> deleteDuplicateFolder(vector<vector<string>>& paths) {\n        auto trie = make_unique<TrieNode>();\n        for (const auto& path : paths) {\n            trie->Insert(path);\n        }\n        unordered_map<string, TrieNode*> lookup;\n        mark(trie.get(), &lookup);\n        vector<vector<string>> result;\n        vector<string> path;\n        sweep(trie.get(), &path, &result);\n        return result;\n    }\n\nprivate:\n    string mark(TrieNode *node, unordered_map<string, TrieNode*> *lookup) {\n        string serialized_tree = \"(\";\n        for (const auto& [subfolder, child] : node->leaves) {\n            serialized_tree += subfolder + mark(child.get(), lookup);\n        }\n        serialized_tree += \")\";\n        if (serialized_tree != \"()\") {\n            if (lookup->count(serialized_tree)) {\n                (*lookup)[serialized_tree]->deleted = true;\n                node->deleted = true;\n            } else {\n                (*lookup)[serialized_tree] = node;\n            }\n        }\n        return serialized_tree;\n    }\n\n    void sweep(TrieNode *node, vector<string> *path, vector<vector<string>> *result) {\n        if (!empty(*path)) {\n            result->emplace_back(*path);\n        }\n        for (const auto& [subfolder, child] : node->leaves) {\n            if (child->deleted) {\n                continue;\n            }\n            path->emplace_back(subfolder);\n            sweep(child.get(), path, result);\n            path->pop_back();\n        }\n    }\n};\nb:Te52,# Time:  O(n * m * l + tlogt + l * t), m is the max number of folders in a path,\n#                                    , n is the number of paths\n#                                    , l is the max length of folder name\n#                                    , t is the size of trie\n# Space: O(l * t)\n\nimport collections\n\n\nclass Solution(object):\n    def deleteDuplicateFolder(self, paths):\n        \"\"\"\n        :type paths: List[List[str]]\n        :rtype: List[List[str]]\n        \"\"\"\n        def mark(node, lookup, node_ids):\n            id_pairs = []\n            for subfolder_id, child in node.iteritems():\n                if child == \"_del\":\n                    continue\n                id_pairs.append((subfolder_id, mark(child, lookup, node_ids)))\n            id_pairs.sort()\n            node_id = node_ids[tuple(id_pairs)]\n            if node_id:\n                if node_id in lookup:\n                    lookup[node_id][\"_del\"]\n                    node[\"_del\"]\n                else:\n                    lookup[node_id] = node\n            return node_id\n\n        def sweep(node, id_folders, path, result):\n            if path:\n                result.append([id_folders[i] for i in path])\n            for subfolder_id, child in node.iteritems():\n                if \"_del\" in child:\n                    continue\n                path.append(subfolder_id)\n                sweep(child, id_folders, path, result)\n                path.pop()\n\n        _trie = lambda: collections.defaultdict(_trie)\n        trie = _trie()\n        folder_ids = collections.defaultdict()\n        folder_ids.default_factory = folder_ids.__len__\n        id_folders = {}\n        for path in paths:\n            node = trie\n            for folder in path:\n                if folder_ids[folder] not in id_folders:\n                    id_folders[folder_ids[folder]] = folder\n                node = node[folder_ids[folder]]\n        node_ids = collections.defaultdict()\n        node_ids.default_factory = node_ids.__len__\n        mark(trie, {}, node_ids)\n        result = []\n        sweep(trie, id_folders, [], result)\n        return result\n\n\n# Time:  O(n * m * l + l * tlogt + l * t^2), m is the max number of folders in a path,\n#                                          , n is the number of paths\n#                                          , l is the max length of folder name\n#                                          , t is the size of trie\n# Space: O(l * t^2)\nimport collections\n\n\nclass Solution2(object):\n    def deleteDuplicateFolder(self, paths):\n        \"\"\"\n        :type paths: List[List[str]]\n        :rtype: List[List[str]]\n        \"\"\"\n        def mark(node, lookup):\n            serialized_tree = \"(\" + \"\".join(subfolder + mark(child, lookup) for subfolder, child in sorted(node.iteritems()) if child != \"_del\") + \")\"\n            if serialized_tree != \"()\":\n                if serialized_tree in lookup:\n                    lookup[serialized_tree][\"_del\"]\n                    node[\"_del\"]\n                else:\n                    lookup[serialized_tree] = node\n            return serialized_tree\n        \n        def sweep(node, path, result):\n            if path:\n                result.append(path[:])\n            for subfolder, child in node.iteritems():\n                if \"_del\" in child:\n                    continue\n                path.append(subfolder)\n                sweep(child, path, result)\n                path.pop()\n\n        _trie = lambda: collections.defaultdict(_trie)\n        trie = _trie()\n        for path in paths:\n            reduce(dict.__getitem__, path, trie)\n        mark(trie, {})\n        result = []\n        sweep(trie, [], result)\n        return result\n4:[\"$\",\"div\",null,{\"className\":\"mt-6 grid lg:grid-cols-[1fr_280px] gap-10\",\"children\":[[\"$\",\"article\",null,{\"children\":[[\"$\",\"header\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-wrap items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-sm text-muted-foreground tabular-nums\",\"children\":[\"#\",1948]}],[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\",\"children\":\"Hard\"}],false,[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":[\"~\",50,\" min\"]}]]}],[\"$\",\"h1\",null,{\"className\":\"text-3xl md:text-4xl font-bold tracking-tight\",\"children\":\"Delete Duplicate Folders in System\"}],[\"$\",\"p\",null,{\"className\":\"text-muted-foreground max-w-2xl\",\"children\":[\"Time \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O(n * m * l + tlogt + l * t)\"}],\" · \",\"Space \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O(l * t)\"}],\" · \",[\"$\",\"a\",null,{\"href\":\"https://leetcode.com/problems/delete-duplicate-folders-in-system/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-primary underline-offset-2 hover:underline\",\"children\":\"Official statement on LeetCode\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[[\"$\",\"$L7\",\"tree\",{\"href\":\"/topics/tree\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-primary/15 text-primary\",\"children\":\"tree\"}]}]],[[\"$\",\"$L7\",\"trie\",{\"href\":\"/patterns/trie\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"trie\"}]}],[\"$\",\"$L7\",\"dfs-backtracking\",{\"href\":\"/patterns/dfs-backtracking\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"dfs backtracking\"}]}]],[]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2 pt-1\",\"children\":[[\"$\",\"$L8\",null,{\"slug\":\"delete-duplicate-folders-in-system\"}],[[\"$\",\"$L7\",\"cpp\",{\"href\":\"/problems/delete-duplicate-folders-in-system/cpp\",\"className\":\"text-sm text-primary hover:underline\",\"children\":\"cpp\"}],[\"$\",\"$L7\",\"python\",{\"href\":\"/problems/delete-duplicate-folders-in-system/python\",\"className\":\"text-sm text-primary hover:underline\",\"children\":\"python\"}]]]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"id\":\"solutions\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Solutions\"}],[\"$\",\"$L9\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"delete-duplicate-folders-in-system.cpp\",\"code\":\"$a\",\"sourcePath\":\"C++/delete-duplicate-folders-in-system.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"delete-duplicate-folders-in-system.py\",\"code\":\"$b\",\"sourcePath\":\"Python/delete-duplicate-folders-in-system.py\"}}}]]}],[\"$Lc\",\"$Ld\",\"$Le\",\"$Lf\",\"$L10\",\"$L11\",\"$L12\",\"$L13\",\"$L14\",\"$L15\"],\"$L16\",\"$L17\",\"$L18\",\"$L19\",\"$L1a\",\"$L1b\"]}],\"$L1c\"]}]\n5:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/259rkrk9l2f9c.js\",\"async\":true}]\n6:[\"$\",\"$L1d\",null,{\"children\":[\"$\",\"$1e\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@1f\"}]}]\nc:[\"$\",\"section\",\"beginner\",{\"id\":\"beginner\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Beginner Explanation\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>What is Delete Duplicate Folders in System?</h2>\\n<p><strong>Delete Duplicate Folders in System</strong> (LeetCode #1948) is a <strong>Hard</strong> problem that primarily trains <strong>tree</strong>.</p>\\n<h3>How to think about it</h3>\\n<ol>\\n<li><strong>Restate the goal</strong> in your own words before coding.</li>\\n<li>Work a <strong>tiny example</strong> by hand so the invariant becomes obvious.</li>\\n<li>Identify the <strong>pattern</strong> — this problem aligns with <strong>trie and dfs backtracking</strong>.</li>\\n<li>Only then translate the idea into code.</li>\\n</ol>\\n<h3>Why this problem matters</h3>\\n<p>Hard problems force you to combine patterns and prove complexity carefully — interview gold.\\nOfficial solution notes mention: Trie, DFS, Hash.</p>\\n<blockquote>\\n<p>AlgoForge explanations are original teaching notes. Always open the <a href=\\\"https://leetcode.com/problems/delete-duplicate-folders-in-system/\\\">official problem statement on LeetCode</a> for constraints and examples.</p>\\n</blockquote>\\n\"}}]]}]\n20:T4ea,<h2>Interview approach for Delete Duplicate Folders in System</h2>\n<h3>Opening (30–60 seconds)</h3>\n<ul>\n<li>Clarify inputs/outputs and edge cases (empty input, single element, duplicates, overflow).</li>\n<li>State a <strong>brute force</strong> so the interviewer knows you can solve it naively.</li>\n<li>Propose the <strong>optimal direction</strong> tied to <strong>trie and dfs backtracking</strong>.</li>\n</ul>\n<h3>Core solution narrative</h3>\n<ol>\n<li>Define the <strong>state</strong> you track (pointers, DP cell, set membership, stack top, etc.).</li>\n<li>Explain the <strong>transition</strong> when you process the next element.</li>\n<li>Call out <strong>time</strong> (O(n * m * l + tlogt + l * t)) and <strong>space</strong> (O(l * t)) before coding.</li>\n<li>Code cleanly; narrate variable names.</li>\n</ol>\n<h3>What interviewers listen for</h3>\n<ul>\n<li>Correctness on edge cases</li>\n<li>Complexity honesty</li>\n<li>Ability to discuss <strong>trade-offs</strong> (e.g., hash map space vs. sort + two pointers)</li>\n</ul>\n<h3>Follow-up questions they may ask</h3>\n<ul>\n<li>Can you solve it with less memory?</li>\n<li>What if the input stream is infinite / doesn't fit in RAM?</li>\n<li>How would tests look for adversarial inputs?</li>\n</ul>\nd:[\"$\",\"section\",\"interview\",{\"id\":\"interview\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Interview Walkthrough\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"$20\"}}]]}]\ne:[\"$\",\"section\",\"optimized\",{\"id\":\"optimized\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Optimized Approach\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Optimized solution notes</h2>\\n<p>The reference solutions on AlgoForge target <strong>O(n * m * l + tlogt + l * t)</strong> time and <strong>O(l * t)</strong> space.</p>\\n<h3>Pattern focus: trie and dfs backtracking</h3>\\n<p>Use the pattern as a checklist:</p>\\n<ul>\\n<li><strong>trie</strong> — confirm the invariant holds after each step</li>\\n<li><strong>dfs backtracking</strong> — confirm the invariant holds after each step</li>\\n</ul>\\n<p>Multiple methods appear in the source solutions — compare them and explain when each is preferable.</p>\\n<h3>Implementation tips</h3>\\n<ul>\\n<li>Prefer readable names over micro-optimizations in interviews.</li>\\n<li>Extract helpers only when they clarify (e.g., expand-around-center, DFS visit).</li>\\n<li>After AC-level logic, re-scan for off-by-one and null checks.</li>\\n</ul>\\n\"}}]]}]\nf:[\"$\",\"section\",\"complexity\",{\"id\":\"complexity\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Complexity Analysis\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Complexity</h2>\\n<table>\\n<thead>\\n<tr>\\n<th>Measure</th>\\n<th>Bound</th>\\n</tr>\\n</thead>\\n<tbody>\\n<tr>\\n<td>Time</td>\\n<td><strong>O(n * m * l + tlogt + l * t)</strong></td>\\n</tr>\\n<tr>\\n<td>Space</td>\\n<td><strong>O(l * t)</strong></td>\\n</tr>\\n</tbody>\\n</table>\\n<h3>How to justify this in an interview</h3>\\n<ul>\\n<li><strong>Time:</strong> count loops, map/set operations, and recursive branching; state average vs worst case if relevant.</li>\\n<li><strong>Space:</strong> include hash maps, recursion stack, and output allocation when the problem asks for it.</li>\\n</ul>\\n<p>If your implementation differs from the reference, re-derive big-O from <em>your</em> code — never memorize a complexity you cannot defend.</p>\\n\"}}]]}]\n10:[\"$\",\"section\",\"common-mistakes\",{\"id\":\"common-mistakes\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Common Mistakes\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Common mistakes on Delete Duplicate Folders in System</h2>\\n<ol>\\n<li><strong>Skipping edge cases</strong> — empty collections, single-element inputs, max constraints.</li>\\n<li><strong>Wrong invariant</strong> for trie and dfs backtracking — updating state too early or too late.</li>\\n<li><strong>Mutating input unexpectedly</strong> when the problem forbids it.</li>\\n<li><strong>Off-by-one</strong> in windows, ranges, or binary search bounds.</li>\\n<li><strong>Ignoring overflow / precision</strong> for integer arithmetic problems.</li>\\n<li><strong>Overengineering</strong> — jumping to an advanced structure when a simpler approach works.</li>\\n</ol>\\n\"}}]]}]\n11:[\"$\",\"section\",\"alternatives\",{\"id\":\"alternatives\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Alternative Approaches\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Alternatives</h2>\\n<p>The source file includes more than one method. Compare:</p>\\n<ol>\\n<li><strong>Primary optimized path</strong> — best complexity for typical interviews.</li>\\n<li><strong>Secondary approach</strong> — often brute force, sorting-based, or space-optimized variant.</li>\\n</ol>\\n<p>Practice articulating <strong>when</strong> you would pick each (constraints, readability, follow-ups).</p>\\n\"}}]]}]\n12:[\"$\",\"section\",\"edge-cases\",{\"id\":\"edge-cases\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Edge Cases\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Edge cases checklist</h2>\\n<ul>\\n<li>Minimum input size</li>\\n<li>Maximum input size / time limits</li>\\n<li>Duplicates and already-sorted input</li>\\n<li>Negative numbers / zeros (if applicable)</li>\\n<li>Disconnected structures (graphs/trees)</li>\\n<li>Single path vs branching recursion depth</li>\\n</ul>\\n\"}}]]}]\n13:[\"$\",\"section\",\"pattern-recognition\",{\"id\":\"pattern-recognition\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Pattern Recognition\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Spotting this pattern</h2>\\n<p>Signal phrases that point to <strong>trie and dfs backtracking</strong>:</p>\\n<ul>\\n<li>Sorted input or ability to sort without changing the answer class</li>\\n<li>Need for contiguous subarray / substring → consider sliding window</li>\\n<li>Need for O(1) membership → hash set/map</li>\\n<li>Optimal substructure + overlapping subproblems → DP</li>\\n<li>Connectivity / components → graph DFS/BFS or Union-Find</li>\\n</ul>\\n<p>Primary topics: <strong>tree</strong>.</p>\\n\"}}]]}]\n14:[\"$\",\"section\",\"follow-ups\",{\"id\":\"follow-ups\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Follow-up Interview Questions\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Follow-ups</h2>\\n<ol>\\n<li>How does the solution change if the input is a stream?</li>\\n<li>Can you solve it in-place?</li>\\n<li>What if duplicates must be handled differently?</li>\\n<li>How would you parallelize the approach?</li>\\n<li>Design tests that would break a buggy implementation.</li>\\n</ol>\\n\"}}]]}]\n15:[\"$\",\"section\",\"practice\",{\"id\":\"practice\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Practice Recommendations\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>What to practice next</h2>\\n<ol>\\n<li>Re-solve <strong>Delete Duplicate Folders in System</strong> in a second language (cpp, python).</li>\\n<li>Drill 3–5 more problems tagged <strong>tree</strong>.</li>\\n<li>Teach the solution out loud in under 5 minutes.</li>\\n<li>Add this problem to your revision calendar in 3 days and 14 days.</li>\\n</ol>\\n\"}}]]}]\n16:[\"$\",\"section\",null,{\"id\":\"visualization\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Visualization\"}],[\"$\",\"div\",null,{\"className\":\"rounded-xl border border-dashed border-border bg-muted/40 p-6 text-sm text-muted-foreground\",\"children\":\"Conceptual diagram for Delete Duplicate Folders in System: show input structure (tree), highlight the moving parts of the trie and dfs backtracking approach, and annotate each step with the maintained invariant and complexity.\"}]]}]\n17:[\"$\",\"section\",null,{\"id\":\"checklist\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Study checklist\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"li\",\"Read the official problem statement on LeetCode\",{\"className\":\"flex gap-2 text-sm\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-primary\",\"aria-hidden\":true,\"children\":\"☐\"}],\"Read the official problem statement on LeetCode\"]}],[\"$\",\"li\",\"Solve on paper / whiteboard first\",{\"className\":\"flex gap-2 text-sm\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-primary\",\"aria-hidden\":true,\"children\":\"☐\"}],\"Solve on paper / whiteboard first\"]}],[\"$\",\"