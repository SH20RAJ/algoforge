\nclass Solution {\\nprivate:\\n    template \\u003ctypename T\\u003e\\n    struct PairHash {\\n        size_t operator()(const pair\\u003cT, T\\u003e\\u0026 p) const {\\n            size_t seed = 0;\\n            seed ^= std::hash\\u003cT\\u003e{}(p.first)  + 0x9e3779b9 + (seed\\u003c\\u003c6) + (seed\\u003e\\u003e2);\\n            seed ^= std::hash\\u003cT\\u003e{}(p.second) + 0x9e3779b9 + (seed\\u003c\\u003c6) + (seed\\u003e\\u003e2);\\n            return seed;\\n        }\\n    };\\n\\n    template\\u003ctypename T\\u003e\\n    struct VectorPairHash {\\n        size_t operator()(const std::vector\\u003cpair\\u003cT, T\\u003e\\u003e\\u0026 v) const {\\n            size_t seed = 0;\\n            for (const auto\\u0026 i : v) {\\n                seed ^= PairHash\\u003cT\\u003e{}(i)  + 0x9e3779b9 + (seed\\u003c\\u003c6) + (seed\\u003e\\u003e2);\\n            }\\n            return seed;\\n        }\\n    };\\n\\n    class TrieNode { \\n    public:\\n        void Insert(const vector\\u003cstring\\u003e\\u0026 s,\\n                    unordered_map\\u003cstring, int\\u003e *folder_ids,\\n                    unordered_map\\u003cint, string\\u003e *id_folders) {\\n            auto p = this;\\n            for (const auto\\u0026 c : s) {\\n                if (!folder_ids-\\u003ecount(c)) {\\n                    (*folder_ids)[c] = size(*folder_ids);\\n                    (*id_folders)[(*folder_ids)[c]] = c;\\n                }\\n                const auto folder_id = (*folder_ids)[c];\\n                if (!p-\\u003eleaves.count(folder_id)) {\\n                    p-\\u003eleaves[folder_id] = make_unique\\u003cTrieNode\\u003e();\\n                }\\n                p = p-\\u003eleaves[folder_id].get();\\n            }\\n        }\\n\\n        bool deleted = false;\\n        unordered_map\\u003cint, unique_ptr\\u003cTrieNode\\u003e\\u003e leaves;\\n    };\\n  \\npublic:\\n    vector\\u003cvector\\u003cstring\\u003e\\u003e deleteDuplicateFolder(vector\\u003cvector\\u003cstring\\u003e\\u003e\\u0026 paths) {\\n        auto trie = make_unique\\u003cTrieNode\\u003e();\\n        unordered_map\\u003cstring, int\\u003e folder_ids;\\n        unordered_map\\u003cint, string\\u003e id_folders;\\n        for (const auto\\u0026 path : paths) {\\n            trie-\\u003eInsert(path, \\u0026folder_ids, \\u0026id_folders);\\n        }\\n        unordered_map\\u003cint, TrieNode*\\u003e lookup;\\n        unordered_map\\u003cvector\\u003cpair\\u003cint, int\\u003e\\u003e, int, VectorPairHash\\u003cint\\u003e\\u003e node_ids;\\n        mark(trie.get(), \\u0026lookup, \\u0026node_ids);\\n        vector\\u003cvector\\u003cstring\\u003e\\u003e result;\\n        vector\\u003cint\\u003e path;\\n        sweep(trie.get(), id_folders, \\u0026path, \\u0026result);\\n        return result;\\n    }\\n\\nprivate:\\n    int mark(TrieNode *node,\\n             unordered_map\\u003cint, TrieNode*\\u003e *lookup,\\n             unordered_map\\u003cvector\\u003cpair\\u003cint, int\\u003e\\u003e, int, VectorPairHash\\u003cint\\u003e\\u003e *node_ids) {\\n        vector\\u003cpair\\u003cint, int\\u003e\\u003e id_pairs;\\n        for (const auto\\u0026 [subfolder_id, child] : node-\\u003eleaves) {\\n            id_pairs.emplace_back(subfolder_id, mark(child.get(), lookup, node_ids));\\n        }\\n        sort(begin(id_pairs), end(id_pairs));\\n        if (!node_ids-\\u003ecount(id_pairs)) {\\n            (*node_ids)[id_pairs] = size(*node_ids);\\n        }\\n        int node_id = (*node_ids)[id_pairs];\\n        if (node_id) {\\n            if (lookup-\\u003ecount(node_id)) {\\n                (*lookup)[node_id]-\\u003edeleted = true;\\n                node-\\u003edeleted = true;\\n            } else {\\n                (*lookup)[node_id] = node;\\n            }\\n        }\\n        return node_id;\\n    }\\n\\n    void sweep(TrieNode *node,\\n               const unordered_map\\u003cint, string\\u003e\\u0026 id_folders,\\n               vector\\u003cint\\u003e *path,\\n               vector\\u003cvector\\u003cstring\\u003e\\u003e *result) {\\n        if (!empty(*path)) {\\n            result-\\u003eemplace_back();\\n            transform(cbegin(*path), cend(*path), back_inserter(result-\\u003eback()),\\n                      [\\u0026id_folders](const auto\\u0026 i) {\\n                          return id_folders.at(i);\\n                      });\\n        }\\n        for (const auto\\u0026 [subfolder_id, child] : node-\\u003eleaves) {\\n            if (child-\\u003edeleted) {\\n                continue;\\n            }\\n            path-\\u003eemplace_back(subfolder_id);\\n            sweep(child.get(), id_folders, path, result);\\n            path-\\u003epop_back();\\n        }\\n    }\\n};\\n\\n// Time:  O(n * m * l + l * tlogt + l * t^2), m is the max number of folders in a path,\\n//                                          , n is the number of paths\\n//                                          , l is the max length of folder name\\n//                                          , t is the size of trie\\n// Space: O(l * t^2)\\nclass Solution2 {\\nprivate:\\n    class TrieNode { \\n    public:\\n        void Insert(const vector\\u003cstring\\u003e\\u0026 s) {\\n            auto p = this;\\n            for (const auto\\u0026 c : s) {\\n                if (!p-\\u003eleaves.count(c)) {\\n                    p-\\u003eleaves[c] = make_unique\\u003cTrieNode\\u003e();\\n                }\\n                p = p-\\u003eleaves[c].get();\\n            }\\n        }\\n\\n        bool deleted = false;\\n        map\\u003cstring, unique_ptr\\u003cTrieNode\\u003e\\u003e leaves;\\n    };\\n  \\npublic:\\n    vector\\u003cvector\\u003cstring\\u003e\\u003e deleteDuplicateFolder(vector\\u003cvector\\u003cstring\\u003e\\u003e\\u0026 paths) {\\n        auto trie = make_unique\\u003cTrieNode\\u003e();\\n        for (const auto\\u0026 path : paths) {\\n            trie-\\u003eInsert(path);\\n        }\\n        unordered_map\\u003cstring, TrieNode*\\u003e lookup;\\n        mark(trie.get(), \\u0026lookup);\\n        vector\\u003cvector\\u003cstring\\u003e\\u003e result;\\n        vector\\u003cstring\\u003e path;\\n        sweep(trie.get(), \\u0026path, \\u0026result);\\n        return result;\\n    }\\n\\nprivate:\\n    string mark(TrieNode *node, unordered_map\\u003cstring, TrieNode*\\u003e *lookup) {\\n        string serialized_tree = \\\"(\\\";\\n        for (const auto\\u0026 [subfolder, child] : node-\\u003eleaves) {\\n            serialized_tree += subfolder + mark(child.get(), lookup);\\n        }\\n        serialized_tree += \\\")\\\";\\n        if (serialized_tree != \\\"()\\\") {\\n            if (lookup-\\u003ecount(serialized_tree)) {\\n                (*lookup)[serialized_tree]-\\u003edeleted = true;\\n                node-\\u003edeleted = true;\\n            } else {\\n                (*lookup)[serialized_tree] = node;\\n            }\\n        }\\n        return serialized_tree;\\n    }\\n\\n    void sweep(TrieNode *node, vector\\u003cstring\\u003e *path, vector\\u003cvector\\u003cstring\\u003e\\u003e *result) {\\n        if (!empty(*path)) {\\n            result-\\u003eemplace_back(*path);\\n        }\\n        for (const auto\\u0026 [subfolder, child] : node-\\u003eleaves) {\\n            if (child-\\u003edeleted) {\\n                continue;\\n            }\\n            path-\\u003eemplace_back(subfolder);\\n            sweep(child.get(), path, result);\\n            path-\\u003epop_back();\\n        }\\n    }\\n};\\n\"])</script><script>self.__next_f.push([1,\"23:Te52,\"])</script><script>self.__next_f.push([1,\"# Time:  O(n * m * l + tlogt + l * t), m is the max number of folders in a path,\\n#                                    , n is the number of paths\\n#                                    , l is the max length of folder name\\n#                                    , t is the size of trie\\n# Space: O(l * t)\\n\\nimport collections\\n\\n\\nclass Solution(object):\\n    def deleteDuplicateFolder(self, paths):\\n        \\\"\\\"\\\"\\n        :type paths: List[List[str]]\\n        :rtype: List[List[str]]\\n        \\\"\\\"\\\"\\n        def mark(node, lookup, node_ids):\\n            id_pairs = []\\n            for subfolder_id, child in node.iteritems():\\n                if child == \\\"_del\\\":\\n                    continue\\n                id_pairs.append((subfolder_id, mark(child, lookup, node_ids)))\\n            id_pairs.sort()\\n            node_id = node_ids[tuple(id_pairs)]\\n            if node_id:\\n                if node_id in lookup:\\n                    lookup[node_id][\\\"_del\\\"]\\n                    node[\\\"_del\\\"]\\n                else:\\n                    lookup[node_id] = node\\n            return node_id\\n\\n        def sweep(node, id_folders, path, result):\\n            if path:\\n                result.append([id_folders[i] for i in path])\\n            for subfolder_id, child in node.iteritems():\\n                if \\\"_del\\\" in child:\\n                    continue\\n                path.append(subfolder_id)\\n                sweep(child, id_folders, path, result)\\n                path.pop()\\n\\n        _trie = lambda: collections.defaultdict(_trie)\\n        trie = _trie()\\n        folder_ids = collections.defaultdict()\\n        folder_ids.default_factory = folder_ids.__len__\\n        id_folders = {}\\n        for path in paths:\\n            node = trie\\n            for folder in path:\\n                if folder_ids[folder] not in id_folders:\\n                    id_folders[folder_ids[folder]] = folder\\n                node = node[folder_ids[folder]]\\n        node_ids = collections.defaultdict()\\n        node_ids.default_factory = node_ids.__len__\\n        mark(trie, {}, node_ids)\\n        result = []\\n        sweep(trie, id_folders, [], result)\\n        return result\\n\\n\\n# Time:  O(n * m * l + l * tlogt + l * t^2), m is the max number of folders in a path,\\n#                                          , n is the number of paths\\n#                                          , l is the max length of folder name\\n#                                          , t is the size of trie\\n# Space: O(l * t^2)\\nimport collections\\n\\n\\nclass Solution2(object):\\n    def deleteDuplicateFolder(self, paths):\\n        \\\"\\\"\\\"\\n        :type paths: List[List[str]]\\n        :rtype: List[List[str]]\\n        \\\"\\\"\\\"\\n        def mark(node, lookup):\\n            serialized_tree = \\\"(\\\" + \\\"\\\".join(subfolder + mark(child, lookup) for subfolder, child in sorted(node.iteritems()) if child != \\\"_del\\\") + \\\")\\\"\\n            if serialized_tree != \\\"()\\\":\\n                if serialized_tree in lookup:\\n                    lookup[serialized_tree][\\\"_del\\\"]\\n                    node[\\\"_del\\\"]\\n                else:\\n                    lookup[serialized_tree] = node\\n            return serialized_tree\\n        \\n        def sweep(node, path, result):\\n            if path:\\n                result.append(path[:])\\n            for subfolder, child in node.iteritems():\\n                if \\\"_del\\\" in child:\\n                    continue\\n                path.append(subfolder)\\n                sweep(child, path, result)\\n                path.pop()\\n\\n        _trie = lambda: collections.defaultdict(_trie)\\n        trie = _trie()\\n        for path in paths:\\n            reduce(dict.__getitem__, path, trie)\\n        mark(trie, {})\\n        result = []\\n        sweep(trie, [], result)\\n        return result\\n\"])</script><script>self.__next_f.push([1,\"1f:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-6 grid lg:grid-cols-[1fr_280px] gap-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"article\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"header\\\",null,{\\\"className\\\":\\\"space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-sm text-muted-foreground tabular-nums\\\",\\\"children\\\":[\\\"#\\\",1948]}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\\\",\\\"children\\\":\\\"Hard\\\"}],false,[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":[\\\"~\\\",50,\\\" min\\\"]}]]}],[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-tight\\\",\\\"children\\\":\\\"Delete Duplicate Folders in System\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-muted-foreground max-w-2xl\\\",\\\"children\\\":[\\\"Time \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"className\\\":\\\"text-foreground\\\",\\\"children\\\":\\\"O(n * m * l + tlogt + l * t)\\\"}],\\\" · \\\",\\\"Space \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"className\\\":\\\"text-foreground\\\",\\\"children\\\":\\\"O(l * t)\\\"}],\\\" · \\\",[\\\"$\\\",\\\"a\\\",null,{\\\"href\\\":\\\"https://leetcode.com/problems/delete-duplicate-folders-in-system/\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"text-primary underline-offset-2 hover:underline\\\",\\\"children\\\":\\\"Official statement on LeetCode\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap gap-2\\\",\\\"children\\\":[[[\\\"$\\\",\\\"$L3\\\",\\\"tree\\\",{\\\"href\\\":\\\"/topics/tree\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-primary/15 text-primary\\\",\\\"children\\\":\\\"tree\\\"}]}]],[[\\\"$\\\",\\\"$L3\\\",\\\"trie\\\",{\\\"href\\\":\\\"/patterns/trie\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":\\\"trie\\\"}]}],[\\\"$\\\",\\\"$L3\\\",\\\"dfs-backtracking\\\",{\\\"href\\\":\\\"/patterns/dfs-backtracking\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":\\\"dfs backtracking\\\"}]}]],[]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap gap-2 pt-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L20\\\",null,{\\\"slug\\\":\\\"delete-duplicate-folders-in-system\\\"}],[[\\\"$\\\",\\\"$L3\\\",\\\"cpp\\\",{\\\"href\\\":\\\"/problems/delete-duplicate-folders-in-system/cpp\\\",\\\"className\\\":\\\"text-sm text-primary hover:underline\\\",\\\"children\\\":\\\"cpp\\\"}],[\\\"$\\\",\\\"$L3\\\",\\\"python\\\",{\\\"href\\\":\\\"/problems/delete-duplicate-folders-in-system/python\\\",\\\"className\\\":\\\"text-sm text-primary hover:underline\\\",\\\"children\\\":\\\"python\\\"}]]]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mt-10\\\",\\\"id\\\":\\\"solutions\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold mb-3\\\",\\\"children\\\":\\\"Solutions\\\"}],[\\\"$\\\",\\\"$L21\\\",null,{\\\"solutions\\\":{\\\"cpp\\\":{\\\"language\\\":\\\"C++\\\",\\\"languageSlug\\\":\\\"cpp\\\",\\\"filename\\\":\\\"delete-duplicate-folders-in-system.cpp\\\",\\\"code\\\":\\\"$22\\\",\\\"sourcePath\\\":\\\"C++/delete-duplicate-folders-in-system.cpp\\\"},\\\"python\\\":{\\\"language\\\":\\\"Python\\\",\\\"languageSlug\\\":\\\"python\\\",\\\"filename\\\":\\\"delete-duplicate-folders-in-system.py\\\",\\\"code\\\":\\\"$23\\\",\\\"sourcePath\\\":\\\"Python/delete-duplicate-folders-in-system.py\\\"}}}]]}],[\\\"$L24\\\",\\\"$L25\\\",\\\"$L26\\\",\\\"$L27\\\",\\\"$L28\\\",\\\"$L29\\\",\\\"$L2a\\\",\\\"$L2b\\\",\\\"$L2c\\\",\\\"$L2d\\\"],\\\"$L2e\\\",\\\"$L2f\\\",\\\"$L30\\\",\\\"$L31\\\",\\\"$L32\\\",\\\"$L33\\\"]}],\\\"$L34\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"3c:I[203221,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\",\\\"/_next/static/chunks/259rkrk9l2f9c.js\\\"],\\\"ConfidenceTracker\\\"]\\n\"])</script><script>self.__next_f.push([1,\"24:[\\\"$\\\",\\\"section\\\",\\\"beginner\\\",{\\\"id\\\":\\\"beginner\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Beginner Explanation\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003ch2\\u003eWhat is Delete Duplicate Folders in System?\\u003c/h2\\u003e\\\\n\\u003cp\\u003e\\u003cstrong\\u003eDelete Duplicate Folders in System\\u003c/strong\\u003e (LeetCode #1948) is a \\u003cstrong\\u003eHard\\u003c/strong\\u003e problem that primarily trains \\u003cstrong\\u003etree\\u003c/strong\\u003e.\\u003c/p\\u003e\\\\n\\u003ch3\\u003eHow to think about it\\u003c/h3\\u003e\\\\n\\u003col\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eRestate the goal\\u003c/strong\\u003e in your own words before coding.\\u003c/li\\u003e\\\\n\\u003cli\\u003eWork a \\u003cstrong\\u003etiny example\\u003c/strong\\u003e by hand so the invariant becomes obvious.\\u003c/li\\u003e\\\\n\\u003cli\\u003eIdentify the \\u003cstrong\\u003epattern\\u003c/strong\\u003e — this problem aligns with \\u003cstrong\\u003etrie and dfs backtracking\\u003c/strong\\u003e.\\u003c/li\\u003e\\\\n\\u003cli\\u003eOnly then translate the idea into code.\\u003c/li\\u003e\\\\n\\u003c/ol\\u003e\\\\n\\u003ch3\\u003eWhy this problem matters\\u003c/h3\\u003e\\\\n\\u003cp\\u003eHard problems force you to combine patterns and prove complexity carefully — interview gold.\\\\nOfficial solution notes mention: Trie, DFS, Hash.\\u003c/p\\u003e\\\\n\\u003cblockquote\\u003e\\\\n\\u003cp\\u003eAlgoForge explanations are original teaching notes. Always open the \\u003ca href=\\\\\\\"https://leetcode.com/problems/delete-duplicate-folders-in-system/\\\\\\\"\\u003eofficial problem statement on LeetCode\\u003c/a\\u003e for constraints and examples.\\u003c/p\\u003e\\\\n\\u003c/blockquote\\u003e\\\\n\\\"}}]]}]\\n\"])</script><script>self.__next_f.push([1,\"35:T4ea,\\u003ch2\\u003eInterview approach for Delete Duplicate Folders in System\\u003c/h2\\u003e\\n\\u003ch3\\u003eOpening (30–60 seconds)\\u003c/h3\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eClarify inputs/outputs and edge cases (empty input, single element, duplicates, overflow).\\u003c/li\\u003e\\n\\u003cli\\u003eState a \\u003cstrong\\u003ebrute force\\u003c/strong\\u003e so the interviewer knows you can solve it naively.\\u003c/li\\u003e\\n\\u003cli\\u003ePropose the \\u003cstrong\\u003eoptimal direction\\u003c/strong\\u003e tied to \\u003cstrong\\u003etrie and dfs backtracking\\u003c/strong\\u003e.\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch3\\u003eCore solution narrative\\u003c/h3\\u003e\\n\\u003col\\u003e\\n\\u003cli\\u003eDefine the \\u003cstrong\\u003estate\\u003c/strong\\u003e you track (pointers, DP cell, set membership, stack top, etc.).\\u003c/li\\u003e\\n\\u003cli\\u003eExplain the \\u003cstrong\\u003etransition\\u003c/strong\\u003e when you process the next element.\\u003c/li\\u003e\\n\\u003cli\\u003eCall out \\u003cstrong\\u003etime\\u003c/strong\\u003e (O(n * m * l + tlogt + l * t)) and \\u003cstrong\\u003espace\\u003c/strong\\u003e (O(l * t)) before coding.\\u003c/li\\u003e\\n\\u003cli\\u003eCode cleanly; narrate variable names.\\u003c/li\\u003e\\n\\u003c/ol\\u003e\\n\\u003ch3\\u003eWhat interviewers listen for\\u003c/h3\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eCorrectness on edge cases\\u003c/li\\u003e\\n\\u003cli\\u003eComplexity honesty\\u003c/li\\u003e\\n\\u003cli\\u003eAbility to discuss \\u003cstrong\\u003etrade-offs\\u003c/strong\\u003e (e.g., hash map space vs. sort + two pointers)\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch3\\u003eFollow-up questions they may ask\\u003c/h3\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eCan you solve it with less memory?\\u003c/li\\u003e\\n\\u003cli\\u003eWhat if the input stream is infinite / doesn't fit in RAM?\\u003c/li\\u003e\\n\\u003cli\\u003eHow would tests look for adversarial inputs?\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n25:[\\\"$\\\",\\\"section\\\",\\\"interview\\\",{\\\"id\\\":\\\"interview\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Interview Walkthrough\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$35\\\"}}]]}]\\n26:[\\\"$\\\",\\\"section\\\",\\\"optimized\\\",{\\\"id\\\":\\\"optimized\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Optimized Approach\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003ch2\\u003eOptimized solution notes\\u003c/h2\\u003e\\\\n\\u003cp\\u003eThe reference solutions on AlgoForge target \\u003cstrong\\u003eO(n * m * l + tlogt + l * t)\\u003c/strong\\u003e time and \\u003cstrong\\u003eO(l * t)\\u003c/strong\\u003e space.\\u003c/p\\u003e\\\\n\\u003ch3\\u003ePattern focus: trie and dfs backtracking\\u003c/h3\\u003e\\\\n\\u003cp\\u003eUse the pattern as a checklist:\\u003c/p\\u003e\\\\n\\u003cul\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003etrie\\u003c/strong\\u003e — confirm the invariant holds after each step\\u003c/li\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003edfs backtracking\\u003c/strong\\u003e — confirm the invariant holds after each step\\u003c/li\\u003e\\\\n\\u003c/ul\\u003e\\\\n\\u003cp\\u003eMultiple methods appear in the source solutions — compare them and explain when each is preferable.\\u003c/p\\u003e\\\\n\\u003ch3\\u003eImplementation tips\\u003c/h3\\u003e\\\\n\\u003cul\\u003e\\\\n\\u003cli\\u003ePrefer readable names over micro-optimizations in interviews.\\u003c/li\\u003e\\\\n\\u003cli\\u003eExtract helpers only when they clarify (e.g., expand-around-center, DFS visit).\\u003c/li\\u003e\\\\n\\u003cli\\u003eAfter AC-level logic, re-scan for off-by-one and null checks.\\u003c/li\\u003e\\\\n\\u003c/ul\\u003e\\\\n\\\"}}]]}]\\n27:[\\\"$\\\",\\\"section\\\",\\\"complexity\\\",{\\\"id\\\":\\\"complexity\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Complexity Analysis\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003ch2\\u003eComplexity\\u003c/h2\\u003e\\\\n\\u003ctable\\u003e\\\\n\\u003cthead\\u003e\\\\n\\u003ctr\\u003e\\\\n\\u003cth\\u003eMeasure\\u003c/th\\u003e\\\\n\\u003cth\\u003eBound\\u003c/th\\u003e\\\\n\\u003c/tr\\u003e\\\\n\\u003c/thead\\u003e\\\\n\\u003ctbody\\u003e\\\\n\\u003ctr\\u003e\\\\n\\u003ctd\\u003eTime\\u003c/td\\u003e\\\\n\\u003ctd\\u003e\\u003cstrong\\u003eO(n * m * l + tlogt + l * t)\\u003c/strong\\u003e\\u003c/td\\u003e\\\\n\\u003c/tr\\u003e\\\\n\\u003ctr\\u003e\\\\n\\u003ctd\\u003eSpace\\u003c/td\\u003e\\\\n\\u003ctd\\u003e\\u003cstrong\\u003eO(l * t)\\u003c/strong\\u003e\\u003c/td\\u003e\\\\n\\u003c/tr\\u003e\\\\n\\u003c/tbody\\u003e\\\\n\\u003c/table\\u003e\\\\n\\u003ch3\\u003eHow to justify this in an interview\\u003c/h3\\u003e\\\\n\\u003cul\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eTime:\\u003c/strong\\u003e count loops, map/set operations, and recursive branching; state average vs worst case if relevant.\\u003c/li\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eSpace:\\u003c/strong\\u003e include hash maps, recursion stack, and output allocation when the problem asks for it.\\u003c/li\\u003e\\\\n\\u003c/ul\\u003e\\\\n\\u003cp\\u003eIf your implementation differs from the reference, re-derive big-O from \\u003cem\\u003eyour\\u003c/em\\u003e code — never memorize a complexity you cannot defend.\\u003c/p\\u003e\\\\n\\\"}}]]}]\\n28:[\\\"$\\\",\\\"section\\\",\\\"common-mistakes\\\",{\\\"id\\\":\\\"common-mistakes\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\"])</script><script>self.__next_f.push([1,\"\\\",\\\"children\\\":\\\"Common Mistakes\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003ch2\\u003eCommon mistakes on Delete Duplicate Folders in System\\u003c/h2\\u003e\\\\n\\u003col\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eSkipping edge cases\\u003c/strong\\u003e — empty collections, single-element inputs, max constraints.\\u003c/li\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eWrong invariant\\u003c/strong\\u003e for trie and dfs backtracking — updating state too early or too late.\\u003c/li\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eMutating input unexpectedly\\u003c/strong\\u003e when the problem forbids it.\\u003c/li\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eOff-by-one\\u003c/strong\\u003e in windows, ranges, or binary search bounds.\\u003c/li\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u