TML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"Article\\\",\\\"headline\\\":\\\"Number of Integers With Popcount-Depth Equal to K II\\\",\\\"description\\\":\\\"Original Hard explanation for Number of Integers With Popcount-Depth Equal to K II (LeetCode #3624). Pattern: fenwick tree. Time precompute: O((logr) * log(logr)) runtime: O(nlogr + maxk * n + nlogn + qlogn), space O(logr + maxk * n). Multi-language solutions and interview tips.\\\",\\\"url\\\":\\\"https://algoforge.dev/problems/number-of-integers-with-popcount-depth-equal-to-k-ii\\\",\\\"author\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"AlgoForge\\\"},\\\"publisher\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"AlgoForge\\\"},\\\"datePublished\\\":\\\"2026-01-01\\\",\\\"dateModified\\\":\\\"2026-07-17\\\"}\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$1d\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"HowTo\\\",\\\"name\\\":\\\"How to solve Number of Integers With Popcount-Depth Equal to K II\\\",\\\"description\\\":\\\"Original Hard explanation for Number of Integers With Popcount-Depth Equal to K II (LeetCode #3624). Pattern: fenwick tree. Time precompute: O((logr) * log(logr)) runtime: O(nlogr + maxk * n + nlogn + qlogn), space O(logr + maxk * n). Multi-language solutions and interview tips.\\\",\\\"step\\\":[{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":1,\\\"text\\\":\\\"Read the official problem statement on LeetCode\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":2,\\\"text\\\":\\\"Solve on paper / whiteboard first\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":3,\\\"text\\\":\\\"Implement the fenwick tree approach\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":4,\\\"text\\\":\\\"Verify edge cases from the checklist\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":5,\\\"text\\\":\\\"State time and space complexity aloud\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":6,\\\"text\\\":\\\"Compare with the AlgoForge reference solution\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":7,\\\"text\\\":\\\"Schedule a revision session\\\"}]}\"}}],[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Number of Integers With Popcount-Depth Equal to K II\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/number-of-integers-with-popcount-depth-equal-to-k-ii\\\"}]}\"}}],\"$L1e\"]}],\"$L1f\"]}]\n20:I[56303,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"BookmarkButton\"]\n21:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"CodeTabs\"]\n1e:[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/number-of-integers-with-popcount-depth-equal-to-k-ii\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"Number of Integers With Popcount-Depth Equal to K II\"}]]}]]}]\n22:T906,// Time:  precompute: O((logr) * log(logr) + log*(r) * (logr)) = O((logr) * log(logr)), r = max(n)\n//        runtime:    O(nlogr + max_k * n + nlogn + qlogn)\n// Space: O(logr + max_k * n)\n\n// fenwick tree\nclass BIT {\npublic:\n    BIT(int n) : bit_(n + 1) {  // 0-indexed\n    }\n    \n    void add(int i, int val) {\n        ++i;\n        for (; i < size(bit_); i += lower_bit(i)) {\n            bit_[i] += val;\n        }\n    }\n\n    int query(int i) const {\n        ++i;\n        int total = 0;\n        for (; i > 0; i -= lower_bit(i)) {\n            total += bit_[i];\n        }\n        return total;\n    }\n\nprivate:\n    int lower_bit(int i) const {\n        return i & -i;\n    }\n    \n    vector<int> bit_;\n};\n\nint bit_length(int64_t x) {\n    return (x ? std::__lg(x) : -1) + 1;\n}\n\nint ceil_log2(int64_t x) {\n    return std::__lg(x - 1) + 1;\n};\n\npair<vector<int>, int> init() {\n    int64_t MAX_N = 1e15;\n    static const int MAX_BIT_LEN = bit_length(MAX_N);\n    vector<int> D(MAX_BIT_LEN + 1, 0);\n    for (int i = 2; i < size(D); ++i) {\n        D[i] = D[__builtin_popcount(i)] + 1;\n    }\n    int MAX_K = 0;\n    for (; MAX_N != 1; ++MAX_K) {  // O(log*(MAX_N)) times\n        MAX_N = ceil_log2(MAX_N);\n    }\n    return {D, MAX_K};\n}\n\nconst auto& [D, MAX_K] = init();\nclass Solution {\npublic:\n    vector<int> popcountDepth(vector<long long>& nums, vector<vector<long long>>& queries) {\n        const auto& count = [](int64_t x) {\n            return x != 1 ? D[__builtin_popcountll(x)] + 1 : 0;\n        };\n\n        vector<BIT> bit(MAX_K + 1, BIT(size(nums)));\n        for (int i = 0; i < size(nums); ++i) {\n            bit[count(nums[i])].add(i, +1);\n        }\n        vector<int> result;\n        for (const auto& q : queries) {\n            if (q[0] == 1) {\n                const int l = q[1], r = q[2], k = q[3];\n                assert(k < size(bit));\n                result.emplace_back(bit[k].query(r) - bit[k].query(l - 1));\n            } else {\n                const auto& i = q[1], &x = q[2];\n                const auto& old_d = count(nums[i]);\n                const auto& new_d = count(x);\n                if (new_d != old_d) {\n                    bit[old_d].add(i, -1);\n                    bit[new_d].add(i, +1);\n                }\n                nums[i] = x;\n            }\n        }\n        return result;\n    }\n};\n23:T76c,# Time:  precompute: O((logr) * log(logr) + log*(r) * (logr)) = O((logr) * log(logr)), r = max(n)\n#        runtime:    O(nlogr + max_k * n + nlogn + qlogn)\n# Space: O(logr + max_k * n)\n\n# fenwick tree\ndef popcount(x):\n    return bin(x).count('1')\n\n\ndef ceil_log2(x):\n    return (x-1).bit_length()\n\n\nclass BIT(object):  # 0-indexed.\n    def __init__(self, n):\n        self.__bit = [0]*(n+1)  # Extra one for dummy node.\n\n    def add(self, i, val):\n        i += 1  # Extra one for dummy node.\n        while i < len(self.__bit):\n            self.__bit[i] += val\n            i += (i & -i)\n\n    def query(self, i):\n        i += 1  # Extra one for dummy node.\n        ret = 0\n        while i > 0:\n            ret += self.__bit[i]\n            i -= (i & -i)\n        return ret\n\n\nMAX_N = 10**15\nMAX_BIT_LEN = MAX_N.bit_length()\nD = [0]*(MAX_BIT_LEN+1)\nfor i in xrange(2, MAX_BIT_LEN+1):\n    D[i] = D[popcount(i)]+1\nMAX_K = 0\nwhile MAX_N != 1:  # O(log*(MAX_N)) times\n    MAX_N = ceil_log2(MAX_N)\n    MAX_K += 1\nclass Solution(object):\n    def popcountDepth(self, nums, queries):\n        \"\"\"\n        :type nums: List[int]\n        :type queries: List[List[int]]\n        :rtype: List[int]\n        \"\"\"\n        def count(x):\n            return D[popcount(x)]+1 if x != 1 else 0\n        \n        bit = [BIT(len(nums)) for _ in xrange(MAX_K+1)]\n        for i in xrange(len(nums)):\n            bit[count(nums[i])].add(i, +1)\n        result = []\n        for q in queries:\n            if q[0] == 1:\n                _, l, r, k = q\n                assert(k < len(bit))\n                result.append(bit[k].query(r)-bit[k].query(l-1))\n            else:\n                _, i, x = q\n                old_d = count(nums[i])\n                new_d = count(x)\n                if new_d != old_d:\n                    bit[old_d].add(i, -1)\n                    bit[new_d].add(i, +1)\n                nums[i] = x\n        return result\n1f:[\"$\",\"div\",null,{\"className\":\"mt-6 grid lg:grid-cols-[1fr_280px] gap-10\",\"children\":[[\"$\",\"article\",null,{\"children\":[[\"$\",\"header\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-wrap items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-sm text-muted-foreground tabular-nums\",\"children\":[\"#\",3624]}],[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\",\"children\":\"Hard\"}],false,[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":[\"~\",50,\" min\"]}]]}],[\"$\",\"h1\",null,{\"className\":\"text-3xl md:text-4xl font-bold tracking-tight\",\"children\":\"Number of Integers With Popcount-Depth Equal to K II\"}],[\"$\",\"p\",null,{\"className\":\"text-muted-foreground max-w-2xl\",\"children\":[\"Time \",[\