t-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}\"}}],[\"$\",\"h1\",null,{\"className\":\"next-error-h1\",\"style\":{\"display\":\"inline-block\",\"margin\":\"0 20px 0 0\",\"padding\":\"0 23px 0 0\",\"fontSize\":24,\"fontWeight\":500,\"verticalAlign\":\"top\",\"lineHeight\":\"49px\"},\"children\":404}],[\"$\",\"div\",null,{\"style\":{\"display\":\"inline-block\"},\"children\":[\"$\",\"h2\",null,{\"style\":{\"fontSize\":14,\"fontWeight\":400,\"lineHeight\":\"49px\",\"margin\":0},\"children\":\"This page could not be found.\"}]}]]}]}]],[]],\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}]\n9:[\"$\",\"footer\",null,{\"className\":\"mt-20 border-t border-border bg-sidebar\",\"children\":[[\"$\",\"div\",null,{\"className\":\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-lg\",\"children\":\"AlgoForge\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground max-w-xs\",\"children\":\"Master coding interviews with patterns, roadmaps, and solutions\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-sm mb-3\",\"children\":\"Learn\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary\",\"children\":\"Problems\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/patterns\",\"className\":\"hover:text-primary\",\"children\":\"Patterns\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/roadmaps\",\"className\":\"hover:text-primary\",\"children\":\"Roadmaps\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/blind-75\",\"className\":\"hover:text-primary\",\"children\":\"Blind 75\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/grind-169\",\"className\":\"hover:text-primary\",\"children\":\"Grind 169\"}]}]]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-sm mb-3\",\"children\":\"Interview\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/companies\",\"className\":\"hover:text-primary\",\"children\":\"Companies\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/interview-preparation\",\"className\":\"hover:text-primary\",\"children\":\"Interview prep\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/system-design\",\"className\":\"hover:text-primary\",\"children\":\"System design\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/glossary\",\"className\":\"hover:text-primary\",\"children\":\"Glossary\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/blog\",\"className\":\"hover:text-primary\",\"children\":\"Blog\"}]}]]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-sm mb-3\",\"children\":\"Product\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/pricing\",\"className\":\"hover:text-primary\",\"children\":\"Pricing\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/about\",\"className\":\"hover:text-primary\",\"children\":\"About\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/about/attribution\",\"className\":\"hover:text-primary\",\"children\":\"Attribution\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/sitemap-html\",\"className\":\"hover:text-primary\",\"children\":\"Sitemap\"}]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"border-t border-border\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-af py-4 flex flex-col sm:flex-row gap-2 justify-between text-xs text-muted-foreground\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"© \",2026,\" \",\"AlgoForge\",\". Educational use only.\"]}],[\"$\",\"p\",null,{\"children\":[\"Solution code sourced under MIT from\",\" \",[\"$\",\"a\",null,{\"href\":\"https://github.com/kamyu104/LeetCode-Solutions\",\"className\":\"underline hover:text-primary\",\"rel\":\"noopener noreferrer\",\"target\":\"_blank\",\"children\":\"kamyu104/LeetCode-Solutions\"}],\". Explanations are original AlgoForge content.\"]}]]}]}]]}]\na:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nb:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nc:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nd:[\"$\",\"$1\",\"c\",{\"children\":[\"$L15\",[[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0a2gmow1_jiq0.js\",\"async\":true,\"nonce\":\"$undefined\"}]],[\"$\",\"$L16\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@18\"}]}]]}]\n19:[]\ne:\"$W19\"\nf:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1a\",null,{\"children\":\"$L1b\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1d\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n11:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/340fxer6uczx7.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n1e:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n1f:T1d7d,// Time:  O((n + k) * logn)\n// Space: O(n + k)\n\n// heap, sort, two pointers\nclass Solution {\nprivate:\n    struct TupleHash {\n        template <typename... T>\n        std::size_t operator()(const std::tuple<T...>& t) const {\n            return apply([](const auto&... args) {\n                std::size_t seed = 0;\n                ((seed ^= std::hash<std::decay_t<decltype(args)>>{}(args) + \n                        0x9e3779b9 + (seed << 6) + (seed >> 2)), ...);\n                return seed;\n            }, t);\n        }\n    };\n\npublic:\n    long long maxTotalValue(vector<int>& nums, int k) {\n        vector<int> idxs(size(nums));\n        iota(begin(idxs), end(idxs), 0);\n        sort(begin(idxs), end(idxs), [&](const auto& a, const auto& b) {\n            return nums[a] != nums[b] ? nums[a] < nums[b] : a < b;\n        });\n        const auto& nxt = [&](int left, int right, int i, int j) {\n            for (; !(left <= idxs[i] && idxs[i] <= right); ++i);\n            for (; !(left <= idxs[j] && idxs[j] <= right); --j);\n            return tuple(i, j);\n        };\n\n        unordered_map<tuple<int, int>, tuple<int, int>, TupleHash> lookup;\n        lookup[{0, size(idxs) - 1}] = {0, size(idxs) - 1};\n        using P = pair<int, pair<int, int>>;\n        priority_queue<P> max_heap;\n        max_heap.push({nums[idxs[size(idxs) - 1]] - nums[idxs[0]], {0, size(idxs) - 1}});\n        int64_t result = 0;\n        while (k) {\n            const auto [v, l_r] = max_heap.top();  max_heap.pop();\n            const auto& [l, r] = l_r;\n            const auto& [i, j] = lookup[{l, r}];\n            const auto& nl = min(idxs[i], idxs[j]);\n            const auto& nr = max(idxs[i], idxs[j]);\n            const int64_t c = min((nl - l + 1) * (r - nr + 1), k);\n            k -= c;\n            result += c * v;\n            if (nl + 1 <= r && !lookup.count({nl + 1, r})) {\n                const auto& [ni, nj] = nxt(nl + 1, r, i, j);\n                lookup[{nl + 1, r}] = {ni, nj};\n                max_heap.push({nums[idxs[nj]] - nums[idxs[ni]], {nl + 1, r}});\n            }\n            if (l <= nr - 1 && !lookup.count({l, nr - 1})) {\n                const auto& [ni, nj] = nxt(l, nr - 1, i, j);\n                lookup[{l, nr - 1}] = {ni, nj};\n                max_heap.push({nums[idxs[nj]] - nums[idxs[ni]], {l, nr - 1}});\n            }\n        }\n        return result;\n    }\n};\n\n// Time:  O((n + k) * logn)\n// Space: O(nlogn)\n// heap, rmq, sparse table\nclass Solution2 {\npublic:\n    long long maxTotalValue(vector<int>& nums, int k) {\n        SparseTable rmq_min(nums, [](const auto& a, const auto& b) {\n            return a < b ? a : b;\n        });\n        SparseTable rmq_max(nums, [](const auto& a, const auto& b) {\n            return a > b ? a : b;\n        });\n        using P = pair<int, pair<int, int>>;\n        vector<P> arr(size(nums));\n        for (int i = 0; i < size(nums); ++i) {\n            arr[i] = {rmq_max.query(i, size(nums) - 1) - rmq_min.query(i, size(nums) - 1), {i, size(nums) - 1}};\n        }\n        priority_queue<P> max_heap(cbegin(arr), cend(arr));\n        int64_t result = 0;\n        for (int _ = 0; _ < k; ++_) {\n            const auto [v, i_j] = max_heap.top(); max_heap.pop();\n            const auto& [i, j] = i_j;\n            result += v;\n            if (i <= j - 1) {\n                max_heap.push({rmq_max.query(i, j - 1) - rmq_min.query(i, j - 1), {i, j - 1}});\n            }\n        }\n        return result;\n    }\n\nprivate:\n    // Reference: https://cp-algorithms.com/data_structures/sparse-table.html\n    class SparseTable {\n    public:\n        SparseTable(const vector<int>& arr, function<int (int, int)> fn)\n         :  fn(fn) {  // Time: O(nlogn) * O(fn) = O(nlogn), Space: O(nlogn)\n            const int n = size(arr);\n            const int k = __lg(n);\n            st.assign(k + 1, vector<int64_t>(n));\n            st[0].assign(cbegin(arr), cend(arr));\n            for (int i = 1; i <= k; ++i) {\n                for (int j = 0; j + (1 << i) <= n; ++j) {\n                    st[i][j] = fn(st[i - 1][j], st[i - 1][j + (1 << (i - 1))]);\n                }\n            }\n         }\n\n        int64_t query(int L, int R) const {\n            const int i = __lg(R - L + 1);\n            return fn(st[i][L], st[i][R - (1 << i) + 1]);  // Time: O(fn) = O(1)\n        }\n    \n    private:\n        vector<vector<int64_t>> st;\n        const function<int (int, int)>& fn;\n    };\n};\n\n// Time:  O((n + k) * logn)\n// Space: O(n)\n// heap, segment tree\nconst int NEG_INF = numeric_limits<int>::min();\nconst int POS_INF = numeric_limits<int>::max();\nclass Solution3 {\npublic:\n    long long maxTotalValue(vector<int>& nums, int k) {\n        SegmentTreeMin st_min(nums);\n        SegmentTreeMax st_max(nums);\n        using P = pair<int, pair<int, int>>;\n        vector<P> arr(size(nums));\n        for (int i = 0; i < size(nums); ++i) {\n            arr[i] = {st_max.query(i, size(nums) - 1) - st_min.query(i, size(nums) - 1), {i, size(nums) - 1}};\n        }\n        priority_queue<P> max_heap(cbegin(arr), cend(arr));\n        int64_t result = 0;\n        for (int _ = 0; _ < k; ++_) {\n            const auto [v, i_j] = max_heap.top(); max_heap.pop();\n            const auto& [i, j] = i_j;\n            result += v;\n            if (i <= j - 1) {\n                max_heap.push({st_max.query(i, j - 1) - st_min.query(i, j - 1), {i, j - 1}});\n            }\n        }\n        return result;\n    }\n\nprivate:\n    class SegmentTreeMax {\n    public:\n        explicit SegmentTreeMax(const auto& nums)\n         :  base_(size(nums) > 1 ? 1 << (__lg(size(nums) - 1) + 1) : 1),\n            tree(size(nums) > 1 ? 1 << (__lg(size(nums) - 1) + 2) : 2, NEG_INF) {\n            for (int i = base_; i < base_ + size(nums); ++i) {\n                tree[i] = nums[i - base_];\n            }\n            for (int i = base_ - 1; i >= 1; --i) {\n                tree[i] = max(tree[i << 1], tree[(i << 1) + 1]);\n            }\n        }\n\n        int query(int L, int R) {\n            if (L > R) {\n                return NEG_INF;\n            }\n            L += base_;\n            R += base_;\n            int left = NEG_INF, right = NEG_INF;\n            for (; L <= R; L >>= 1, R >>= 1) {\n                if ((L & 1) == 1) {\n                    left = max(left, tree[L++]);\n                }\n                if ((R & 1) == 0) {\n                    right = max(tree[R--], right);\n                }\n            }\n            return max(left, right);\n        }\n\n        vector<int> tree;\n        int base_;\n    };\n\n    class SegmentTreeMin {\n    public:\n        explicit SegmentTreeMin(const auto& nums)\n         :  base_(size(nums) > 1 ? 1 << (__lg(size(nums) - 1) + 1) : 1),\n            tree(size(nums) > 1 ? 1 << (__lg(size(nums) - 1) + 2) : 2, POS_INF) {\n            for (int i = base_; i < base_ + size(nums); ++i) {\n                tree[i] = nums[i - base_];\n            }\n            for (int i = base_ - 1; i >= 1; --i) {\n                tree[i] = min(tree[i << 1], tree[(i << 1) + 1]);\n            }\n        }\n\n        int query(int L, int R) {\n            if (L > R) {\n                return POS_INF;\n            }\n            L += base_;\n            R += base_;\n            int left = POS_INF, right = POS_INF;\n            for (; L <= R; L >>= 1, R >>= 1) {\n                if ((L & 1) == 1) {\n                    left = min(left, tree[L++]);\n                }\n                if ((R & 1) == 0) {\n                    right = min(tree[R--], right);\n                }\n            }\n            return min(left, right);\n        }\n\n        vector<int> tree;\n        int base_;\n    };\n};\n20:T14a5,# Time:  O((n + k) * logn)\n# Space: O(n + k)\n\nimport heapq\n\n\n# heap, sort, two pointers\nclass Solution(object):\n    def maxTotalValue(self, nums, k):\n        \"\"\"\n        :type nums: List[int]\n        :type k: int\n        :rtype: int\n        \"\"\"\n        def nxt(left, right, i, j):\n            while not (left <= idxs[i] <= right):\n                i += 1\n            while not (left <= idxs[j] <= right):\n                j -= 1\n            return (i, j)\n            \n        idxs = range(len(nums))\n        idxs.sort(key=lambda x: (nums[x], x))\n        lookup = {(0, len(nums)-1):(0, len(idxs)-1)}\n        max_heap = [(-(nums[idxs[len(idxs)-1]]-nums[idxs[0]]), (0, len(idxs)-1))]\n        result = 0\n        while k:\n            v, (l, r) = heapq.heappop(max_heap)\n            i, j = lookup[(l, r)]\n            nl, nr = min(idxs[i], idxs[j]), max(idxs[i], idxs[j])\n            c = min((nl-l+1)*(r-nr+1), k)\n            k -= c\n            result += c*(-v)\n            if nl+1 <= r and (nl+1, r) not in lookup:\n                lookup[(nl+1, r)] = (ni, nj) = nxt(nl+1, r, i, j)\n                heapq.heappush(max_heap, (-(nums[idxs[nj]]-nums[idxs[ni]]), (nl+1, r)))\n            if l <= nr-1 and (l, nr-1) not in lookup:\n                lookup[(l, nr-1)] = (ni, nj) = nxt(l, nr-1, i, j)\n                heapq.heappush(max_heap, (-(nums[idxs[nj]]-nums[idxs[ni]]), (l, nr-1)))\n        return result\n\n\n# Time:  O((n + k) * logn)\n# Space: O(nlogn)\nimport heapq\n\n\n# heap, rmq, sparse table\nclass Solution2(object):\n    def maxTotalValue(self, nums, k):\n        \"\"\"\n        :type nums: List[int]\n        :type k: int\n        :rtype: int\n        \"\"\"\n        # RMQ - Sparse Table\n        # Template: https://github.com/kamyu104/GoogleCodeJam-Farewell-Rounds/blob/main/Round%20D/genetic_sequences2.py3\n        # Time:  ctor:  O(NlogN) * O(fn)\n        #        query: O(fn)\n        # Space: O(NlogN)\n        class SparseTable(object):\n            def __init__(self, arr, fn):\n                self.fn = fn\n                self.bit_length = [0]\n                n = len(arr)\n                k = n.bit_length()-1  # log2_floor(n)\n                for i in xrange(k+1):\n                    self.bit_length.extend(i+1 for _ in xrange(min(1<<i, (n+1)-len(self.bit_length))))\n                self.st = [[0]*n for _ in xrange(k+1)]\n                self.st[0] = arr[:]\n                for i in xrange(1, k+1):  # Time: O(NlogN) * O(fn)\n                    for j in xrange((n-(1<<i))+1):\n                        self.st[i][j] = fn(self.st[i-1][j], self.st[i-1][j+(1<<(i-1))])\n        \n            def query(self, L, R):  # Time: O(fn)\n                i = self.bit_length[R-L+1]-1  # log2_floor(R-L+1)\n                return self.fn(self.st[i][L], self.st[i][R-(1<<i)+1])\n        \n        rmq_min = SparseTable(nums, min)\n        rmq_max = SparseTable(nums, max)\n        max_heap = [(-(rmq_max.query(i, len(nums)-1)-rmq_min.query(i, len(nums)-1)), (i, len(nums)-1)) for i in xrange(len(nums))]\n        heapq.heapify(max_heap)\n        result = 0\n        for _ in xrange(k):\n            v, (i, j) = heappop(max_heap)\n            result += -v\n            if i <= j-1:\n                heapq.heappush(max_heap, (-(rmq_max.query(i, j-1)-rmq_min.query(i, j-1)), (i, j-1)))\n        return result\n\n\n# Time:  O((n + k) * logn)\n# Space: O(n)\nimport heapq\n\n\n# heap, segment tree\nclass Solution3(object):\n    def maxTotalValue(self, nums, k):\n        \"\"\"\n        :type nums: List[int]\n        :type k: int\n        :rtype: int\n        \"\"\"\n        class SegmentTree(object):\n            def __init__(self, N, build_fn, query_fn):\n                self.tree = [None]*(1<<((N-1).bit_length()+1))\n                self.base = len(self.tree)>>1\n                self.query_fn = query_fn\n                for i in xrange(self.base, self.base+N):\n                    self.tree[i] = build_fn(i-self.base)\n                for i in reversed(xrange(1, self.base)):\n                    self.tree[i] = query_fn(self.tree[i<<1], self.tree[(i<<1)+1])\n\n            def query(self, L, R):\n                if L > R:\n                    return None\n                L += self.base\n                R += self.base\n                left = right = None\n                while L <= R:\n                    if L & 1:\n                        left = self.query_fn(left, self.tree[L])\n                        L += 1\n                    if R & 1 == 0:\n                        right = self.query_fn(self.tree[R], right)\n                        R -= 1\n                    L >>= 1\n                    R >>= 1\n                return self.query_fn(left, right)\n\n    \n        st_min = SegmentTree(len(nums), build_fn=lambda x: nums[x], query_fn=lambda x, y: y if x is None else x if y is None else min(x, y))\n        st_max = SegmentTree(len(nums), build_fn=lambda x: nums[x], query_fn=lambda x, y: y if x is None else x if y is None else max(x, y))\n        max_heap = [(-(st_max.query(i, len(nums)-1)-st_min.query(i, len(nums)-1)), (i, len(nums)-1)) for i in xrange(len(nums))]\n        heapq.heapify(max_heap)\n        result = 0\n        for _ in xrange(k):\n            v, (i, j) = heappop(max_heap)\n            result += -v\n            if i <= j-1:\n                heapq.heappush(max_heap, (-(st_max.query(i, j-1)-st_min.query(i, j-1)), (i, j-1)))\n        return result\n15:[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Maximum Total Subarray Value II\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/maximum-total-subarray-value-ii\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"Python\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/maximum-total-subarray-value-ii/python\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/maximum-total-subarray-value-ii\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems/maximum-total-subarray-value-ii\",\"className\":\"hover:text-prim