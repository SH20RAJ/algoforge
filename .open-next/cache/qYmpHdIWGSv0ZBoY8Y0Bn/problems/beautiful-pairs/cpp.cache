{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/problems/layout,_N_T_/problems/[slug]/layout,_N_T_/problems/[slug]/[lang]/layout,_N_T_/problems/[slug]/[lang]/page,_N_T_/problems/beautiful-pairs/cpp"},"segmentPaths":["/_tree","/_full","/problems/$d$slug/$d$lang/__PAGE__","/problems/$d$slug/$d$lang","/problems/$d$slug","/problems","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/340fxer6uczx7.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/05kafvajig4wu.js\"/><script src=\"/_next/static/chunks/2o5-igl1ik8oj.js\" async=\"\"></script><script src=\"/_next/static/chunks/1uejzok0tpgy1.js\" async=\"\"></script><script src=\"/_next/static/chunks/3ujjz4ap-oopx.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3om3j4o09b7fr.js\" async=\"\"></script><script src=\"/_next/static/chunks/2fvm6eoqeukxu.js\" async=\"\"></script><script src=\"/_next/static/chunks/1ntn7efqc-iiw.js\" async=\"\"></script><script src=\"/_next/static/chunks/0plpm2axnqe9k.js\" async=\"\"></script><script src=\"/_next/static/chunks/0a2gmow1_jiq0.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Beautiful Pairs C++ Solution | AlgoForge</title><meta name=\"description\" content=\"C++ solution for Beautiful Pairs (LeetCode #2613). Time O(n) on average, space O(n).\"/><meta name=\"keywords\" content=\"Beautiful Pairs cpp,Beautiful Pairs C++,cpp leetcode\"/><link rel=\"canonical\" href=\"https://algoforge.dev/problems/beautiful-pairs/cpp\"/><meta property=\"og:title\" content=\"Beautiful Pairs C++ Solution | AlgoForge\"/><meta property=\"og:description\" content=\"C++ solution for Beautiful Pairs (LeetCode #2613). Time O(n) on average, space O(n).\"/><meta property=\"og:url\" content=\"https://algoforge.dev/problems/beautiful-pairs/cpp\"/><meta property=\"og:site_name\" content=\"AlgoForge\"/><meta property=\"og:image\" content=\"https://algoforge.dev/og-default.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"Beautiful Pairs C++ Solution | AlgoForge\"/><meta property=\"og:type\" content=\"article\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Beautiful Pairs C++ Solution | AlgoForge\"/><meta name=\"twitter:description\" content=\"C++ solution for Beautiful Pairs (LeetCode #2613). Time O(n) on average, space O(n).\"/><meta name=\"twitter:image\" content=\"https://algoforge.dev/og-default.png\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/favicon.ico\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"geist_deef94d5-module__Sms4YG__variable geist_mono_1bf8cbf6-module__FlyLvG__variable antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><script>((a,b,c,d,e,f,g,h)=>{let i=document.documentElement,j=[\"light\",\"dark\"];function k(b){var c;(Array.isArray(a)?a:[a]).forEach(a=>{let c=\"class\"===a,d=c&&f?e.map(a=>f[a]||a):e;c?(i.classList.remove(...d),i.classList.add(f&&f[b]?f[b]:b)):i.setAttribute(a,b)}),c=b,h&&j.includes(c)&&(i.style.colorScheme=c)}if(d)k(d);else try{let a=localStorage.getItem(b)||c,d=g&&\"system\"===a?window.matchMedia(\"(prefers-color-scheme: dark)\").matches?\"dark\":\"light\":a;k(d)}catch(a){}})(\"class\",\"theme\",\"system\",null,[\"light\",\"dark\"],null,true,true)</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"AlgoForge\",\"url\":\"https://algoforge.dev\",\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\"}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"AlgoForge\",\"url\":\"https://algoforge.dev\",\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://algoforge.dev/search?q={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"AlgoForge\",\"applicationCategory\":\"EducationalApplication\",\"operatingSystem\":\"Web\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"},\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\"}</script><header class=\"sticky top-0 z-50 border-b border-border/80 bg-background/85 backdrop-blur-md\"><div class=\"container-af flex h-14 items-center justify-between gap-4\"><div class=\"flex items-center gap-6\"><a class=\"flex items-center gap-2 font-bold tracking-tight\" href=\"/\"><span class=\"inline-flex h-7 w-7 items-center justify-center rounded-md bg-primary text-primary-foreground text-xs font-black\">AF</span><span class=\"hidden sm:inline\">AlgoForge</span></a><nav class=\"hidden lg:flex items-center gap-1\" aria-label=\"Main\"><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/problems\">Problems</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/topics\">Topics</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/patterns\">Patterns</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/roadmaps\">Roadmaps</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blind-75\">Blind 75</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/companies\">Companies</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blog\">Blog</a></nav></div><div class=\"flex items-center gap-1\"><a class=\"hidden sm:inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-1.5 text-sm text-muted-foreground hover:border-primary/40 transition-colors\" href=\"/search\"><span>Search…</span><kbd class=\"rounded border border-border bg-muted px-1.5 text-[10px] font-mono\">/</kbd></a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground\" href=\"/dashboard\">Progress</a><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 hover:bg-muted text-foreground h-9 w-9\" aria-label=\"Toggle theme\"></button></div></div></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Beautiful Pairs\",\"item\":\"https://algoforge.dev/problems/beautiful-pairs\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"C++\",\"item\":\"https://algoforge.dev/problems/beautiful-pairs/cpp\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/beautiful-pairs\">Beautiful Pairs</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">C++</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\">Hard</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Beautiful Pairs<!-- --> — <!-- -->C++</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/beautiful-pairs\">Full explanation</a> · <!-- -->Time <!-- -->O(n) on average<!-- --> · Space <!-- -->O(n)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">C++</button><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code>// Time:  O(n) on average\n// Space: O(n)\n\n// random algorithms, variant of closest pair\n// reference: https://github.com/jilljenn/tryalgo/blob/master/tryalgo/closest_points.py\nclass Solution {\nprivate:\n    template&lt;typename T&gt;\n    struct VectorHash {\n        size_t operator()(const std::vector&lt;T&gt;&amp; v) const {\n            size_t seed = 0;\n            for (const auto&amp; i : v) {\n                seed ^= std::hash&lt;T&gt;{}(i)  + 0x9e3779b9 + (seed&lt;&lt;6) + (seed&gt;&gt;2);\n            }\n            return seed;\n        }\n    };\n\npublic:\n    vector&lt;int&gt; beautifulPair(vector&lt;int&gt;&amp; nums1, vector&lt;int&gt;&amp; nums2) {\n        static const int INF = numeric_limits&lt;int&gt;::max();\n        srand(time(0));\n\n        vector&lt;vector&lt;int&gt;&gt; points;\n        for (int i = 0; i &lt; size(nums1); ++i) {\n            points.push_back({nums1[i], nums2[i], i});\n        }\n        vector&lt;int&gt; result(3, INF);\n        unordered_map&lt;vector&lt;int&gt;, int, VectorHash&lt;int&gt;&gt; lookup;\n        for (int i = size(points) - 1; i &gt;= 0; --i) {\n            const auto&amp; key = vector&lt;int&gt;{points[i][0], points[i][1]};\n            if (lookup.count(key)) {\n                result = min(result, vector&lt;int&gt;{0, i, lookup[key]});\n            }\n            lookup[key] = i;\n        }\n        if (result[0] == 0) {\n            return {result[1], result[2]};\n        }\n        vector&lt;int&gt; order(size(points));\n        iota(begin(order), end(order), 0);\n        sort(begin(order), end(order), [&amp;](const auto&amp; a, const auto&amp; b) {\n            return points[a] &lt; points[b];\n        });\n        const auto&amp; dist = [&amp;](auto a, auto b) {\n            if (a[2] &gt; b[2]) {\n                swap(a, b);\n            }\n            return vector&lt;int&gt;{abs(a[0] - b[0]) + abs(a[1] - b[1]), a[2], b[2]};\n        };\n\n        const auto&amp; improve = [&amp;]() {\n            unordered_map&lt;vector&lt;int&gt;, vector&lt;int&gt;, VectorHash&lt;int&gt;&gt; lookup;\n            for (const auto&amp; p : points) {\n                const double size = result[0] / 2.0;\n                const int i = floor(p[0] / size), j = floor(p[1] / size);\n                for (int ni = i - 2; ni &lt;= i + 2; ++ni) {\n                    for (int nj = j - 2; nj &lt;= j + 2; ++nj) {\n                        const auto&amp; key = vector&lt;int&gt;{ni, nj};\n                        if (!lookup.count(key)) {\n                            continue;\n                        }\n                        const auto&amp; d = dist(p, lookup[key]);\n                        if (d &lt; result) {\n                            result = d;\n                            return true;\n                        }\n                    }\n                }\n                lookup[vector&lt;int&gt;{i, j}] = p;\n            }\n            return false;\n        };\n\n        random_shuffle(begin(points), end(points));\n        result = dist(points[0], points[1]);\n        while (improve());\n        return {result[1], result[2]};\n    }\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// divide and conquer, merge sort, variant of closest pair\n// reference: https://www.baeldung.com/cs/minimal-manhattan-distance\nclass Solution2 {\nprivate:\n    template&lt;typename T&gt;\n    struct VectorHash {\n        size_t operator()(const std::vector&lt;T&gt;&amp; v) const {\n            size_t seed = 0;\n            for (const auto&amp; i : v) {\n                seed ^= std::hash&lt;T&gt;{}(i)  + 0x9e3779b9 + (seed&lt;&lt;6) + (seed&gt;&gt;2);\n            }\n            return seed;\n        }\n    };\n\npublic:\n    vector&lt;int&gt; beautifulPair(vector&lt;int&gt;&amp; nums1, vector&lt;int&gt;&amp; nums2) {\n        static const int INF = numeric_limits&lt;int&gt;::max();\n        static const int MAX_NEIGHBOR_COUNT = (8 + 2) / 2;\n\n        vector&lt;vector&lt;int&gt;&gt; points;\n        for (int i = 0; i &lt; size(nums1); ++i) {\n            points.push_back({nums1[i], nums2[i]});\n        }\n        vector&lt;int&gt; result(3, INF);\n        unordered_map&lt;vector&lt;int&gt;, int, VectorHash&lt;int&gt;&gt; lookup;\n        for (int i = size(points) - 1; i &gt;= 0; --i) {\n            if (lookup.count(points[i])) {\n                result = min(result, vector&lt;int&gt;{0, i, lookup[points[i]]});\n            }\n            lookup[points[i]] = i;\n        }\n        if (result[0] == 0) {\n            return {result[1], result[2]};\n        }\n        vector&lt;int&gt; order(size(points));\n        iota(begin(order), end(order), 0);\n        sort(begin(order), end(order), [&amp;](const auto&amp; a, const auto&amp; b) {\n            return points[a][0] &lt; points[b][0];\n        });\n        const auto&amp; dist = [&amp;](auto a, auto b) {\n            if (a &gt; b) {\n                swap(a, b);\n            }\n            return vector&lt;int&gt;{abs(points[a][0] - points[b][0]) + abs(points[a][1] - points[b][1]), a, b};\n        };\n\n        const function&lt;void (int, int)&gt; merge_sort = [&amp;](int left, int right) {\n            const auto&amp; update = [&amp;](const auto&amp; arr, int i) {  // added\n                for (int j = size(arr) - 1; j &gt;= 0; --j) {\n                    if (points[i][1] - points[arr[j]][1] &gt; result[0]) {\n                        break;\n                    }\n                    assert((size(arr) - 1) - j + 1 &lt;= MAX_NEIGHBOR_COUNT);\n                    result = min(result, dist(i, arr[j]));\n                }\n            };\n            \n            if (left == right) {\n                return;\n            }\n            const int mid = left + (right - left) / 2;\n            const int x = points[order[mid]][0];  // added\n            merge_sort(left, mid);\n            merge_sort(mid + 1, right);\n            vector&lt;int&gt; tmp, tmp_l, tmp_r;\n            for (int l = left, r = mid + 1; l &lt; mid + 1 || r &lt; right + 1;) {\n                if (r &gt;= right + 1 || (l &lt; mid + 1 &amp;&amp; points[order[l]][1] &lt;= points[order[r]][1])) {  // modified\n                    update(tmp_r, order[l]);\n                    if (x - points[order[l]][0] &lt;= result[0]) {  // added\n                        tmp_l.emplace_back(order[l]);\n                    }\n                    tmp.emplace_back(order[l++]);\n                } else {\n                    update(tmp_l, order[r]);\n                    if (points[order[r]][0] - x &lt;= result[0]) {  // added\n                        tmp_r.emplace_back(order[r]);\n                    }\n                    tmp.emplace_back(order[r++]);\n                }\n            }\n            copy(cbegin(tmp), cend(tmp), begin(order) + left);\n        };\n        \n        merge_sort(0, size(points) - 1);\n        return {result[1], result[2]};\n    }\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// divide and conquer, merge sort, variant of closest pair\n// reference: https://www.baeldung.com/cs/minimal-manhattan-distance\nclass Solution3 {\nprivate:\n    template&lt;typename T&gt;\n    struct VectorHash {\n        size_t operator()(const std::vector&lt;T&gt;&amp; v) const {\n            size_t seed = 0;\n            for (const auto&amp; i : v) {\n                seed ^= std::hash&lt;T&gt;{}(i)  + 0x9e3779b9 + (seed&lt;&lt;6) + (seed&gt;&gt;2);\n            }\n            return seed;\n        }\n    };\n\npublic:\n    vector&lt;int&gt; beautifulPair(vector&lt;int&gt;&amp; nums1, vector&lt;int&gt;&amp; nums2) {\n        static const int INF = numeric_limits&lt;int&gt;::max();\n        static const int MAX_NEIGHBOR_COUNT = 8;\n\n        vector&lt;vector&lt;int&gt;&gt; points;\n        for (int i = 0; i &lt; size(nums1); ++i) {\n            points.push_back({nums1[i], nums2[i]});\n        }\n        vector&lt;int&gt; result(3, INF);\n        unordered_map&lt;vector&lt;int&gt;, int, VectorHash&lt;int&gt;&gt; lookup;\n        for (int i = size(points) - 1; i &gt;= 0; --i) {\n            if (lookup.count(points[i])) {\n                result = min(result, vector&lt;int&gt;{0, i, lookup[points[i]]});\n            }\n            lookup[points[i]] = i;\n        }\n        if (result[0] == 0) {\n            return {result[1], result[2]};\n        }\n        vector&lt;int&gt; order(size(points));\n        iota(begin(order), end(order), 0);\n        sort(begin(order), end(order), [&amp;](const auto&amp; a, const auto&amp; b) {\n            return points[a][0] &lt; points[b][0];\n        });\n        const auto&amp; dist = [&amp;](auto a, auto b) {\n            if (a &gt; b) {\n                swap(a, b);\n            }\n            return vector&lt;int&gt;{abs(points[a][0] - points[b][0]) + abs(points[a][1] - points[b][1]), a, b};\n        };\n\n        const function&lt;void (int, int)&gt; merge_sort = [&amp;](int left, int right) {\n            if (left == right) {\n                return;\n            }\n            const int mid = left + (right - left) / 2;\n            const int x = points[order[mid]][0];  // added\n            merge_sort(left, mid);\n            merge_sort(mid + 1, right);\n            vector&lt;int&gt; tmp;\n            for (int l = left, r = mid + 1; l &lt;= mid; ++l) {\n                while (r &lt;= right &amp;&amp; points[order[r]][1] &lt; points[order[l]][1]) {  // modified\n                    tmp.emplace_back(order[r++]);\n                }\n                tmp.emplace_back(order[l]);\n            }\n            copy(cbegin(tmp), cend(tmp), begin(order) + left);\n\n            // added below\n            vector&lt;int&gt; stripe;\n            for (int i = left; i &lt;= right; ++i) {\n                if (abs(points[order[i]][0] - x) &lt;= result[0]) {\n                    stripe.emplace_back(order[i]);\n                }\n            }\n            for (int i = 0; i + 1 &lt; size(stripe); ++i) {\n                for (int j = i + 1; j &lt; size(stripe); ++j) {\n                    int x = stripe[i], y = stripe[j];\n                    if (points[y][1] - points[x][1] &gt; result[0]) {\n                        break;\n                    }\n                    assert(j - (i + 1) + 1 &lt;= MAX_NEIGHBOR_COUNT);\n                    result = min(result, dist(x, y));\n                }\n            }      \n        };\n        \n        merge_sort(0, size(points) - 1);\n        return {result[1], result[2]};\n    }\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// segment tree\nclass Solution4 {\nprivate:\n    template&lt;typename T&gt;\n    struct VectorHash {\n        size_t operator()(const std::vector&lt;T&gt;&amp; v) const {\n            size_t seed = 0;\n            for (const auto&amp; i : v) {\n                seed ^= std::hash&lt;T&gt;{}(i)  + 0x9e3779b9 + (seed&lt;&lt;6) + (seed&gt;&gt;2);\n            }\n            return seed;\n        }\n    };\n\npublic:\n    vector&lt;int&gt; beautifulPair(vector&lt;int&gt;&amp; nums1, vector&lt;int&gt;&amp; nums2) {\n        static const int INF = numeric_limits&lt;int&gt;::max();\n\n        vector&lt;vector&lt;int&gt;&gt; points;\n        for (int i = 0; i &lt; size(nums1); ++i) {\n            points.push_back({nums1[i], nums2[i]});\n        }\n        vector&lt;int&gt; result(3, INF);\n        unordered_map&lt;vector&lt;int&gt;, int, VectorHash&lt;int&gt;&gt; lookup;\n        for (int i = size(points) - 1; i &gt;= 0; --i) {\n            if (lookup.count(points[i])) {\n                result = min(result, vector&lt;int&gt;{0, i, lookup[points[i]]});\n            }\n            lookup[points[i]] = i;\n        }\n        if (result[0] == 0) {\n            return {result[1], result[2]};\n        }\n        vector&lt;int&gt; order(size(points));\n        iota(begin(order), end(order), 0);\n        sort(begin(order), end(order), [&amp;](const auto&amp; a, const auto&amp; b) {\n            return points[a][0] &lt; points[b][0];\n        });\n        const auto&amp; dist = [&amp;](auto a, auto b) {\n            if (a &gt; b) {\n                swap(a, b);\n            }\n            return vector&lt;int&gt;{abs(points[a][0] - points[b][0]) + abs(points[a][1] - points[b][1]), a, b};\n        };\n\n        unordered_set&lt;int&gt; y_set;\n        for (const auto&amp; p : points) {\n            y_set.emplace(p[1]);\n        }\n        vector&lt;int&gt; sorted_y(cbegin(y_set), cend(y_set));\n        sort(begin(sorted_y), end(sorted_y));\n        unordered_map&lt;int, int&gt; y_to_idx;\n        for (int i = 0; i &lt; size(sorted_y); ++i) {  // coordinate compression\n            y_to_idx[sorted_y[i]] = i;\n        }\n        SegmentTree st1(size(y_to_idx)), st2(size(y_to_idx));\n        for (const auto&amp; i : order) {\n            int j = -st1.query(0, y_to_idx[points[i][1]] - 1)[1];  // min((xi-xj)+(yi-yj) for j in range(y_to_idx[points[i][1])) = (xi+yi)-max((xj+yj) for j in range(y_to_idx[points[i][1]))\n            if (j != INF) {\n                assert(points[j][1] &lt; points[i][1]);\n                result = min(result, dist(i, j));\n            }\n            st1.update(y_to_idx[points[i][1]], vector&lt;int&gt;{points[i][0] + points[i][1], -i});\n            j = -st2.query(y_to_idx[points[i][1]], size(y_to_idx) - 1)[1];   // min((xi-xj)+(yj-yi) for j in range(y_to_idx[points[i][1], len(y_to_idx))) = (xi-yi)-max((xj-yj) for j in range(y_to_idx[points[i][1], len(y_to_idx))\n            if (j != INF) {\n                assert(points[j][1] &gt;= points[i][1]);\n                result = min(result, dist(i, j));\n            }\n            st2.update(y_to_idx[points[i][1]], vector&lt;int&gt;{points[i][0] - points[i][1], -i});\n        }\n        return {result[1], result[2]};\n    }\n\nprivate:\n    class SegmentTree {\n    private:\n        static const int INF = numeric_limits&lt;int&gt;::max();\n      \n    public:\n        explicit SegmentTree(int N)\n          : tree(N &gt; 1 ? 1 &lt;&lt; (__lg(N - 1) + 2) : 2, vector&lt;int&gt;{-INF, -INF}),\n            base(N &gt; 1 ? 1 &lt;&lt; (__lg(N - 1) + 1) : 1) {\n\n        }\n\n        void update(int i, const vector&lt;int&gt;&amp; h) {\n            int x = base + i;\n            tree[x] = h;\n            while (x &gt; 1) {\n                x /= 2;\n                tree[x] = max(tree[x * 2], tree[x * 2 + 1]);\n            }\n        }\n\n        vector&lt;int&gt; query(int L, int R) {\n            vector&lt;int&gt; result = {-INF, -INF};\n            if (L &gt; R) {\n                return result;\n            }\n            L += base;\n            R += base;\n            for (; L &lt;= R; L /= 2, R /= 2) {\n                if (L &amp; 1) {\n                    result = max(result, tree[L]);\n                    ++L;\n                }\n                if ((R &amp; 1) == 0) {\n                    result = max(tree[R], result);\n                    --R;\n                }\n            }\n            return result;\n        }\n\n        vector&lt;vector&lt;int&gt;&gt; tree;\n        int base;\n    };\n};\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">Learn</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/problems\">Problems</a></li><li><a class=\"hover:text-primary\" href=\"/patterns\">Patterns</a></li><li><a class=\"hover:text-primary\" href=\"/roadmaps\">Roadmaps</a></li><li><a class=\"hover:text-primary\" href=\"/blind-75\">Blind 75</a></li><li><a class=\"hover:text-primary\" href=\"/grind-169\">Grind 169</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Interview</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/companies\">Companies</a></li><li><a class=\"hover:text-primary\" href=\"/interview-preparation\">Interview prep</a></li><li><a class=\"hover:text-primary\" href=\"/system-design\">System design</a></li><li><a class=\"hover:text-primary\" href=\"/glossary\">Glossary</a></li><li><a class=\"hover:text-primary\" href=\"/blog\">Blog</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Product</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/pricing\">Pricing</a></li><li><a class=\"hover:text-primary\" href=\"/about\">About</a></li><li><a class=\"hover:text-primary\" href=\"/about/attribution\">Attribution</a></li><li><a class=\"hover:text-primary\" href=\"/sitemap-html\">Sitemap</a></li></ul></div></div><div class=\"border-t border-border\"><div class=\"container-af py-4 flex flex-col sm:flex-row gap-2 justify-between text-xs text-muted-foreground\"><p>© <!-- -->2026<!-- --> <!-- -->AlgoForge<!-- -->. Educational use only.</p><p>Solution code sourced under MIT from<!-- --> <a href=\"https://github.com/kamyu104/LeetCode-Solutions\" class=\"underline hover:text-primary\" rel=\"noopener noreferrer\" target=\"_blank\">kamyu104/LeetCode-Solutions</a>. Explanations are original AlgoForge content.</p></div></div></footer><script src=\"/_next/static/chunks/05kafvajig4wu.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[427423,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\"],\\\"ThemeProvider\\\"]\\n3:I[522016,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\",\\\"/_next/static/chunks/0a2gmow1_jiq0.js\\\"],\\\"\\\"]\\n10:I[168027,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/340fxer6uczx7.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"c\\\":[\\\"\\\",\\\"problems\\\",\\\"beautiful-pairs\\\",\\\"cpp\\\"],\\\"q\\\":\\\"\\\",\\\"i\\\":