x h-14 items-center justify-between gap-4\"><div class=\"flex items-center gap-6\"><a class=\"flex items-center gap-2 font-bold tracking-tight\" href=\"/\"><span class=\"inline-flex h-7 w-7 items-center justify-center rounded-md bg-primary text-primary-foreground text-xs font-black\">AF</span><span class=\"hidden sm:inline\">AlgoForge</span></a><nav class=\"hidden lg:flex items-center gap-1\" aria-label=\"Main\"><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/problems\">Problems</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/topics\">Topics</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/patterns\">Patterns</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/roadmaps\">Roadmaps</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blind-75\">Blind 75</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/companies\">Companies</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blog\">Blog</a></nav></div><div class=\"flex items-center gap-1\"><a class=\"hidden sm:inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-1.5 text-sm text-muted-foreground hover:border-primary/40 transition-colors\" href=\"/search\"><span>Search…</span><kbd class=\"rounded border border-border bg-muted px-1.5 text-[10px] font-mono\">/</kbd></a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground\" href=\"/dashboard\">Progress</a><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 hover:bg-muted text-foreground h-9 w-9\" aria-label=\"Toggle theme\"></button></div></div></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Difference Between Maximum and Minimum Price Sum\",\"item\":\"https://algoforge.dev/problems/difference-between-maximum-and-minimum-price-sum\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"C++\",\"item\":\"https://algoforge.dev/problems/difference-between-maximum-and-minimum-price-sum/cpp\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/difference-between-maximum-and-minimum-price-sum\">Difference Between Maximum and Minimum Price Sum</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">C++</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\">Hard</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Difference Between Maximum and Minimum Price Sum<!-- --> — <!-- -->C++</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/difference-between-maximum-and-minimum-price-sum\">Full explanation</a> · <!-- -->Time <!-- -->O(n)<!-- --> · Space <!-- -->O(n)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">C++</button><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code>// Time:  O(n)\n// Space: O(n)\n\n// iterative dfs, tree dp\nclass Solution {\npublic:\n    long long maxOutput(int n, vector&lt;vector&lt;int&gt;&gt;&amp; edges, vector&lt;int&gt;&amp; price) {\n        vector&lt;vector&lt;int&gt;&gt; adj(n);\n        for (const auto&amp; e : edges) {\n            adj[e[0]].emplace_back(e[1]);\n            adj[e[1]].emplace_back(e[0]);\n        }\n        const auto&amp; iter_dfs = [&amp;]() {\n            int64_t result = 0;\n            using RET = vector&lt;int64_t&gt;;\n            RET ret = {price[0], 0};\n            vector&lt;tuple&lt;int, int, int, int, shared_ptr&lt;RET&gt;, RET *&gt;&gt; stk = {{1, 0, -1, -1, nullptr, &amp;ret}};\n            while (!empty(stk)) {\n                const auto [step, u, p, i, new_ret, ret] = stk.back(); stk.pop_back();\n                if (step == 1) {\n                    stk.emplace_back(2, u, p, 0, nullptr, ret);\n                } else if (step == 2) {\n                    if (i == size(adj[u])) {\n                        continue;\n                    }\n                    stk.emplace_back(2, u, p, i + 1, nullptr, ret);\n                    const int v = adj[u][i];\n                    if (v == p) {\n                        continue;\n                    }\n                    const auto&amp; new_ret = make_shared&lt;RET&gt;(vector&lt;int64_t&gt;{price[v], 0});  // [max_sum, max_sum_without_last_node]\n                    stk.emplace_back(3, u, -1, -1, new_ret, ret);\n                    stk.emplace_back(1, v, u, -1, nullptr, new_ret.get());\n                } else if (step == 3) {\n                    result = max({result, (*ret)[0] + (*new_ret)[1], (*ret)[1] + (*new_ret)[0]});\n                    (*ret)[0] = max((*ret)[0], (*new_ret)[0] + price[u]);\n                    (*ret)[1] = max((*ret)[1], (*new_ret)[1] + price[u]);\n                }\n            }\n            return result;\n        };\n    \n        return iter_dfs();\n    }\n};\n\n// Time:  O(n)\n// Space: O(n)\n// dfs, tree dp\nclass Solution2 {\npublic:\n    long long maxOutput(int n, vector&lt;vector&lt;int&gt;&gt;&amp; edges, vector&lt;int&gt;&amp; price) {\n        vector&lt;vector&lt;int&gt;&gt; adj(n);\n        for (const auto&amp; e : edges) {\n            adj[e[0]].emplace_back(e[1]);\n            adj[e[1]].emplace_back(e[0]);\n        }\n        int64_t result = 0;\n        const function&lt;vector&lt;int64_t&gt;(int, int)&gt; dfs = [&amp;](int u, int p) {\n            vector&lt;int64_t&gt; dp = {price[u], 0};  // [max_sum, max_sum_without_last_node]\n            for (const auto&amp; v : adj[u]) {\n                if (v == p) {\n                    continue;\n                }\n                const auto&amp; new_dp = dfs(v, u);\n                result = max({result, dp[0] + new_dp[1], dp[1] + new_dp[0]});\n                dp[0] = max(dp[0], new_dp[0] + price[u]);\n                dp[1] = max(dp[1], new_dp[1] + price[u]);\n            }\n            return dp;\n        };\n\n        dfs(0, -1);\n        return result;\n    }\n};\n\n// Time:  O(n)\n// Space: O(n)\n// iterative dfs, tree dp\nclass Solution3 {\npublic:\n    long long maxOutput(int n, vector&lt;vector&lt;int&gt;&gt;&amp; edges, vector&lt;int&gt;&amp; price) {\n        vector&lt;vector&lt;int&gt;&gt; adj(n);\n        for (const auto&amp; e : edges) {\n            adj[e[0]].emplace_back(e[1]);\n            adj[e[1]].emplace_back(e[0]);\n        }\n        \n        const auto&amp; iter_dfs = [&amp;]() {\n            vector&lt;int64_t&gt; dp(n);\n            vector&lt;tuple&lt;int, int, int&gt;&gt; stk = {{1, 0, -1}};\n            while (!empty(stk)) {\n                const auto [step, u, p] = stk.back(); stk.pop_back();\n                if (step == 1) {\n                    stk.emplace_back(2, u, p);\n                    for (const auto&amp; v : adj[u]) {\n                        if (v == p) {\n                            continue;\n                        }\n                        stk.emplace_back(1, v, u);\n                    }\n                } else if (step == 2) {\n                    dp[u] = price[u];\n                    for (const auto&amp; v : adj[u]) {\n                        if (v == p) {\n                            continue;\n                        }\n                        dp[u] = max(dp[u], dp[v] + price[u]);\n                    }\n                }\n            }\n            return dp;\n        };\n\n        const auto&amp; dp = iter_dfs();\n        const auto&amp; iter_dfs2 = [&amp;]() {\n            int64_t result = 0;\n            vector&lt;tuple&lt;int, int, int64_t&gt;&gt; stk = {{0, -1, 0}};\n            while (!empty(stk)) {\n                const auto [u, p, curr] = stk.back(); stk.pop_back();\n                result = max({result, curr, dp[u] - price[u]});\n                vector&lt;vector&lt;int64_t&gt;&gt; top2 = {{curr, p}, {0, -1}};\n                for (const auto&amp; v : adj[u]) {\n                    if (v == p) {\n                        continue;\n                    }\n                    vector&lt;int64_t&gt; curr = {dp[v], v};\n                    for (int i = 0; i &lt; size(top2); ++i) {\n                        if (curr &gt; top2[i]) {\n                            swap(top2[i], curr);\n                        }\n                    }\n                }\n                for (const auto&amp; v : adj[u]) {\n                    if (v == p) {\n                        continue;\n                    }\n                    stk.emplace_back(v, u, ((top2[0][1] != v) ? top2[0][0] : top2[1][0]) + price[u]);\n                }\n            }\n            return result;\n        };\n\n        return iter_dfs2();\n    }\n};\n\n// Time:  O(n)\n// Space: O(n)\n// dfs, tree dp\nclass Solution4_RE { // stack overflow due to deep recursion\npublic:\n    long long maxOutput(int n, vector&lt;vector&lt;int&gt;&gt;&amp; edges, vector&lt;int&gt;&amp; price) {\n        vector&lt;vector&lt;int&gt;&gt; adj(n);\n        for (const auto&amp; e : edges) {\n            adj[e[0]].emplace_back(e[1]);\n            adj[e[1]].emplace_back(e[0]);\n        }\n        vector&lt;int64_t&gt; dp(n);\n        const function&lt;int64_t(int, int)&gt; dfs = [&amp;](int u, int p) {\n            dp[u] = price[u];\n            for (const auto&amp; v : adj[u]) {\n                if (v == p) {\n                    continue;\n                }\n                dp[u] = max(dp[u], dfs(v, u) + price[u]);\n            }\n            return dp[u];\n        };\n\n        int64_t result = 0;\n        const function&lt;void(int, int, int64_t)&gt; dfs2 = [&amp;](int u, int p, int64_t curr) {\n            result = max({result, curr, dp[u] - price[u]});\n            vector&lt;vector&lt;int64_t&gt;&gt; top2 = {{curr, p}, {0, -1}};\n            for (const auto&amp; v : adj[u]) {\n                if (v == p) {\n                    continue;\n                }\n                vector&lt;int64_t&gt; curr = {dp[v], v};\n                for (int i = 0; i &lt; size(top2); ++i) {\n                    if (curr &gt; top2[i]) {\n                        swap(top2[i], curr);\n                    }\n                }\n            }\n            for (const auto&amp; v : adj[u]) {\n                if (v == p) {\n                    continue;\n                }\n                dfs2(v, u, ((top2[0][1] != v) ? top2[0][0] : top2[1][0]) + price[u]);\n            }\n        };\n\n        dfs(0, -1);\n        dfs2(0, -1, 0);\n        return result;\n    }\n};\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">Learn</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/problems\">Problems</