\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\",\"children\":\"Hard\"}]}],[\"$\",\"h1\",null,{\"className\":\"mt-3 text-3xl font-bold tracking-tight\",\"children\":[\"Equal Rational Numbers\",\" — \",\"Python\"]}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-muted-foreground\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/problems/equal-rational-numbers\",\"className\":\"text-primary hover:underline\",\"children\":\"Full explanation\"}],\" · \",\"Time \",\"O(1)\",\" · Space \",\"O(1)\"]}],[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L1e\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"equal-rational-numbers.cpp\",\"code\":\"$1f\",\"sourcePath\":\"C++/equal-rational-numbers.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"equal-rational-numbers.py\",\"code\":\"# Time:  O(1)\\n# Space: O(1)\\n\\nfrom fractions import Fraction\\n\\n\\nclass Solution(object):\\n    def isRationalEqual(self, S, T):\\n        \\\"\\\"\\\"\\n        :type S: str\\n        :type T: str\\n        :rtype: bool\\n        \\\"\\\"\\\"\\n        def frac(S):\\n            if '.' not in S:\\n                return Fraction(int(S), 1)\\n\\n            i = S.index('.')\\n            result = Fraction(int(S[:i]), 1)\\n            non_int_part = S[i+1:]\\n            if '(' not in non_int_part:\\n                if non_int_part:\\n                    result += Fraction(int(non_int_part), 10**len(non_int_part))\\n                return result\\n\\n            i = non_int_part.index('(')\\n            if i:\\n                result += Fraction(int(non_int_part[:i]), 10**i)\\n            repeat_part = non_int_part[i+1:-1]\\n            result += Fraction(int(repeat_part), 10**i * (10**len(repeat_part)-1))\\n            return result\\n\\n        return frac(S) == frac(T)\\n\",\"sourcePath\":\"Python/equal-rational-numbers.py\"}},\"defaultLang\":\"python\"}]}]]}]\n1b:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n20:I[27201,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"IconMark\"]\n18:null\n1d:[[\"$\",\"title\",\"0\",{\"children\":\"Equal Rational Numbers Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Python solution for Equal Rational Numbers (LeetCode #972). Time O(1), space O(1).\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"Equal Rational Numbers python,Equal Rational Numbers Python,python leetcode\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://algoforge.dev/problems/equal-rational-numbers/python\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"Equal Rational Numbers Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"Python solution for Equal Rational Numbers (LeetCode #972). Time O(1), space O(1).\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:url\",\"content\":\"https://algoforge.dev/problems/equal-rational-numbers/python\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:site_name\",\"content\":\"AlgoForge\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:image:alt\",\"content\":\"Equal Rational Numbers Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"13\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:title\",\"content\":\"Equal Rational Numbers Python Solution | AlgoForge\"}],