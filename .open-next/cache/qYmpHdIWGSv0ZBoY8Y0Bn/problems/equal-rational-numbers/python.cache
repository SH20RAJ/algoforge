.' not in S:\\n                return Fraction(int(S), 1)\\n\\n            i = S.index('.')\\n            result = Fraction(int(S[:i]), 1)\\n            non_int_part = S[i+1:]\\n            if '(' not in non_int_part:\\n                if non_int_part:\\n                    result += Fraction(int(non_int_part), 10**len(non_int_part))\\n                return result\\n\\n            i = non_int_part.index('(')\\n            if i:\\n                result += Fraction(int(non_int_part[:i]), 10**i)\\n            repeat_part = non_int_part[i+1:-1]\\n            result += Fraction(int(repeat_part), 10**i * (10**len(repeat_part)-1))\\n            return result\\n\\n        return frac(S) == frac(T)\\n\",\"sourcePath\":\"Python/equal-rational-numbers.py\"}},\"defaultLang\":\"python\"}]}]]}],[\"$L5\"],\"$L6\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"qYmpHdIWGSv0ZBoY8Y0Bn\"}\n5:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0a2gmow1_jiq0.js\",\"async\":true}]\n6:[\"$\",\"$L7\",null,{\"children\":[\"$\",\"$8\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@9\"}]}]\n9:null\n","/problems/$d$slug/$d$lang":"1:\"$Sreact.fragment\"\n2:I[339756,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"default\"]\n3:I[837457,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"default\"]\n4:[]\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"template\":[\"$\",\"$L3\",null,{}]}]]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":\"$W4\",\"buildId\":\"qYmpHdIWGSv0ZBoY8Y0Bn\"}\n","/problems/$d$slug":"1:\"$Sreact.fragment\"\n2:I[339756,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"default\"]\n3:I[837457,[\"/_next/static/chunks/2fvm6eoqeu