iv></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Equal Rational Numbers\",\"item\":\"https://algoforge.dev/problems/equal-rational-numbers\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Python\",\"item\":\"https://algoforge.dev/problems/equal-rational-numbers/python\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/equal-rational-numbers\">Equal Rational Numbers</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">Python</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\">Hard</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Equal Rational Numbers<!-- --> — <!-- -->Python</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/equal-rational-numbers\">Full explanation</a> · <!-- -->Time <!-- -->O(1)<!-- --> · Space <!-- -->O(1)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">C++</button><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code># Time:  O(1)\n# Space: O(1)\n\nfrom fractions import Fraction\n\n\nclass Solution(object):\n    def isRationalEqual(self, S, T):\n        &quot;&quot;&quot;\n        :type S: str\n        :type T: str\n        :rtype: bool\n        &quot;&quot;&quot;\n        def frac(S):\n            if &#x27;.&#x27; not in S:\n                return Fraction(int(S), 1)\n\n            i = S.index(&#x27;.&#x27;)\n            result = Fraction(int(S[:i]), 1)\n            non_int_part = S[i+1:]\n            if &#x27;(&#x27; not in non_int_part:\n                if non_int_part:\n                    result += Fraction(int(non_int_part), 10**len(non_int_part))\n                return result\n\n            i = non_int_part.index(&#x27;(&#x27;)\n            if i:\n                result += Fraction(int(non_int_part[:i]), 10**i)\n            repeat_part = non_int_part[i+1:-1]\n            result += Fraction(int(repeat_part), 10**i * (10**len(repeat_part)-1))\n            return result\n\n        return frac(S) == frac(T)\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">Learn</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/problems\">Problems</a></li><li><a class=\"hover:text-primary\" href=\"/patterns\">Patterns</a></li><li><a class=\"hover:text-primary\" href=\"/roadmaps\">Roadmaps</a></li><li><a class=\"hover:text-primary\" href=\"/blind-75\">Blind 75</a></li><li><a class=\"hover:text-primary\" href=\"/grind-169\">Grind 169</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Interview</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/companies\">Companies</a></li><li><a class=\"hover:text-primary\" href=\"/interview-preparation\">Interview prep</a></li><li><a class=\"hover:text-primary\" href=\"/system-design\">System design</a></li><li><a class=\"hover:text-primary\" href=\"/glossary\">Glossary</a></li><li><a class=\"hover:text-primary\" href=\"/blog\">Blog</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Product</p><ul class=\"space-y-2 text-sm text-muted-fo