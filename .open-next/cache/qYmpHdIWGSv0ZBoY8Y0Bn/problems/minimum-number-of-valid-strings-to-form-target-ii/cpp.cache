backdrop-blur-md\"><div class=\"container-af flex h-14 items-center justify-between gap-4\"><div class=\"flex items-center gap-6\"><a class=\"flex items-center gap-2 font-bold tracking-tight\" href=\"/\"><span class=\"inline-flex h-7 w-7 items-center justify-center rounded-md bg-primary text-primary-foreground text-xs font-black\">AF</span><span class=\"hidden sm:inline\">AlgoForge</span></a><nav class=\"hidden lg:flex items-center gap-1\" aria-label=\"Main\"><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/problems\">Problems</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/topics\">Topics</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/patterns\">Patterns</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/roadmaps\">Roadmaps</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blind-75\">Blind 75</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/companies\">Companies</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blog\">Blog</a></nav></div><div class=\"flex items-center gap-1\"><a class=\"hidden sm:inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-1.5 text-sm text-muted-foreground hover:border-primary/40 transition-colors\" href=\"/search\"><span>Search…</span><kbd class=\"rounded border border-border bg-muted px-1.5 text-[10px] font-mono\">/</kbd></a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground\" href=\"/dashboard\">Progress</a><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 hover:bg-muted text-foreground h-9 w-9\" aria-label=\"Toggle theme\"></button></div></div></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Minimum Number of Valid Strings to Form Target II\",\"item\":\"https://algoforge.dev/problems/minimum-number-of-valid-strings-to-form-target-ii\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"C++\",\"item\":\"https://algoforge.dev/problems/minimum-number-of-valid-strings-to-form-target-ii/cpp\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/minimum-number-of-valid-strings-to-form-target-ii\">Minimum Number of Valid Strings to Form Target II</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">C++</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\">Hard</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Minimum Number of Valid Strings to Form Target II<!-- --> — <!-- -->C++</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/minimum-number-of-valid-strings-to-form-target-ii\">Full explanation</a> · <!-- -->Time <!-- -->O(n + w * l)<!-- --> · Space <!-- -->O(n + t)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">C++</button><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code>// Time:  O(n + w * l)\n// Space: O(n + w * l)\n\n// rolling hash, hash table, two pointers, sliding window, dp\nclass Solution {\npublic:\n    int minValidStrings(vector&lt;string&gt;&amp; words, string target) {\n        static const int MOD = 1e9 + 7, P = 131;\n        vector&lt;int64_t&gt; power = {1};\n        for (int _ = 0; _ &lt; size(target); ++_) {\n            power.emplace_back(power.back() * P % MOD);\n        }\n        unordered_set&lt;int&gt; lookup;\n        for (const auto&amp; w : words) {\n            int64_t h = 0;\n            for (const auto&amp; x : w) {\n                h = (h * P + (x - &#x27;a&#x27; + 1)) % MOD;\n                lookup.emplace(h);\n            }\n        }\n        vector&lt;int&gt; dp(size(target) + 1);\n        for (int64_t right = 0, left = 0, h = 0; right &lt; size(target); ++right) {\n            h = (h * P + (target[right] - &#x27;a&#x27; + 1)) % MOD;\n            for (; right - left + 1 &gt;= 1 &amp;&amp; !lookup.count(h); ++left) {\n                h = ((h - (target[left] - &#x27;a&#x27; + 1) * power[(right - left + 1) - 1]) % MOD + MOD) % MOD;\n            }\n            if (right - left + 1 == 0) {\n                return -1;\n            }\n            dp[right + 1] = dp[(right - (right - left + 1)) + 1] + 1;\n        }\n        return dp.back();\n    }\n};\n\n// Time:  O(n + w * l)\n// Space: O(n + t), t is the total size of ac automata trie\nstruct AhoNode {\n    vector&lt;AhoNode *&gt; children;\n    AhoNode *suffix;\n    int length;\n    AhoNode() :\n        children(26, nullptr),\n        suffix(nullptr),\n        length(0) {}\n};\n\nclass AhoTrie {\npublic:\n    AhoTrie(const vector&lt;string&gt;&amp; patterns) : root_(createACTrie(patterns)) {\n        node_ = createACSuffixAndOutputLinks(root_);\n    }\n\n    int step(char letter) {\n        while (node_ &amp;&amp; !node_-&gt;children[letter - &#x27;a&#x27;]) {\n            node_ = node_-&gt;suffix;\n        }\n        node_ = node_ ? node_-&gt;children[letter - &#x27;a&#x27;] : root_;\n        return getACNodeOutputs(node_);\n    }\n    \n    void reset() {\n        node_ = root_;\n    }\n\nprivate:\n    AhoNode *createACTrie(const vector&lt;string&gt;&amp; patterns) {  // Time:  O(n), Space: O(t)\n        auto root = new AhoNode();\n        for (int i = 0; i &lt; patterns.size(); ++i) {\n            auto node = root;\n            for (int l = 1; l &lt;= size(patterns[i]); ++l) {\n                const auto c = patterns[i][l - 1];\n                if (!node-&gt;children[c - &#x27;a&#x27;]) {\n                    node-&gt;children[c - &#x27;a&#x27;] = new AhoNode();\n                }\n                node = node-&gt;children[c - &#x27;a&#x27;];\n                node-&gt;length = l;\n            }\n        }\n        return root;\n    }\n    \n    AhoNode *createACSuffixAndOutputLinks(AhoNode *root) {  // Time:  O(n), Space: O(t)\n        queue&lt;AhoNode *&gt; q;\n        for (auto node : root-&gt;children) {\n            if (!node) {\n                continue;\n            }\n            q.emplace(node);\n            node-&gt;suffix = root;\n        }\n                \n        while (!q.empty()) {\n            auto node = q.front(); q.pop();\n            for (int c = 0; c &lt; node-&gt;children.size(); ++c) {\n                if (!node-&gt;children[c]) {\n                    continue;\n                }\n                auto child = node-&gt;children[c];\n                q.emplace(child);\n                auto suffix = node-&gt;suffix;\n                while (suffix &amp;&amp; !suffix-&gt;children[c]) {\n                    suffix = suffix-&gt;suffix;\n                }\n                child-&gt;suffix = suffix ? suffix-&gt;children[c] : root;\n            }\n        }\n        \n        return root;\n    }\n    \n    int getACNodeOutputs(AhoNode *node) {  // modified\n        return node-&gt;length;\n    }\n    \n    AhoNode * const root_;\n    AhoNode *node_;\n};\n\n// ac automata trie\nclass Solution2 {\npublic:\n    int minValidStrings(vector&lt;string&gt;&amp; words, string target) {\n        auto trie = AhoTrie(words);\n        vector&lt;int&gt; dp(size(target) + 1);\n        for (int i = 0; i &lt; size(target); ++i) {\n            const int l = trie.step(target[i]);\n            if (!l) {\n                return -1;\n            }\n            dp[i + 1] = dp[(i - l) + 1] + 1;\n        }\n        return dp.back();\n    }\n};\n\n// Time:  O(w * (l + n))\n// Space: O(l + n)\n// kmp, dp\nclass Solution3 {\npublic:\n    int minValidStrings(vector&lt;string&gt;&amp; words, string target) {\n        const auto&amp; getPrefix = [](const string&amp; pattern) {\n            vector&lt;int&gt; prefix(size(pattern), -1);\n            int j = -1;\n            for (int i = 1; i &lt; size(pattern); ++i) {\n                while (j != -1 &amp;&amp; pattern[j + 1] != pattern[i]) {\n                    j = prefix[j];\n                }\n                if (pattern[j + 1] == pattern[i]) {\n                    ++j;\n                }\n                prefix[i] = j;\n            }\n            return prefix;\n        };\n\n        const auto&amp; KMP = [&amp;](const string&amp; text, const string&amp; pattern, const auto&amp; update) {\n            const vector&lt;int&gt; prefix = getPrefix(pattern);\n            int j = -1;\n            for (int i = 0; i &lt; size(text); ++i) {\n                while (j &gt; -1 &amp;&amp; pattern[j + 1] != text[i]) {\n                    j = prefix[j];\n                }\n                if (pattern[j + 1] == text[i]) {\n                    ++j;\n                }\n                update(i, j);\n                if (j == size(pattern) - 1) {\n                    j = prefix[j];\n                }\n            }\n        };\n    \n        vector&lt;int&gt; lookup(size(target));\n        const auto&amp; update = [&amp;](int i, int j) {\n            lookup[i] = max(lookup[i], j + 1);\n        };\n\n        for (const auto&amp; w : words) {\n            KMP(target, w, update);\n        }\n        vector&lt;int&gt; dp(size(target) + 1);\n        for (int i = 0; i &lt; size(target); ++i) {\n            if (!lookup[i]) {\n                return -1;\n            }\n            dp[i + 1] = dp[(i - lookup[i]) + 1] + 1;\n        }\n        return dp.back();\n    }\n};\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">Learn</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/problems\">Problems</a></li><li><a class=\"hover:text-primary\" href=\"/patterns\">Patterns</a></li><li><a class=\"hover:text-primary\" href=\"/roadmaps\">Roadmaps</a></li><li><a class=\"hover:text-primary\" href=\"/blind-75\">Blind 75</a></li><li><a class=\"hover:text-primary\" href=\"/grind-169\">Grind 169</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Interview</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/companies\">Companies</a></li><li><a class=\"hover:text-primary\" href=\"/interview-preparation\">Interview prep</a></li><li><a class=\"hover:text-primary\" href=\"/system-design\">System design</a></li><li><a class=\"hover:text-primary\" href=\"/glossary\">Glossary</a></li><li><a class=\"hover:text-primary\" href=\"/blog\">Blog</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Product</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/pricing\">Pricing</a></li><li><a class=\"hover:text-primary\" href=\"/about\">About</a></li><li><a class=\"hover:text-primary\" href=\"/