{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/problems/layout,_N_T_/problems/[slug]/layout,_N_T_/problems/[slug]/[lang]/layout,_N_T_/problems/[slug]/[lang]/page,_N_T_/problems/minimum-edge-weight-equilibrium-queries-in-a-tree/cpp"},"segmentPaths":["/_tree","/_full","/problems/$d$slug/$d$lang/__PAGE__","/problems/$d$slug/$d$lang","/problems/$d$slug","/problems","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/340fxer6uczx7.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/05kafvajig4wu.js\"/><script src=\"/_next/static/chunks/2o5-igl1ik8oj.js\" async=\"\"></script><script src=\"/_next/static/chunks/1uejzok0tpgy1.js\" async=\"\"></script><script src=\"/_next/static/chunks/3ujjz4ap-oopx.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3om3j4o09b7fr.js\" async=\"\"></script><script src=\"/_next/static/chunks/2fvm6eoqeukxu.js\" async=\"\"></script><script src=\"/_next/static/chunks/1ntn7efqc-iiw.js\" async=\"\"></script><script src=\"/_next/static/chunks/0plpm2axnqe9k.js\" async=\"\"></script><script src=\"/_next/static/chunks/0a2gmow1_jiq0.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Minimum Edge Weight Equilibrium Queries in a Tree C++ Solution | AlgoForge</title><meta name=\"description\" content=\"C++ solution for Minimum Edge Weight Equilibrium Queries in a Tree (LeetCode #2846). Time O(r * (n + q)), space O(r * n + q).\"/><meta name=\"keywords\" content=\"Minimum Edge Weight Equilibrium Queries in a Tree cpp,Minimum Edge Weight Equilibrium Queries in a Tree C++,cpp leetcode\"/><link rel=\"canonical\" href=\"https://algoforge.dev/problems/minimum-edge-weight-equilibrium-queries-in-a-tree/cpp\"/><meta property=\"og:title\" content=\"Minimum Edge Weight Equilibrium Queries in a Tree C++ Solution | AlgoForge\"/><meta property=\"og:description\" content=\"C++ solution for Minimum Edge Weight Equilibrium Queries in a Tree (LeetCode #2846). Time O(r * (n + q)), space O(r * n + q).\"/><meta property=\"og:url\" content=\"https://algoforge.dev/problems/minimum-edge-weight-equilibrium-queries-in-a-tree/cpp\"/><meta property=\"og:site_name\" content=\"AlgoForge\"/><meta property=\"og:image\" content=\"https://algoforge.dev/og-default.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"Minimum Edge Weight Equilibrium Queries in a Tree C++ Solution | AlgoForge\"/><meta property=\"og:type\" content=\"article\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Minimum Edge Weight Equilibrium Queries in a Tree C++ Solution | AlgoForge\"/><meta name=\"twitter:description\" content=\"C++ solution for Minimum Edge Weight Equilibrium Queries in a Tree (LeetCode #2846). Time O(r * (n + q)), space O(r * n + q).\"/><meta name=\"twitter:image\" content=\"https://algoforge.dev/og-default.png\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/favicon.ico\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"geist_deef94d5-module__Sms4YG__variable geist_mono_1bf8cbf6-module__FlyLvG__variable antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><script>((a,b,c,d,e,f,g,h)=>{let i=document.documentElement,j=[\"light\",\"dark\"];function k(b){var c;(Array.isArray(a)?a:[a]).forEach(a=>{let c=\"class\"===a,d=c&&f?e.map(a=>f[a]||a):e;c?(i.classList.remove(...d),i.classList.add(f&&f[b]?f[b]:b)):i.setAttribute(a,b)}),c=b,h&&j.includes(c)&&(i.style.colorScheme=c)}if(d)k(d);else try{let a=localStorage.getItem(b)||c,d=g&&\"system\"===a?window.matchMedia(\"(prefers-color-scheme: dark)\").matches?\"dark\":\"light\":a;k(d)}catch(a){}})(\"class\",\"theme\",\"system\",null,[\"light\",\"dark\"],null,true,true)</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"AlgoForge\",\"url\":\"https://algoforge.dev\",\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\"}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"AlgoForge\",\"url\":\"https://algoforge.dev\",\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://algoforge.dev/search?q={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"AlgoForge\",\"applicationCategory\":\"EducationalApplication\",\"operatingSystem\":\"Web\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"},\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\"}</script><header class=\"sticky top-0 z-50 border-b border-border/80 bg-background/85 backdrop-blur-md\"><div class=\"container-af flex h-14 items-center justify-between gap-4\"><div class=\"flex items-center gap-6\"><a class=\"flex items-center gap-2 font-bold tracking-tight\" href=\"/\"><span class=\"inline-flex h-7 w-7 items-center justify-center rounded-md bg-primary text-primary-foreground text-xs font-black\">AF</span><span class=\"hidden sm:inline\">AlgoForge</span></a><nav class=\"hidden lg:flex items-center gap-1\" aria-label=\"Main\"><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/problems\">Problems</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/topics\">Topics</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/patterns\">Patterns</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/roadmaps\">Roadmaps</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blind-75\">Blind 75</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/companies\">Companies</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blog\">Blog</a></nav></div><div class=\"flex items-center gap-1\"><a class=\"hidden sm:inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-1.5 text-sm text-muted-foreground hover:border-primary/40 transition-colors\" href=\"/search\"><span>Search…</span><kbd class=\"rounded border border-border bg-muted px-1.5 text-[10px] font-mono\">/</kbd></a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground\" href=\"/dashboard\">Progress</a><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 hover:bg-muted text-foreground h-9 w-9\" aria-label=\"Toggle theme\"></button></div></div></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Minimum Edge Weight Equilibrium Queries in a Tree\",\"item\":\"https://algoforge.dev/problems/minimum-edge-weight-equilibrium-queries-in-a-tree\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"C++\",\"item\":\"https://algoforge.dev/problems/minimum-edge-weight-equilibrium-queries-in-a-tree/cpp\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/minimum-edge-weight-equilibrium-queries-in-a-tree\">Minimum Edge Weight Equilibrium Queries in a Tree</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">C++</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\">Hard</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Minimum Edge Weight Equilibrium Queries in a Tree<!-- --> — <!-- -->C++</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/minimum-edge-weight-equilibrium-queries-in-a-tree\">Full explanation</a> · <!-- -->Time <!-- -->O(r * (n + q))<!-- --> · Space <!-- -->O(r * n + q)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">C++</button><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code>// Time:  O(r * (n + q)), r = max(w for _, _, w in edges)\n// Space: O(r * n + q)\n\n// Tarjan&#x27;s Offline LCA Algorithm\nclass Solution {\nprivate:\n    static const int MAX_W = 26;\n\npublic:\n    vector&lt;int&gt; minOperationsQueries(int n, vector&lt;vector&lt;int&gt;&gt;&amp; edges, vector&lt;vector&lt;int&gt;&gt;&amp; queries) {\n        vector&lt;vector&lt;pair&lt;int, int&gt;&gt;&gt; adj(n);\n        for (const auto&amp; e : edges) {\n            adj[e[0]].emplace_back(e[1], e[2] - 1), adj[e[1]].emplace_back(e[0], e[2] - 1);\n        }\n        unordered_map&lt;int, unordered_set&lt;int&gt;&gt; pairs;\n        for (const auto&amp; q : queries) {\n            pairs[q[0]].emplace(q[1]), pairs[q[1]].emplace(q[0]);\n        }\n        TreeInfos tree_infos(adj, pairs);\n        vector&lt;int&gt; result(size(queries));\n        for (int i = 0; i &lt; size(queries); ++i) {\n            const auto&amp; a = queries[i][0], &amp;b = queries[i][1];\n            const auto&amp; lca = tree_infos.lca(a, b);\n            int mx = 0;\n            for (int w = 0; w &lt; MAX_W; ++w) {\n                mx = max(mx, tree_infos.count(a, w) + tree_infos.count(b, w) - 2 * tree_infos.count(lca, w));\n            }\n            result[i] = (tree_infos.depth(a) + tree_infos.depth(b) - 2 * tree_infos.depth(lca)) - mx;\n        }\n        return result;\n    }\n\nprivate:\n    class UnionFind {\n    public:\n        UnionFind(int n)\n         : set_(n)\n         , rank_(n)\n         , ancestor_(n) {\n            iota(set_.begin(), set_.end(), 0);\n            iota(ancestor_.begin(), ancestor_.end(), 0);  // added\n        }\n\n        int find_set(int x) {\n           if (set_[x] != x) {\n               set_[x] = find_set(set_[x]);  // Path compression.\n           }\n           return set_[x];\n        }\n\n        bool union_set(int x, int y) {\n            x = find_set(x), y = find_set(y);\n            if (x == y) {\n                return false;\n            }\n            if (rank_[x] &gt; rank_[y]) {\n                swap(x, y);\n            }\n            set_[x] = y;  // Union by rank.\n            if (rank_[x] == rank_[y]) {\n                ++rank_[y];\n            }\n            return true;\n        }\n\n    int find_ancestor_of_set(int x) {  // added\n        return ancestor_[find_set(x)];\n    }\n\n    void update_ancestor_of_set(int x) {  // added\n        ancestor_[find_set(x)] = x;\n    }\n\n    private:\n        vector&lt;int&gt; set_;\n        vector&lt;int&gt; rank_;\n        vector&lt;int&gt; ancestor_;  // added\n    };\n    \n    class TreeInfos {\n    public:\n        TreeInfos(const vector&lt;vector&lt;pair&lt;int, int&gt;&gt;&gt;&amp; adj, const unordered_map&lt;int, unordered_set&lt;int&gt;&gt;&amp; pairs)\n         : D_(size(adj))\n         , uf_(size(adj))\n         , lookup_(size(adj))\n         , CNT_(size(adj))  // added\n         , cnt_(MAX_W) {  // added\n\n             dfs(adj, pairs, 0, -1);\n        }\n\n        int lca(int a, int b) const {\n            if (a &gt; b) {\n                swap(a, b);\n            }\n            return lca_.at(a).at(b);\n        }\n\n        int depth(int a) const {\n            return D_[a];\n        }\n\n        int count(int a, int w) const {  // added\n            return CNT_[a][w];\n        }\n    \n    private:\n        void dfs(const vector&lt;vector&lt;pair&lt;int, int&gt;&gt;&gt;&amp; adj,\n                 const unordered_map&lt;int, unordered_set&lt;int&gt;&gt;&amp; pairs,\n                 int u, int p) {\n\n            D_[u] = (p == -1) ? 1 : D_[p] + 1;\n            CNT_[u] = cnt_;  // added\n            for (const auto&amp; [v, w] : adj[u]) {\n                if (v == p) {\n                    continue;\n                }\n                ++cnt_[w];  // added\n                dfs(adj, pairs, v, u);\n                --cnt_[w];  // added\n                uf_.union_set(v, u);\n                uf_.update_ancestor_of_set(u);\n            }\n            lookup_[u] = true;\n            if (!pairs.count(u)) {\n                return;\n            }\n            for (const auto&amp; v : pairs.at(u)) {\n                if (!lookup_[v]) {\n                    continue;\n                }\n                lca_[min(u, v)][max(u, v)] = uf_.find_ancestor_of_set(v);\n            }\n        }\n\n        vector&lt;int&gt; D_;\n        UnionFind uf_;\n        unordered_map&lt;int, unordered_map&lt;int, int&gt;&gt; lca_;\n        vector&lt;bool&gt; lookup_;\n        vector&lt;vector&lt;int&gt;&gt; CNT_;  // added\n        vector&lt;int&gt; cnt_;  // added\n    };\n};\n\n// Time:  O(r * (n + q) + nlogn + qlogn), r = max(w for _, _, w in edges)\n// Space: O(r * n + nlogn)\n// binary lifting (online lca algorithm)\nclass Solution2 {\nprivate:\n    static const int MAX_W = 26;\n\npublic:\n    vector&lt;int&gt; minOperationsQueries(int n, vector&lt;vector&lt;int&gt;&gt;&amp; edges, vector&lt;vector&lt;int&gt;&gt;&amp; queries) {\n        vector&lt;vector&lt;pair&lt;int, int&gt;&gt;&gt; adj(n);\n        for (const auto&amp; e : edges) {\n            adj[e[0]].emplace_back(e[1], e[2] - 1), adj[e[1]].emplace_back(e[0], e[2] - 1);\n        }\n        TreeInfos tree_infos(adj);\n        vector&lt;int&gt; result(size(queries));\n        for (int i = 0; i &lt; size(queries); ++i) {\n            const auto&amp; a = queries[i][0], &amp;b = queries[i][1];\n            const auto&amp; lca = tree_infos.lca(a, b);\n            int mx = 0;\n            for (int w = 0; w &lt; MAX_W; ++w) {\n                mx = max(mx, tree_infos.count(a, w) + tree_infos.count(b, w) - 2 * tree_infos.count(lca, w));\n            }\n            result[i] = (tree_infos.depth(a) + tree_infos.depth(b) - 2 * tree_infos.depth(lca)) - mx;\n        }\n        return result;\n    }\n\nprivate:\n    class TreeInfos {\n    public:\n        TreeInfos(const vector&lt;vector&lt;pair&lt;int, int&gt;&gt;&gt;&amp; adj)\n         : L_(size(adj))\n         , R_(size(adj))\n         , D_(size(adj))\n         , P_(size(adj))\n         , C_(-1)\n         , CNT_(size(adj))  // added\n         , cnt_(MAX_W) {  // added\n\n             dfs(adj, 0, -1);\n        }\n        \n        bool is_ancestor(int a, int b) const {\n            return L_[a] &lt;= L_[b] &amp;&amp; R_[b] &lt;= R_[a];\n        }\n\n        int lca(int a, int b) const {\n            if (D_[a] &gt; D_[b]) {\n                swap(a, b);\n            }\n            if (is_ancestor(a, b)) {\n                return a;\n            }\n            for (int i = size(P_[a]) - 1; i &gt;= 0; --i) {  // O(logN)\n                if (i &lt; size(P_[a]) &amp;&amp; !is_ancestor(P_[a][i], b)) {\n                    a = P_[a][i];\n                }\n            }\n            return P_[a][0];\n        }\n\n        int depth(int a) const {\n            return D_[a];\n        }\n    \n        int count(int a, int w) const {  // added\n            return CNT_[a][w];\n        }\n\n    private:\n        void dfs(const vector&lt;vector&lt;pair&lt;int, int&gt;&gt;&gt;&amp; adj, int u, int p) {\n            D_[u] = (p == -1) ? 1 : D_[p] + 1;\n            if (p != -1) {\n                P_[u].emplace_back(p);  // ancestors of the node i\n            }\n            for (int i = 0; i &lt; size(P_[u]); ++i) {\n                if (i &gt;= size(P_[P_[u][i]])) {\n                    break;\n                }\n                P_[u].emplace_back(P_[P_[u][i]][i]);\n            }\n            L_[u] = ++C_; \n            CNT_[u] = cnt_;  // added\n            for (const auto&amp; [v, w] : adj[u]) {\n                if (v == p) {\n                    continue;\n                }\n                ++cnt_[w];  // added\n                dfs(adj, v, u);\n                --cnt_[w];  // added\n            }\n            R_[u] = C_;\n        }\n\n        vector&lt;int&gt; L_;\n        vector&lt;int&gt; R_;\n        vector&lt;int&gt; D_;\n        vector&lt;vector&lt;int&gt;&gt; P_;\n        int C_;\n        vector&lt;vector&lt;int&gt;&gt; CNT_;  // added\n        vector&lt;int&gt; cnt_;  // added\n    };\n};\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">Learn</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/problems\">Problems</a></li><li><a class=\"hover:text-primary\" href=\"/patterns\">Patterns</a></li><li><a class=\"hover:text-primary\" href=\"/roadmaps\">Roadmaps</a></li><li><a class=\"hover:text-primary\" href=\"/blind-75\">Blind 75</a></li><li><a class=\"hover:text-primary\" href=\"/grind-169\">Grind 169</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Interview</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/companies\">Companies</a></li><li><a class=\"hover:text-primary\" href=\"/interview-preparation\">Interview prep</a></li><li><a class=\"hover:text-primary\" href=\"/system-design\">System design</a></li><li><a class=\"hover:text-primary\" href=\"/glossary\">Glossary</a></li><li><a class=\"hover:text-primary\" href=\"/blog\">Blog</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Product</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/pricing\">Pricing</a></li><li><a class=\"hover:text-primary\" href=\"/about\">About</a></li><li><a class=\"hover:text-primary\" href=\"/about/attribution\">Attribution</a></li><li><a class=\"hover:text-primary\" href=\"/sitemap-html\">Sitemap</a></li></ul></div></div><div class=\"border-t border-border\"><div class=\"container-af py-4 flex flex-col sm:flex