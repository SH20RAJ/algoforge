nd/85 backdrop-blur-md\"><div class=\"container-af flex h-14 items-center justify-between gap-4\"><div class=\"flex items-center gap-6\"><a class=\"flex items-center gap-2 font-bold tracking-tight\" href=\"/\"><span class=\"inline-flex h-7 w-7 items-center justify-center rounded-md bg-primary text-primary-foreground text-xs font-black\">AF</span><span class=\"hidden sm:inline\">AlgoForge</span></a><nav class=\"hidden lg:flex items-center gap-1\" aria-label=\"Main\"><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/problems\">Problems</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/topics\">Topics</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/patterns\">Patterns</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/roadmaps\">Roadmaps</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blind-75\">Blind 75</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/companies\">Companies</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blog\">Blog</a></nav></div><div class=\"flex items-center gap-1\"><a class=\"hidden sm:inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-1.5 text-sm text-muted-foreground hover:border-primary/40 transition-colors\" href=\"/search\"><span>Search…</span><kbd class=\"rounded border border-border bg-muted px-1.5 text-[10px] font-mono\">/</kbd></a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground\" href=\"/dashboard\">Progress</a><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 hover:bg-muted text-foreground h-9 w-9\" aria-label=\"Toggle theme\"></button></div></div></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Power Update After K-th Largest Insertion II\",\"item\":\"https://algoforge.dev/problems/power-update-after-k-th-largest-insertion-ii\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"C++\",\"item\":\"https://algoforge.dev/problems/power-update-after-k-th-largest-insertion-ii/cpp\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/power-update-after-k-th-largest-insertion-ii\">Power Update After K-th Largest Insertion II</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">C++</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\">Hard</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Power Update After K-th Largest Insertion II<!-- --> — <!-- -->C++</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/power-update-after-k-th-largest-insertion-ii\">Full explanation</a> · <!-- -->Time <!-- -->O((n + q) * log(n * q) + q * logr)<!-- --> · Space <!-- -->O(n + q)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">C++</button><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code>// Time:  O((n + q) * log(n * q) + q * logr)\n// Space: O(n + q)\n\n#include &lt;ext/pb_ds/assoc_container.hpp&gt;\n#include &lt;ext/pb_ds/tree_policy.hpp&gt;\nusing namespace __gnu_pbds;\n\n// ordered set, fast exponentiation\nclass Solution {\npublic:\n    vector&lt;int&gt; powerUpdate(vector&lt;int&gt;&amp; nums, int p, vector&lt;vector&lt;int&gt;&gt;&amp; queries) {\n        static const uint32_t MOD = 1e9 + 7;\n\n        const auto&amp; powmod = [&amp;](uint32_t a, uint32_t b, uint32_t mod) {\n            a %= mod;\n            uint32_t result = 1;\n            while (b) {\n                if (b &amp; 1) {\n                    result = (static_cast&lt;uint64_t&gt;(result) * a) % mod;\n                }\n                a = (static_cast&lt;uint64_t&gt;(a) * a) % mod;\n                b &gt;&gt;= 1;\n            }\n            return result;\n        };\n\n        using ordered_set = tree&lt;pair&lt;int, int&gt;, null_type, less&lt;pair&lt;int, int&gt;&gt;, rb_tree_tag, tree_order_statistics_node_update&gt;;\n        ordered_set os;\n        int i = 0;\n        for (; i &lt; size(nums); ++i) {\n            os.insert({nums[i], i});\n        }\n        vector&lt;int&gt; result;\n        result.reserve(size(queries));\n        for (const auto&amp; q : queries) {\n            os.insert({q[0], i++});\n            p = powmod(p, os.find_by_order(size(os) - q[1])-&gt;first, MOD);\n            result.emplace_back(p);\n        }\n        return result;\n    }\n};\n\n// Time:  O((n + q) * log(n * q) + q * logr)\n// Space: O(n + q)\n// sort, coordinate compression, fenwick tree, fast exponentiation\nclass Solution2 {\npublic:\n    vector&lt;int&gt; powerUpdate(vector&lt;int&gt;&amp; nums, int p, vector&lt;vector&lt;int&gt;&gt;&amp; queries) {\n        static const uint32_t MOD = 1e9 + 7;\n\n        const auto&amp; powmod = [&amp;](uint32_t a, uint32_t b, uint32_t mod) {\n            a %= mod;\n            uint32_t result = 1;\n            while (b) {\n                if (b &amp; 1) {\n                    result = (static_cast&lt;uint64_t&gt;(result) * a) % mod;\n                }\n                a = (static_cast&lt;uint64_t&gt;(a) * a) % mod;\n                b &gt;&gt;= 1;\n            }\n            return result;\n        };\n\n        vector&lt;int&gt; sorted_vals(nums);\n        for (const auto&amp; q : queries) {\n            sorted_vals.emplace_back(q[0]);\n        }\n        ranges::sort(sorted_vals);\n        sorted_vals.erase(unique(begin(sorted_vals), end(sorted_vals)), end(sorted_vals));\n        unordered_map&lt;int, int&gt; val_to_idx;\n        for (int i = 0; i &lt; size(sorted_vals); ++i) {\n            val_to_idx[sorted_vals[i]] = i;\n        }\n        BIT bit(size(val_to_idx));\n        for (const auto&amp; x : nums) {\n            bit.add(val_to_idx[x], +1);\n        }\n        vector&lt;int&gt; result;\n        result.reserve(size(queries));\n        int total = size(nums);\n        for (const auto&amp; q : queries) {\n            bit.add(val_to_idx[q[0]], +1);\n            const auto&amp; i = bit.kth_element(++total - q[1] + 1);\n            p = powmod(p, sorted_vals[i], MOD);\n            result.emplace_back(p);\n        }\n        return result;\n    }\n\nprivate:\n    class BIT {\n    public:\n        BIT(int n) : bit_(n + 1) {  // 0-indexed\n        }\n        \n        void add(int i, int val) {\n            ++i;\n            for (; i &lt; size(bit_); i += lower_bit(i)) {\n                bit_[i] += val;\n            }\n        }\n\n        int query(int i) const {\n            ++i;\n            int total = 0;\n            for (; i &gt; 0; i -= lower_bit(i)) {\n                total += bit_[i];\n            }\n            return total;\n        }\n        \n        int kth_element(int k) const {\n            int total = 0;\n            int pos = 0;\n            for (int i = floor_log2_x(size(bit_) - 1); i &gt;= 0; --i) {\n                if (pos + (1 &lt;&lt; i) &lt; size(bit_) &amp;&amp; !(total + bit_[pos + (1 &lt;&lt; i)] &gt;= k)) {\n                    total += bit_[pos + (1 &lt;&lt; i)];\n                    pos += (1 &lt;&lt; i);\n                }\n            }\n            return (pos + 1) - 1;\n        }\n    \n    private:\n        int lower_bit(int i) const {\n            return i &amp; -i;\n        }\n        \n        int floor_log2_x(int x) const {\n            return bit_width(static_cast&lt;uint32_t&gt;(x)) - 1;\n        };\n        \n        vector&lt;int&gt; bit_;\n    };\n};\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">Learn</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/problems\">Problems</a></li><li><a class=\"hover:text-primary\" href=\"/patterns\">Patterns</a></li><li><a class=\"hover:text-primary\" href=\"/roadmaps\">Roadmaps</a></li><li><a class=\"hover:text-primary\" href=\"/blind-75\">Blind 75</a></li><li><a class=\"hover:text-primary\" href=\"/grind-169\">Grind 169</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Interview</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/companies\">Companies</a></li><li><a class=\"hover:text-primary\" href=\"/interview-preparation\">Interview prep</a></li><li><a class=\"hover:text-primary\" href=\"/system-design\">System design</a></li><li><a class=\"hover:text-primary\" href=\"/glossary\">Glossary</a></li><li><a class=\"hover:text-primary\" href=\"/blog\">Blog</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Product</p><ul class=\"space-y-2 text-sm text-muted-foreground\"