,\"$L3\",null,{\"href\":\"/about\",\"className\":\"hover:text-primary\",\"children\":\"About\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/about/attribution\",\"className\":\"hover:text-primary\",\"children\":\"Attribution\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/sitemap-html\",\"className\":\"hover:text-primary\",\"children\":\"Sitemap\"}]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"border-t border-border\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-af py-4 flex flex-col sm:flex-row gap-2 justify-between text-xs text-muted-foreground\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"© \",2026,\" \",\"AlgoForge\",\". Educational use only.\"]}],[\"$\",\"p\",null,{\"children\":[\"Solution code sourced under MIT from\",\" \",[\"$\",\"a\",null,{\"href\":\"https://github.com/kamyu104/LeetCode-Solutions\",\"className\":\"underline hover:text-primary\",\"rel\":\"noopener noreferrer\",\"target\":\"_blank\",\"children\":\"kamyu104/LeetCode-Solutions\"}],\". Explanations are original AlgoForge content.\"]}]]}]}]]}]\na:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nb:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nc:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nd:[\"$\",\"$1\",\"c\",{\"children\":[\"$L15\",[[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0a2gmow1_jiq0.js\",\"async\":true,\"nonce\":\"$undefined\"}]],[\"$\",\"$L16\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@18\"}]}]]}]\n19:[]\ne:\"$W19\"\nf:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1a\",null,{\"children\":\"$L1b\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1d\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n11:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/340fxer6uczx7.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n1e:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n1f:Td70,// Time:  O(n * m * logn * logm)\n// Space: O(n * m * logn * logm)\n\n// 2d sparse table\nclass Solution {\npublic:\n    int countLocalMaximums(vector<vector<int>>& matrix) {\n        const int n = size(matrix);\n        const int m = size(matrix[0]);\n        SparseTable2D st(matrix, [](const auto& x, const auto& y) {\n            return x < y ? y : x;\n        });\n\n        int result = 0;\n        for (int r = 0; r < n; ++r) {\n            const auto& row = matrix[r];\n            for (int c = 0; c < m; ++c) {\n                const auto& x = row[c];\n                if (x == 0) {\n                    continue;\n                }\n                const auto& r1 = max(r - x, 0);\n                const auto& r2 = min(r + x, n - 1);\n                const auto& c1 = max(c - x, 0);\n                const auto& c2 = min(c + x, m - 1);\n                const auto& tl = r - x >= 0 && c - x >= 0;\n                const auto& tr = r - x >= 0 && c + x <= m - 1;\n                const auto& bl = r + x <= n - 1 && c - x >= 0;\n                const auto& br = r + x <= n - 1 && c + x <= m - 1;\n                const auto& topX = tl || tr, botX = bl || br;\n                if (max(st.query(r1, c1 + (tl || bl ? 1 : 0), r2, c2 - (tr || br ? 1 : 0)),\n                        st.query(r1 + (tl || tr ? 1 : 0), c1, r2 - (bl || br ? 1 : 0), c2)) <= x) {\n                    ++result;\n                }\n            }\n        }\n        return result;\n    }\n\nprivate:\n    // Reference: https://cp-algorithms.com/data_structures/sparse-table.html\n    class SparseTable2D {\n    public:\n        // Time: O(n * m * log(n) * log(m)) * O(fn), Space: O(n * m * log(n) * log(m))\n        SparseTable2D(const vector<vector<int>>& matrix, function<int(int, int)> fn)\n        : fn(fn) {\n            const auto& n = size(matrix);\n            const auto& m = size(matrix[0]);\n            const auto& logn = __lg(n);\n            const auto& logm = __lg(m);\n            st.assign(logn + 1, vector<vector<vector<int>>>(logm + 1, vector<vector<int>>(n, vector<int>(m))));            \n            for (int r = 0; r < n; ++r) {\n                for (int c = 0; c < m; ++c) {\n                    st[0][0][r][c] = matrix[r][c];\n                }\n            }\n            for (int j = 1; j <= logm; ++j) {\n                for (int r = 0; r < n; ++r) {\n                    for (int c = 0; c + (1 << j) <= m; ++c) {\n                        st[0][j][r][c] = fn(st[0][j - 1][r][c], st[0][j - 1][r][c + (1 << (j - 1))]);\n                    }\n                }\n            }            \n            for (int i = 1; i <= logn; ++i) {\n                for (int j = 0; j <= logm; ++j) {\n                    for (int r = 0; r + (1 << i) <= n; ++r) {\n                        for (int c = 0; c + (1 << j) <= m; ++c) {\n                            st[i][j][r][c] = fn(st[i - 1][j][r][c], st[i - 1][j][r + (1 << (i - 1))][c]);\n                        }\n                    }\n                }\n            }\n        }\n        \n        int query(int r1, int c1, int r2, int c2) const {\n            const int i = __lg(r2 - r1 + 1);\n            const int j = __lg(c2 - c1 + 1);\n            return fn(\n                fn(st[i][j][r1][c1], st[i][j][r1][c2 - (1 << j) + 1]),\n                fn(st[i][j][r2 - (1 << i) + 1][c1], st[i][j][r2 - (1 << i) + 1][c2 - (1 << j) + 1])\n            );\n        }\n\n    private:\n        vector<vector<vector<vector<int>>>> st;\n        const function<int(int, int)> fn;\n    };\n};\n20:Tb72,# Time:  O(n * m * logn * logm)\n# Space: O(n * m * logn * logm)\n\n# 2d sparse table\nclass Solution(object):\n    def countLocalMaximums(self, matrix):\n        \"\"\"\n        :type matrix: List[List[int]]\n        :rtype: int\n        \"\"\"\n        # RMQ - 2D Sparse Table\n        # Time:  ctor:  O(N * M * logN * logM) * O(fn)\n        #        query: O(fn)\n        # Space: O(N * M * logN * logM)\n        class SparseTable2D(object):\n            def __init__(self, matrix, fn):\n                self.fn = fn\n                n = len(matrix)\n                m = len(matrix[0])\n                logn = n.bit_length()-1  # log2_floor(n)\n                logm = m.bit_length()-1  # log2_floor(m)\n                self.bit_length = [0]\n                for i in xrange(max(logn, logm)+1):\n                    self.bit_length.extend(i+1 for _ in xrange(min(1<<i, (max(n, m)+1)-len(self.bit_length))))\n                self.st = [[[[0]*m for _ in xrange(n)] for _ in xrange(logm+1)] for _ in xrange(logn+1)]\n                for r in xrange(n):\n                    for c in xrange(m):\n                        self.st[0][0][r][c] = matrix[r][c]\n                for j in xrange(1, logm+1):\n                    for r in xrange(n):\n                        for c in xrange((m-(1<<j))+1):\n                            self.st[0][j][r][c] = fn(self.st[0][j-1][r][c], self.st[0][j-1][r][c+(1<<(j-1))])\n                for i in xrange(1, logn+1):\n                    for j in xrange(logm+1):\n                        for r in xrange((n-(1<<i))+1):\n                            for c in xrange((m-(1<<j))+1):\n                                self.st[i][j][r][c] = fn(self.st[i-1][j][r][c], self.st[i-1][j][r+(1<<(i-1))][c])\n\n            def query(self, r1, c1, r2, c2):  # Time: O(fn)\n                i = self.bit_length[r2-r1+1]-1  # log2_floor(r2-r1+1)\n                j = self.bit_length[c2-c1+1]-1  # log2_floor(c2-c1+1)\n                return self.fn(\n                    self.fn(self.st[i][j][r1][c1], self.st[i][j][r1][c2-(1<<j)+1]),\n                    self.fn(self.st[i][j][r2-(1<<i)+1][c1], self.st[i][j][r2-(1<<i)+1][c2-(1<<j)+1])\n                )\n\n        n, m = len(matrix), len(matrix[0])\n        st = SparseTable2D(matrix, max)\n        result = 0\n        for r in xrange(n):\n            row = matrix[r]\n            for c in xrange(m):\n                x = row[c]\n                if x == 0:\n                    continue\n                r1, r2 = max(0, r-x), min(n-1, r+x)\n                c1, c2 = max(0, c-x), min(m-1, c+x)\n                tl = r-x >= 0 and c-x >= 0\n                tr = r-x >= 0 and c+x <= m-1\n                bl = r+x <= n-1 and c-x >= 0\n                br = r+x <= n-1 and c+x <= m-1\n                if max(st.query(r1, c1+(1 if tl or bl else 0), r2, c2-(1 if tr or br else 0)),\n                       st.query(r1+(1 if tl or tr else 0), c1, r2-(1 if bl or br else 0), c2)) <= x:\n                    result += 1\n        return result\n15:[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Largest Local Values in a Matrix II\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/largest-local-values-in-a-matrix-ii\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"Python\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/largest-local-values-in-a-matrix-ii/python\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/largest-local-values-in-a-matrix-ii\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems/largest-local-values-in-a-matrix-ii\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Largest Local Values in a Matrix II\"}]]}],[\"$\",\"li\",\"/problems/largest-local-values-in-a-matrix-ii/python\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"Python\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 flex flex-wrap items-center gap-2\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-medium/15 text-medium\",\"children\":\"Medium\"}]}],[\"$\",\"h1\",null,{\"className\":\"mt-3 text-3xl font-bold tracking-tight\",\"children\":[\"Largest Local Values in a Matrix II\",\" — \",\"Python\"]}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-muted-foreground\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/problems/largest-local-values-in-a-matrix-ii\",\"className\":\"text-primary hover:underline\",\"children\":\"Full explanation\"}],\" · \",\"Time \",\"O(n * m * logn * logm)\",\" · Space \",\"O(n * m * logn * logm)\"]}],[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L1e\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"largest-local-values-in-a-matrix-ii.cpp\",\"code\":\"$1f\",\"sourcePath\":\"C++/largest-local-values-in-a-matrix-ii.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"largest-local-values-in-a-matrix-ii.py\",\"code\":\"$20\",\"sourcePath\":\"Python/largest-local-values-in-a-matrix-ii.py\"}},\"defaultLang\":\"python\"}]}]]}]\n1b:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n21:I[27201,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"IconMark\"]\n18:null\n1d:[[\"$\",\"title\",\"0\",{\"children\":\"Largest Local Values in a Matrix II Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Python solution for Largest Local Values in a Matrix II (LeetCode #3933). Time O(n * m * logn * logm), space O(n * m * logn * logm).\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"Largest Local Values in a Matrix II python,Largest Local Values in a Matrix II Python,python leetcode\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://algoforge.dev/problems/largest-local-values-in-a-matrix-ii/python\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"Largest Local Values in a Matrix II Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"Python solution for Largest Local Values in a Matrix II (LeetCode #3933). Time O(n * m * logn * logm), space O(n * m * logn * logm).\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:url\",\"content\":\"https://algoforge.dev/problems/largest-local-values-in-a-matrix-ii/python\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:site_name\",\"content\":\"AlgoForge\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:image:alt\",\"content\":\"Largest Local Values in a Matrix II Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"13\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:title\",\"content\":\"Largest Local Values in a Matrix II Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"15\",{\"name\":\"twitter:description\",\"content\":\"Python solution for Largest Local Values in a Matrix II (LeetCode #3933). Time O(n * m * logn * logm), space O(n * m * logn * logm).\"}],[\"$\",\"meta\",\"16\",{\"name\":\"twitter:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"link\",\"17\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.2vob68tjqpejf.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"link\",\"18\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\"}],[\"$\",\"$L21\",\"19\",{}]]\n","/problems/$d$slug/$d$lang/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[522016,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"\"]\n3:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n8:I[897367,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"OutletBoundary\"]\n9:\"$Sreact.suspense\"\n4:Td70,// Time:  O(n * m * logn * logm)\n// Space: O(n * m * logn * logm)\n\n// 2d sparse table\nclass Solution {\npublic:\n    int countLocalMaximums(vector<vector<int>>& matrix) {\n        const int n = size(matrix);\n        const int m = size(matrix[0]);\n        SparseTable2D st(matrix, [](const auto& x, const auto& y) {\n            return x < y ? y : x;\n        });\n\n        int result = 0;\n        for (int r = 0; r < n; ++r) {\n            const auto& row = matrix[r];\n            for (int c = 0; c < m; ++c) {\n                const auto& x = row[c];\n                if (x == 0) {\n                    continue;\n                }\n                const auto& r1 = max(r - x, 0);\n                const auto& r2 = min(r + x, n - 1);\n                const auto& c1 = max(c - x, 0);\n                const auto& c2 = min(c + x, m - 1);\n                const auto& tl = r - x >= 0 && c - x >= 0;\n                const auto& tr = r - x >= 0 && c + x <= m - 1;\n                const auto& bl = r + x <= n - 1 && c - x >= 0;\n                const auto& br = r + x <= n - 1 && c + x <= m - 1;\n                const auto& topX = tl || tr, botX = bl || br;\n                if (max(st.query(r1, c1 + (tl || bl ? 1 : 0), r2, c2 - (tr || br ? 1 : 0)),\n                        st.query(r1 + (tl || tr ? 1 : 0), c1, r2 - (bl || br ? 1 : 0), c2)) <= x) {\n                    ++result;\n                }\n            }\n        }\n        return result;\n    }\n\nprivate:\n    // Reference: https://cp-algorithms.com/data_structures/sparse-table.html\n    class SparseTable2D {\n    public:\n        // Time: O(n * m * log(n) * log(m)) * O(fn), Space: O(n * m * log(n) * log(m))\n        SparseTable2D(const vector<vector<int>>& matrix, function<int(int, int)> fn)\n        : fn(fn) {\n            const auto& n = size(matrix);\n            const auto& m = size(matrix[0]);\n            const auto& logn = __lg(n);\n            const auto& logm = __lg(m);\n            st.assign(logn + 1, vector<vector<vector<int>>>(logm + 1, vector<vector<int>>(n, vector<int>(m))));            \n            for (int r = 0; r < n; ++r) {\n                for (int c = 0; c < m; ++c) {\n                    st[0][0][r][c] = matrix[r][c];\n                }\n            }\n            for (int j = 1; j <= logm; ++j) {\n                for (int r = 0; r < n; ++r) {\n                    for (int c = 0; c + (1 << j) <= m; ++c) {\n                        st[0][j][r][c] = fn(st[0][j - 1][r][c], st[0][j - 1][r][c + (1 << (j - 1))]);\n                    }\n                }\n            }            \n            for (int i = 1; i <= logn; ++i) {\n                for (int j = 0; j <= logm; ++j) {\n                    for (int r = 0; r + (1 << i) <= n; ++r) {\n                        for (int c = 0; c + (1 << j) <= m; ++c) {\n                            st[i][j][r][c] = fn(st[i - 1][j][r][c], st[i - 1][j][r + (1 << (i - 1))][c]);\n                        }\n                    }\n                }\n            }\n        }\n        \n        int query(int r1, int c1, int r2, int c2) const {\n            const int i = __lg(r2 - r1 + 1);\n            const int j = __lg(c2 - c1 + 1);\n            return fn(\n                fn(st[i][j][r1][c1], st[i][j][r1][c2 - (1 << j) + 1]),\n                fn(st[i][j][r2 - (1 << i) + 1][c1], st[i][j][r2 - (1 << i) + 1][c2 - (1 << j) + 1])\n            );\n        }\n\n    private:\n        vector<vector<vector<vector<int>>>> st;\n        const function<int(int, int)> fn;\n    };\n};\n5:Tb72,# Time:  O(n * m * logn * logm)\n# Space: O(n * m * logn * logm)\n\n# 2d sparse table\nclass Solution(object):\n    def countLocalMaximums(self, matrix):\n        \"\"\"\n        :type matrix: List[List[int]]\n        :rtype: int\n        \"\"\"\n        # RMQ - 2D Sparse Table\n        # Time:  ctor:  O(N * M * logN * logM) * O(fn)\n        #        query: O(fn)\n        # Space: O(N * M * logN * logM)\n        class SparseTable2D(object):\n            def __init__(self, matrix, fn):\n                self.fn = fn\n                n = len(matrix)\n                m = len(matrix[0])\n                logn = n.bit_length()-1  # log2_floor(n)\n                logm = m.bit_length()-1  # log2_floor(m)\n                self.bit_length = [0]\n                for i in xrange(max(logn, logm)+1):\n                    self.bit_length.extend(i+1 for _ in xrange(min(1<<i, (max(n, m)+1)-len(self.bit_length))))\n                self.st = [[[[0]*m for _ in xrange(n)] for _ in xrange(logm+1)] for _ in xrange(logn+1)]\n                for r in xrange(n):\n                    for c in xrange(m):\n                        self.st[0][0][r][c] = matrix[r][c]\n                for j in xrange(1, logm+1):\n                    for r in xrange(n):\n                        for c in xrange((m-(1<<j))+1):\n                            self.st[0][j][r][c] = fn(self.st[0][j-1][r][c], self.st[0][j-1][r][c+(1<<(j-1))])\n                for i in xrange(1, logn+1):\n                    for j in xrange(logm+1):\n                        for r in xrange((n-(1<<i))+1):\n                            for c in xrange((m-(1<<j))+1):\n                                self.st[i][j][r][c] = fn(self.st[i-1][j][r][c], self.st[i-1][j][r+(1<<(i-1))][c])\n\n            def query(self, r1, c1, r2, c2):  # Time: O(fn)\n                i = self.bit_length[r2-r1+1]-1  # log2_floor(r2-r1+1)\n                j = self.bit_length[c2-c1+1]-1  # log2_floor(c2-c1+1)\n                return self.fn(\n                    self.fn(self.st[i][j][r1][c1], self.st[i][j][r1][c2-(1<<j)+1]),\n                    self.fn(self.st[i][j][r2-(1<<i)+1][c1], self.st[i][j][r2-(1<<i)+1][c2-(1<<j)+1])\n                )\n\n        n, m = len(matrix), len(matrix[0])\n        st = SparseTable2D(matrix, max)\n        result = 0\n        for r in xrange(n):\n            row = matrix[r]\n            for c in xrange(m):\n                x = row[c]\n                if x == 0:\n                    continue\n                r1, r2 = max(0, r-x), min(n-1, r+x)\n                c1, c2 = max(0, c-x), min(m-1, c+x)\n                tl = r-x >= 0 and c-x >= 0\n                tr = r-x >= 0 and c+x <= m-1\n                bl = r+x <= n-1 and c-x >= 0\n                br = r+x <= n-1 and c+x <= m-1\n                if max(st.query(r1, c1+(1 if tl or bl else 0), r2, c2-(1 if tr or br else 0)),\n                       st.query(r1+(1 if tl or tr else 0), c1, r2-(1 if bl or br else 0), c2)) <= x:\n                    result += 1\n        return result\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Largest Local Values in a Matrix II\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/largest-local-values-in-a-matrix-ii\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"Python\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/largest-local-values-in-a-matrix-ii/python\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L2\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L2\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/largest-local-values-in-a-matrix-ii\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L2\",null,{\"href\":\"/problems/largest-local-values-in-a-matrix-ii\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Largest Local Values in a Matrix II\"}]]}],[\"$\",\"li\",\"/problems/largest-local-values-in-a-matrix-ii/python\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"Python\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 flex flex-wrap items-center gap-2\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center ro