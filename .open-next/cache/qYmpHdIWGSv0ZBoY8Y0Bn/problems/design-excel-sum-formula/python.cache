ocus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 hover:bg-muted text-foreground h-9 w-9\" aria-label=\"Toggle theme\"></button></div></div></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Design Excel Sum Formula\",\"item\":\"https://algoforge.dev/problems/design-excel-sum-formula\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Python\",\"item\":\"https://algoforge.dev/problems/design-excel-sum-formula/python\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/design-excel-sum-formula\">Design Excel Sum Formula</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">Python</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\">Hard</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Design Excel Sum Formula<!-- --> — <!-- -->Python</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/design-excel-sum-formula\">Full explanation</a> · <!-- -->Time <!-- -->set: O((r * c)^2) get: O(1) sum: O((r * c)^2)<!-- --> · Space <!-- -->O(r * c)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">C++</button><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code># Time:  set: O((r * c)^2)\n#        get: O(1)\n#        sum: O((r * c)^2)\n# Space: O(r * c)\n\nimport collections\n\n\nclass Excel(object):\n\n    def __init__(self, H, W):\n        &quot;&quot;&quot;\n        :type H: int\n        :type W: str\n        &quot;&quot;&quot;\n        self.__exl = [[0 for _ in xrange(ord(W)-ord(&#x27;A&#x27;)+1)] \\\n                      for _ in xrange(H+1)]\n        self.__fward = collections.defaultdict(lambda : collections.defaultdict(int))\n        self.__bward = collections.defaultdict(set)\n\n\n    def set(self, r, c, v):\n        &quot;&quot;&quot;\n        :type r: int\n        :type c: str\n        :type v: int\n        :rtype: void\n        &quot;&quot;&quot;\n        self.__reset_dependency(r, c)\n        self.__update_others(r, c, v)\n\n\n    def get(self, r, c):\n        &quot;&quot;&quot;\n        :type r: int\n        :type c: str\n        :rtype: int\n        &quot;&quot;&quot;\n        return self.__exl[r][ord(c) - ord(&#x27;A&#x27;)]\n\n\n    def sum(self, r, c, strs):\n        &quot;&quot;&quot;\n        :type r: int\n        :type c: str\n        :type strs: List[str]\n        :rtype: int\n        &quot;&quot;&quot;\n        self.__reset_dependency(r, c)\n        result = self.__calc_and_update_dependency(r, c, strs)\n        self.__update_others(r, c, result)\n        return result\n\n\n    def __reset_dependency(self, r, c):\n        key = (r, c)\n        if key in self.__bward.keys():\n            for k in self.__bward[key]:\n                self.__fward[k].pop(key, None)\n            self.__bward[key] = set()\n\n\n    def __calc_and_update_dependency(self, r, c, strs):\n        result = 0\n        for s in strs:\n            s, e = s.split(&#x27;:&#x27;)[0], s.split(&#x27;:&#x27;)[1] if &#x27;:&#x27; in s else s\n            left, right, top, bottom = ord(s[0])-ord(&#x27;A&#x27;), ord(e[0])-ord(&#x27;A&#x27;), int(s[1:]), int(e[1:])\n            for i in xrange(top, bottom+1):\n                for j in xrange(left, right+1):\n                    result += self.__exl[i][j]\n                    self.__fward[(i, chr(ord(&#x27;A&#x27;)+j))][(r, c)] += 1\n                    self.__bward[(r, c)].add((i, chr(ord(&#x27;A&#x27;)+j)))\n        return result\n\n\n    def __update_others(self, r, c, v):\n        prev = self.__exl[r][ord(c)-ord(&#x27;A&#x27;)]\n        self.__exl[r][ord(c)-ord(&#x27;A&#x27;)] = v\n        q = collections.deque()\n        q.append(((r, c), v-prev))\n        while q:\n            key, diff = q.popleft()\n            if key in self.__fward:\n                for k, count in self.__fward[key].iteritems():\n                    q.append((k, diff*count))\n                    self.__exl[k[0]][ord(k[1])-ord(&#x27;A&#x27;)] += diff*count\n\n\n\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">Learn</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/problems\">Problems</a></li><li><a class=\"hover:text-primary\" href=\"/patterns\">Patterns</a></li><li><a class=\"hover:text-primary\" href=\"/roadmaps\">Roadmaps</a></li><li><a class=\"hover:text-primary\" href=\"/blind-75\">Blind 75</a></li><li><a class=\"hover:text-primary\" href=\"/grind-169\">Grind 169</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Interview</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/companies\">Companies</a></li><li><a class=\"hover:text-primary\" href=\"/interview-preparation\">Interview prep</a></li><li><a class=\"hover:text-primary\" href=\"/system-design\">System design</a></li><li><a class=\"hover:text-primary\" href=\"/glossary\">Glossary</a></li><li><a class=\"hover:text-primary\" href=\"/blog\">Blog</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Product</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/pricing\">Pricing</a></li><li><a class=\"hover:text-primary\" href=\"/about\">About</a></li><li><a class=\"hover:text-primary\" href=\"/about/attribution\">Attribution</a></li><li><a class=\"hover:text-primary\" href=\"/sitemap-html\">Sitemap</a></li></ul></div></div><div class=\"border-t border-border\"><div class=\"container-af py-4 flex flex-col sm:flex-row gap-2 justify-between text-xs text-muted-foreground\"><p>© <!-- -->2026<!-- --> <!-- -->AlgoForge<!-- -->. Educational use only.</p><p>Solution code sourced under MIT from<!-- --> <a href=\"https://github.com/kamyu104/LeetCode-Solutions\" class=\"underline hover:text-primary\" rel=\"noopener noreferrer\" target=\"_blank\">kamyu104/LeetCode-Solutions</a>. Explanations are original AlgoForge content.</p></div></div></footer><script src=\"/_next/static/chunks/05kafvajig4wu.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[427423,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\"],\\\"ThemeProvider\\\"]\\n3:I[522016,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\",\\\"/_next/static/chunks/0a2gmow1_jiq0.js\\\"],\\\"\\\"]\\n10:I[168027,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/340fxer6uczx7.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\