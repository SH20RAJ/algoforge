$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nc:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nd:[\"$\",\"$1\",\"c\",{\"children\":[\"$L15\",[[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0a2gmow1_jiq0.js\",\"async\":true,\"nonce\":\"$undefined\"}]],[\"$\",\"$L16\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@18\"}]}]]}]\n19:[]\ne:\"$W19\"\nf:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1a\",null,{\"children\":\"$L1b\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1d\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n11:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/340fxer6uczx7.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n1e:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n1f:Tb0b,// Time:  set: O((r * c)^2)\n//        get: O(1)\n//        sum: O((r * c)^2)\n// Space: O(r * c)\n\nclass Excel {\npublic:\n    Excel(int H, char W) : Exl_(H + 1, vector<int>(W - 'A' + 1)) {\n    }\n    \n    // Time:  O((r * c)^2)\n    void set(int r, char c, int v) {\n        auto col = c - 'A';\n        reset_dependency(r, col);\n        update_others(r, col, v);\n    }\n    \n    // Time:  O(1)\n    int get(int r, char c) {\n        return Exl_[r][c - 'A'];\n    }\n\n    // Time:  O((r * c)^2)\n    int sum(int r, char c, vector<string> strs) {\n        auto col = c - 'A';\n        reset_dependency(r, col);\n        auto result = calc_and_update_dependency(r, col, strs);\n        update_others(r, col, result);\n        return result;\n    }\n\nprivate:\n    // Time:  O(r * c)\n    void reset_dependency(int r, int col) {\n        auto key = r * 26 + col;\n        if (bward_.count(key)) {\n            for (const auto& k : bward_[key]) {\n                fward_[k].erase(key);\n            }\n            bward_.erase(key);\n        }\n    }\n\n    // Time:  O(r * c * l), l is the length of strs\n    int calc_and_update_dependency(int r, int col, const vector<string>& strs) {\n        auto result = 0;\n        for (const auto& s : strs) {\n            int p = s.find(':'), left, right, top, bottom;\n            left = s[0] - 'A';\n            right = s[p + 1] - 'A';\n            top = (p == string::npos) ? stoi(s.substr(1)) : stoi(s.substr(1, p - 1));\n            bottom = stoi(s.substr(p + 2));\n            for (int i = top; i <= bottom; ++i) {\n                for (int j = left; j <= right; ++j) {\n                    result += Exl_[i][j];\n                    ++fward_[i * 26 + j][r * 26 + col];\n                    bward_[r * 26 + col].emplace(i * 26 + j);\n                }\n            }\n        }\n        return result;\n    }\n\n    // Time:  O((r * c)^2)\n    void update_others(int r, int col, int v) {\n        auto prev = Exl_[r][col];\n        Exl_[r][col] = v;\n        queue<pair<int, int>> q;\n        q.emplace(make_pair(r * 26 + col, v - prev));\n        while (!q.empty()) {\n            int key, diff;\n            tie(key, diff) = q.front(), q.pop();\n            if (fward_.count(key)) {\n                for (auto it = fward_[key].begin(); it != fward_[key].end(); ++it) {\n                    int k, count;\n                    tie(k, count) = *it;\n                    q.emplace(make_pair(k, diff * count));\n                    Exl_[k / 26][k % 26] += diff * count;\n                }\n            }\n        }\n    }\n    \n    unordered_map<int, unordered_map<int, int>> fward_;\n    unordered_map<int, unordered_set<int>> bward_;\n    vector<vector<int>> Exl_;\n};\n\n/**\n * Your Excel object will be instantiated and called as such:\n * Excel obj = new Excel(H, W);\n * obj.set(r,c,v);\n * int param_2 = obj.get(r,c);\n * int param_3 = obj.sum(r,c,strs);\n */\n20:T980,# Time:  set: O((r * c)^2)\n#        get: O(1)\n#        sum: O((r * c)^2)\n# Space: O(r * c)\n\nimport collections\n\n\nclass Excel(object):\n\n    def __init__(self, H, W):\n        \"\"\"\n        :type H: int\n        :type W: str\n        \"\"\"\n        self.__exl = [[0 for _ in xrange(ord(W)-ord('A')+1)] \\\n                      for _ in xrange(H+1)]\n        self.__fward = collections.defaultdict(lambda : collections.defaultdict(int))\n        self.__bward = collections.defaultdict(set)\n\n\n    def set(self, r, c, v):\n        \"\"\"\n        :type r: int\n        :type c: str\n        :type v: int\n        :rtype: void\n        \"\"\"\n        self.__reset_dependency(r, c)\n        self.__update_others(r, c, v)\n\n\n    def get(self, r, c):\n        \"\"\"\n        :type r: int\n        :type c: str\n        :rtype: int\n        \"\"\"\n        return self.__exl[r][ord(c) - ord('A')]\n\n\n    def sum(self, r, c, strs):\n        \"\"\"\n        :type r: int\n        :type c: str\n        :type strs: List[str]\n        :rtype: int\n        \"\"\"\n        self.__reset_dependency(r, c)\n        result = self.__calc_and_update_dependency(r, c, strs)\n        self.__update_others(r, c, result)\n        return result\n\n\n    def __reset_dependency(self, r, c):\n        key = (r, c)\n        if key in self.__bward.keys():\n            for k in self.__bward[key]:\n                self.__fward[k].pop(key, None)\n            self.__bward[key] = set()\n\n\n    def __calc_and_update_dependency(self, r, c, strs):\n        result = 0\n        for s in strs:\n            s, e = s.split(':')[0], s.split(':')[1] if ':' in s else s\n            left, right, top, bottom = ord(s[0])-ord('A'), ord(e[0])-ord('A'), int(s[1:]), int(e[1:])\n            for i in xrange(top, bottom+1):\n                for j in xrange(left, right+1):\n                    result += self.__exl[i][j]\n                    self.__fward[(i, chr(ord('A')+j))][(r, c)] += 1\n                    self.__bward[(r, c)].add((i, chr(ord('A')+j)))\n        return result\n\n\n    def __update_others(self, r, c, v):\n        prev = self.__exl[r][ord(c)-ord('A')]\n        self.__exl[r][ord(c)-ord('A')] = v\n        q = collections.deque()\n        q.append(((r, c), v-prev))\n        while q:\n            key, diff = q.popleft()\n            if key in self.__fward:\n                for k, count in self.__fward[key].iteritems():\n                    q.append((k, diff*count))\n                    self.__exl[k[0]][ord(k[1])-ord('A')] += diff*count\n\n\n\n15:[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Design Excel Sum Formula\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/design-excel-sum-formula\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"Python\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/design-excel-sum-formula/python\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/design-excel-sum-formula\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems/design-excel-sum-formula\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Design Excel Sum Formula\"}]]}],[\"$\",\"li\",\"/problems/design-excel-sum-formula/python\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"Python\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 flex flex-wrap items-center gap-2\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\",\"children\":\"Hard\"}]}],[\"$\",\"h1\",null,{\"className\":\"mt-3 text-3xl font-bold tracking-tight\",\"children\":[\"Design Excel Sum Formula\",\" — \",\"Python\"]}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-muted-foreground\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/problems/design-excel-sum-formula\",\"className\":\"text-primary hover:underline\",\"children\":\"Full explanation\"}],\" · \",\"Time \",\"set: O((r * c)^2) get: O(1) sum: O((r * c)^2)\",\" · Space \",\"O(r * c)\"]}],[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L1e\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"design-excel-sum-formula.cpp\",\"code\":\"$1f\",\"sourcePath\":\"C++/design-excel-sum-formula.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"design-excel-sum-formula.py\",\"code\":\"$20\",\"sourcePath\":\"Python/design-excel-sum-formula.py\"}},\"defaultLang\":\"python\"}]}]]}]\n1b:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n21:I[27201,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"IconMark\"]\n18:null\n1d:[[\"$\",\"title\",\"0\",{\"children\":\"Design Excel Sum Formula Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Python solution for Design Excel Sum Formula (LeetCode #631). Time set: O((r * c)^2) get: O(1) sum: O((r * c)^2), space O(r * c).\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"Design Excel Sum Formula python,Design Excel Sum Formula Python,python leetcode\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://algoforge.dev/problems/design-excel-sum-formula/python\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"Design Excel Sum Formula Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"Python solution for Design Excel Sum Formula (LeetCode #631). Time set: O((r * c)^2) get: O(1) sum: O((r * c)^2), space O(r * c).\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:url\",\"content\":\"https://algoforge.dev/problems/design-excel-sum-formula/python\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:site_name\",\"content\":\"AlgoForge\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:image:alt\",\"content\":\"Design Excel Sum Formula Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"13\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:title\",\"content\":\"Design Excel Sum Formula Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"15\",{\"name\":\"twitter:description\",\"content\":\"Python solution for Design Excel Sum Formula (LeetCode #631). Time set: O((r * c)^2) get: O(1) sum: O((r * c)^2), space O(r * c).\"}],[\"$\",\"meta\",\"16\",{\"name\":\"twitter:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"link\",\"17\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.2vob68tjqpejf.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"link\",\"18\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\"}],[\"$\",\"$L21\",\"19\",{}]]\n","/problems/$d$slug/$d$lang/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[522016,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"\"]\n3:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n8:I[897367,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"OutletBoundary\"]\n9:\"$Sreact.suspense\"\n4:Tb0b,// Time:  set: O((r * c)^2)\n//        get: O(1)\n//        sum: O((r * c)^2)\n// Space: O(r * c)\n\nclass Excel {\npublic:\n    Excel(int H, char W) : Exl_(H + 1, vector<int>(W - 'A' + 1)) {\n    }\n    \n    // Time:  O((r * c)^2)\n    void set(int r, char c, int v) {\n        auto col = c - 'A';\n        reset_dependency(r, col);\n        update_others(r, col, v);\n    }\n    \n    // Time:  O(1)\n    int get(int r, char c) {\n        return Exl_[r][c - 'A'];\n    }\n\n    // Time:  O((r * c)^2)\n    int sum(int r, char c, vector<string> strs) {\n        auto col = c - 'A';\n        reset_dependency(r, col);\n        auto result = calc_and_update_dependency(r, col, strs);\n        update_others(r, col, result);\n        return result;\n    }\n\nprivate:\n    // Time:  O(r * c)\n    void reset_dependency(int r, int col) {\n        auto key = r * 26 + col;\n        if (bward_.count(key)) {\n            for (const auto& k : bward_[key]) {\n                fward_[k].erase(key);\n            }\n            bward_.erase(key);\n        }\n    }\n\n    // Time:  O(r * c * l), l is the length of strs\n    int calc_and_update_dependency(int r, int col, const vector<string>& strs) {\n        auto result = 0;\n        for (const auto& s : strs) {\n            int p = s.find(':'), left, right, top, bottom;\n            left = s[0] - 'A';\n            right = s[p + 1] - 'A';\n            top = (p == string::npos) ? stoi(s.substr(1)) : stoi(s.substr(1, p - 1));\n            bottom = stoi(s.substr(p + 2));\n            for (int i = top; i <= bottom; ++i) {\n                for (int j = left; j <= right; ++j) {\n                    result += Exl_[i][j];\n                    ++fward_[i * 26 + j][r * 26 + col];\n                    bward_[r * 26 + col].emplace(i * 26 + j);\n                }\n            }\n        }\n        return result;\n    }\n\n    // Time:  O((r * c)^2)\n    void update_others(int r, int col, int v) {\n        auto prev = Exl_[r][col];\n        Exl_[r][col] = v;\n        queue<pair<int, int>> q;\n        q.emplace(make_pair(r * 26 + col, v - prev));\n        while (!q.empty()) {\n            int key, diff;\n            tie(key, diff) = q.front(), q.pop();\n            if (fward_.count(key)) {\n                for (auto it = fward_[key].begin(); it != fward_[key].end(); ++it) {\n                    int k, count;\n                    tie(k, count) = *it;\n                    q.emplace(make_pair(k, diff * count));\n                    Exl_[k / 26][k % 26] += diff * count;\n                }\n            }\n        }\n    }\n    \n    unordered_map<int, unordered_map<int, int>> fward_;\n    unordered_map<int, unordered_set<int>> bward_;\n    vector<vector<int>> Exl_;\n};\n\n/**\n * Your Excel object will be instantiated and called as such:\n * Excel obj = new Excel(H, W);\n * obj.set(r,c,v);\n * int param_2 = obj.get(r,c);\n * int param_3 = obj.sum(r,c,strs);\n */\n5:T980,# Time:  set: O((r * c)^2)\n#        get: O(1)\n#        sum: O((r * c)^2)\n# Space: O(r * c)\n\nimport collections\n\n\nclass Excel(object):\n\n    def __init__(self, H, W):\n        \"\"\"\n        :type H: int\n        :type W: str\n        \"\"\"\n        self.__exl = [[0 for _ in xrange(ord(W)-ord('A')+1)] \\\n                      for _ in xrange(H+1)]\n        self.__fward = collections.defaultdict(lambda : collections.defaultdict(int))\n        self.__bward = collections.defaultdict(set)\n\n\n    def set(self, r, c, v):\n        \"\"\"\n        :type r: int\n        :type c: str\n        :type v: int\n        :rtype: void\n        \"\"\"\n        self.__reset_dependency(r, c)\n        self.__update_others(r, c, v)\n\n\n    def get(self, r, c):\n        \"\"\"\n        :type r: int\n        :type c: str\n        :rtype: int\n        \"\"\"\n        return self.__exl[r][ord(c) - ord('A')]\n\n\n    def sum(self, r, c, strs):\n        \"\"\"\n        :type r: int\n        :type c: str\n        :type strs: List[str]\n        :rtype: int\n        \"\"\"\n        self.__reset_dependency(r, c)\n        result = self.__calc_and_update_dependency(r, c, strs)\n        self.__update_others(r, c, result)\n        return result\n\n\n    def __reset_dependency(self, r, c):\n        key = (r, c)\n        if key in self.__bward.keys():\n            for k in self.__bward[key]:\n                self.__fward[k].pop(key, None)\n            self.__bward[key] = set()\n\n\n    def __calc_and_update_dependency(self, r, c, strs):\n        result = 0\n        for s in strs:\n            s, e = s.split(':')[0], s.split(':')[1] if ':' in s else s\n            left, right, top, bottom = ord(s[0])-ord('A'), ord(e[0])-ord('A'), int(s[1:]), int(e[1:])\n            for i in xrange(top, bottom+1):\n                for j in xrange(left, right+1):\n                    result += self.__exl[i][j]\n                    self.__fward[(i, chr(ord('A')+j))][(r, c)] += 1\n                    self.__bward[(r, c)].add((i, chr(ord('A')+j)))\n        return result\n\n\n    def __update_others(self, r, c, v):\n        prev = self.__exl[r][ord(c)-ord('A')]\n        self.__exl[r][ord(c)-ord('A')] = v\n        q = collections.deque()\n        q.append(((r, c), v-prev))\n        while q:\n            key, diff = q.popleft()\n            if key in self.__fward:\n                for k, count in self.__fward[key].iteritems():\n                    q.append((k, diff*count))\n                    self.__exl[k[0]][ord(k[1])-ord('A')] += diff*count\n\n\n\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\