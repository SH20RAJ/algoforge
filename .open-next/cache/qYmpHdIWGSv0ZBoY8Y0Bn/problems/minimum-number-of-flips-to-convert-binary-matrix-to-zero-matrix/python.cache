        }\\n        return -1;\\n    }\\n};\\n\"])</script><script>self.__next_f.push([1,\"20:T44b,# Time:  O((m * n) * 2^(m * n))\\n# Space: O((m * n) * 2^(m * n))\\n\\nimport collections\\n\\n\\nclass Solution(object):\\n    def minFlips(self, mat):\\n        \\\"\\\"\\\"\\n        :type mat: List[List[int]]\\n        :rtype: int\\n        \\\"\\\"\\\"\\n        directions = [(0, 0), (0, 1), (1, 0), (0, -1), (-1, 0)]\\n        start = sum(val \\u003c\\u003c r*len(mat[0])+c for r, row in enumerate(mat) for c, val in enumerate(row))\\n        q = collections.deque([(start, 0)])\\n        lookup = {start}\\n        while q:\\n            state, step = q.popleft()\\n            if not state:\\n                return step\\n            for r in xrange(len(mat)):\\n                for c in xrange(len(mat[0])):\\n                    new_state = state\\n                    for dr, dc in directions:\\n                        nr, nc = r+dr, c+dc\\n                        if 0 \\u003c= nr \\u003c len(mat) and 0 \\u003c= nc \\u003c len(mat[0]):\\n                            new_state ^= 1 \\u003c\\u003c nr*len(mat[0])+nc\\n                    if new_state in lookup:\\n                        continue\\n                    lookup.add(new_state)\\n                    q.append((new_state, step+1))\\n        return -1\\n\"])</script><script>self.__next_f.push([1,\"15:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"container-af py-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"nav\\\",null,{\\\"aria-label\\\":\\\"Breadcrumb\\\",\\\"className\\\":\\\"text-sm text-muted-foreground\\\",\\\"children\\\":[[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"BreadcrumbList\\\\\\\",\\\\\\\"itemListElement\\\\\\\":[{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":1,\\\\\\\"name\\\\\\\":\\\\\\\"Home\\\\\\\",\\