\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n1e:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n1f:T5d8,// Time:  O((m * n) * 2^(m * n))\n// Space: O((m * n) * 2^(m * n))\n\nclass Solution {\npublic:\n    int minFlips(vector<vector<int>>& mat) {\n        static const vector<pair<int, int>> directions{{0, 0}, {0, 1}, {1, 0}, {0, -1}, {-1, 0}};\n        int start = 0;\n        for (int r = 0; r < mat.size(); ++r) {\n            for (int c = 0; c < mat[0].size(); ++c) {\n                start |= mat[r][c] << r * mat[0].size() + c;\n            }\n        }\n        queue<pair<int, int>> q({{start, 0}});\n        unordered_set<int> lookup = {start};\n        while (!q.empty()) {\n            const auto [state, step] = q.front(); q.pop();\n            if (!state) {\n                return step;\n            }\n            for (int r = 0; r < mat.size(); ++r) {\n                for (int c = 0; c < mat[0].size(); ++c) {\n                    int new_state = state;\n                    for (const auto& [dr, dc] : directions) {\n                        const auto& [nr, nc] = make_pair(r + dr, c + dc);\n                        if (0 <= nr && nr < mat.size() &&\n                            0 <= nc && nc < mat[0].size()) {\n                            new_state ^= 1 << nr * mat[0].size() + nc;\n                        }\n                    }\n                    if (lookup.count(new_state)) {\n                        continue;\n                    }\n                    lookup.emplace(new_state);\n                    q.emplace(new_state, step + 1);\n                 }\n            }\n        }\n        return -1;\n    }\n};\n20:T44b,# Time:  O((m * n) * 2^(m * n))\n# Space: O((m * n) * 2^(m * n))\n\nimport collections\n\n\nclass Solution(object):\n    def minFlips(self, mat):\n        \"\"\"\n        :type mat: List[List[int]]\n        :rtype: int\n        \"\"\"\n        directions = [(0, 0), (0, 1), (1, 0), (0, -1), (-1, 0)]\n        start = sum(val << r*len(mat[0])+c for r, row in enumerate(mat) for c, val in enumerate(row))\n        q = collections.deque([(start, 0)])\n        lookup = {start}\n        while q:\n            state, step = q.popleft()\n            if not state:\n                return step\n            for r in xrange(len(mat)):\n                for c in xrange(len(mat[0])):\n                    new_state = state\n                    for dr, dc in directions:\n                        nr, nc = r+dr, c+dc\n                        if 0 <= nr < len(mat) and 0 <= nc < len(mat[0]):\n                            new_state ^= 1 << nr*len(mat[0])+nc\n                    if new_state in lookup:\n                        continue\n                    lookup.add(new_state)\n                    q.append((new_state, step+1))\n        return -1\n15:[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Minimum Number of Flips to Convert Binary Matrix to Zero Matrix\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/minimum-number-of-flips-to-convert-binary-matrix-to-zero-matrix\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"Python\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/minimum-number-of-fli