tion\\\":5,\\\"text\\\":\\\"State time and space complexity aloud\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":6,\\\"text\\\":\\\"Compare with the AlgoForge reference solution\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":7,\\\"text\\\":\\\"Schedule a revision session\\\"}]}\"}}],[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Query Kth Smallest Trimmed Number\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/query-kth-smallest-trimmed-number\\\"}]}\"}}],\"$L1e\"]}],\"$L1f\"]}]\n20:I[56303,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"BookmarkButton\"]\n21:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"CodeTabs\"]\n1e:[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/query-kth-smallest-trimmed-number\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"Query Kth Smallest Trimmed Number\"}]]}]]}]\n22:Tdca,// Time:  O(q + n * t)\n// Space: O(t + n + q)\n\n// radix sort\nclass Solution {\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums, vector<vector<int>>& queries) {\n        int max_t = 0;\n        for (int i = 0; i < size(queries); ++i) {\n            max_t = max(max_t, queries[i][1]);\n        }\n        vector<vector<pair<int, int>>> lookup(max_t + 1);\n        for (int i = 0; i < size(queries); ++i) {\n            lookup[queries[i][1]].emplace_back(queries[i][0], i);\n        }\n        vector<int> idxs(size(nums));\n        iota(begin(idxs), end(idxs), 0);\n        vector<int> result(size(queries));\n        for (int l = 1; l <= max_t; ++l) {\n            vector<int> cnt(10);\n            for (int i = 0; i < size(idxs); ++i) {\n                const int d = nums[idxs[i]][size(nums[idxs[i]]) - l]- '0';\n                ++cnt[d];\n            }\n            for (int d = 0; d < 9; ++d) {\n                cnt[d + 1] += cnt[d];\n            }\n            vector<int> new_idxs(size(nums));\n            for (int i = size(idxs) - 1; i >= 0; --i) {\n                const int d = nums[idxs[i]][size(nums[idxs[i]]) - l] - '0';\n                --cnt[d];\n                new_idxs[cnt[d]] = idxs[i];\n            }\n            idxs = move(new_idxs);\n            for (const auto& [k, i] : lookup[l]) {\n                result[i] = idxs[k - 1];\n            }\n        }\n        return result;\n    }\n};\n\n// Time:  O(q * n * t) on average\n// Space: O(n + q)\n// quick select\nclass Solution2 {\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums, vector<vector<int>>& queries) {\n        vector<int> idxs(size(nums));\n        iota(begin(idxs), end(idxs), 0);\n        vector<int> result;\n        for (const auto& q : queries) {\n            nth_element(begin(idxs), begin(idxs) + (q[0] - 1), end(idxs),\n                        [&](const auto& a, const auto& b) {\n                            const int cmp = nums[a].compare(size(nums[a]) - q[1], string::npos,\n                                                            nums[b], size(nums[b]) - q[1], string::npos);\n                            return cmp ? cmp < 0 : a < b;\n                        }\n            );\n            result.emplace_back(idxs[q[0] - 1]);\n        }\n        return result;\n    }\n};\n\n// Time:  O(q + nlogn * t)\n// Space: O(t + n + q)\n// sort\nclass Solution3 {\npublic:\n    vector<int> smallestTrimmedNumbers(vector<string>& nums, vector<vector<int>>& queries) {\n        int max_t = 0;\n        for (int i = 0; i < size(queries); ++i) {\n            max_t = max(max_t, queries[i][1]);\n        }\n        vector<vector<pair<int, int>>> lookup(max_t + 1);\n        for (int i = 0; i < size(queries); ++i) {\n            lookup[queries[i][1]].emplace_back(queries[i][0], i);\n        }\n        vector<int> idxs(size(nums));\n        iota(begin(idxs), end(idxs), 0);\n        vector<int> result(size(queries));\n        for (int t = 1; t <= max_t; ++t) {\n            if (empty(lookup[t])) {\n                continue;\n            }\n            sort(begin(idxs), end(idxs),\n                       [&](const auto& a, const auto& b) {\n                           const int cmp = nums[a].compare(size(nums[a]) - t, string::npos,\n                                                           nums[b], size(nums[b]) - t, string::npos);\n                           return cmp ? cmp < 0 : a < b;\n                       }\n            );\n            for (const auto& [k, i] : lookup[t]) {\n                result[i] = idxs[k - 1];\n            }\n        }\n        return result;\n    }\n};\n23:Tf06,# Time:  O(q + n * t)\n# Space: O(t + n + q)\n\n# radix sort\nclass Solution(object):\n    def smallestTrimmedNumbers(self, nums, queries):\n        \"\"\"\n        :type nums: List[str]\n        :type queries: List[List[int]]\n        :rtype: List[int]\n        \"\"\"\n        max_t = max(t for _, t in queries)\n        lookup = [[] for _ in xrange(max_t+1)]\n        for i, (k, t) in enumerate(queries):\n            lookup[t].append((k, i))\n        result = [0]*len(queries)\n        idxs = range(len(nums))\n        for l in xrange(1, max_t+1):\n            cnt = [0]*10\n            for i in idxs:\n                d = int(nums[i][-l])\n                cnt[d] += 1\n            for d in xrange(9):\n                cnt[d+1] += cnt[d]\n            new_idxs = [0]*len(nums)\n            for i in reversed(idxs):\n                d = int(nums[i][-l])\n                cnt[d] -= 1\n                new_idxs[cnt[d]] = i\n            idxs = new_idxs\n            for k, i in lookup[l]:\n                result[i] = idxs[k-1]\n        return result\n\n            \n# Time:  O(q * n * t) on average\n# Space: O(n + q)\nimport random\n\n\n# quick select\nclass Solution2(object):\n    def smallestTrimmedNumbers(self, nums, queries):\n        \"\"\"\n        :type nums: List[str]\n        :type queries: List[List[int]]\n        :rtype: List[int]\n        \"\"\"\n        def nth_element(nums, n, compare=lambda a, b: a < b):\n            def tri_partition(nums, left, right, target, compare):\n                mid = left\n                while mid <= right:\n                    if nums[mid] == target:\n                        mid += 1\n                    elif compare(nums[mid], target):\n                        nums[left], nums[mid] = nums[mid], nums[left]\n                        left += 1\n                        mid += 1\n                    else:\n                        nums[mid], nums[right] = nums[right], nums[mid]\n                        right -= 1\n                return left, right\n\n            left, right = 0, len(nums)-1\n            while left <= right:\n                pivot_idx = random.randint(left, right)\n                pivot_left, pivot_right = tri_partition(nums, left, right, nums[pivot_idx], compare)\n                if pivot_left <= n <= pivot_right:\n                    return\n                elif pivot_left > n:\n                    right = pivot_left-1\n                else:  # pivot_right < n.\n                    left = pivot_right+1\n\n        def compare(a, b):\n            for i in xrange(len(nums[a])-t, len(nums[a])):\n                if nums[a][i] < nums[b][i]:\n                    return True\n                if nums[a][i] > nums[b][i]:\n                    return False\n            return cmp(a, b) < 0\n\n        result = []\n        idxs = range(len(nums))\n        for k, t in queries:\n            nth_element(idxs, k-1, compare=compare)\n            result.append(idxs[k-1])\n        return result\n\n\n# Time:  O(q + nlogn * t)\n# Space: O(t + n + q)\n# sort\nclass Solution3(object):\n    def smallestTrimmedNumbers(self, nums, queries):\n        \"\"\"\n        :type nums: List[str]\n        :type queries: List[List[int]]\n        :rtype: List[int]\n        \"\"\"\n        def compare(a, b):\n            for i in xrange(len(nums[a])-t, len(nums[a])):\n                if nums[a][i] < nums[b][i]:\n                    return -1\n                if nums[a][i] > nums[b][i]:\n                    return 1\n            return cmp(a, b)\n\n        max_t = max(t for _, t in queries)\n        lookup = [[] for _ in xrange(max_t+1)]\n        for i, (k, t) in enumerate(queries):\n            lookup[t].append((k, i))\n        result = [0]*len(queries)\n        idxs = range(len(nums))\n        for t in xrange(1, max_t+1):\n            if not lookup[t]:\n                continue\n            idxs.sort(cmp=compare)\n            for k, i in lookup[t]:\n                result[i] = idxs[k-1]\n        return result\n1f:[\"$\",\"div\",null,{\"className\":\"mt-6 grid lg:grid-cols-[1fr_280px] gap-10\",\"children\":[[\"$\",\"article\",null,{\"children\":[[\"$\",\"header\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-wrap items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-sm text-muted-foreground tabular-nums\",\"children\":[\"#\",2343]}],[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-medium/15 text-medium\",\"children\":\"Medium\"}],false,[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":[\"~\",35,\" min\"]}]]}],[\"$\",\"h1\",null,{\"className\":\"text-3xl md:text-4xl font-bold tracking-tight\",\"children\":\"Query Kth Smallest Trimmed Number\"}],[\"$\",\"p\",null,{\"className\":\"text-muted-foreground max-w-2xl\",\"children\":[\"Time \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O(q + n * t)\"}],\" · \",\"Space \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O(t + n + q)\"}],\" · \",[\"$\",\"a\",null,{\"href\":\"https://leetcode.com/problems/query-kth-smallest-trimmed-number/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-primary underline-offset-2 hover:underline\",\"children\":\"Official statement on LeetCode\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[[\"$\",\"$L3\",\"sort\",{\"href\":\"/topics/sort\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-primary/15 text-primary\",\"children\":\"sort\"}]}]],[[\"$\",\"$L3\",\"sort\",{\"href\":\"/patterns/sort\",\"children\":[\"$\"