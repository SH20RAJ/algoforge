\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Yes — as a Medium problem it is a solid practice target. Pair it with related problems in the same pattern family for spaced repetition.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Where can I read the official statement?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Open the official LeetCode page for constraints and examples: https://leetcode.com/problems/query-kth-smallest-trimmed-number/\\\"}}]}\"])</script><script>self.__next_f.push([1,\"14:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"container-af py-8\\\",\\\"children\\\":[[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"Article\\\\\\\",\\\\\\\"headline\\\\\\\":\\\\\\\"Query Kth Smallest Trimmed Number\\\\\\\",\\\\\\\"description\\\\\\\":\\\\\\\"Original Medium explanation for Query Kth Smallest Trimmed Number (LeetCode #2343). Pattern: sort. Time O(q + n * t), space O(t + n + q). Multi-language solutions and interview tips.\\\\\\\",\\\\\\\"url\\\\\\\":\\\\\\\"https://algoforge.dev/problems/query-kth-smallest-trimmed-number\\\\\\\",\\\\\\\"author\\\\\\\":{\\\\\\\"@type\\\\\\\":\\\\\\\"Organization\\\\\\\",\\\\\\\"name\\\\\\\":\\\\\\\"AlgoForge\\\\\\\"},\\\\\\\"publisher\\\\\\\":{\\\\\\\"@type\\\\\\\":\\\\\\\"Organization\\\\\\\",\\\\\\\"name\\\\\\\":\\\\\\\"AlgoForge\\\\\\\"},\\\\\\\"datePublished\\\\\\\":\\\\\\\"2026-01-01\\\\\\\",\\\\\\\"dateModified\\\\\\\":\\\\\\\"2026-07-17\\\\\\\"}\\\"}}],[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$1d\\\"}}],[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"HowTo\\\\\\\",\\\\\\\"name\\\\\\\":\\\\\\\"How to solve Query Kth Smallest Trimmed Number\\\\\\\",\\\\\\\"description\\\\\\\":\\\\\\\"Original Medium explanation for Query Kth Smallest Trimmed Number (LeetCode #2343). Pattern: sort. Time O(q + n * t), space O(t + n + q). Multi-language solutions and interview tips.\\\\\\\",\\\\\\\"step\\\\\\\":[{\\\\\\\"@type\\\\\\\":\\\\\\\"HowToStep\\\\\\\",\\\\\\\"position\\\\\\\":1,\\\\\\\"text\\\\\\\":\\\\\\\"Read the official problem statement on LeetCode\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"HowToStep\\\\\\\",\\\\\\\"position\\\\\\\":2,\\\\\\\"text\\\\\\\":\\\\\\\"Solve on paper / whiteboard first\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"HowToStep\\\\\\\",\\\\\\\"position\\\\\\\":3,\\\\\\\"text\\\\\\\":\\\\\\\"Implement the sort and radix sort approach\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"HowToStep\\\\\\\",\\\\\\\"position\\\\\\\":4,\\\\\\\"text\\\\\\\":\\\\\\\"Verify edge cases from the checklist\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"HowToStep\\\\\\\",\\\\\\\"position\\\\\\\":5,\\\\\\\"text\\\\\\\":\\\\\\\"State time and space complexity aloud\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"HowToStep\\\\\\\",\\\\\\\"position\\\\\\\":6,\\\\\\\"text\\\\\\\":\\\\\\\"Compare with the AlgoForge reference solution\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"HowToStep\\\\\\\",\\\\\\\"position\\\\\\\":7,\\\\\\\"text\\\\\\\":\\\\\\\"Schedule a revision session\\\\\\\"}]}\\\"}}],[\\\"$\\\",\\\"nav\\\",null,{\\\"aria-label\\\":\\\"Breadcrumb\\\",\\\"className\\\":\\\"text-sm text-muted-foreground\\\",\\\"children\\\":[[\\\"$\\\",\\\"script\\\",null,{\\\"type\\\":\\\"application/ld+json\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"{\\\\\\\"@context\\\\\\\":\\\\\\\"https://schema.org\\\\\\\",\\\\\\\"@type\\\\\\\":\\\\\\\"BreadcrumbList\\\\\\\",\\\\\\\"itemListElement\\\\\\\":[{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":1,\\\\\\\"name\\\\\\\":\\\\\\\"Home\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://algoforge.dev/\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":2,\\\\\\\"name\\\\\\\":\\\\\\\"Problems\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://algoforge.dev/problems\\\\\\\"},{\\\\\\\"@type\\\\\\\":\\\\\\\"ListItem\\\\\\\",\\\\\\\"position\\\\\\\":3,\\\\\\\"name\\\\\\\":\\\\\\\"Query Kth Smallest Trimmed Number\\\\\\\",\\\\\\\"item\\\\\\\":\\\\\\\"https://algoforge.dev/problems/query-kth-smallest-trimmed-number\\\\\\\"}]}\\\"}}],\\\"$L1e\\\"]}],\\\"$L1f\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"20:I[56303,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\",\\\"/_next/static/chunks/259rkrk9l2f9c.js\\\"],\\\"BookmarkButton\\\"]\\n21:I[705747,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\",\\\"/_next/static/chunks/259rkrk9l2f9c.js\\\"],\\\"CodeTabs\\\"]\\n1e:[\\\"$\\\",\\\"ol\\\",null,{\\\"className\\\":\\\"flex flex-wrap items-center gap-1.5\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"/\\\",{\\\"className\\\":\\\"flex items-center gap-1.5\\\",\\\"children\\\":[false,[\\\"$\\\",\\\"$L3\\\",null,{\\\"href\\\":\\\"/\\\",\\\"className\\\":\\\"hover:text-primary transition-colors\\\",\\\"children\\\":\\\"Home\\\"}]]}],[\\\"$\\\",\\\"li\\\",\\\"/problems\\\",{\\\"className\\\":\\\"flex items-center gap-1.5\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"aria-hidden\\\":true,\\\"className\\\":\\\"text-border\\\",\\\"children\\\":\\\"/\\\"}],[\\\"$\\\",\\\"$L3\\\",null,{\\\"href\\\":\\\"/problems\\\",\\\"className\\\":\\\"hover:text-primary transition-colors\\\",\\\"children\\\":\\\"Problems\\\"}]]}],[\\\"$\\\",\\\"li\\\",\\\"/problems/query-kth-smallest-trimmed-number\\\",{\\\"className\\\":\\\"flex items-center gap-1.5\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"aria-hidden\\\":true,\\\"className\\\":\\\"text-border\\\",\\\"children\\\":\\\"/\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-foreground font-medium\\\",\\\"aria-current\\\":\\\"page\\\",\\\"children\\\":\\\"Query Kth Smallest Trimmed Number\\\"}]]}]]}]\\n22:Tdca,\"])</script><script>self.__next_f.push([1,\"// Time:  O(q + n * t)\\n// Space: O(t + n + q)\\n\\n// radix sort\\nclass Solution {\\npublic:\\n    vector\\u003cint\\u003e smallestTrimmedNumbers(vector\\u003cstring\\u003e\\u0026 nums, vector\\u003cvector\\u003cint\\u003e\\u003e\\u0026 queries) {\\n        int max_t = 0;\\n        for (int i = 0; i \\u003c size(queries); ++i) {\\n            max_t = max(max_t, queries[i][1]);\\n        }\\n        vector\\u003cvector\\u003cpair\\u003cint, int\\u003e\\u003e\\u003e lookup(max_t + 1);\\n        for (int i = 0; i \\u003c size(queries); ++i) {\\n            lookup[queries[i][1]].emplace_back(queries[i][0], i);\\n        }\\n        vector\\u003cint\\u003e idxs(size(nums));\\n        iota(begin(idxs), end(idxs), 0);\\n        vector\\u003cint\\u003e result(size(queries));\\n        for (int l = 1; l \\u003c= max_t; ++l) {\\n            vector\\u003cint\\u003e cnt(10);\\n            for (int i = 0; i \\u003c size(idxs); ++i) {\\n                const int d = nums[idxs[i]][size(nums[idxs[i]]) - l]- '0';\\n                ++cnt[d];\\n            }\\n            for (int d = 0; d \\u003c 9; ++d) {\\n                cnt[d + 1] += cnt[d];\\n            }\\n            vector\\u003cint\\u003e new_idxs(size(nums));\\n            for (int i = size(idxs) - 1; i \\u003e= 0; --i) {\\n                const int d = nums[idxs[i]][size(nums[idxs[i]]) - l] - '0';\\n                --cnt[d];\\n                new_idxs[cnt[d]] = idxs[i];\\n            }\\n            idxs = move(new_idxs);\\n            for (const auto\\u0026 [k, i] : lookup[l]) {\\n                result[i] = idxs[k - 1];\\n            }\\n        }\\n        return result;\\n    }\\n};\\n\\n// Time:  O(q * n * t) on average\\n// Space: O(n + q)\\n// quick select\\nclass Solution2 {\\npublic:\\n    vector\\u003cint\\u003e smallestTrimmedNumbers(vector\\u003cstring\\u003e\\u0026 nums, vector\\u003cvector\\u003cint\\u003e\\u003e\\u0026 queries) {\\n        vector\\u003cint\\u003e idxs(size(nums));\\n        iota(begin(idxs), end(idxs), 0);\\n        vector\\u003cint\\u003e result;\\n        for (const auto\\u0026 q : queries) {\\n            nth_element(begin(idxs), begin(idxs) + (q[0] - 1), end(idxs),\\n                        [\\u0026](const auto\\u0026 a, const auto\\u0026 b) {\\n                            const int cmp = nums[a].compare(size(nums[a]) - q[1], string::npos,\\n                                                            nums[b], size(nums[b]) - q[1], string::npos);\\n                            return cmp ? cmp \\u003c 0 : a \\u003c b;\\n                        }\\n            );\\n            result.emplace_back(idxs[q[0] - 1]);\\n        }\\n        return result;\\n    }\\n};\\n\\n// Time:  O(q + nlogn * t)\\n// Space: O(t + n + q)\\n// sort\\nclass Solution3 {\\npublic:\\n    vector\\u003cint\\u003e smallestTrimmedNumbers(vector\\u003cstring\\u003e\\u0026 nums, vector\\u003cvector\\u003cint\\u003e\\u003e\\u0026 queries) {\\n        int max_t = 0;\\n        for (int i = 0; i \\u003c size(queries); ++i) {\\n            max_t = max(max_t, queries[i][1]);\\n        }\\n        vector\\u003cvector\\u003cpair\\u003cint, int\\u003e\\u003e\\u003e lookup(max_t + 1);\\n        for (int i = 0; i \\u003c size(queries); ++i) {\\n            lookup[queries[i][1]].emplace_back(queries[i][0], i);\\n        }\\n        vector\\u003cint\\u003e idxs(size(nums));\\n        iota(begin(idxs), end(idxs), 0);\\n        vector\\u003cint\\u003e result(size(queries));\\n        for (int t = 1; t \\u003c= max_t; ++t) {\\n            if (empty(lookup[t])) {\\n                continue;\\n            }\\n            sort(begin(idxs), end(idxs),\\n                       [\\u0026](const auto\\u0026 a, const auto\\u0026 b) {\\n                           const int cmp = nums[a].compare(size(nums[a]) - t, string::npos,\\n                                                           nums[b], size(nums[b]) - t, string::npos);\\n                           return cmp ? cmp \\u003c 0 : a \\u003c b;\\n                       }\\n            );\\n            for (const auto\\u0026 [k, i] : lookup[t]) {\\n                result[i] = idxs[k - 1];\\n            }\\n        }\\n        return result;\\n    }\\n};\\n\"])</script><script>self.__next_f.push([1,\"23:Tf06,\"])</script><script>self.__next_f.push([1,\"# Time:  O(q + n * t)\\n# Space: O(t + n + q)\\n\\n# radix sort\\nclass Solution(object):\\n    def smallestTrimmedNumbers(self, nums, queries):\\n        \\\"\\\"\\\"\\n        :type nums: List[str]\\n        :type queries: List[List[int]]\\n        :rtype: List[int]\\n        \\\"\\\"\\\"\\n        max_t = max(t for _, t in queries)\\n        lookup = [[] for _ in xrange(max_t+1)]\\n        for i, (k, t) in enumerate(queries):\\n            lookup[t].append((k, i))\\n        result = [0]*len(queries)\\n        idxs = range(len(nums))\\n        for l in xrange(1, max_t+1):\\n            cnt = [0]*10\\n            for i in idxs:\\n                d = int(nums[i][-l])\\n                cnt[d] += 1\\n            for d in xrange(9):\\n                cnt[d+1] += cnt[d]\\n            new_idxs = [0]*len(nums)\\n            for i in reversed(idxs):\\n                d = int(nums[i][-l])\\n                cnt[d] -= 1\\n                new_idxs[cnt[d]] = i\\n            idxs = new_idxs\\n            for k, i in lookup[l]:\\n                result[i] = idxs[k-1]\\n        return result\\n\\n            \\n# Time:  O(q * n * t) on average\\n# Space: O(n + q)\\nimport random\\n\\n\\n# quick select\\nclass Solution2(object):\\n    def smallestTrimmedNumbers(self, nums, queries):\\n        \\\"\\\"\\\"\\n        :type nums: List[str]\\n        :type queries: List[List[int]]\\n        :rtype: List[int]\\n        \\\"\\\"\\\"\\n        def nth_element(nums, n, compare=lambda a, b: a \\u003c b):\\n            def tri_partition(nums, left, right, target, compare):\\n                mid = left\\n                while mid \\u003c= right:\\n                    if nums[mid] == target:\\n                        mid += 1\\n                    elif compare(nums[mid], target):\\n                        nums[left], nums[mid] = nums[mid], nums[left]\\n                        left += 1\\n                        mid += 1\\n                    else:\\n                        nums[mid], nums[right] = nums[right], nums[mid]\\n                        right -= 1\\n                return left, right\\n\\n            left, right = 0, len(nums)-1\\n            while left \\u003c= right:\\n                pivot_idx = random.randint(left, right)\\n                pivot_left, pivot_right = tri_partition(nums, left, right, nums[pivot_idx], compare)\\n                if pivot_left \\u003c= n \\u003c= pivot_right:\\n                    return\\n                elif pivot_left \\u003e n:\\n                    right = pivot_left-1\\n                else:  # pivot_right \\u003c n.\\n                    left = pivot_right+1\\n\\n        def compare(a, b):\\n            for i in xrange(len(nums[a])-t, len(nums[a])):\\n                if nums[a][i] \\u003c nums[b][i]:\\n                    return True\\n                if nums[a][i] \\u003e nums[b][i]:\\n                    return False\\n            return cmp(a, b) \\u003c 0\\n\\n        result = []\\n        idxs = range(len(nums))\\n        for k, t in queries:\\n            nth_element(idxs, k-1, compare=compare)\\n            result.append(idxs[k-1])\\n        return result\\n\\n\\n# Time:  O(q + nlogn * t)\\n# Space: O(t + n + q)\\n# sort\\nclass Solution3(object):\\n    def smallestTrimmedNumbers(self, nums, queries):\\n        \\\"\\\"\\\"\\n        :type nums: List[str]\\n        :type queries: List[List[int]]\\n        :rtype: List[int]\\n        \\\"\\\"\\\"\\n        def compare(a, b):\\n            for i in xrange(len(nums[a])-t, len(nums[a])):\\n                if nums[a][i] \\u003c nums[b][i]:\\n                    return -1\\n                if nums[a][i] \\u003e nums[b][i]:\\n                    return 1\\n            return cmp(a, b)\\n\\n        max_t = max(t for _, t in queries)\\n        lookup = [[] for _ in xrange(max_t+1)]\\n        for i, (k, t) in enumerate(queries):\\n            lookup[t].append((k, i))\\n        result = [0]*len(queries)\\n        idxs = range(len(nums))\\n        for t in xrange(1, max_t+1):\\n            if not lookup[t]:\\n                continue\\n            idxs.sort(cmp=compare)\\n            for k, i in lookup[t]:\\n                result[i] = idxs[k-1]\\n        return result\\n\"])</script><script>self.__next_f.push([1,\"1f:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-6 grid lg:grid-cols-[1fr_280px] gap-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"article\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"header\\\",null,{\\\"className\\\":\\\"space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-sm text-muted-foreground tabular-nums\\\",\\\"children\\\":[\\\"#\\\",2343]}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-medium/15 text-medium\\\",\\\"children\\\":\\\"Medium\\\"}],false,[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":[\\\"~\\\",35,\\\" min\\\"]}]]}],[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-tight\\\",\\\"children\\\":\\\"Query Kth Smallest Trimmed Number\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-muted-foreground max-w-2xl\\\",\\\"children\\\":[\\\"Time \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"className\\\":\\\"text-foreground\\\",\\\"children\\\":\\\"O(q + n * t)\\\"}],\\\" · \\\",\\\"Space \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"className\\\":\\\"text-foreground\\\",\\\"children\\\":\\\"O(t + n + q)\\\"}],\\\" · \\\",[\\\"$\\\",\\\"a\\\",null,{\\\"href\\\":\\\"https://leetcode.com/problems/query-kth-smallest-trimmed-number/\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"text-primary underline-offset-2 hover:underline\\\",\\\"children\\\":\\\"Official statement on LeetCode\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap gap-2\\\",\\\"children\\\":[[[\\\"$\\\",\\\"$L3\\\",\\\"sort\\\",{\\\"href\\\":\\\"/topics/sort\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-primary/15 text-primary\\\",\\\"children\\\":\\\"sort\\\"}]}]],[[\\\"$\\\",\\\"$L3\\\",\\\"sort\\\",{\\\"href\\\":\\\"/patterns/sort\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":\\\"sort\\\"}]}],[\\\"$\\\",\\\"$L3\\\",\\\"radix-sort\\\",{\\\"href\\\":\\\"/patterns/radix-sort\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":\\\"radix sort\\\"}]}]],[]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap gap-2 pt-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L20\\\",null,{\\\"slug\\\":\\\"query-kth-smallest-trimmed-number\\\"}],[[\\\"$\\\",\\\"$L3\\\",\\\"cpp\\\",{\\\"href\\\":\\\"/problems/query-kth-smallest-trimmed-number/cpp\\\",\\\"className\\\":\\\"text-sm text-primary hover:underline\\\",\\\"children\\\":\\\"cpp\\\"}],[\\\"$\\\",\\\"$L3\\\",\\\"python\\\",{\\\"href\\\":\\\"/problems/query-kth-smallest-trimmed-number/python\\\",\\\"className\\\":\\\"text-sm text-primary hover:underline\\\",\\\"children\\\":\\\"python\\\"}]]]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mt-10\\\",\\\"id\\\":\\\"solutions\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold mb-3\\\",\\\"children\\\":\\\"Solutions\\\"}],[\\\"$\\\",\\\"$L21\\\",null,{\\\"solutions\\\":{\\\"cpp\\\":{\\\"language\\\":\\\"C++\\\",\\\"languageSlug\\\":\\\"cpp\\\",\\\"filename\\\":\\\"query-kth-smallest-trimmed-number.cpp\\\",\\\"code\\\":\\\"$22\\\",\\\"sourcePath\\\":\\\"C++/query-kth-smallest-trimmed-number.cpp\\\"},\\\"python\\\":{\\\"language\\\":\\\"Python\\\",\\\"languageSlug\\\":\\\"python\\\",\\\"filename\\\":\\\"query-kth-smallest-trimmed-number.py\\\",\\\"code\\\":\\\"$23\\\",\\\"sourcePath\\\":\\\"Python/query-kth-smallest-trimmed-number.py\\\"}}}]]}],[\\\"$L24\\\",\\\"$L25\\\",\\\"$L26\\\",\\\"$L27\\\",\\\"$L28\\\",\\\"$L29\\\",\\\"$L2a\\\",\\\"$L2b\\\",\\\"$L2c\\\",\\\"$L2d\\\"],\\\"$L2e\\\",\\\"$L2f\\\",\\\"$L30\\\",\\\"$L31\\\",\\\"$L32\\\",\\\"$L33\\\"]}],\\\"$L34\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"3c:I[203221,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\",\\\"/_next/static/chunks/259rkrk9l2f9c.js\\\"],\\\"ConfidenceTracker\\\"]\\n35:T406,\\u003ch2\\u003eWhat is Query Kth Smallest Trimmed Number?\\u003c/h2\\u003e\\n\\u003cp\\u003e\\u003cstrong\\u003eQuery Kth Smallest Trimmed Number\\u003c/strong\\u003e (LeetCode #2343) is a \\u003cstrong\\u003eMedium\\u003c/strong\\u003e problem that primarily trains \\u003cstrong\\u003esort\\u003c/strong\\u003e.\\u003c/p\\u003e\\n\\u003ch3\\u003eHow to think about it\\u003c/h3\\u003e\\n\\u003col\\u003e\\n\\u003cli\\u003e\\u003cstrong\\u003eRestate the goal\\u003c/strong\\u003e in your own words before coding.\\u003c/li\\u003e\\n\\u003cli\\u003eWork a \\u003cstrong\\u003etiny example\\u003c/strong\\u003e by hand so the invariant becomes obvious.\\u003c/li\\u003e\\n\\u003cli\\u003eIdentify the \\u003cstrong\\u003epattern\\u003c/strong\\u003e — this problem aligns with \\u003cstrong\\u003esort and radix sort\\u003c/strong\\u003e.\\u003c/li\\u003e\\n\\u003cli\\u003eOnly then translate the idea into code.\\u003c/li\\u003e\\n\\u003c/ol\\u003e\\n\\u003ch3\\u003eWhy this problem matters\\u003c/h3\\u003e\\n\\u003cp\\u003eIt sits in the sweet spot of interview difficulty: multiple valid approaches, clear trade-offs.\\nOfficial solution notes mention: Sort, Quick Select, Radix Sort.\\u003c/p\\u003e\\n\\u003cblockquote\\u003e\\n\\u003cp\\u003eAlgoForge explanations are original teaching notes. Always open the \\u003ca href=\\\"https://leetcode.com/problems/query-kth-smallest-trimmed-number/\\\"\\u003eofficial problem statement on LeetCode\\u003c/a\\u003e for constraints and examples.\\u003c/p\\u003e\\n\\u003c/blockquote\\u003e\\n24:[\\\"$\\\",\\\"section\\\",\\\"beginner\\\",{\\\"id\\\":\\\"beginner\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Beginner Explanation\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$35\\\"}}]]}]\\n36:T4d7,\\u003ch2\\u003eInterview approach for Query Kth Smallest Trimmed Number\\u003c/h2\\u003e\\n\\u003ch3\\u003eOpening (30–60 seconds)\\u003c/h3\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eClarify inputs/outputs and edge cases (empty input, single element, duplicates, overflow).\\u003c/li\\u003e\\n\\u003cli\\u003eState a \\u003cstrong\\u003ebrute force\\u003c/strong\\u003e so the interviewer knows you can solve it naively.\\u003c/li\\u003e\\n\\u003cli\\u003ePropose the \\u003cstrong\\u003eoptimal direction\\u003c/strong\\u003e tied to \\u003cstrong\\u003esort and radix sort\\u003c/strong\\u003e.\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch3\\u003eCore solution narrative\\u003c/h3\\u003e\\n\\u003col\\u003e\\n\\u003cli\\u003eDefine the \\u003cstrong\\u003estate\\u003c/strong\\u003e you track (pointers, DP cell, set membership, stack top, etc.).\\u003c/li\\u003e\\n\\u003cli\\u003eExplain the \\u003cstrong\\u003etransition\\u003c/strong\\u003e when you process the next element.\\u003c/li\\u003e\\n\\u003cli\\u003eCall out \\u003cstrong\\u003etime\\u003c/strong\\u003e (O(q + n * t)) and \\u003cstrong\\u003espace\\u003c/strong\\u003e (O(t + n + q)) before coding.\\u003c/li\\u003e\\n\\u003cli\\u003eCode cleanly; narrate variable names.\\u003c/li\\u003e\\n\\u003c/ol\\u003e\\n\\u003ch3\\u003eWhat interviewers listen for\\u003c/h3\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eCorrectness on edge cases\\u003c/li\\u003e\\n\\u003cli\\u003eComplexity honesty\\u003c/li\\u003e\\n\\u003cli\\u003eAbility to discuss \\u003cstrong\\u003etrade-offs\\u003c/strong\\u003e (e.g., hash map space vs. sort + two pointers)\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch3\\u003eFollow-up questions they may ask\\u003c/h3\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eCan you solve it with less memory?\\u003c/li\\u003e\\n\\u003cli\\u003eWhat if the input stream is infinite / doesn't fit in RAM?\\u003c/li\\u003e\\n\\u003cli\\u003eHow would tests look for adversarial inputs?\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n25:[\\\"$\\\",\\\"section\\\",\\\"interview\\\",{\\\"id\\\":\\\"interview\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Interview Walkthrough\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$36\\\"}}]]}]\\n26:[\\\"$\\\",\\\"section\\\",\\\"optimized\\\",{\\\"id\\\":\\\"optimized\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Optimized Approach\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003ch2\\u003eOptimized solution notes\\u003c/h2\\u003e\\\\n\\u003cp\\u003eThe reference solutions on AlgoForge target \\u003cstrong\\u003eO(q + n * t)\\u003c/strong\\u003e time and \\u003cstrong\\u003eO(t + n + q)\\u003c/strong\\u003e space.\\u003c/p\\u003e\\\\n\\u003ch3\\u003ePattern focus: sort and radix sort\\u003c/h3\\u003e\\\\n\\u003cp\\u003eUse the pattern as a checklist:\\u003c/p\\u003e\\\\n\\u003cul\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003esort\\u003c/strong\\u003e — confirm the invariant holds after each step\\u003c/li\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eradix sort\\u003c/strong\\u003e — confirm the invariant holds after each step\\u003c/li\\u003e\\\\n\\u003c/ul\\u003e\\\\n\\u003cp\\u003eMultiple methods appear in the source solutions — compare them and explain when each is preferable.\\u003c/p\\u003e\\\\n\\u003ch3\\u003eImplementation tips\\u003c/h3\\u003e\\\\n\\u003cul\\u003e\\\\n\\u003cli\\u003ePrefer readable\"])</script><script>self.__next_f.push([1,\" names over micro-optimizations in interviews.\\u003c/li\\u003e\\\\n\\u003cli\\u003eExtract helpers only when they clarify (e.g., expand-around-center, DFS visit).\\u003c/li\\u003e\\\\n\\u003cli\\u003eAfter AC-level logic, re-scan for off-by-one and null checks.\\u003c/li\\u003e\\\\n\\u003c/ul\\u003e\\\\n\\\"}}]]}]\\n27:[\\\"$\\\",\\\"section\\\",\\\"complexity\\\",{\\\"id\\\":\\\"complexity\\\",\\