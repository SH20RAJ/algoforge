oreground h-9 w-9\" aria-label=\"Toggle theme\"></button></div></div></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Remove Invalid Parentheses\",\"item\":\"https://algoforge.dev/problems/remove-invalid-parentheses\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Python\",\"item\":\"https://algoforge.dev/problems/remove-invalid-parentheses/python\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/remove-invalid-parentheses\">Remove Invalid Parentheses</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">Python</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\">Hard</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Remove Invalid Parentheses<!-- --> — <!-- -->Python</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/remove-invalid-parentheses\">Full explanation</a> · <!-- -->Time <!-- -->O(C(n, c))<!-- --> · Space <!-- -->O(c)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">C++</button><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code># Time:  O(C(n, c)), try out all possible substrings with the minimum c deletion.\n# Space: O(c), the depth is at most c, and it costs n at each depth\n\nclass Solution(object):\n    def removeInvalidParentheses(self, s):\n        &quot;&quot;&quot;\n        :type s: str\n        :rtype: List[str]\n        &quot;&quot;&quot;\n        # Calculate the minimum left and right parantheses to remove\n        def findMinRemove(s):\n            left_removed, right_removed = 0, 0\n            for c in s:\n                if c == &#x27;(&#x27;:\n                    left_removed += 1\n                elif c == &#x27;)&#x27;:\n                    if not left_removed:\n                        right_removed += 1\n                    else:\n                        left_removed -= 1\n            return (left_removed, right_removed)\n\n        # Check whether s is valid or not.\n        def isValid(s):\n            sum = 0\n            for c in s:\n                if c == &#x27;(&#x27;:\n                    sum += 1\n                elif c == &#x27;)&#x27;:\n                    sum -= 1\n                if sum &lt; 0:\n                    return False\n            return sum == 0\n\n        def removeInvalidParenthesesHelper(start, left_removed, right_removed):\n            if left_removed == 0 and right_removed == 0:\n                tmp = &quot;&quot;\n                for i, c in enumerate(s):\n                    if i not in removed:\n                        tmp += c\n                if isValid(tmp):\n                    res.append(tmp)\n                return\n\n            for i in xrange(start, len(s)):\n                if right_removed == 0 and left_removed &gt; 0 and s[i] == &#x27;(&#x27;:\n                    if i == start or s[i] != s[i - 1]:  # Skip duplicated.\n                        removed[i] = True\n                        removeInvalidParenthesesHelper(i + 1, left_removed - 1, right_removed)\n                        del removed[i]\n                elif right_removed &gt; 0 and s[i] == &#x27;)&#x27;:\n                    if i == start or s[i] != s[i - 1]:  # Skip duplicated.\n                        removed[i] = True\n                        removeInvalidParenthesesHelper(i + 1, left_removed, right_removed - 1)\n                        del removed[i]\n\n        res, removed = [], {}\n        (left_removed, right_removed) = findMinRemove(s)\n        removeInvalidParenthesesHelper(0, left_removed, right_removed)\n        return res\n\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">Learn</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/problems\">Problems</a></li><li><a class=\"hover:text-primary\" href=\"/patterns\">Patterns</a></li><li><a class=\"hover:text-primary\" href=\"/roadmaps\">Roadmaps</a></li><li><a class=\"hover:text-primary\" href=\"/blind-75\">Blind 75</a></li><li><a class=\"hover:text-primary\" href=\"/grind-169\">Grind 169</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Interview</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/companies\">Companies</a></li><li><a class=\"hover:text-primary\" href=\"/interview-preparation\">Interview prep</a></li><li><a class=\"hover:text-primary\" href=\"/system-design\">System design</a></li><li><a class=\"hover:text-primary\" href=\"/glossary\">Glossary</a></li><li><a class=\"hover:text-primary\" href=\"/blog\">Blog</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Product</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/pricing\">Pricing</a></li><li><a class=\"hover:text-primary\" href=\"/about\">About</a></li><li><a class=\"hover:text-primary\" href=\"/about/attribution\">Attribution</a></li><li><a class=\"hover:text-primary\" href=\"/sitemap-html\">Sitemap</a></li></ul></div></div><div class=\"border-t border-border\"><div class=\"container-af py-4 flex flex-col sm:flex-row gap-2 justify-between text-xs text-muted-foreground\"><p>© <!-- -->2026<!-- --> <!-- -->AlgoForge<!-- -->. Educational use only.</p><p>Solution code sourced under MIT from<!-- --> <a href=\"https://github.com/kamyu104/LeetCode-Solutions\" class=\"underline hover:text-primary\" rel=\"noopener noreferrer\" target=\"_blank\">kamyu104/LeetCode-Solutions</a>. Explanations are original AlgoForge content.</p></div></div></footer><script src=\"/_next/static/chunks/05kafvajig4wu.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[427423,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\"],\\\"ThemeProvider\\\"]\\n3:I[522016,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\",\\\"/_next/static/chunks/0a2gmow1_jiq0.js\\\"],\\\"\\\"]\\n10:I[168027,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/340fxer6uczx7.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"c\\\":[\\\"\\\",\\\"problems\\\",\\\"remove-invalid-parentheses\\\",\\\"python\\\"],\\\"q\\\":\\\"\\\",\\\"i\\\":false,\\\"f\\\":[[[\\\"\\\",{\\\"children\\\":[\\\"problems\\\",{\\\"children\\\":[[\\\"slug\\\",\\\"remove-invalid-parentheses\\\",\\\"d\\\",null],{\\\"children\\\":[[\\\"lang\\\",\\\"python\\\",\\\"d\\\",null],{\\\"children\\\":[\\\"__PAGE__\\\",{}]}]}]}]},\\\"$undefined\\\",\