\":\"/interview-preparation\",\"className\":\"hover:text-primary\",\"children\":\"Interview prep\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/system-design\",\"className\":\"hover:text-primary\",\"children\":\"System design\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/glossary\",\"className\":\"hover:text-primary\",\"children\":\"Glossary\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/blog\",\"className\":\"hover:text-primary\",\"children\":\"Blog\"}]}]]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-sm mb-3\",\"children\":\"Product\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/pricing\",\"className\":\"hover:text-primary\",\"children\":\"Pricing\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/about\",\"className\":\"hover:text-primary\",\"children\":\"About\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/about/attribution\",\"className\":\"hover:text-primary\",\"children\":\"Attribution\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/sitemap-html\",\"className\":\"hover:text-primary\",\"children\":\"Sitemap\"}]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"border-t border-border\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-af py-4 flex flex-col sm:flex-row gap-2 justify-between text-xs text-muted-foreground\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"© \",2026,\" \",\"AlgoForge\",\". Educational use only.\"]}],[\"$\",\"p\",null,{\"children\":[\"Solution code sourced under MIT from\",\" \",[\"$\",\"a\",null,{\"href\":\"https://github.com/kamyu104/LeetCode-Solutions\",\"className\":\"underline hover:text-primary\",\"rel\":\"noopener noreferrer\",\"target\":\"_blank\",\"children\":\"kamyu104/LeetCode-Solutions\"}],\". Explanations are