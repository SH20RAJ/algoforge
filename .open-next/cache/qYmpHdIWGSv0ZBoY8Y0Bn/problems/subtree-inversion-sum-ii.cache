l\\\",null,{\\\"className\\\":\\\"flex flex-wrap items-center gap-1.5\\\",\\\"children\\\":[[\\\"$\\\",\\\"li\\\",\\\"/\\\",{\\\"className\\\":\\\"flex items-center gap-1.5\\\",\\\"children\\\":[false,[\\\"$\\\",\\\"$L3\\\",null,{\\\"href\\\":\\\"/\\\",\\\"className\\\":\\\"hover:text-primary transition-colors\\\",\\\"children\\\":\\\"Home\\\"}]]}],[\\\"$\\\",\\\"li\\\",\\\"/problems\\\",{\\\"className\\\":\\\"flex items-center gap-1.5\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"aria-hidden\\\":true,\\\"className\\\":\\\"text-border\\\",\\\"children\\\":\\\"/\\\"}],[\\\"$\\\",\\\"$L3\\\",null,{\\\"href\\\":\\\"/problems\\\",\\\"className\\\":\\\"hover:text-primary transition-colors\\\",\\\"children\\\":\\\"Problems\\\"}]]}],[\\\"$\\\",\\\"li\\\",\\\"/problems/subtree-inversion-sum-ii\\\",{\\\"className\\\":\\\"flex items-center gap-1.5\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"aria-hidden\\\":true,\\\"className\\\":\\\"text-border\\\",\\\"children\\\":\\\"/\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-foreground font-medium\\\",\\\"aria-current\\\":\\\"page\\\",\\\"children\\\":\\\"Subtree Inversion Sum II\\\"}]]}]]}]\\n22:T1134,\"])</script><script>self.__next_f.push([1,\"// Time:  O(n * k)\\n// Space: O(n + h * k)\\n\\n// iterative dfs, tree dp\\nclass Solution {\\npublic:\\n    int subtreeInversionSum(vector\\u003cvector\\u003cint\\u003e\\u003e\\u0026 edges, vector\\u003cint\\u003e\\u0026 nums, int k) {\\n        vector\\u003cvector\\u003cint\\u003e\\u003e adj(size(nums));\\n        const auto\\u0026 iter_dfs = [\\u0026]() {\\n            using RET = vector\\u003cvector\\u003cint64_t\\u003e\\u003e;\\n            RET result{};\\n            vector\\u003ctuple\\u003cint, int, int, int, shared_ptr\\u003cRET\\u003e, RET *\\u003e\\u003e stk = {{1, 0, -1, -1, nullptr, \\u0026result}};\\n            while (!empty(stk)) {\\n                const auto [step, u, p, i, new_ret, ret] = stk.back(); stk.pop_back();\\n                if (step == 1) {\\n                    ret-\\u003eassign(2, vector\\u003cint64_t\\u003e(k, nums[u]));\\n                    stk.emplace_back(4, -1, -1, -1, nullptr, ret);\\n                    stk.emplace_back(2, u, p, 0, nullptr, ret);\\n                } else if (step == 2) {\\n                    if (i == size(adj[u])) {\\n                        continue;\\n                    }\\n                    const auto\\u0026 v = adj[u][i];\\n                    stk.emplace_back(2, u, p, i + 1, nullptr, ret);\\n                    if (v == p) {\\n                        continue;\\n                    }\\n                    const auto\\u0026 new_ret = make_shared\\u003cRET\\u003e();\\n                    stk.emplace_back(3, -1, -1, -1, new_ret, ret);\\n                    stk.emplace_back(1, v, u, -1, nullptr, new_ret.get());\\n                } else if (step == 3) {\\n                    auto\\u0026 new_dp1 = (*new_ret)[0], \\u0026new_dp2 = (*new_ret)[1];\\n                    auto\\u0026 dp1 = (*ret)[0], \\u0026dp2 = (*ret)[1];\\n                    for (int i = 0; i \\u003c k / 2; ++i) {\\n                        dp1[i] = max(dp1[i] + new_dp1[(k - 2) - i], dp1[(k - 2) - i] + new_dp1[i]);\\n                        dp2[i] = min(dp2[i] + new_dp2[(k - 2) - i], dp2[(k - 2) - i] + new_dp2[i]);\\n                    }\\n                    for (int i = k / 2; i \\u003c k; ++i) {\\n                        dp1[i] += new_dp1[i];\\n                        dp2[i] += new_dp2[i];\\n                    }\\n                    for (int i = k - 2; i \\u003e= 0; --i) {\\n                        dp1[i] = max(dp1[i], dp1[i + 1]);\\n                        dp2[i] = min(dp2[i], dp2[i + 1]);\\n                    }\\n                } else if (step == 4) {\\n                    auto\\u0026 dp1 = (*ret)[0], \\u0026dp2 = (*ret)[1];\\n                    const auto mx = max(dp1[0], -dp2[k - 1]);\\n                    const auto mn = min(dp2[0], -dp1[k - 1]);\\n                    dp1.insert(begin(dp1), mx); dp1.pop_back();\\n                    dp2.insert(begin(dp2), mn); dp2.pop_back();\\n                }\\n            }\\n            return result[0][0];\\n        };\\n        \\n        for (auto\\u0026 e : edges) {\\n            adj[e[0]].emplace_back(e[1]);\\n            adj[e[1]].emplace_back(e[0]);\\n        }\\n        return iter_dfs();\\n    }\\n};\\n\\n// Time:  O(n * k)\\n// Space: O(n + h * k)\\n// dfs, tree dp\\nclass Solution2 {\\npublic:\\n    int subtreeInversionSum(vector\\u003cvector\\u003cint\\u003e\\u003e\\u0026 edges, vector\\u003cint\\u003e\\u0026 nums, int k) {\\n        vector\\u003cvector\\u003cint\\u003e\\u003e adj(size(nums));\\n        const auto dfs = [\\u0026](this auto\\u0026\\u0026 dfs, int u, int p) -\\u003e pair\\u003cvector\\u003cint64_t\\u003e, vector\\u003cint64_t\\u003e\\u003e {\\n            vector\\u003cint64_t\\u003e dp1(k, nums[u]), dp2(k, nums[u]);\\n            for (const auto\\u0026 v : adj[u]) {\\n                if (v == p) {\\n                    continue;\\n                }\\n                const auto\\u0026 [new_dp1, new_dp2] = dfs(v, u);\\n                for (int i = 0; i \\u003c k / 2; ++i) {\\n                    dp1[i] = max(dp1[i] + new_dp1[(k - 2) - i], dp1[(k - 2) - i] + new_dp1[i]);\\n                    dp2[i] = min(dp2[i] + new_dp2[(k - 2) - i], dp2[(k - 2) - i] + new_dp2[i]);\\n                }\\n                for (int i = k / 2; i \\u003c k; ++i) {\\n                    dp1[i] += new_dp1[i];\\n                    dp2[i] += new_dp2[i];\\n                }\\n                for (int i = k - 2; i \\u003e= 0; --i) {\\n                    dp1[i] = max(dp1[i], dp1[i + 1]);\\n                    dp2[i] = min(dp2[i], dp2[i + 1]);\\n                }\\n            }\\n            const auto mx = max(dp1[0], -dp2[k - 1]);\\n            const auto mn = min(dp2[0], -dp1[k - 1]);\\n            dp1.insert(begin(dp1), mx); dp1.pop_back();\\n            dp2.insert(begin(dp2), mn); dp2.pop_back();\\n            return pair(dp1, dp2);\\n        };\\n        \\n        for (auto\\u0026 e : edges) {\\n            adj[e[0]].emplace_back(e[1]);\\n            adj[e[1]].emplace_back(e[0]);\\n        }\\n        const auto\\u0026 [dp1, _] = dfs(0, -1);\\n        return dp1[0];\\n    }\\n};\\n\"])</script><script>self.__next_f.push([1,\"23:Tdbe,\"])</script><script>self.__next_f.push([1,\"# Time:  O(n * k)\\n# Space: O(n + h * k)\\n\\n# iterative dfs, tree dp\\nclass Solution(object):\\n    def subtreeInversionSum(self, edges, nums, k):\\n        \\\"\\\"\\\"\\n        :type edges: List[List[int]]\\n        :type nums: List[int]\\n        :type k: int\\n        :rtype: int\\n        \\\"\\\"\\\"\\n        def iter_dfs():\\n            result = []\\n            stk = [(1, (0, -1, result))]\\n            while stk:\\n                step, args = stk.pop()\\n                if step == 1:\\n                    u, p, ret = args\\n                    ret[:] = [[nums[u]]*k, [nums[u]]*k]\\n                    stk.append((4, (u, p, ret)))\\n                    stk.append((2, (u, p, 0, ret)))\\n                elif step == 2:\\n                    u, p, i, ret = args\\n                    if i == len(adj[u]):\\n                        continue\\n                    v = adj[u][i]\\n                    stk.append((2, (u, p, i+1, ret)))\\n                    if v == p:\\n                        continue\\n                    new_ret = []\\n                    stk.append((3, (new_ret, ret)))\\n                    stk.append((1, (v, u, new_ret)))\\n                elif step == 3:\\n                    new_ret, ret = args\\n                    new_dp1, new_dp2 = new_ret\\n                    dp1, dp2 = ret\\n                    for i in xrange(k//2):\\n                        dp1[i] = max(dp1[i]+new_dp1[(k-2)-i], dp1[(k-2)-i]+new_dp1[i])\\n                        dp2[i] = min(dp2[i]+new_dp2[(k-2)-i], dp2[(k-2)-i]+new_dp2[i])\\n                    for i in xrange(k//2, k):\\n                        dp1[i] += new_dp1[i]\\n                        dp2[i] += new_dp2[i]\\n                    for i in reversed(xrange(k-1)):\\n                        dp1[i] = max(dp1[i], dp1[i+1])\\n                        dp2[i] = min(dp2[i], dp2[i+1])\\n                elif step == 4:\\n                    u, p, ret = args\\n                    dp1, dp2 = ret\\n                    dp1.insert(0, max(dp1[0], -dp2[-1]))\\n                    dp2.insert(0, min(dp2[0], -dp1[-1]))\\n                    dp1.pop()\\n                    dp2.pop()\\n            return result[0][0]\\n\\n        adj = [[] for _ in xrange(len(nums))]\\n        for u, v in edges:\\n            adj[u].append(v)\\n            adj[v].append(u)\\n        return iter_dfs()\\n\\n\\n# Time:  O(n * k)\\n# Space: O(n + h * k)\\n# dfs, tree dp\\nclass Solution2(object):\\n    def subtreeInversionSum(self, edges, nums, k):\\n        \\\"\\\"\\\"\\n        :type edges: List[List[int]]\\n        :type nums: List[int]\\n        :type k: int\\n        :rtype: int\\n        \\\"\\\"\\\"\\n        def dfs(u, p):\\n            dp1, dp2 = [nums[u]]*k, [nums[u]]*k\\n            for v in adj[u]:\\n                if v == p:\\n                    continue\\n                new_dp1, new_dp2 = dfs(v, u)\\n                for i in xrange(k//2):\\n                    dp1[i] = max(dp1[i]+new_dp1[(k-2)-i], dp1[(k-2)-i]+new_dp1[i])\\n                    dp2[i] = min(dp2[i]+new_dp2[(k-2)-i], dp2[(k-2)-i]+new_dp2[i])\\n                for i in xrange(k//2, k):\\n                    dp1[i] += new_dp1[i]\\n                    dp2[i] += new_dp2[i]\\n                for i in reversed(xrange(k-1)):\\n                    dp1[i] = max(dp1[i], dp1[i+1])\\n                    dp2[i] = min(dp2[i], dp2[i+1])\\n            dp1.insert(0, max(dp1[0], -dp2[-1]))\\n            dp2.insert(0, min(dp2[0], -dp1[-1]))\\n            dp1.pop()\\n            dp2.pop()\\n            return dp1, dp2\\n\\n        adj = [[] for _ in xrange(len(nums))]\\n        for u, v in edges:\\n            adj[u].append(v)\\n            adj[v].append(u)\\n        dp1, _ = dfs(0, -1)\\n        return dp1[0]\\n\"])</script><script>self.__next_f.push([1,\"1f:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-6 grid lg:grid-cols-[1fr_280px] gap-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"article\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"header\\\",null,{\\\"className\\\":\\\"space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-sm text-muted-foreground tabular-nums\\\",\\\"children\\\":[\\\"#\\\",3949]}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\\\",\\\"children\\\":\\\"Hard\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-muted text-muted-foreground\\\",\\\"children\\\":\\\"Premium on LC\\\"}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":[\\\"~\\\",50,\\\" min\\\"]}]]}],[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-tight\\\",\\\"children\\\":\\\"Subtree Inversion Sum II\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-muted-foreground max-w-2xl\\\",\\\"children\\\":[\\\"Time \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"className\\\":\\\"text-foreground\\\",\\\"children\\\":\\\"O(n * k)\\\"}],\\\" · \\\",\\\"Space \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"className\\\":\\\"text-foreground\\\",\\\"children\\\":\\\"O(n + h * k)\\\"}],\\\" · \\\",[\\\"$\\\",\\\"a\\\",null,{\\\"href\\\":\\\"https://leetcode.com/problems/subtree-inversion-sum-ii/\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",\\\"className\\\":\\\"text-primary underline-offset-2 hover:underline\\\",\\\"children\\\":\\\"Official statement on LeetCode\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap gap-2\\\",\\\"children\\\":[[[\\\"$\\\",\\\"$L3\\\",\\\"dynamic-programming\\\",{\\\"href\\\":\\\"/topics/dynamic-programming\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-primary/15 text-primary\\\",\\\"children\\\":\\\"dynamic programming\\\"}]}]],[[\\\"$\\\",\\\"$L3\\\",\\\"dfs-backtracking\\\",{\\\"href\\\":\\\"/patterns/dfs-backtracking\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":\\\"dfs backtracking\\\"}]}],[\\\"$\\\",\\\"$L3\\\",\\\"tree-dp\\\",{\\\"href\\\":\\\"/patterns/tree-dp\\\",\\\"children\\\":[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":\\\"tree dp\\\"}]}]],[]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap gap-2 pt-1\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L20\\\",null,{\\\"slug\\\":\\\"subtree-inversion-sum-ii\\\"}],[[\\\"$\\\",\\\"$L3\\\",\\\"cpp\\\",{\\\"href\\\":\\\"/problems/subtree-inversion-sum-ii/cpp\\\",\\\"className\\\":\\\"text-sm text-primary hover:underline\\\",\\\"children\\\":\\\"cpp\\\"}],[\\\"$\\\",\\\"$L3\\\",\\\"python\\\",{\\\"href\\\":\\\"/problems/subtree-inversion-sum-ii/python\\\",\\\"className\\\":\\\"text-sm text-primary hover:underline\\\",\\\"children\\\":\\\"python\\\"}]]]}]]}],[\\\"$\\\",\\\"section\\\",null,{\\\"className\\\":\\\"mt-10\\\",\\\"id\\\":\\\"solutions\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold mb-3\\\",\\\"children\\\":\\\"Solutions\\\"}],[\\\"$\\\",\\\"$L21\\\",null,{\\\"solutions\\\":{\\\"cpp\\\":{\\\"language\\\":\\\"C++\\\",\\\"languageSlug\\\":\\\"cpp\\\",\\\"filename\\\":\\\"subtree-inversion-sum-ii.cpp\\\",\\\"code\\\":\\\"$22\\\",\\\"sourcePath\\\":\\\"C++/subtree-inversion-sum-ii.cpp\\\"},\\\"python\\\":{\\\"language\\\":\\\"Python\\\",\\\"languageSlug\\\":\\\"python\\\",\\\"filename\\\":\\\"subtree-inversion-sum-ii.py\\\",\\\"code\\\":\\\"$23\\\",\\\"sourcePath\\\":\\\"Python/subtree-inversion-sum-ii.py\\\"}}}]]}],[\\\"$L24\\\",\\\"$L25\\\",\\\"$L26\\\",\\\"$L27\\\",\\\"$L28\\\",\\\"$L29\\\",\\\"$L2a\\\",\\\"$L2b\\\",\\\"$L2c\\\",\\\"$L2d\\\"],\\\"$L2e\\\",\\\"$L2f\\\",\\\"$L30\\\",\\\"$L31\\\",\\\"$L32\\\",\\\"$L33\\\"]}],\\\"$L34\\\"]}]\\n\"])</script><script>self.__next_f.push([1,\"3a:I[203221,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\",\\\"/_next/static/chunks/259rkrk9l2f9c.js\\\"],\\\"ConfidenceTracker\\\"]\\n24:[\\\"$\\\",\\\"section\\\",\\\"beginner\\\",{\\\"id\\\":\\\"beginner\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Beginner Explanation\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003ch2\\u003eWhat is Subtree Inversion Sum II?\\u003c/h2\\u003e\\\\n\\u003cp\\u003e\\u003cstrong\\u003eSubtree Inversion Sum II\\u003c/strong\\u003e (LeetCode #3949) is a \\u003cstrong\\u003eHard\\u003c/strong\\u003e problem that primarily trains \\u003cstrong\\u003edynamic programming\\u003c/strong\\u003e.\\u003c/p\\u003e\\\\n\\u003ch3\\u003eHow to think about it\\u003c/h3\\u003e\\\\n\\u003col\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eRestate the goal\\u003c/strong\\u003e in your own words before coding.\\u003c/li\\u003e\\\\n\\u003cli\\u003eWork a \\u003cstrong\\u003etiny example\\u003c/strong\\u003e by hand so the invariant becomes obvious.\\u003c/li\\u003e\\\\n\\u003cli\\u003eIdentify the \\u003cstrong\\u003epattern\\u003c/strong\\u003e — this problem aligns with \\u003cstrong\\u003edfs backtracking and tree dp\\u003c/strong\\u003e.\\u003c/li\\u003e\\\\n\\u003cli\\u003eOnly then translate the idea into code.\\u003c/li\\u003e\\\\n\\u003c/ol\\u003e\\\\n\\u003ch3\\u003eWhy this problem matters\\u003c/h3\\u003e\\\\n\\u003cp\\u003eHard problems force you to combine patterns and prove complexity carefully — interview gold.\\\\nOfficial solution notes mention: DFS, Tree DP.\\u003c/p\\u003e\\\\n\\u003cblockquote\\u003e\\\\n\\u003cp\\u003eAlgoForge explanations are original teaching notes. Always open the \\u003ca href=\\\\\\\"https://leetcode.com/problems/subtree-inversion-sum-ii/\\\\\\\"\\u003eofficial problem statement on LeetCode\\u003c/a\\u003e for constraints and examples.\\u003c/p\\u003e\\\\n\\u003c/blockquote\\u003e\\\\n\\\"}}]]}]\\n35:T4d3,\\u003ch2\\u003eInterview approach for Subtree Inversion Sum II\\u003c/h2\\u003e\\n\\u003ch3\\u003eOpening (30–60 seconds)\\u003c/h3\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eClarify inputs/outputs and edge cases (empty input, single element, duplicates, overflow).\\u003c/li\\u003e\\n\\u003cli\\u003eState a \\u003cstrong\\u003ebrute force\\u003c/strong\\u003e so the interviewer knows you can solve it naively.\\u003c/li\\u003e\\n\\u003cli\\u003ePropose the \\u003cstrong\\u003eoptimal direction\\u003c/strong\\u003e tied to \\u003cstrong\\u003edfs backtracking and tree dp\\u003c/strong\\u003e.\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch3\\u003eCore solution narrative\\u003c/h3\\u003e\\n\\u003col\\u003e\\n\\u003cli\\u003eDefine the \\u003cstrong\\u003estate\\u003c/strong\\u003e you track (pointers, DP cell, set membership, stack top, etc.).\\u003c/li\\u003e\\n\\u003cli\\u003eExplain the \\u003cstrong\\u003etransition\\u003c/strong\\u003e when you process the next element.\\u003c/li\\u003e\\n\\u003cli\\u003eCall out \\u003cstrong\\u003etime\\u003c/strong\\u003e (O(n * k)) and \\u003cstrong\\u003espace\\u003c/strong\\u003e (O(n + h * k)) before coding.\\u003c/li\\u003e\\n\\u003cli\\u003eCode cleanly; narrate variable names.\\u003c/li\\u003e\\n\\u003c/ol\\u003e\\n\\u003ch3\\u003eWhat interviewers listen for\\u003c/h3\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eCorrectness on edge cases\\u003c/li\\u003e\\n\\u003cli\\u003eComplexity honesty\\u003c/li\\u003e\\n\\u003cli\\u003eAbility to discuss \\u003cstrong\\u003etrade-offs\\u003c/strong\\u003e (e.g., hash map space vs. sort + two pointers)\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n\\u003ch3\\u003eFollow-up questions they may ask\\u003c/h3\\u003e\\n\\u003cul\\u003e\\n\\u003cli\\u003eCan you solve it with less memory?\\u003c/li\\u003e\\n\\u003cli\\u003eWhat if the input stream is infinite / doesn't fit in RAM?\\u003c/li\\u003e\\n\\u003cli\\u003eHow would tests look for adversarial inputs?\\u003c/li\\u003e\\n\\u003c/ul\\u003e\\n25:[\\\"$\\\",\\\"section\\\",\\\"interview\\\",{\\\"id\\\":\\\"interview\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Interview Walkthrough\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"$35\\\"}}]]}]\\n26:[\\\"$\\\",\\\"section\\\",\\\"optimized\\\",{\\\"id\\\":\\\"optimized\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Optimized Approach\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003ch2\\u003eOptimized solution notes\\u003c/h2\\u003e\\\\n\\u003cp\\u003eThe reference solutions on AlgoForge target \\u003cstrong\\u003eO(n * k)\\u003c/strong\\u003e time and \\u003cstrong\\u003eO(n + h * k)\\u003c/strong\\u003e space.\\u003c/p\\u003e\\\\n\\u003ch3\\u003ePattern focus: dfs backtracking and tree dp\\u003c/h3\\u003e\\\\n\\u003cp\\u003eUse the pattern as a checklist:\\u003c/p\\u003e\\\\n\\u003cul\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003edfs backtracking\\u003c/strong\\u003e — confirm the invariant holds after each step\\u003c/li\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003etree dp\\u003c/strong\\u003e — confirm the invariant holds after each step\\u003c/li\\u003e\\\\n\\u003c/ul\\u003e\\\\n\\u003cp\\u003eMultiple methods appear in the source solutions — compare them and explain when each is preferable.\\u003c/p\\u003e\\\\n\\u003ch3\\u003eImplementation tips\\u003c/h3\\u003e\\\\n\\u003cul\\u003e\\\\n\\u003cli\\u003ePrefer readable names o\"])</script><script>self.__next_f.push([1,\"ver micro-optimizations in interviews.\\u003c/li\\u003e\\\\n\\u003cli\\u003eExtract helpers only when they clarify (e.g., expand-around-center, DFS visit).\\u003c/li\\u003e\\\\n\\u003cli\\u003eAfter AC-level logic, re-scan for off-by-one and null checks.\\u003c/li\\u003e\\\\n\\u003c/ul\\u003e\\\\n\\\"}}]]}]\\n27:[\\\"$\\\",\\\"section\\\",\\\"complexity\\\",{\\\"id\\\":\\\"complexity\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Complexity Analysis\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003ch2\\u003eComplexity\\u003c/h2\\u003e\\\\n\\u003ctable\\u003e\\\\n\\u003cthead\\u003e\\\\n\\u003ctr\\u003e\\\\n\\u003cth\\u003eMeasure\\u003c/th\\u003e\\\\n\\u003cth\\u003eBound\\u003c/th\\u003e\\\\n\\u003c/tr\\u003e\\\\n\\u003c/thead\\u003e\\\\n\\u003ctbody\\u003e\\\\n\\u003ctr\\u003e\\\\n\\u003ctd\\u003eTime\\u003c/td\\u003e\\\\n\\u003ctd\\u003e\\u003cstrong\\u003eO(n * k)\\u003c/strong\\u003e\\u003c/td\\u003e\\\\n\\u003c/tr\\u003e\\\\n\\u003ctr\\u003e\\\\n\\u003ctd\\u003eSpace\\u003c/td\\u003e\\\\n\\u003ctd\\u003e\\u003cstrong\\u003eO(n + h * k)\\u003c/strong\\u003e\\u003c/td\\u003e\\\\n\\u003c/tr\\u003e\\\\n\\u003c/tbody\\u003e\\\\n\\u003c/table\\u003e\\\\n\\u003ch3\\u003eHow to justify this in an interview\\u003c/h3\\u003e\\\\n\\u003cul\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eTime:\\u003c/strong\\u003e count loops, map/set operations, and recursive branching; state average vs worst case if relevant.\\u003c/li\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eSpace:\\u003c/strong\\u003e include hash maps, recursion stack, and output allocation when the problem asks for it.\\u003c/li\\u003e\\\\n\\u003c/ul\\u003e\\\\n\\u003cp\\u003eIf your implementation differs from the reference, re-derive big-O from \\u003cem\\u003eyour\\u003c/em\\u003e code — never memorize a complexity you cannot defend.\\u003c/p\\u003e\\\\n\\\"}}]]}]\\n28:[\\\"$\\\",\\\"section\\\",\\\"common-mistakes\\\",{\\\"id\\\":\\\"common-mistakes\\\",\\\"className\\\":\\\"mt-10 scroll-mt-24\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex items-center gap-2 mb-3\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-xl font-bold\\\",\\\"children\\\":\\\"Common Mistakes\\\"}],false]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"prose-af\\\",\\\"dangerouslySetInnerHTML\\\":{\\\"__html\\\":\\\"\\u003ch2\\u003eCommon mistakes on Subtree Inversion Sum II\\u003c/h2\\u003e\\\\n\\u003col\\u003e\\\\n\\u003cli\\u003e\\u003cstrong\\u003eSkipping edge cases\\u003c/strong\\u003e — em