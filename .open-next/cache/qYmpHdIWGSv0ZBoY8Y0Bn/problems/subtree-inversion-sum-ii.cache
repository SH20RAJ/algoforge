ication/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"Article\\\",\\\"headline\\\":\\\"Subtree Inversion Sum II\\\",\\\"description\\\":\\\"Original Hard explanation for Subtree Inversion Sum II (LeetCode #3949). Pattern: dfs backtracking. Time O(n * k), space O(n + h * k). Multi-language solutions and interview tips.\\\",\\\"url\\\":\\\"https://algoforge.dev/problems/subtree-inversion-sum-ii\\\",\\\"author\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"AlgoForge\\\"},\\\"publisher\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"AlgoForge\\\"},\\\"datePublished\\\":\\\"2026-01-01\\\",\\\"dateModified\\\":\\\"2026-07-17\\\"}\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$1d\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"HowTo\\\",\\\"name\\\":\\\"How to solve Subtree Inversion Sum II\\\",\\\"description\\\":\\\"Original Hard explanation for Subtree Inversion Sum II (LeetCode #3949). Pattern: dfs backtracking. Time O(n * k), space O(n + h * k). Multi-language solutions and interview tips.\\\",\\\"step\\\":[{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":1,\\\"text\\\":\\\"Read the official problem statement on LeetCode\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":2,\\\"text\\\":\\\"Solve on paper / whiteboard first\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":3,\\\"text\\\":\\\"Implement the dfs backtracking and tree dp approach\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":4,\\\"text\\\":\\\"Verify edge cases from the checklist\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":5,\\\"text\\\":\\\"State time and space complexity aloud\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":6,\\\"text\\\":\\\"Compare with the AlgoForge reference solution\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":7,\\\"text\\\":\\\"Schedule a revision session\\\"}]}\"}}],[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Subtree Inversion Sum II\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/subtree-inversion-sum-ii\\\"}]}\"}}],\"$L1e\"]}],\"$L1f\"]}]\n20:I[56303,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"BookmarkButton\"]\n21:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"CodeTabs\"]\n1e:[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/subtree-inversion-sum-ii\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"Subtree Inversion Sum II\"}]]}]]}]\n22:T1134,// Time:  O(n * k)\n// Space: O(n + h * k)\n\n// iterative dfs, tree dp\nclass Solution {\npublic:\n    int subtreeInversionSum(vector<vector<int>>& edges, vector<int>& nums, int k) {\n        vector<vector<int>> adj(size(nums));\n        const auto& iter_dfs = [&]() {\n            using RET = vector<vector<int64_t>>;\n            RET result{};\n            vector<tuple<int, int, int, int, shared_ptr<RET>, RET *>> stk = {{1, 0, -1, -1, nullptr, &result}};\n            while (!empty(stk)) {\n                const auto [step, u, p, i, new_ret, ret] = stk.back(); stk.pop_back();\n                if (step == 1) {\n                    ret->assign(2, vector<int64_t>(k, nums[u]));\n                    stk.emplace_back(4, -1, -1, -1, nullptr, ret);\n                    stk.emplace_back(2, u, p, 0, nullptr, ret);\n                } else if (step == 2) {\n                    if (i == size(adj[u])) {\n                        continue;\n                    }\n                    const auto& v = adj[u][i];\n                    stk.emplace_back(2, u, p, i + 1, nullptr, ret);\n                    if (v == p) {\n                        continue;\n                    }\n                    const auto& new_ret = make_shared<RET>();\n                    stk.emplace_back(3, -1, -1, -1, new_ret, ret);\n                    stk.emplace_back(1, v, u, -1, nullptr, new_ret.get());\n                } else if (step == 3) {\n                    auto& new_dp1 = (*new_ret)[0], &new_dp2 = (*new_ret)[1];\n                    auto& dp1 = (*ret)[0], &dp2 = (*ret)[1];\n                    for (int i = 0; i < k / 2; ++i) {\n                        dp1[i] = max(dp1[i] + new_dp1[(k - 2) - i], dp1[(k - 2) - i] + new_dp1[i]);\n                        dp2[i] = min(dp2[i] + new_dp2[(k - 2) - i], dp2[(k - 2) - i] + new_dp2[i]);\n                    }\n                    for (int i = k / 2; i < k; ++i) {\n                        dp1[i] += new_dp1[i];\n                        dp2[i] += new_dp2[i];\n                    }\n                    for (int i = k - 2; i >= 0; --i) {\n                        dp1[i] = max(dp1[i], dp1[i + 1]);\n                        dp2[i] = min(dp2[i], dp2[i + 1]);\n                    }\n                } else if (step == 4) {\n                    auto& dp1 = (*ret)[0], &dp2 = (*ret)[1];\n                    const auto mx = max(dp1[0], -dp2[k - 1]);\n                    const auto mn = min(dp2[0], -dp1[k - 1]);\n                    dp1.insert(begin(dp1), mx); dp1.pop_back();\n                    dp2.insert(begin(dp2), mn); dp2.pop_back();\n                }\n            }\n            return result[0][0];\n        };\n        \n        for (auto& e : edges) {\n            adj[e[0]].emplace_back(e[1]);\n            adj[e[1]].emplace_back(e[0]);\n        }\n        return iter_dfs();\n    }\n};\n\n// Time:  O(n * k)\n// Space: O(n + h * k)\n// dfs, tree dp\nclass Solution2 {\npublic:\n    int subtreeInversionSum(vector<vector<int>>& edges, vector<int>& nums, int k) {\n        vector<vector<int>> adj(size(nums));\n        const auto dfs = [&](this auto&& dfs, int u, int p) -> pair<vector<int64_t>, vector<int64_t>> {\n            vector<int64_t> dp1(k, nums[u]), dp2(k, nums[u]);\n            for (const auto& v : adj[u]) {\n                if (v == p) {\n                    continue;\n                }\n                const auto& [new_dp1, new_dp2] = dfs(v, u);\n                for (int i = 0; i < k / 2; ++i) {\n                    dp1[i] = max(dp1[i] + new_dp1[(k - 2) - i], dp1[(k - 2) - i] + new_dp1[i]);\n                    dp2[i] = min(dp2[i] + new_dp2[(k - 2) - i], dp2[(k - 2) - i] + new_dp2[i]);\n                }\n                for (int i = k / 2; i < k; ++i) {\n                    dp1[i] += new_dp1[i];\n                    dp2[i] += new_dp2[i];\n                }\n                for (int i = k - 2; i >= 0; --i) {\n                    dp1[i] = max(dp1[i], dp1[i + 1]);\n                    dp2[i] = min(dp2[i], dp2[i + 1]);\n                }\n            }\n            const auto mx = max(dp1[0], -dp2[k - 1]);\n            const auto mn = min(dp2[0], -dp1[k - 1]);\n            dp1.insert(begin(dp1), mx); dp1.pop_back();\n            dp2.insert(begin(dp2), mn); dp2.pop_back();\n            return pair(dp1, dp2);\n        };\n        \n        for (auto& e : edges) {\n            adj[e[0]].emplace_back(e[1]);\n            adj[e[1]].emplace_back(e[0]);\n        }\n        const auto& [dp1, _] = dfs(0, -1);\n        return dp1[0];\n    }\n};\n23:Tdbe,# Time:  O(n * k)\n# Space: O(n + h * k)\n\n# iterative dfs, tree dp\nclass Solution(object):\n    def subtreeInversionSum(self, edges, nums, k):\n        \"\"\"\n        :type edges: List[List[int]]\n        :type nums: List[int]\n        :type k: int\n        :rtype: int\n        \"\"\"\n        def iter_dfs():\n            result = []\n            stk = [(1, (0, -1, result))]\n            while stk:\n                step, args = stk.pop()\n                if step == 1:\n                    u, p, ret = args\n                    ret[:] = [[nums[u]]*k, [nums[u]]*k]\n                    stk.append((4, (u, p, ret)))\n                    stk.append((2, (u, p, 0, ret)))\n                elif step == 2:\n                    u, p, i, ret = args\n                    if i == len(adj[u]):\n                        continue\n                    v = adj[u][i]\n                    stk.append((2, (u, p, i+1, ret)))\n                    if v == p:\n                        continue\n                    new_ret = []\n                    stk.append((3, (new_ret, ret)))\n                    stk.append((1, (v, u, new_ret)))\n                elif step == 3:\n                    new_ret, ret = args\n                    new_dp1, new_dp2 = new_ret\n                    dp1, dp2 = ret\n                    for i in xrange(k//2):\n                        dp1[i] = max(dp1[i]+new_dp1[(k-2)-i], dp1[(k-2)-i]+new_dp1[i])\n                        dp2[i] = min(dp2[i]+new_dp2[(k-2)-i], dp2[(k-2)-i]+new_dp2[i])\n                    for i in xrange(k//2, k):\n                        dp1[i] += new_dp1[i]\n                        dp2[i] += new_dp2[i]\n                    for i in reversed(xrange(k-1)):\n                        dp1[i] = max(dp1[i], dp1[i+1])\n                        dp2[i] = min(dp2[i], dp2[i+1])\n                elif step == 4:\n                    u, p, ret = args\n                    dp1, dp2 = ret\n                    dp1.insert(0, max(dp1[0], -dp2[-1]))\n                    dp2.insert(0, min(dp2[0], -dp1[-1]))\n                    dp1.pop()\n                    dp2.pop()\n            return result[0][0]\n\n        adj = [[] for _ in xrange(len(nums))]\n        for u, v in edges:\n            adj[u].append(v)\n            adj[v].append(u)\n        return iter_dfs()\n\n\n# Time:  O(n * k)\n# Space: O(n + h * k)\n# dfs, tree dp\nclass Solution2(object):\n    def subtreeInversionSum(self, edges, nums, k):\n        \"\"\"\n        :type edges: List[List[int]]\n        :type nums: List[int]\n        :type k: int\n        :rtype: int\n        \"\"\"\n        def dfs(u, p):\n            dp1, dp2 = [nums[u]]*k, [nums[u]]*k\n            for v in adj[u]:\n                if v == p:\n                    continue\n                new_dp1, new_dp2 = dfs(v, u)\n                for i in xrange(k//2):\n                    dp1[i] = max(dp1[i]+new_dp1[(k-2)-i], dp1[(k-2)-i]+new_dp1[i])\n                    dp2[i] = min(dp2[i]+new_dp2[(k-2)-i], dp2[(k-2)-i]+new_dp2[i])\n                for i in xrange(k//2, k):\n                    dp1[i] += new_dp1[i]\n                    dp2[i] += new_dp2[i]\n                for i in reversed(xrange(k-1)):\n                    dp1[i] = max(dp1[i], dp1[i+1])\n                    dp2[i] = min(dp2[i], dp2[i+1])\n            dp1.insert(0, max(dp1[0], -dp2[-1]))\n            dp2.insert(0, min(dp2[0], -dp1[-1]))\n            dp1.pop()\n            dp2.pop()\n            return dp1, dp2\n\n        adj = [[] for _ in xrange(len(nums))]\n        for u, v in edges:\n            adj[u].append(v)\n            adj[v].append(u)\n        dp1, _ = dfs(0, -1)\n        return dp1[0]\n1f:[\"$\",\"div\",null,{\"className\":\"mt-6 grid lg:grid-cols-[1fr_280px] gap-10\",\"children\":[[\"$\",\"article\",null,{\"children\":[[\"$\",\"header\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-wrap items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-sm text-muted-foreground tabular-nums\",\"children\":[\"#\",3949]}],[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\",\"children\":\"Hard\"}],[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-muted text-muted-foreground\",\"children\":\"Premium on LC\"}],[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":[\"~\",50,\" min\"]}]]}],[\"$\",\"h1\",null,{\"className\":\"text-3xl md:text-4xl font-bold tracking-tight\",\"children\":\"Subtree Inversion Sum II\"}],[\"$\",\"p\",null,{\"className\":\"text-muted-foreground max-w-2xl\",\"children\":[\"Time \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O(n * k)\"}],\" · \",\"Space \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O(n + h * k)\"}],\" · \",[\"$\",\"a\",null,{\"href\":\"https://leetcode.com/problems/subtree-inversion-sum-ii/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-primary underline-offset-2 hover:underline\",\"children\":\"Official statement on LeetCode\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[[\"$\",\"$L3\",\"dynamic-programming\",{\"href\":\"/topics/dynamic-programming\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-primary/15 text-primary\",\"children\":\"dynamic programming\"}]}]],[[\"$\",\"$L3\",\"dfs-backtracking\",{\"href\":\"/patterns/dfs-backtracking\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"dfs backtracking\"}]}],[\"$\",\"$L3\",\"tree-dp\",{\"href\":\"/patterns/tree-dp\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"tree dp\"}]}]],[]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2 pt-1\",\"children\":[[\"$\",\"$L20\",null,{\"slug\":\"subtree-inversion-sum-ii\"}],[[\"$\",\"$L3\",\"cpp\",{\"href\":\"/problems/subtree-inversion-sum-ii/cpp\",\"className\":\"text-sm text-primary hover:underline\",\"children\":\"cpp\"}],[\"$\",\"$L3\",\"python\",{\"href\":\"/problems/subtree-inversion-sum-ii/python\",\"className\":\"text-sm text-primary hover:underline\",\"children\":\"python\"}]]]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"id\":\"solutions\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Solutions\"}],[\"$\",\"$L21\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"subtree-inversion-sum-ii.cpp\",\"code\":\"$22\",\"sourcePath\":\"C++/subtree-inversion-sum-ii.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"subtree-inversion-sum-ii.py\",\"code\":\"$23\",\"sourcePath\":\"Python/subtree-inversion-sum-ii.py\"}}}]]}],[\"$L24\",\"$L25\",\"$L26\",\"$L27\",\"$L28\",\"$L29\",\"$L2a\",\"$L2b\",\"$L2c\",\"$L2d\"],\"$L2e\",\"$L2f\",\"$L30\",\"$L31\",\"$L32\",\"$L33\"]}],\"$L34\"]}]\n3a:I[203221,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"ConfidenceTracker\"]\n24:[\"$\",\"section\",\"beginner\",{\"id\":\"beginner\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Beginner Explanation\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>What is Subtree Inversion Sum II?</h2>\\n<p><strong>Subtree Inversion Sum II</strong> (LeetCode #3949) is a <strong>Hard</strong> problem that primarily trains <strong>dynamic programming</strong>.</p>\\n<h3>How to think about it</h3>\\n<ol>\\n<li><strong>Restate the goal</strong> in your own words before coding.</li>\\n<li>Work a <strong>tiny example</strong> by hand so the invariant becomes obvious.</li>\\n<li>Identify the <strong>pattern</strong> — this problem aligns with <strong>dfs backtracking and tree dp</strong>.</li>\\n<li>Only then translate the idea into code.</li>\\n</ol>\\n<h3>Why this problem matters</h3>\\n<p>Hard problems force you to combine patterns and prove complexity carefully — interview gold.\\nOfficial solution notes mention: DFS, Tree DP.</p>\\n<blockquote>\\n<p>AlgoForge explanations are original teaching notes. Always open the <a href=\\\"https://leetcode.com/problems/subtree-inversion-sum-ii/\\\">official problem statement on LeetCode</a> for constraints and examples.</p>\\n</blockquote>\\n\"}}]]}]\n35:T4d3,<h2>Interview approach for Subtree Inversion Sum II</h2>\n<h3>Opening (30–60 seconds)</h3>\n<ul>\n<li>Clarify inputs/outputs and edge cases (empty input, single element, duplicates, overflow).</li>\n<li>State a <strong>brute force</strong> so the interviewer knows you can solve it naively.</li>\n<li>Propose the <strong>optimal direction</strong> tied to <strong>dfs backtracking and tree dp</strong>.</li>\n</ul>\n<h3>Core solution narrative</h3>\n<ol>\n<li>Define the <strong>state</strong> you track (pointers, DP cell, set membership, stack top, etc.).</li>\n<li>Explain the <strong>transition</strong> when you process the next element.</li>\n<li>Call out <strong>time</strong> (O(n * k)) and <strong>space</strong> (O(n + h * k)) before coding.</li>\n<li>Code cleanly; narrate variable names.</li>\n</ol>\n<h3>What interviewers listen for</h3>\n<ul>\n<li>Correctness on edge cases</li>\n<li>Complexity honesty</li>\n<li>Ability to discuss <strong>trade-offs</strong> (e.g., hash map space vs. sort + two pointers)</li>\n</ul>\n<h3>Follow-up questions they may ask</h3>\n<ul>\n<li>Can you solve it with less memory?</li>\n<li>What if the input stream is infinite / doesn't fit in RAM?</li>\n<li>How would tests look for adversarial inputs?</li>\n</ul>\n25:[\"$\",\"section\",\"interview\",{\"id\":\"interview\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Interview Walkthrough\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"$35\"}}]]}]\n26:[\"$\",\"section\",\"optimized\",{\"id\":\"optimized\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Optimized Approach\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Optimized solution notes</h2>\\n<p>The reference solutions on AlgoForge target <strong>O(n * k)</strong> time and <strong>O(n + h * k)</strong> space.</p>\\n<h3>Pattern focus: dfs backtracking and tree dp</h3>\\n<p>Use the pattern as a checklist:</p>\\n<ul>\\n<li><strong>dfs backtracking</strong> — confirm the invariant holds after each step</li>\\n<li><strong>tree dp</strong> — confirm the invariant holds after each step</li>\\n</ul>\\n<p>Multiple methods appear in the source solutions — compare them and explain when each is preferable.</p>\\n<h3>Implementation tips</h3>\\n<ul>\\n<li>Prefer readable names over micro-optimizations in interviews.</li>\\n<li>Extract helpers only when they clarify (e.g., expand-around-center, DFS visit).</li>\\n<li>After AC-level logic, re-scan for off-by-one and null checks.</li>\\n</ul>\\n\"}}]]}]\n27:[\"$\",\"section\",\"complexity\",{\"id\":\"complexity\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Complexity Analysis\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Complexity</h2>\\n<table>\\n<thead>\\n<tr>\\n<th>Measure</th>\\n<th>Bound</th>\\n</tr>\\n</thead>\\n<tbody>\\n<tr>\\n<td>Time</td>\\n<td><strong>O(n * k)</strong></td>\\n</tr>\\n<tr>\\n<td>Space</td>\\n<td><strong>O(n + h * k)</strong></td>\\n</tr>\\n</tbody>\\n</table>\\n<h3>How to justify this in an interview</h3>\\n<ul>\\n<li><strong>Time:</strong> count loops, map/set operations, and recursive branching; state average vs worst case if relevant.</li>\\n<li><strong>Space:</strong> include hash maps, recursion stack, and output allocation when the problem asks for it.</li>\\n</ul>\\n<p>If your implementation differs from the reference, re-derive big-O from <em>your</em> code — never memorize a complexity you cannot defend.</p>\\n\"}}]]}]\n28:[\"$\",\"section\",\"common-mistakes\",{\"id\":\"common-mistakes\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Common Mistakes\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Common mistakes on Subtree Inversion Sum II</h2>\\n<ol>\\n<li><strong>Skipping edge cases</strong> — empty collections, single-element inputs, max constraints.</li>\\n<li><strong>Wrong invariant</strong> for dfs backtracking and tree dp — updating state too early or too late.</li>\\n<li><strong>Mutating input unexpectedly</strong> when the problem forbids it.</li>\\n<li><strong>Off-by-one</strong> in windows, ranges, or binary search bounds.</li>\\n<li><strong>Ignoring overflow / precision</strong> for integer arithmetic problems.</li>\\n<li><strong>Overengineering</strong> — jumping to an advanced structure when a simpler approach works.</li>\\n</ol>\\n\"}}]]}]\n29:[\"$\",\"section\",\"alternatives\",{\"id\":\"alternatives\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Alternative Approaches\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Alternatives</h2>\\n<p>The source file includes more than one method. Compare:</p>\\n<ol>\\n<li><strong>Primary optimized path</strong> — best complexity for typical interviews.</li>\\n<li><strong>Secondary approach</strong> — often brute force, sorting-based, or space-optimized variant.</li>\\n</ol>\\n<p>Practice articulating <strong>when</strong> you would pick each (constraints, readability, follow-ups).</p>\\n\"}}]]}]\n2a:[\"$\",\"section\",\"edge-cases\",{\"id\":\"edge-cases\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Edge Cases\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Edge cases checklist</h2>\\n<ul>\\n<li>Minimum input size</li>\\n<li>Maximum input size / time limits</li>\\n<li>Duplicates and already-sorted input</li>\\n<li>Negative numbers / zeros (if applicable)</li>\\n<li>Disconnected structures (graphs/trees)</li>\\n<li>Single path vs branching recursion depth</li>\\n</ul>\\n\"}}]]}]\n2b:[\"$\",\"section\",\"pattern-recognition\",{\"id\":\"pattern-recognition\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Pattern Recognition\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Spotting this pattern</h2>\\n<p>Signal phrases that point to <strong>dfs backtracking and tree dp</strong>:</p>\\n<ul>\\n<li>Sorted input or ability to sort without changing the answer class</li>\\n<li>Need for contiguous subarray / substring → consider sliding window</li>\\n<li>Need for O(1) membership → hash set/map</li>\\n<li>Optimal substructure + overlapping subproblems → DP</li>\\n<li>Connectivity / components → graph DFS/BFS or Union-Find</li>\\n</ul>\\n<p>Primary topics: <strong>dynamic programming</strong>.</p>\\n\"}}]]}]\n2c:[\"$\",\"section\",\"follow-ups\",{\"id\":\"follow-ups\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Follow-up Interview Questions\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Follow-ups</h2>\\n<ol>\\n<li>How does the solution change if the input is a stream?</li>\\n<li>Can you solve it in-place?</li>\\n<li>What if duplicates must be handled differently?</li>\\n<li>How would you parallelize the approach?</li>\\n<li>Design tests that would break a buggy implementation.</li>\\n</ol>\\n\"}}]]}]\n2d:[\"$\",\"section\",\"practice\",{\"id\":\"practice\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Practice Recommendations\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>What to practice next</h2>\\n<ol>\\n<li>Re-solve <strong>Subtree Inversion Sum II</strong> in a second language (cpp, python).</li>\\n<li>Drill 3–5 more problems tagged <strong>dynamic programming</strong>.</li>\\n<li>Teach the solution out loud in under 5 minutes.</li>\\n<li>Add this problem to your revision calendar in 3 days and 14 days.</li>\\n</ol>\\n\"}}]]}]\n2e:[\"$\",\"section\",null,{\"id\":\"visualization\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Visualization\"}],[\"$\",\"div\",null,{\"className\":\"rounded-xl border border-dashed border-border bg-muted/40 p-6 text-sm text-muted-foreground\",\"children\":\"Conceptual diagram for Subtree Inversion Sum II: show input structure (dynamic programming), highlight the moving parts of the dfs backtracking and tree dp approach, and annotate each step with the maintained invariant and complexity.\"}]]}]\n2f:[\"$\",\"section\",null,{\"id\":\"checklist\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Study checklist\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"li\",\"Read the official problem statement on LeetCode\",{\"className\":\"flex gap-2 text-sm\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-primary\",\"aria-hidden\":true,\"children\":\"☐\"}],\"Read the official problem statement on 