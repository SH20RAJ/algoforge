{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/problems/layout,_N_T_/problems/[slug]/layout,_N_T_/problems/[slug]/page,_N_T_/problems/sliding-puzzle"},"segmentPaths":["/_tree","/_full","/problems/$d$slug/__PAGE__","/problems/$d$slug","/problems","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/340fxer6uczx7.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/05kafvajig4wu.js\"/><script src=\"/_next/static/chunks/2o5-igl1ik8oj.js\" async=\"\"></script><script src=\"/_next/static/chunks/1uejzok0tpgy1.js\" async=\"\"></script><script src=\"/_next/static/chunks/3ujjz4ap-oopx.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3om3j4o09b7fr.js\" async=\"\"></script><script src=\"/_next/static/chunks/2fvm6eoqeukxu.js\" async=\"\"></script><script src=\"/_next/static/chunks/1ntn7efqc-iiw.js\" async=\"\"></script><script src=\"/_next/static/chunks/0plpm2axnqe9k.js\" async=\"\"></script><script src=\"/_next/static/chunks/259rkrk9l2f9c.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Sliding Puzzle Solution — Hard | AlgoForge</title><meta name=\"description\" content=\"Original Hard explanation for Sliding Puzzle (LeetCode #773). Pattern: a search algorithm. Time O((m * n) * (m * n)!), space O((m * n) * (m * n)!). Multi-language solutions and interview tips.\"/><meta name=\"keywords\" content=\"Sliding Puzzle,Sliding Puzzle solution,Sliding Puzzle leetcode,breadth-first-search,a-search-algorithm,hard\"/><link rel=\"canonical\" href=\"https://algoforge.dev/problems/sliding-puzzle\"/><meta property=\"og:title\" content=\"Sliding Puzzle Solution — Hard | AlgoForge\"/><meta property=\"og:description\" content=\"Original Hard explanation for Sliding Puzzle (LeetCode #773). Pattern: a search algorithm. Time O((m * n) * (m * n)!), space O((m * n) * (m * n)!). Multi-language solutions and interview tips.\"/><meta property=\"og:url\" content=\"https://algoforge.dev/problems/sliding-puzzle\"/><meta property=\"og:site_name\" content=\"AlgoForge\"/><meta property=\"og:image\" content=\"https://algoforge.dev/og-default.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"Sliding Puzzle Solution — Hard | AlgoForge\"/><meta property=\"og:type\" content=\"article\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Sliding Puzzle Solution — Hard | AlgoForge\"/><meta name=\"twitter:description\" content=\"Original Hard explanation for Sliding Puzzle (LeetCode #773). Pattern: a search algorithm. Time O((m * n) * (m * n)!), space O((m * n) * (m * n)!). Multi-language solutions and interview tips.\"/><meta name=\"twitter:image\" content=\"https://algoforge.dev/og-default.png\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/favicon.ico\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"geist_deef94d5-module__Sms4YG__variable geist_mono_1bf8cbf6-module__FlyLvG__variable antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><script>((a,b,c,d,e,f,g,h)=>{let i=document.documentElement,j=[\"light\",\"dark\"];function k(b){var c;(Array.isArray(a)?a:[a]).forEach(a=>{let c=\"class\"===a,d=c&&f?e.map(a=>f[a]||a):e;c?(i.classList.remove(...d),i.class