m * n) * (m * n)!). Multi-language solutions and interview tips.\\\",\\\"url\\\":\\\"https://algoforge.dev/problems/sliding-puzzle\\\",\\\"author\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"AlgoForge\\\"},\\\"publisher\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"AlgoForge\\\"},\\\"datePublished\\\":\\\"2026-01-01\\\",\\\"dateModified\\\":\\\"2026-07-17\\\"}\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$2\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"HowTo\\\",\\\"name\\\":\\\"How to solve Sliding Puzzle\\\",\\\"description\\\":\\\"Original Hard explanation for Sliding Puzzle (LeetCode #773). Pattern: a search algorithm. Time O((m * n) * (m * n)!), space O((m * n) * (m * n)!). Multi-language solutions and interview tips.\\\",\\\"step\\\":[{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":1,\\\"text\\\":\\\"Read the official problem statement on LeetCode\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":2,\\\"text\\\":\\\"Solve on paper / whiteboard first\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":3,\\\"text\\\":\\\"Implement the a search algorithm approach\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":4,\\\"text\\\":\\\"Verify edge cases from the checklist\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":5,\\\"text\\\":\\\"State time and space complexity aloud\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":6,\\\"text\\\":\\\"Compare with the AlgoForge reference solution\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":7,\\\"text\\\":\\\"Schedule a revision session\\\"}]}\"}}],[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Sliding Puzzle\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/sliding-puzzle\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[\"$L3\",\"$L4\",\"$L5\"]}]]}],\"$L6\"]}],[\"$L7\"],\"$L8\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"qYmpHdIWGSv0ZBoY8Y0Bn\"}\n3:[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L9\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}]\n4:[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L9\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}]\n5:[\"$\",\"li\",\"/problems/sliding-puzzle\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"Sliding Puzzle\"}]]}]\nc:T1b2c,// Time:  O((m * n) * (m * n)!)\n// Space: O((m * n) * (m * n)!)\n\n// A* Search Algorithm\nclass Solution {\npublic:\n    int slidingPuzzle(vector<vector<int>>& board) {\n        const auto& R = board.size(), &C = board[0].size();\n        vector<int> begin, end;\n        unordered_map<int, pair<int, int>> expected;\n        int zero_idx = 0;\n        for (int i = 0; i < R; ++i) {\n            for (int j = 0; j < C; ++j) {\n                auto val = (C * i + j + 1) % (R * C);\n                expected[val] = {i, j};\n                if (board[i][j] == 0) {\n                    zero_idx = begin.size();\n                }\n                begin.emplace_back(board[i][j]);\n                end.emplace_back(val);\n            }\n        }\n        \n        int min_steps = heuristic_estimate(begin, R, C, expected);\n        unordered_set<vector<int>, Hash<vector<int>>> lookup;\n        vector<pair<int, vector<int>>> closer{make_pair(zero_idx, begin)}, detour;\n        while (true) {\n            if (closer.empty()) {\n                if (detour.empty()) {\n                    return -1;\n                }\n                min_steps += 2;\n                swap(closer, detour);\n            }\n            int zero;\n            vector<int> board;\n            tie(zero, board) = closer.back(); closer.pop_back();\n            if (board == end) {\n                return min_steps;\n            }\n            if (!lookup.count(board)) {\n                lookup.emplace(board);\n                int r = zero / C;\n                int c = zero % C;\n                static const vector<pair<int, int>> directions{{-1, 0}, {1, 0}, {0, -1}, {0, 1}};\n                for (const auto& direction : directions) {\n                    int i = r + direction.first;\n                    int j = c + direction.second;\n                    if (0 <= i && i < R && 0 <= j && j < C) {\n                        auto new_zero = C * i + j;\n                        auto new_board = board;\n                        swap(new_board[zero], new_board[new_zero]);\n                        int r2, c2;\n                        tie(r2, c2) = expected[board[new_zero]];\n                        int r1 = zero / C;\n                        int c1 = zero % C;\n                        int r0 = new_zero / C;\n                        int c0 = new_zero % C;\n                        bool is_closer = dot({r1 - r0, c1 - c0}, {r2 - r0, c2 - c0}) > 0;\n                        is_closer ? closer.emplace_back(new_zero, new_board) : detour.emplace_back(new_zero, new_board);\n                    }\n                }\n            }\n        }\n\n        return min_steps;\n    }\n\nprivate:\n    int heuristic_estimate(const vector<int>& board, int R, int C, const unordered_map<int, pair<int, int>>& expected) {\n        int result = 0;\n        for (int i = 0; i < R; ++i) {\n            for (int j = 0; j < C; ++j) {\n                const auto& val = board[C * i + j];\n                if (val == 0) {\n                    continue;\n                }\n                int r, c;\n                tie(r, c) = expected.at(val);\n                result += abs(r - i) + abs(c - j);\n            }\n        }\n        return result;\n    }\n\n    inline int dot(const pair<int, int>& a, const pair<int, int>& b) {\n        return a.first * b.first + a.second * b.second;\n    }\n                        \n    template<typename ContType>\n    struct Hash {\n        size_t operator()(const ContType& v) const {\n            size_t seed = 0;\n            for (const auto& i : v) {\n                seed ^= std::hash<typename ContType::value_type>{}(i)  + 0x9e3779b9 + (seed<<6) + (seed>>2);\n            }\n            return seed;\n        }\n    };\n};\n\n// Time:  O((m * n) * (m * n)! * log((m * n)!))\n// Space: O((m * n) * (m * n)!)\n// A* Search Algorithm\nclass Solution2 {\npublic:\n    int slidingPuzzle(vector<vector<int>>& board) {\n        const auto& R = board.size(), &C = board[0].size();\n        vector<int> begin, end;\n        unordered_map<int, pair<int, int>> expected;\n        int zero_idx = 0;\n        for (int i = 0; i < R; ++i) {\n            for (int j = 0; j < C; ++j) {\n                auto val = (C * i + j + 1) % (R * C);\n                expected[val] = {i, j};\n                if (board[i][j] == 0) {\n                    zero_idx = begin.size();\n                }\n                begin.emplace_back(board[i][j]);\n                end.emplace_back(val);\n            }\n        }\n        vector<int> end_wrong(end);\n        swap(end_wrong[end_wrong.size() - 2], end_wrong[end_wrong.size() - 3]);\n           \n        using P = tuple<int, int, int, vector<int>>;\n        priority_queue<P, vector<P>, greater<P>> min_heap;\n        min_heap.emplace(make_tuple(0, 0, zero_idx, begin));\n        unordered_map<vector<int>, int, Hash<vector<int>>> lookup;\n        lookup[begin] = 0;\n        while (!min_heap.empty()) {\n            int f, g, zero;\n            vector<int> board;\n            tie(f, g, zero, board) = min_heap.top(); min_heap.pop();\n            if (board == end) {\n                return g;\n            }\n            if (board == end_wrong) {\n                return -1;\n            }\n            if (f > lookup[board]) {\n                continue;\n            }\n            int r = zero / C;\n            int c = zero % C;\n            static const vector<pair<int, int>> directions{{-1, 0}, {1, 0}, {0, -1}, {0, 1}};\n            for (const auto& direction : directions) {\n                int i = r + direction.first;\n                int j = c + direction.second;\n                if (0 <= i && i < R && 0 <= j && j < C) {\n                    auto new_zero = C * i + j;\n                    auto new_board = board;\n                    swap(new_board[zero], new_board[new_zero]);\n                    f = g + 1 + heuristic_estimate(new_board, R, C, expected);\n                    if (!lookup.count(new_board) || f < lookup[new_board])\n                        lookup[new_board] = f;\n                        min_heap.emplace(make_tuple(f, g + 1, new_zero, new_board));\n                    }\n                }\n            }\n        }\n        return -1;\n    }\n\nprivate:\n    int heuristic_estimate(const vector<int>& board, int R, int C, const unordered_map<int, pair<int, int>>& expected) {\n        int result = 0;\n        for (int i = 0; i < R; ++i) {\n            for (int j = 0; j < C; ++j) {\n                const auto& val = board[C * i + j];\n                if (val == 0) {\n                    continue;\n                }\n                int r, c;\n                tie(r, c) = expected.at(val);\n                result += abs(r - i) + abs(c - j);\n            }\n        }\n        return result;\n    }\n                        \n    template<typename ContType>\n    struct Hash {\n        size_t operator()(const ContType& v) const {\n            size_t seed = 0;\n            for (const auto& i : v) {\n                seed ^= std::hash<typename ContType::value_type>{}(i)  + 0x9e3779b9 + (seed<<6) + (seed>>2);\n            }\n            return seed;\n        }\n    };\n};\nd:Tfbd,# Time:  O((m * n) * (m * n)!)\n# Space: O((m * n) * (m * n)!)\n\nimport heapq\nimport itertools\n\n\n# A* Search Algorithm\nclass Solution(object):\n    def slidingPuzzle(self, board):\n        \"\"\"\n        :type board: List[List[int]]\n        :rtype: int\n        \"\"\"\n        def dot(p1, p2):\n            return p1[0]*p2[0]+p1[1]*p2[1]\n\n        def heuristic_estimate(board, R, C, expected):\n            result = 0\n            for i in xrange(R):\n                for j in xrange(C):\n                    val = board[C*i + j]\n                    if val == 0: continue\n                    r, c = expected[val]\n                    result += abs(r-i) + abs(c-j)\n            return result\n\n        R, C = len(board), len(board[0])\n        begin = tuple(itertools.chain(*board))\n        end = tuple(range(1, R*C) + [0])\n        expected = {(C*i+j+1) % (R*C) : (i, j)\n                    for i in xrange(R) for j in xrange(C)}\n\n        min_steps = heuristic_estimate(begin, R, C, expected)\n        closer, detour = [(begin.index(0), begin)], []\n        lookup = set()\n        while True:\n            if not closer:\n                if not detour:\n                    return -1\n                min_steps += 2\n                closer, detour = detour, closer\n            zero, board = closer.pop()\n            if board == end:\n                return min_steps\n            if board not in lookup:\n                lookup.add(board)\n                r, c = divmod(zero, C)\n                for direction in ((-1, 0), (1, 0), (0, -1), (0, 1)):\n                    i, j = r+direction[0], c+direction[1]\n                    if 0 <= i < R and 0 <= j < C:\n                        new_zero = i*C+j\n                        tmp = list(board)\n                        tmp[zero], tmp[new_zero] = tmp[new_zero], tmp[zero]\n                        new_board = tuple(tmp)\n                        r2, c2 = expected[board[new_zero]]\n                        r1, c1 = divmod(zero, C)\n                        r0, c0 = divmod(new_zero, C)\n                        is_closer = dot((r1-r0, c1-c0), (r2-r0, c2-c0)) > 0\n                        (closer if is_closer else detour).append((new_zero, new_board))\n        return min_steps\n\n\n# Time:  O((m * n) * (m * n)! * log((m * n)!))\n# Space: O((m * n) * (m * n)!)\n# A* Search Algorithm\nclass Solution2(object):\n    def slidingPuzzle(self, board):\n        \"\"\"\n        :type board: List[List[int]]\n        :rtype: int\n        \"\"\"\n        def heuristic_estimate(board, R, C, expected):\n            result = 0\n            for i in xrange(R):\n                for j in xrange(C):\n                    val = board[C*i + j]\n                    if val == 0: continue\n                    r, c = expected[val]\n                    result += abs(r-i) + abs(c-j)\n            return result\n\n        R, C = len(board), len(board[0])\n        begin = tuple(itertools.chain(*board))\n        end = tuple(range(1, R*C) + [0])\n        end_wrong = tuple(range(1, R*C-2) + [R*C-1, R*C-2, 0])\n        expected = {(C*i+j+1) % (R*C) : (i, j)\n                    for i in xrange(R) for j in xrange(C)}\n\n        min_heap = [(0, 0, begin.index(0), begin)]\n        lookup = {begin: 0}\n        while min_heap:\n            f, g, zero, board = heapq.heappop(min_heap)\n            if board == end: return g\n            if board == end_wrong: return -1\n            if f > lookup[board]: continue\n\n            r, c = divmod(zero, C)\n            for direction in ((-1, 0), (1, 0), (0, -1), (0, 1)):\n                i, j = r+direction[0], c+direction[1]\n                if 0 <= i < R and 0 <= j < C:\n                    new_zero = C*i+j\n                    tmp = list(board)\n                    tmp[zero], tmp[new_zero] = tmp[new_zero], tmp[zero]\n                    new_board = tuple(tmp)\n                    f = g+1+heuristic_estimate(new_board, R, C, expected)\n                    if f < lookup.get(new_board, float(\"inf\")):\n                        lookup[new_board] = f\n                        heapq.heappush(min_heap, (f, g+1, new_zero, new_board))\n        return -1\n\n6:[\"$\",\"div\",null,{\"className\":\"mt-6 grid lg:grid-cols-[1fr_280px] gap-10\",\"children\":[[\"$\",\"article\",null,{\"children\":[[\"$\",\"header\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-wrap items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-sm text-muted-foreground tabular-nums\",\"children\":[\"#\",773]}],[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\",\"children\":\"Hard\"}],false,[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":[\"~\",50,\" min\"]}]]}],[\"$\",\"h1\",null,{\"className\":\"text-3xl md:text-4xl font-bold tracking-tight\",\"children\":\"Sliding Puzzle\"}],[\"$\",\"p\",null,{\"className\":\"text-muted-foreground max-w-2xl\",\"children\":[\"Time \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O((m * n) * (m * n)!)\"}],\" · \",\"Space \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O((m * n) * (m * n)!)\"}],\" · \",[\"$\",\"a\",null,{\"href\":\"https://leetcode.com/problems/sliding-puzzle/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-primary underline-offset-2 hover:underline\",\"children\":\"Official statement on LeetCode\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[[\"$\",\"$L9\",\"breadth-first-search\",{\"href\":\"/topics/breadth-first-search\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-primary/15 text-primary\",\"children\":\"breadth first search\"}]}]],[[\"$\",\"$L9\",\"a-search-algorithm\",{\"href\":\"/patterns/a-search-algorithm\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"a search algorithm\"}]}]],[]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2 pt-1\",\"children\":[[\"$\",\"$La\",null,{\"slug\":\"sliding-puzzle\"}],[[\"$\",\"$L9\",\"cpp\",{\"href\":\"/problems/sliding-puzzle/cpp\",\"className\":\"text-sm text-primary hover:underline\",\"children\":\"cpp\"}],[\"$\",\"$L9\",\"python\",{\"href\":\"/problems/sliding-puzzle/python\",\"className\":\"text-sm text-primary hover:underline\",\"children\":\"python\"}]]]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"id\":\"solutions\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Solutions\"}],[\"$\",\"$Lb\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"sliding-puzzle.cpp\",\"code\":\"$c\",\"sourcePath\":\"C++/sliding-puzzle.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"sliding-puzzle.py\",\"code\":\"$d\",\"sourcePath\":\"Python/sliding-puzzle.py\"}}}]]}],[\"$Le\",\"$Lf\",\"$L10\",\"$L11\",\"$L12\",\"$L13\",\"$L14\",\"$L15\",\"$L16\",\"$L17\"],\"$L18\",\"$L19\",\"$L1a\",\"$L1b\",\"$L1c\",\"$L1d\"]}],\"$L1e\"]}]\n7:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/259rkrk9l2f9c.js\",\"async\":true}]\n8:[\"$\",\"$L1f\",null,{\"children\":[\"$\",\"$20\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@21\"}]}]\ne:[\"$\",\"section\",\"beginner\",{\"id\":\"beginner\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Beginner Explanation\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>What is Sliding Puzzle?</h2>\\n<p><strong>Sliding Puzzle</strong> (LeetCode #773) is a <strong>Hard</strong> problem that primarily trains <strong>breadth first search</strong>.</p>\\n<h3>How to think about it</h3>\\n<ol>\\n<li><strong>Restate the goal</strong> in your own words before coding.</li>\\n<li>Work a <strong>tiny example</strong> by hand so the invariant becomes obvious.</li>\\n<li>Identify the <strong>pattern</strong> — this problem aligns with <strong>a search algorithm</strong>.</li>\\n<li>Only then translate the idea into code.</li>\\n</ol>\\n<h3>Why this problem matters</h3>\\n<p>Hard problems force you to combine patterns and prove complexity carefully — interview gold.\\nOfficial solution notes mention: A* Search Algorithm.</p>\\n<blockquote>\\n<p>AlgoForge explanations are original teaching notes. Always open the <a href=\\\"https://leetcode.com/problems/sliding-puzzle/\\\">official problem statement on LeetCode</a> for constraints and examples.</p>\\n</blockquote>\\n\"}}]]}]\n22:T4d5,<h2>Interview approach for Sliding Puzzle</h2>\n<h3>Opening (30–60 seconds)</h3>\n<ul>\n<li>Clarify inputs/outputs and edge cases (empty input, single element, duplicates, overflow).</li>\n<li>State a <strong>brute force</strong> so the interviewer knows you can solve it naively.</li>\n<li>Propose the <strong>optimal direction</strong> tied to <strong>a search algorithm</strong>.</li>\n</ul>\n<h3>Core solution narrative</h3>\n<ol>\n<li>Define the <strong>state</strong> you track (pointers, DP cell, set membership, stack top, etc.).</li>\n<li>Explain the <strong>transition</strong> when you process the next element.</li>\n<li>Call out <strong>time</strong> (O((m * n) * (m * n)!)) and <strong>space</strong> (O((m * n) * (m * n)!)) before coding.</li>\n<li>Code cleanly; narrate variable names.</li>\n</ol>\n<h3>What interviewers listen for</h3>\n<ul>\n<li>Correctness on edge cases</li>\n<li>Complexity honesty</li>\n<li>Ability to discuss <strong>trade-offs</strong> (e.g., hash map space vs. sort + two pointers)</li>\n</ul>\n<h3>Follow-up questions they may ask</h3>\n<ul>\n<li>Can you solve it with less memory?</li>\n<li>What if the input stream is infinite / doesn't fit in RAM?</li>\n<li>How would tests look for adversarial inputs?</li>\n</ul>\nf:[\"$\",\"section\",\"interview\",{\"id\":\"interview\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Interview Walkthrough\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"$22\"}}]]}]\n10:[\"$\",\"section\",\"optimized\",{\"id\":\"optimized\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Optimized Approach\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Optimized solution notes</h2>\\n<p>The reference solutions on AlgoForge target <strong>O((m * n) * (m * n)!)</strong> time and <strong>O((m * n) * (m * n)!)</strong> space.</p>\\n<h3>Pattern focus: a search algorithm</h3>\\n<p>Use the pattern as a checklist:</p>\\n<ul>\\n<li><strong>a search algorithm</strong> — confirm the invariant holds after each step</li>\\n</ul>\\n<p>Multiple methods appear in the source solutions — compare them and explain when each is preferable.</p>\\n<h3>Implementation tips</h3>\\n<ul>\\n<li>Prefer readable names over micro-optimizations in interviews.</li>\\n<li>Extract helpers only when they clarify (e.g., expand-around-center, DFS visit).</li>\\n<li>After AC-level logic, re-scan for off-by-one and null checks.</li>\\n</ul>\\n\"}}]]}]\n11:[\"$\",\"section\",\"complexity\",{\"id\":\"complexity\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Complexity Analysis\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Complexity</h2>\\n<table>\\n<thead>\\n<tr>\\n<th>Measure</th>\\n<th>Bound</th>\\n</tr>\\n</thead>\\n<tbody>\\n<tr>\\n<td>Time</td>\\n<td><strong>O((m * n) * (m * n)!)</strong></td>\\n</tr>\\n<tr>\\n<td>Space</td>\\n<td><strong>O((m * n) * (m * n)!)</strong></td>\\n</tr>\\n</tbody>\\n</table>\\n<h3>How to justify this in an interview</h3>\\n<ul>\\n<li><strong>Time:</strong> count loops, map/set operations, and recursive branching; state average vs worst case if relevant.</li>\\n<li><strong>Space:</strong> include hash maps, recursion stack, and output allocation when the problem asks for it.</li>\\n</ul>\\n<p>If your implementation differs from the reference, re-derive big-O from <em>your</em> code — never memorize a complexity you cannot defend.</p>\\n\"}}]]}]\n12:[\"$\",\"section\",\"common-mistakes\",{\"id\":\"common-mistakes\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Common Mistakes\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Common mistakes on Sliding Puzzle</h2>\\n<ol>\\n<li><strong>Skipping edge cases</strong> — empty collections, single-element inputs, max constraints.</li>\\n<li><strong>Wrong invariant</strong> for a search algorithm — updating state too early or too late.</li>\\n<li><strong>Mutating input unexpectedly</strong> when the problem forbids it.</li>\\n<li><strong>Off-by-one</strong> in windows, ranges, or binary search bounds.</li>\\n<li><strong>Ignoring overflow / precision</strong> for integer arithmetic problems.</li>\\n<li><strong>Overengineering</strong> — jumping to an advanced structure when a simpler approach works.</li>\\n</ol>\\n\"}}]]}]\n13:[\"$\",\"section\",\"alternatives\",{\"id\":\"alternatives\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Alternative Approaches\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Alternatives</h2>\\n<p>The source file includes more than one method. Compare:</p>\\n<ol>\\n<li><strong>Primary optimized path</strong> — best complexity for typical interviews.</li>\\n<li><strong>Secondary approach</strong> — often brute force, sorting-based, or space-optimized variant.</li>\\n</ol>\\n<p>Practice articulating <strong>when</strong> you would pick each (constraints, readability, follow-ups).</p>\\n\"}}]]}]\n14:[\"$\",\"section\",\"edge-cases\",{\"id\":\"edge-cases\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Edge Cases\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Edge cases checklist</h2>\\n<ul>\\n<li>Minimum input size</li>\\n<li>Maximum input size / time limits</li>\\n<li>Duplicates and already-sorted input</li>\\n<li>Negative numbers / zeros (if applicable)</li>\\n<li>Disconnected structures (graphs/trees)</li>\\n<li>Single path vs branching recursion depth</li>\\n</ul>\\n\"}}]]}]\n15:[\"$\",\"section\",\"pattern-recognition\",{\"id\":\"pattern-recognition\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Pattern Recognition\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Spotting this pattern</h2>\\n<p>Signal phrases that point to <strong>a search algorithm</strong>:</p>\\n<ul>\\n<li>Sorted input or ability to sort without changing the answer class</li>\\n<li>Need for contiguous subarray / substring → consider sliding window</li>\\n<li>Need for O(1) membership → hash set/map</li>\\n<li>Optimal substructure + overlapping subproblems → DP</li>\\n<li>Connectivity / components → graph DFS/BFS or Union-Find</li>\\n</ul>\\n<p>Primary topics: <strong>breadth first search</strong>.</p>\\n\"}}]]}]\n16:[\"$\",\"section\",\"follow-ups\",{\"id\":\"follow-ups\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Follow-up Interview Questions\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Follow-ups</h2>\\n<ol>\\n<li>How does the solution change if the input is a stream?</li>\\n<li>Can you solve it in-place?</li>\\n<li>What if duplicates must be handled differently?</li>\\n<li>How would you parallelize the approach?</li>\\n<li>Design tests that would break a buggy implementation.</li>\\n</ol>\\n\"}}]]}]\n17:[\"$\",\"section\",\"practice\",{\"id\":\"practice\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Practice Recommendations\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>What to practice next</h2>\\n<ol>\\n<li>Re-solve <strong>Sliding Puzzle</strong> in a second language (cpp, python).</li>\\n<li>Drill 3–5 more problems tagged <strong>breadth first search</strong>.</li>\\n<li>Teach the solution out loud in under 5 minutes.</li>\\n<li>Add this problem to your revision calendar in 3 days and 14 days.</li>\\n</ol>\\n\"}}]]}]\n18:[\"$\",\"section\",null,{\"id\":\"visualization\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Visualization\"}],[\"$\",\"div\",null,{\"className\":\"rounded-xl border border-dashed border-border bg-muted/40 p-6 text-sm text-muted-foreground\",\"children\":\"Conceptual diagram for Sliding Puzzle: show input structure (breadth first search), highlight the moving parts of the a search algorithm approach, and annotate each step with the maintained invariant and complexity.\"}]]}]\n19:[\"$\",\"section\",null,{\"id\":\"checklist\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Study checklist\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"li\",\"Read the official problem statement on LeetCode\",{\"className\":\"flex gap-2 text-sm\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-primary\",\"aria-hidden\":true,\"children\":\"☐\"}],\"Read the official problem statement on LeetCode\"]}],[\"$\",\"li\",\"Solve on paper / whiteboard first\",{\"className\":\"flex gap-2 text-sm\",\"children\":[[\"$\",\"span