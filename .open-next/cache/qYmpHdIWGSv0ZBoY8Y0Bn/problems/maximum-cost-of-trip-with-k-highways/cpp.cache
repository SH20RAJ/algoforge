ed\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nd:[\"$\",\"$1\",\"c\",{\"children\":[\"$L15\",[[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0a2gmow1_jiq0.js\",\"async\":true,\"nonce\":\"$undefined\"}]],[\"$\",\"$L16\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@18\"}]}]]}]\n19:[]\ne:\"$W19\"\nf:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1a\",null,{\"children\":\"$L1b\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1d\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n11:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/340fxer6uczx7.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n1e:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n1f:T10ca,// Time:  O(n^2 * 2^n)\n// Space: O(n * 2^n)\n\n// combination based dp\nclass Solution {\npublic:\n    int maximumCost(int n, vector<vector<int>>& highways, int k) {\n        if (k + 1 > n) {  // optionally optimize\n            return -1;\n        }\n        vector<vector<pair<int, int>>> adj(n);\n        for (const auto& h : highways) {\n            adj[h[0]].emplace_back(h[1], h[2]);\n            adj[h[1]].emplace_back(h[0], h[2]);\n        }\n        vector<pair<int, vector<int>>> dp(1 << n);\n        for (int u = 0; u < n; ++u) {\n            dp[1 << u].second.emplace_back(u);\n        }\n        int result = k != 1 ? -1 : 0;\n        for (int cnt = 1; cnt <= n; ++cnt) {\n            combinations(n, cnt, \n                         [&k, &adj, &dp, &result](const vector<int>& idxs) {\n                             auto mask = accumulate(cbegin(idxs), cend(idxs), 0,\n                                                    [](const auto& a, const auto& b) {\n                                                        return a | (1 << b);\n                                                    });\n                             const auto& [total, lasts] = dp[mask];\n                             for (const auto& u : lasts) {\n                                 for (const auto& [v, t] : adj[u]) {\n                                     if (mask & (1 << v)) {\n                                         continue;\n                                     }\n                                     int new_mask = mask | (1 << v);\n                                     if (total + t < dp[new_mask].first) {\n                                         continue;\n                                     }\n                                     if (total + t == dp[new_mask].first) {\n                                         dp[new_mask].second.emplace_back(v);\n                                         continue;\n                                     }\n                                     dp[new_mask].first = total + t;\n                                     dp[new_mask].second = {v};\n                                     if (__builtin_popcount(mask) == k) {\n                                         result = max(result, dp[new_mask].first);\n                                     }\n                                 }\n                             }\n                         });\n        }\n        return result;\n    }\n\nprivate:\n    void combinations(int n, int k, const function<void (const vector<int>&)>& callback) {\n        static const auto& next_pos =\n            [](const auto& n, const auto& k, const auto& idxs) {\n                int i = k - 1;\n                for (; i >= 0; --i) {\n                    if (idxs[i] != i + n - k) {\n                        break;\n                    }\n                }\n                return i;\n            };\n    \n        vector<int> idxs(k);\n        iota(begin(idxs), end(idxs), 0);\n        callback(idxs);\n        for (int i; (i = next_pos(n, k, idxs)) >= 0;) {\n            ++idxs[i];\n            for (int j = i + 1; j < k; ++j) {\n                idxs[j] = idxs[j - 1] + 1;\n            }\n            callback(idxs);\n        }\n    }\n};\n\n// Time:  O(n^2 * 2^n)\n// Space: O(n * 2^n)\n// bfs based dp\nclass Solution2 {\npublic:\n    int maximumCost(int n, vector<vector<int>>& highways, int k) {\n        if (k + 1 > n) {  // required to optimize\n            return -1;\n        }\n        vector<vector<pair<int, int>>> adj(n);\n        for (const auto& h : highways) {\n            adj[h[0]].emplace_back(h[1], h[2]);\n            adj[h[1]].emplace_back(h[0], h[2]);\n        }\n        vector<tuple<int, int, int>> dp;\n        for (int u = 0; u < n; ++u) {\n            dp.emplace_back(u, 1 << u, 0);\n        }\n        int result = -1;\n        while (!empty(dp)) {\n            vector<tuple<int, int, int>> new_dp;\n            for (const auto& [u, mask, total] : dp) {\n                if (__builtin_popcount(mask) == k + 1) {\n                    result = max(result, total);\n                }\n                for (const auto& [v, t] : adj[u]) {\n                    if (mask & (1 << v)) {\n                        continue;\n                    }\n                    new_dp.emplace_back(v, mask | (1 << v), total + t);\n                }\n            }\n            dp = move(new_dp);\n        }\n        return result;\n    }\n};\n20:T97b,# Time:  O(n^2 * 2^n)\n# Space: O(n * 2^n)\n\nimport itertools\n\n\n# combination based dp\nclass Solution(object):\n    def maximumCost(self, n, highways, k):\n        \"\"\"\n        :type n: int\n        :type highways: List[List[int]]\n        :type k: int\n        :rtype: int\n        \"\"\"\n        if k+1 > n:  # optionally optimize\n            return -1\n        adj = [[] for _ in xrange(n)]\n        for c1, c2, t in highways:\n            adj[c1].append((c2, t))\n            adj[c2].append((c1, t))\n        result = -1 if k != 1 else 0\n        dp = [[0, []] for _ in xrange((1<<n))]\n        for i in xrange(n):\n            dp[1<<i][1].append(i)\n        for cnt in xrange(1, n+1):\n            for choice in itertools.combinations(xrange(n), cnt):\n                mask = reduce(lambda x, y:x|(1<<y), choice, 0)\n                total, lasts = dp[mask]\n                for u in lasts:\n                    for v, t in adj[u]:\n                        if mask&(1<<v):\n                            continue\n                        new_mask = mask|(1<<v)\n                        if total+t < dp[new_mask][0]:\n                            continue\n                        if total+t == dp[new_mask][0]:\n                            dp[new_mask][1].append(v)\n                            continue\n                        dp[new_mask][0] = total+t\n                        dp[new_mask][1] = [v]\n                        if bin(mask).count('1') == k:\n                            result = max(result, dp[new_mask][0])\n        return result\n\n\n# Time:  O(n^2 * 2^n)\n# Space: O(n * 2^n)\n# bfs based dp\nclass Solution2(object):\n    def maximumCost(self, n, highways, k):\n        \"\"\"\n        :type n: int\n        :type highways: List[List[int]]\n        :type k: int\n        :rtype: int\n        \"\"\"\n        if k+1 > n:  # required to optimize, otherwise, TLE or MLE\n            return -1\n        adj = [[] for _ in xrange(n)]\n        for c1, c2, t in highways:\n            adj[c1].append((c2, t))\n            adj[c2].append((c1, t))\n        result = -1\n        dp = [(u, 1<<u, 0) for u in xrange(n)]\n        while dp:\n            new_dp = []\n            for u, mask, total in dp:\n                if bin(mask).count('1') == k+1:\n                    result = max(result, total)\n                for v, t in adj[u]:\n                    if mask&(1<<v) == 0:\n                        new_dp.append((v, mask|(1<<v), total+t))\n            dp = new_dp\n        return result\n15:[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Maximum Cost of Trip With K Highways\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/maximum-cost-of-trip-with-k-highways\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"C++\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/maximum-cost-of-trip-with-k-highways/cpp\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/maximum-cost-of-trip-with-k-highways\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"clas