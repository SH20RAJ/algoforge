ms-center gap-2 font-bold tracking-tight\" href=\"/\"><span class=\"inline-flex h-7 w-7 items-center justify-center rounded-md bg-primary text-primary-foreground text-xs font-black\">AF</span><span class=\"hidden sm:inline\">AlgoForge</span></a><nav class=\"hidden lg:flex items-center gap-1\" aria-label=\"Main\"><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/problems\">Problems</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/topics\">Topics</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/patterns\">Patterns</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/roadmaps\">Roadmaps</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blind-75\">Blind 75</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/companies\">Companies</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blog\">Blog</a></nav></div><div class=\"flex items-center gap-1\"><a class=\"hidden sm:inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-1.5 text-sm text-muted-foreground hover:border-primary/40 transition-colors\" href=\"/search\"><span>Search…</span><kbd class=\"rounded border border-border bg-muted px-1.5 text-[10px] font-mono\">/</kbd></a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground\" href=\"/dashboard\">Progress</a><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 hover:bg-muted text-foreground h-9 w-9\" aria-label=\"Toggle theme\"></button></div></div></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Maximum Cost of Trip With K Highways\",\"item\":\"https://algoforge.dev/problems/maximum-cost-of-trip-with-k-highways\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"C++\",\"item\":\"https://algoforge.dev/problems/maximum-cost-of-trip-with-k-highways/cpp\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/maximum-cost-of-trip-with-k-highways\">Maximum Cost of Trip With K Highways</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">C++</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\">Hard</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Maximum Cost of Trip With K Highways<!-- --> — <!-- -->C++</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/maximum-cost-of-trip-with-k-highways\">Full explanation</a> · <!-- -->Time <!-- -->O(n^2 * 2^n)<!-- --> · Space <!-- -->O(n * 2^n)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">C++</button><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code>// Time:  O(n^2 * 2^n)\n// Space: O(n * 2^n)\n\n// combination based dp\nclass Solution {\npublic:\n    int maximumCost(int n, vector&lt;vector&lt;int&gt;&gt;&amp; highways, int k) {\n        if (k + 1 &gt; n) {  // optionally optimize\n            return -1;\n        }\n        vector&lt;vector&lt;pair&lt;int, int&gt;&gt;&gt; adj(n);\n        for (const auto&amp; h : highways) {\n            adj[h[0]].emplace_back(h[1], h[2]);\n            adj[h[1]].emplace_back(h[0], h[2]);\n        }\n        vector&lt;pair&lt;int, vector&lt;int&gt;&gt;&gt; dp(1 &lt;&lt; n);\n        for (int u = 0; u &lt; n; ++u) {\n            dp[1 &lt;&lt; u].second.emplace_back(u);\n        }\n        int result = k != 1 ? -1 : 0;\n        for (int cnt = 1; cnt &lt;= n; ++cnt) {\n            combinations(n, cnt, \n                         [&amp;k, &amp;adj, &amp;dp, &amp;result](const vector&lt;int&gt;&amp; idxs) {\n                             auto mask = accumulate(cbegin(idxs), cend(idxs), 0,\n                                                    [](const auto&amp; a, const auto&amp; b) {\n                                                        return a | (1 &lt;&lt; b);\n                                                    });\n                             const auto&amp; [total, lasts] = dp[mask];\n                             for (const auto&amp; u : lasts) {\n                                 for (const auto&amp; [v, t] : adj[u]) {\n                                     if (mask &amp; (1 &lt;&lt; v)) {\n                                         continue;\n                                     }\n                                     int new_mask = mask | (1 &lt;&lt; v);\n                                     if (total + t &lt; dp[new_mask].first) {\n                                         continue;\n                                     }\n                                     if (total + t == dp[new_mask].first) {\n                                         dp[new_mask].second.emplace_back(v);\n                                         continue;\n                                     }\n                                     dp[new_mask].first = total + t;\n                                     dp[new_mask].second = {v};\n                                     if (__builtin_popcount(mask) == k) {\n                                         result = max(result, dp[new_mask].first);\n                                     }\n                                 }\n                             }\n                         });\n        }\n        return result;\n    }\n\nprivate:\n    void combinations(int n, int k, const function&lt;void (const vector&lt;int&gt;&amp;)&gt;&amp; callback) {\n        static const auto&amp; next_pos =\n            [](const auto&amp; n, const auto&amp; k, const auto&amp; idxs) {\n                int i = k - 1;\n                for (; i &gt;= 0; --i) {\n                    if (idxs[i] != i + n - k) {\n                        break;\n                    }\n                }\n                return i;\n            };\n    \n        vector&lt;int&gt; idxs(k);\n        iota(begin(idxs), end(idxs), 0);\n        callback(idxs);\n        for (int i; (i = next_pos(n, k, idxs)) &gt;= 0;) {\n            ++idxs[i];\n            for (int j = i + 1; j &lt; k; ++j) {\n                idxs[j] = idxs[j - 1] + 1;\n            }\n            callback(idxs);\n        }\n    }\n};\n\n// Time:  O(n^2 * 2^n)\n// Space: O(n * 2^n)\n// bfs based dp\nclass Solution2 {\npublic:\n    int maximumCost(int n, vector&lt;vector&lt;int&gt;&gt;&amp; highways, int k) {\n        if (k + 1 &gt; n) {  // required to optimize\n            return -1;\n        }\n        vector&lt;vector&lt;pair&lt;int, int&gt;&gt;&gt; adj(n);\n        for (const auto&amp; h : highways) {\n            adj[h[0]].emplace_back(h[1], h[2]);\n            adj[h[1]].emplace_back(h[0], h[2]);\n        }\n        vector&lt;tuple&lt;int, int, int&gt;&gt; dp;\n        for (int u = 0; u &lt; n; ++u) {\n            dp.emplace_back(u, 1 &lt;&lt; u, 0);\n        }\n        int result = -1;\n        while (!empty(dp)) {\n            vector&lt;tuple&lt;int, int, int&gt;&gt; new_dp;\n            for (const auto&amp; [u, mask, total] : dp) {\n                if (__builtin_popcount(mask) == k + 1) {\n                    result = max(result, total);\n                }\n                for (const auto&amp; [v, t] : adj[u]) {\n                    if (mask &amp; (1 &lt;&lt; v)) {\n                        continue;\n                    }\n                    new_dp.emplace_back(v, mask | (1 &lt;&lt; v), total + t);\n                }\n            }\n            dp = move(new_dp);\n        }\n        return result;\n    }\n};\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">Learn</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/problems\">Problems</a></li><li><a class=\"hover:text-primary\" href=\"/patterns\">Patterns</a></li><li><a class=\"hover:text-primary\" href=\"/roadmaps\">Roadmaps</a></li><li><a class=\"hover:text-primary\" href=\"/blind-75\">Blind 75</a></li><li><a class=\"hover:text-primary\" href=\"/grind-169\">Grind 169</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Interview</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/companies\">Companies</a></li><li><a class=\"hover:text-primary\" href=\"/interview-preparation\">Interview prep</a></li><li><a class=\"hover:text-primary\" href=\"/system-design\">System design</a></li><li><a class=\"hover:text-primary\" href=\"/glossary\">Glossary</a></li><li><a class=\"hover:text-primary\" href=\"/blog\">Blog</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Product</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hove