},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":5,\\\"text\\\":\\\"State time and space complexity aloud\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":6,\\\"text\\\":\\\"Compare with the AlgoForge reference solution\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":7,\\\"text\\\":\\\"Schedule a revision session\\\"}]}\"}}],[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Maximum Profitable Triplets With Increasing Prices I\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/maximum-profitable-triplets-with-increasing-prices-i\\\"}]}\"}}],\"$L1e\"]}],\"$L1f\"]}]\n20:I[56303,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"BookmarkButton\"]\n1e:[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/maximum-profitable-triplets-with-increasing-prices-i\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"Maximum Profitable Triplets With Increasing Prices I\"}]]}]]}]\n1f:[\"$\",\"div\",null,{\"className\":\"mt-6 grid lg:grid-cols-[1fr_280px] gap-10\",\"children\":[[\"$\",\"article\",null,{\"children\":[[\"$\",\"header\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-wrap items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-sm text-muted-foreground tabular-nums\",\"children\":[\"#\",2907]}],[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-medium/15 text-medium\",\"children\":\"Medium\"}],[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-muted text-muted-foreground\",\"children\":\"Premium on LC\"}],[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":[\"~\",35,\" min\"]}]]}],[\"$\",\"h1\",null,{\"className\":\"text-3xl md:text-4xl font-bold tracking-tight\",\"children\":\"Maximum Profitable Triplets With Increasing Prices I\"}],[\"$\",\"p\",null,{\"className\":\"text-muted-foreground max-w-2xl\",\"children\":[\"Time \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O(nlogn)\"}],\" · \",\"Space \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O(n)\"}],\" · \",[\"$\",\"a\",null,{\"href\":\"https://leetcode.com/problems/maximum-profitable-triplets-with-increasing-prices-i/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-primary underline-offset-2 hover:underline\",\"children\":\"Official statement on LeetCode\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[[\"$\",\"$L3\",\"binary-search-tree\",{\"href\":\"/topics/binary-search-tree\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-primary/15 text-primary\",\"children\":\"binary search tree\"}]}]],[[\"$\",\"$L3\",\"prefix-sum\",{\"href\":\"/patterns/prefix-sum\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"prefix sum\"}]}],[\"$\",\"$L3\",\"sorted-list\",{\"href\":\"/patterns/sorted-list\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"sorted list\"}]}],[\"$\",\"$L3\",\"binary-search\",{\"href\":\"/patterns/binary-search\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"binary search\"}]}],[\"$\",\"$L3\",\"stack\",{\"href\":\"/patterns/stack\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"stack\"}]}],[\"$\",\"$L3\",\"fenwick-tree\",{\"href\":\"/patterns/fenwick-tree\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"fenwick tree\"}]}],[\"$\",\"$L3\",\"segment-tree\",{\"href\":\"/patterns/segment-tree\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"segment tree\"}]}]],[]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2 pt-1\",\"children\":[[\"$\",\"$L20\",null,{\"slug\":\"maximum-profitable-triplets-with-increasing-prices-i\"}],[[\"$\",\"$L3\",\"cpp\",{\"href\":\"/problems/maximum-profitable-triplets-with-increasing-prices-i/cpp\",\"className\":\"text-sm text-primary hover:underline\",\"children\":\"cpp\"}],[\"$\",\"$L3\",\"python\",{\"href\":\"/problems/maximum-profitable-triplets-with-increasing-prices-i/python\",\"className\":\"text-sm text-primary hover:underline\",\"children\":\"python\"}]]]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"id\":\"solutions\",\"children\":[\"$L21\",\"$L22\"]}],[\"$L23\",\"$L24\",\"$L25\",\"$L26\",\"$L27\",\"$L28\",\"$L29\",\"$L2a\",\"$L2b\",\"$L2c\"],\"$L2d\",\"$L2e\",\"$L2f\",\"$L30\",\"$L31\",\"$L32\"]}],\"$L33\"]}]\n34:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"CodeTabs\"]\n41:I[203221,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"ConfidenceTracker\"]\n21:[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Solutions\"}]\n35:T279c,// Time:  O(nlogn)\n// Space: O(n)\n\n// prefix sum, bst, binary search, mono stack\nclass Solution {\npublic:\n    int maxProfit(vector<int>& prices, vector<int>& profits) {\n        static const int NEG_INF = numeric_limits<int>::min();\n\n        const auto& query = [](const auto& bst, const auto& k) {\n            const auto it = bst.lower_bound(pair(k, 0));\n            return it != begin(bst) ? prev(it)->second : NEG_INF;\n        };\n\n        const auto& update = [](auto& bst, const auto& k, const auto& v) {\n            const auto it = bst.lower_bound(pair(k, 0));\n            if (it != end(bst) && it->first == k) {\n                if (!(it->second < v)) {\n                    return;\n                }\n                bst.erase(it);\n            } else if (!(it == begin(bst) || prev(it)->second < v)) {\n                return;\n            }\n            const auto [jt, _] = bst.emplace(k, v);\n            while (next(jt) != end(bst) && next(jt)->second <= jt->second) {\n                bst.erase(next(jt));\n            }\n        };\n\n        int result = NEG_INF;\n        set<pair<int, int>> bst1, bst2;\n        for (int i = 0; i < size(prices); ++i) {\n            const int mx2 = query(bst2, prices[i]);\n            if (mx2 != NEG_INF) {\n                result = max(result, mx2 + profits[i]);\n            }\n            update(bst1, prices[i], profits[i]);\n            const int mx1 = query(bst1, prices[i]);\n            if (mx1 != NEG_INF) {\n                update(bst2, prices[i], mx1 + profits[i]);\n            }\n        }\n        return result != NEG_INF ? result : -1;\n    }\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// prefix sum, bst, binary search, mono stack\nclass Solution2 {\npublic:\n    int maxProfit(vector<int>& prices, vector<int>& profits) {\n        static const int NEG_INF = numeric_limits<int>::min();\n\n        vector<int> right(size(prices), NEG_INF);\n        set<pair<int, int>> bst;\n        for (int i = size(prices) - 1; i >= 0; --i) {\n            const auto it = bst.lower_bound(pair(-prices[i], 0));\n            if (it != begin(bst)) {\n                right[i] = prev(it)->second;\n            }\n            if (!(it == begin(bst) || prev(it)->second < profits[i])) {\n                continue;\n            }\n            const auto [jt, _] = bst.emplace(-prices[i], profits[i]);\n            while (next(jt) != end(bst) && next(jt)->second <= jt->second) {\n                bst.erase(next(jt));\n            }\n        }\n        int result = NEG_INF;\n        bst.clear();\n        for (int i = 0; i < size(prices); ++i) {\n            const auto it = bst.lower_bound(pair(prices[i], 0));\n            if (it != begin(bst)) {\n                if (prev(it)->second != NEG_INF && right[i] != NEG_INF) {\n                    result = max(result, prev(it)->second + profits[i] + right[i]);\n                }\n            }\n            if (!(it == begin(bst) || prev(it)->second < profits[i])) {\n                continue;\n            }\n            const auto [jt, _] = bst.emplace(prices[i], profits[i]);\n            while (next(jt) != end(bst) && next(jt)->second <= jt->second) {\n                bst.erase(next(jt));\n            }\n        }\n        return result != NEG_INF ? result : -1;\n    }\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// prefix sum, bit, fenwick tree\nclass Solution3 {\npublic:\n    int maxProfit(vector<int>& prices, vector<int>& profits) {\n        static const int NEG_INF = numeric_limits<int>::min();\n\n        unordered_set<int> prices_set(cbegin(prices), cend(prices));\n        vector<int> sorted_prices(cbegin(prices_set), cend(prices_set));\n        sort(begin(sorted_prices), end(sorted_prices));\n        unordered_map<int, int> price_to_idx;\n        for (int i = 0; i < size(sorted_prices); ++i) {\n            price_to_idx[sorted_prices[i]] = i;\n        }\n        int result = NEG_INF;\n        const auto& fn = [](int a, int b) {\n            return max(a, b);\n        };\n        BIT bit1(size(price_to_idx), NEG_INF, fn), bit2(size(price_to_idx), NEG_INF, fn);\n        for (int i = 0; i < size(prices); ++i) {\n            const int mx2 = bit2.query(price_to_idx[prices[i]] - 1);\n            if (mx2 != NEG_INF) {\n                result = max(result, mx2 + profits[i]);\n            }\n            bit1.update(price_to_idx[prices[i]], profits[i]);\n            const int mx1 = bit1.query(price_to_idx[prices[i]] - 1);\n            if (mx1 != NEG_INF) {\n                bit2.update(price_to_idx[prices[i]], mx1 + profits[i]);\n            }\n        }\n        return result != NEG_INF ? result : -1;\n    }\n\nprivate:\n    class BIT {\n    public:\n        BIT(int n, int val, const function<int (int, int)> fn)\n          : bit_(n + 1, val),\n            fn_(fn) {  // 0-indexed\n        }\n        \n        void update(int i, int val) {\n            ++i;\n            for (; i < size(bit_); i += lower_bit(i)) {\n                bit_[i] = fn_(bit_[i], val);\n            }\n        }\n\n        int query(int i) const {\n            ++i;\n            int total = bit_[0];\n            for (; i > 0; i -= lower_bit(i)) {\n                total = fn_(total, bit_[i]);\n            }\n            return total;\n        }\n    \n    private:\n        int lower_bit(int i) const {\n            return i & -i;\n        }\n        \n        vector<int> bit_;\n        const function<int (int, int)> fn_;\n    };\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// prefix sum, segment tree\nclass Solution4 {\npublic:\n    int maxProfit(vector<int>& prices, vector<int>& profits) {\n        static const int NEG_INF = numeric_limits<int>::min();\n\n        unordered_set<int> prices_set(cbegin(prices), cend(prices));\n        vector<int> sorted_prices(cbegin(prices_set), cend(prices_set));\n        sort(begin(sorted_prices), end(sorted_prices));\n        unordered_map<int, int> price_to_idx;\n        for (int i = 0; i < size(sorted_prices); ++i) {\n            price_to_idx[sorted_prices[i]] = i;\n        }\n        int result = NEG_INF;\n        SegmentTree st1(size(price_to_idx)), st2(size(price_to_idx));\n        for (int i = 0; i < size(prices); ++i) {\n            const int mx2 = st2.query(0, price_to_idx[prices[i]] - 1);\n            if (mx2 != NEG_INF) {\n                result = max(result, mx2 + profits[i]);\n            }\n            st1.update(price_to_idx[prices[i]], profits[i]);\n            const int mx1 = st1.query(0, price_to_idx[prices[i]] - 1);\n            if (mx1 != NEG_INF) {\n                st2.update(price_to_idx[prices[i]], mx1 + profits[i]);\n            }\n        }\n        return result != NEG_INF ? result : -1;\n    }\n\nprivate:\n    class SegmentTree {\n    private:\n        const int NEG_INF = numeric_limits<int>::min();\n      \n    public:\n        explicit SegmentTree(int N)\n          : tree(N > 1 ? 1 << (__lg(N - 1) + 2) : 2, NEG_INF),\n            base(N > 1 ? 1 << (__lg(N - 1) + 1) : 1) {\n\n        }\n\n        void update(int i, int h) {\n            int x = base + i;\n            tree[x] = max(tree[x], h);\n            while (x > 1) {\n                x /= 2;\n                tree[x] = max(tree[x * 2], tree[x * 2 + 1]);\n            }\n        }\n\n        int query(int L, int R) {\n            int result = NEG_INF;\n            if (L > R) {\n                return result;\n            }\n            L += base;\n            R += base;\n            for (; L <= R; L /= 2, R /= 2) {\n                if (L & 1) {\n                    result = max(result, tree[L]);\n                    ++L;\n                }\n                if ((R & 1) == 0) {\n                    result = max(tree[R], result);\n                    --R;\n                }\n            }\n            return result;\n        }\n\n        vector<int> tree;\n        int base;\n    };\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// prefix sum, segment tree\nclass Solution5 {\npublic:\n    int maxProfit(vector<int>& prices, vector<int>& profits) {\n        static const int NEG_INF = numeric_limits<int>::min();\n\n        unordered_set<int> prices_set(cbegin(prices), cend(prices));\n        vector<int> sorted_prices(cbegin(prices_set), cend(prices_set));\n        sort(begin(sorted_prices), end(sorted_prices));\n        unordered_map<int, int> price_to_idx;\n        for (int i = 0; i < size(sorted_prices); ++i) {\n            price_to_idx[sorted_prices[i]] = i;\n        }\n        vector<int> right(size(prices), NEG_INF);\n        SegmentTree st2(size(price_to_idx));\n        for (int i = size(prices) - 1; i >= 0; --i) {\n            right[i] = st2.query(price_to_idx[prices[i]] + 1, size(price_to_idx) - 1);\n            st2.update(price_to_idx[prices[i]], profits[i]);\n        }\n        int result = NEG_INF;\n        vector<int> left(size(prices), NEG_INF);\n        SegmentTree st1(size(price_to_idx));\n        for (int i = 0; i < size(prices); ++i) {\n            const int left = st1.query(0, price_to_idx[prices[i]] - 1);\n            if (left != NEG_INF && right[i] != NEG_INF) {\n                result = max(result, left + profits[i] + right[i]);\n            }\n            st1.update(price_to_idx[prices[i]], profits[i]);\n        }\n        return result != NEG_INF ? result : -1;\n    }\n\nprivate:\n    class SegmentTree {\n    private:\n        const int NEG_INF = numeric_limits<int>::min();\n      \n    public:\n        explicit SegmentTree(int N)\n          : tree(N > 1 ? 1 << (__lg(N - 1) + 2) : 2, NEG_INF),\n            base(N > 1 ? 1 << (__lg(N - 1) + 1) : 1) {\n\n        }\n\n        void update(int i, int h) {\n            int x = base + i;\n            tree[x] = max(tree[x], h);\n            while (x > 1) {\n                x /= 2;\n                tree[x] = max(tree[x * 2], tree[x * 2 + 1]);\n            }\n        }\n\n        int query(int L, int R) {\n            int result = NEG_INF;\n            if (L > R) {\n                return result;\n            }\n            L += base;\n            R += base;\n            for (; L <= R; L /= 2, R /= 2) {\n                if (L & 1) {\n                    result = max(result, tree[L]);\n                    ++L;\n                }\n                if ((R & 1) == 0) {\n                    result = max(tree[R], result);\n                    --R;\n                }\n            }\n            return result;\n        }\n\n        vector<int> tree;\n        int base;\n    };\n};\n36:T2416,# Time:  O(nlogn)\n# Space: O(n)\n\nimport itertools\nfrom sortedcontainers import SortedList\n\n\n# prefix sum, sorted list, binary search, mono stack\nclass Solution(object):\n    def maxProfit(self, prices, profits):\n        \"\"\"\n        :type prices: List[int]\n        :type profits: List[int]\n        :rtype: int\n        \"\"\"\n        NEG_INF = float(\"-inf\")\n        def query(sl, k):\n            j = sl.bisect_left((k,))\n            return sl[j-1][1] if j-1 >= 0 else NEG_INF\n    \n        def update(sl, k, v):\n            j = sl.bisect_left((k,))\n            if j < len(sl) and sl[j][0] == k:\n                if not (sl[j][1] < v):\n                    return\n                del sl[j]\n            elif not (j-1 < 0 or sl[j-1][1] < v):\n                return\n            sl.add((k, v))\n            while j+1 < len(sl) and sl[j+1][1] <= sl[j][1]:\n                del sl[j+1]\n\n        result = NEG_INF\n        sl1, sl2 = SortedList(), SortedList()\n        for price, profit in itertools.izip(prices, profits):\n            result = max(result, query(sl2, price)+profit)\n            update(sl1, price, profit)\n            update(sl2, price, query(sl1, price)+profit)\n        return result if result != NEG_INF else -1\n\n\n# Time:  O(nlogn)\n# Space: O(n)\nfrom sortedcontainers import SortedList\n\n\n# prefix sum, sorted list, binary search, mono stack\nclass Solution2(object):\n    def maxProfit(self, prices, profits):\n        \"\"\"\n        :type prices: List[int]\n        :type profits: List[int]\n        :rtype: int\n        \"\"\"\n        NEG_INF = float(\"-inf\")\n\n        right = [NEG_INF]*len(prices)\n        sl = SortedList()\n        for i in reversed(xrange(len(prices))):\n            j = sl.bisect_left((-prices[i],))\n            if j-1 >= 0:\n                right[i] = sl[j-1][1]\n            if not (j-1 < 0 or sl[j-1][1] < profits[i]):\n                continue\n            sl.add((-prices[i], profits[i]))\n            j = sl.bisect_left((-prices[i], profits[i]))\n            while j+1 < len(sl) and sl[j+1][1] <= sl[j][1]:\n                del sl[j+1]\n        result = NEG_INF\n        sl = SortedList()\n        for i in xrange(len(prices)):\n            j = sl.bisect_left((prices[i],))\n            if j-1 >= 0:\n                result = max(result, sl[j-1][1]+profits[i]+right[i])\n            if not (j-1 < 0 or sl[j-1][1] < profits[i]):\n                continue\n            sl.add((prices[i], profits[i]))\n            j = sl.bisect_left((prices[i], profits[i]))\n            while j+1 < len(sl) and sl[j+1][1] <= sl[j][1]:\n                del sl[j+1]\n        return result if result != NEG_INF else -1\n\n\n# Time:  O(nlogn)\n# Space: O(n)\nimport itertools\n\n\n# prefix sum, bit, fenwick tree\nclass Solution3(object):\n    def maxProfit(self, prices, profits):\n        \"\"\"\n        :type prices: List[int]\n        :type profits: List[int]\n        :rtype: int\n        \"\"\"\n        NEG_INF = float(\"-inf\")\n        class BIT(object):  # 0-indexed.\n            def __init__(self, n, default=0, fn=lambda x, y: x+y):\n                self.__bit = [NEG_INF]*(n+1)  # Extra one for dummy node.\n                self.__default = default\n                self.__fn = fn\n\n            def update(self, i, val):\n                i += 1  # Extra one for dummy node.\n                while i < len(self.__bit):\n                    self.__bit[i] = self.__fn(self.__bit[i], val)\n                    i += (i & -i)\n\n            def query(self, i):\n                i += 1  # Extra one for dummy node.\n                ret = self.__default\n                while i > 0:\n                    ret = self.__fn(ret, self.__bit[i])\n                    i -= (i & -i)\n                return ret\n\n        price_to_idx = {x:i for i, x in enumerate(sorted(set(prices)))}\n        result = NEG_INF\n        bit1, bit2 = BIT(len(price_to_idx), default=NEG_INF, fn=max), BIT(len(price_to_idx), default=NEG_INF, fn=max)\n        for price, profit in itertools.izip(prices, profits):\n            result = max(result, bit2.query(price_to_idx[price]-1)+profit)\n            bit1.update(price_to_idx[price], profit)\n            bit2.update(price_to_idx[price], bit1.query(price_to_idx[price]-1)+profit)\n        return result if result != NEG_INF else -1\n\n\n# Time:  O(nlogn)\n# Space: O(n)\nimport itertools\n\n\n# prefix sum, segment tree\nclass Solution4(object):\n    def maxProfit(self, prices, profits):\n        \"\"\"\n        :type prices: List[int]\n        :type profits: List[int]\n        :rtype: int\n        \"\"\"\n        NEG_INF = float(\"-inf\")\n        # Range Maximum Query\n        class SegmentTree(object):\n            def __init__(self, N,\n                         build_fn=lambda _: None,\n                         query_fn=lambda x, y: max(x, y),\n                         update_fn=lambda x, y: max(x, y)):\n                self.tree = [None]*(2*2**((N-1).bit_length()))\n                self.base = len(self.tree)//2\n                self.query_fn = query_fn\n                self.update_fn = update_fn\n                for i in xrange(self.base, self.base+N):\n                    self.tree[i] = build_fn(i-self.base)\n                for i in reversed(xrange(1, self.base)):\n                    self.tree[i] = query_fn(self.tree[2*i], self.tree[2*i+1])\n\n            def update(self, i, h):\n                x = self.base+i\n                self.tree[x] = self.update_fn(self.tree[x], h)\n                while x > 1:\n                    x //= 2\n                    self.tree[x] = self.query_fn(self.tree[x*2], self.tree[x*2+1])\n\n            def query(self, L, R):\n                if L > R:\n                    return None\n                L += self.base\n                R += self.base\n                left = right = None\n                while L <= R:\n                    if L & 1:\n                        left = self.query_fn(left, self.tree[L])\n                        L += 1\n                    if R & 1 == 0:\n                        right = self.query_fn(self.tree[R], right)\n                        R -= 1\n                    L //= 2\n                    R //= 2\n                return self.query_fn(left, right)\n\n        price_to_idx = {x:i for i, x in enumerate(sorted(set(prices)))}\n        result = NEG_INF\n        st1, st2 = SegmentTree(len(price_to_idx)), SegmentTree(len(price_to_idx))\n        for price, profit in itertools.izip(prices, profits):\n            mx2 = st2.query(0, price_to_idx[price]-1)\n            if mx2 is not None:\n                result = max(result, mx2+profit)\n            st1.update(price_to_idx[price], profit)\n            mx1 = st1.query(0, price_to_idx[price]-1)\n            if mx1 is not None:\n                st2.update(price_to_idx[price], mx1+profit)\n        return result if result != NEG_INF else -1\n\n\n# Time:  O(nlogn)\n# Space: O(n)\n# prefix sum, segment tree\nclass Solution5(object):\n    def maxProfit(self, prices, profits):\n        \"\"\"\n        :type prices: List[int]\n        :type profits: List[int]\n        :rtype: int\n        \"\"\"\n        NEG_INF = float(\"-inf\")\n        # Range Maximum Query\n        class SegmentTree(object):\n            def __init__(self, N,\n                         build_fn=lambda _: None,\n                         query_fn=lambda x, y: max(x, y),\n                         update_fn=lambda x, y: max(x, y)):\n                self.tree = [None]*(2*2**((N-1).bit_length()))\n                self.base = len(self.tree)//2\n                self.query_fn = query_fn\n                self.update_fn = update_fn\n                for i in xrange(self.base, self.base+N):\n                    self.tree[i] = build_fn(i-self.base)\n                for i in reversed(xrange(1, self.base)):\n                    self.tree[i] = query_fn(self.tree[2*i], self.tree[2*i+1])\n\n            def update(self, i, h):\n                x = self.base+i\n                self.tree[x] = self.update_fn(self.tree[x], h)\n                while x > 1:\n                    x //= 2\n                    self.tree[x] = self.query_fn(self.tree[x*2], self.tree[x*2+1])\n\n            def query(self, L, R):\n                if L > R:\n                    return None\n                L += self.base\n                R += self.base\n                left = right = None\n                while L <= R:\n                    if L & 1:\n                        left = self.query_fn(left, self.tree[L])\n                        L += 1\n                    if R & 1 == 0:\n                        right = self.query_fn(self.tree[R], right)\n                        R -= 1\n                    L //= 2\n                    R //= 2\n                return self.query_fn(left, right)\n\n        price_to_idx = {x:i for i, x in enumerate(sorted(set(prices)))}\n        right = [NEG_INF]*len(prices)\n        st = SegmentTree(len(price_to_idx))\n        for i in reversed(xrange(len(prices))):\n            right[i] = st.query(price_to_idx[prices[i]]+1, len(price_to_idx)-1)\n            st.update(price_to_idx[prices[i]], profits[i])\n        result = NEG_INF\n        st = SegmentTree(len(price_to_idx))\n        for i in xrange(len(prices)):\n            left = st.query(0, price_to_idx[prices[i]]-1)\n            if left is not None and right[i] is not None:\n                result = max(result, left+profits[i]+right[i])\n            st.update(price_to_idx[prices[i]], profits[i])\n        return result if result != NEG_INF else -1\n22:[\"$\",\"$L34\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"maximum-profitable-triplets-with-increasing-prices-i.cpp\",\"code\":\"$35\",\"sourcePath\":\"C++/maximum-profitable-triplets-with-increasing-prices-i.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"maximum-profitable-triplets-with-increasing-prices-i.py\",\"code\":\"$36\",\"sourcePath\":\"Python/maximum-profitable-triplets-with-increasing-prices-i.py\"}}}]\n37:T494,<h2>What is Maximum Profitable Triplets With Increasing Prices I?</h2>\n<p><strong>Maximum Profitable Triplets With Increasing Prices I</strong> (LeetCode #2907) is a <strong>Medium</strong> problem that primarily trains <strong>binary search tree</strong>.</p>\n<h3>How to think about it</h3>\n<ol>\n<li><strong>Restate the goal</strong> in your own words before coding.</li>\n<li>Work a <strong>tiny example</strong> by hand so the invariant becomes obvious.</li>\n<li>Identify the <strong>pattern</strong> — this problem aligns with <strong>prefix sum, sorted list, binary search, stack, fenwick tree, and segment tree</strong>.</li>\n<li>Only then translate the idea into code.</li>\n</ol>\n<h3>Why this problem matters</h3>\n<p>It sits in the sweet spot of interview difficulty: multiple valid approaches, clear trade-offs.\nOfficial solution notes mention: Prefix Sum, Sorted List, BST, Binary Search.</p>\n<blockquote>\n<p>AlgoForge explanations are original teaching notes. Always open the <a href=\"https://leetcode.com/problems/maximum-profitable-triplets-with-increasing-prices-i/\">official problem statement on LeetCode</a> for constraints and examples.</p>\n</blockquote>\n23:[\"$\",\"section\",\"beginner\",{\"id\":\"beginner\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Beginner Explanation\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"$37\"}}]]}]\n38:T518,<h2>Interview approach for Maximum Profitable Triplets With Increasing Prices I</h2>\n<h3>Opening (30–60 seconds)</h3>\n<ul>\n<li>Clarify inputs/outputs and edge cases (empty input, single element, duplicates, overflow).</li>\n<li>State a <strong>brute force</strong> so the interviewer knows you can solve it naively.</li>\n<li>Propose the <strong>optimal direction</strong> tied to <strong>prefix sum, sorted list, binary search, stack, fenwick tree, and segment tree</strong>.</li>\n</ul>\n<h3>Core solution narrative</h3>\n<ol>\n<li>Define the <strong>state</strong> you track (pointers, DP cell, set membership, stack top, etc.).</li>\n<li>Explain the <strong>transition</strong> when you process the next element.</li>\n<li>Call out <strong>time</strong> (O(nlogn)) and <strong>space</strong> (O(n)) before coding.</li>\n<li>Code cleanly; narrate variable names.</li>\n</ol>\n<h3>What interviewers listen for</h3>\n<ul>\n<li>Correctness on edge cases</li>\n<li>Complexity honesty</li>\n<li>Ability to discuss <strong>trade-offs</strong> (e.g., hash map space vs. sort + two pointers)</li>\n</ul>\n<h3>Follow-up questions they may ask</h3>\n<ul>\n<li>Can you solve it with less memory?</li>\n<li>What if the input stream is infinite / doesn't fit in RAM?</li>\n<li>How would tests look for adversarial inputs?</li>\n</ul>\n24:[\"$\",\"section\",\"interview\",{\"id\":\"interview\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Interview Walkthrough\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"$38\"}}]]}]\n39:T4aa,<h2>Optimized solution notes</h2>\n<p>The reference solutions on AlgoForge target <strong>O(nlogn)</strong> time and <strong>O(n)</strong> space.</p>\n<h3>Pattern focus: prefix sum, sorted list, binary search, stack, fenwick tree, and segment tree</h3>\n<p>Use the pattern as a checklist:</p>\n<ul>\n<li><strong>prefix sum</strong> — confirm the invariant holds after each step</li>\n<li><strong>sorted list</strong> — confirm the invariant holds after each step</li>\n<li><strong>binary search</strong> — confirm the invariant holds after each step</li>\n<li><strong>stack</strong> — confirm the invariant holds after each step</li>\n<li><strong>fenwick tree</strong> — confirm the invariant holds after each step</li>\n<li><strong>segment tree</strong> — confirm the invariant holds after each step</li>\n</ul>\n<p>Multiple methods appear in the source solutions — compare them and explain when each is preferable.</p>\n<h3>Implementation tips</h3>\n<ul>\n<li>Prefer readable names over micro-optimizations in interviews.</li>\n<li>Extract helpers only when they clarify (e.g., expand-around-center, DFS visit).</li>\n<li>After AC-level logic, re-scan for off-by-one and null checks.</li>\n</ul>\n25:[\"$\",\"section\",\"optimized\",{\"id\":\"optimized\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Optimized Approach\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"$39\"}}]]}]\n26:[\"$\",\"section\",\"complexity\",{\"id\":\"complexity\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Complexity Analysis\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Complexity</h2>\\n<table>\\n<thead>\\n<tr>\\n<th>Measure</th>\\n<th>Bound</th>\\n</tr>\\n</thead>\\n<tbody>\\n<tr>\\n<td>Time</td>\\n<td><strong>O(nlogn)</strong></td>\\n</tr>\\n<tr>\\n<td>Space</td>\\n<td><strong>O(n)</strong></td>\\n</tr>\\n</tbody>\\n</table>\\n<h3>How to justify this in an interview</h3>\\n<ul>\\n<li><strong>Time:</strong> count loops, map/set operations, and recursive branching; state average vs worst case if relevant.</li>\\n<li><strong>Space:</strong> include hash maps, recursion stack, and output allocation when the problem asks for it.</li>\\n</ul>\\n<p>If your implementation differs from the reference, re-derive big-O from <em>your</em> code — never memorize a complexity you cannot defend.</p>\\n\"}}]]}]\n27:[\"$\",\"section\",\"common-mistakes\",{\"id\":\"common-mistakes\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Common Mistakes\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Common mistakes on Maximum Profitable Triplets With Increasing Prices I</h2>\\n<ol>\\n<li><strong>Skipping edge cases</strong> — empty collections, single-element inputs, max constraints.</li>\\n<li><strong>Wrong invariant</strong> for prefix sum, sorted list, binary search, stack, fenwick tree, and segment tree — updating state too early or too late.</li>\\n<li><strong>Mutating input unexpectedly</strong> when the problem forbids it.</li>\\n<li><strong>Off-by-one</strong> in windows, ranges, or binary search bounds.</li>\\n<li><strong>Ignoring overflow / precision</strong> for integer arithmetic problems.</li>\\n<li><strong>Overengineering</strong> — jumping to an advanced structure when a simpler approach works.</li>\\n</ol>\\n\"}}]]}]\n28:[\"$\",\"section\",\"alternatives\",{\"id\":\"alternatives\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Alternative Approaches\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Alternatives</h2>\\n<p>The source file includes more than one method. Compare:</p>\\n<ol>\\n<li><strong>Primary optimized path</strong> — best complexity for typical interviews.</li>\\n<li><strong>Secondary approach</strong> — often brute force, sorting-based, or space-optimized variant.</li>\\n</ol>\\n<p>Practice articulating <strong>when</strong> you would pick each (constraints, readability, follow-ups).</p>\\n\"}}]]}]\n29:[\"$\",\"section\",\"edge-cases\",{\"id\":\"edge-cases\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Edge Cases\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Edge cases checklist</h2>\\n<ul>\\n<li>Minimum input size</li>\\n<li>Maximum input size / time limits</li>\\n<li>Duplicates and already-sorted input</li>\\n<li>Negative numbers / zeros (if applicable)</li>\\n<li>Disconnected structures (graphs/trees)</li>\\n<li>Single path vs branching recursion depth</li>\\n</ul>\\n\"}}]]}]\n2a:[\"$\",\"section\",\"pattern-recognition\",{\"id\":\"pattern-recognition\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Pattern Recognition\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Spotting this pattern</h2>\\n<p>Signal phrases that point to <strong>prefix sum, sorted list, binary search, stack, fenwick tree, and segment tree</strong>:</p>\\n<ul>\\n<li>Sorted input or ability to sort without changing the answer class</li>\\n<li>Need for contiguous subarray / substring → consider sliding window</li>\\n<li>Need for O(1) membership → hash set/map</li>\\n<li>Optimal substructure + overlapping subproblems → DP</li>\\n<li>Connectivity / components → graph DFS/BFS or Union-Find</li>\\n</ul>\\n<p>Primary topics: <strong>binary search tree</strong>.</p>\\n\"}}]]}]\n2b:[\"$\",\"section\",\"follow-ups\",{\"id\":\"follow-ups\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"ch