{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/problems/layout,_N_T_/problems/[slug]/layout,_N_T_/problems/[slug]/[lang]/layout,_N_T_/problems/[slug]/[lang]/page,_N_T_/problems/minimum-incompatibility/cpp"},"segmentPaths":["/_tree","/_full","/problems/$d$slug/$d$lang/__PAGE__","/problems/$d$slug/$d$lang","/problems/$d$slug","/problems","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/340fxer6uczx7.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/05kafvajig4wu.js\"/><script src=\"/_next/static/chunks/2o5-igl1ik8oj.js\" async=\"\"></script><script src=\"/_next/static/chunks/1uejzok0tpgy1.js\" async=\"\"></script><script src=\"/_next/static/chunks/3ujjz4ap-oopx.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3om3j4o09b7fr.js\" async=\"\"></script><script src=\"/_next/static/chunks/2fvm6eoqeukxu.js\" async=\"\"></script><script src=\"/_next/static/chunks/1ntn7efqc-iiw.js\" async=\"\"></script><script src=\"/_next/static/chunks/0plpm2axnqe9k.js\" async=\"\"></script><script src=\"/_next/static/chunks/0a2gmow1_jiq0.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Minimum Incompatibility C++ Solution | AlgoForge</title><meta name=\"description\" content=\"C++ solution for Minimum Incompatibility (LeetCode #1681). Time O(max(n * 2^n, 3^n)), space O(2^n).\"/><meta name=\"keywords\" content=\"Minimum Incompatibility cpp,Minimum Incompatibility C++,cpp leetcode\"/><link rel=\"canonical\" href=\"https://algoforge.dev/problems/minimum-incompatibility/cpp\"/><meta property=\"og:title\" content=\"Minimum Incompatibility C++ Solution | AlgoForge\"/><meta property=\"og:description\" content=\"C++ solution for Minimum Incompatibility (LeetCode #1681). Time O(max(n * 2^n, 3^n)), space O(2^n).\"/><meta property=\"og:url\" content=\"https://algoforge.dev/problems/minimum-incompatibility/cpp\"/><meta property=\"og:site_name\" content=\"AlgoForge\"/><meta property=\"og:image\" content=\"https://algoforge.dev/og-default.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"Minimum Incompatibility C++ Solution | AlgoForge\"/><meta property=\"og:type\" content=\"article\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Minimum Incompatibility C++ Solution | AlgoForge\"/><meta name=\"twitter:description\" content=\"C++ solution for Minimum Incompatibility (LeetCode #1681). Time O(max(n * 2^n, 3^n)), space O(2^n).\"/><meta name=\"twitter:image\" content=\"https://algoforge.dev/og-default.png\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/favicon.ico\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"geist_deef94d5-module__Sms4YG__variable geist_mono_1bf8cbf6-module__FlyLvG__variable antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><script>((a,b,c,d,e,f,g,h)=>{let i=document.documentElement,j=[\"light\",\"dark\"];function k(b){var c;(Array.isArray(a)?a:[a]).forEach(a=>{let c=\"class\"===a,d=c&&f?e.map(a=>f[a]||a):e;c?(i.classList.remove(...d),i.classList.add(f&&f[b]?f[b]:b)):i.setAttribute(a,b)}),c=b,h&&j.includes(c)&&(i.style.colorScheme=c)}if(d)k(d);else try{let a=localStorage.getItem(b)||c,d=g&&\"system\"===a?window.matchMedia(\"(prefers-color-scheme: dark)\").matches?\"dark\":\"light\":a;k(d)}catch(a){}})(\"class\",\"theme\",\"system\",null,[\"light\",\"dark\"],null,true,true)</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"AlgoForge\",\"url\":\"https://algoforge.dev\",\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\"}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"AlgoForge\",\"url\":\"https://algoforge.dev\",\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://algoforge.dev/search?q={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"AlgoForge\",\"applicationCategory\":\"EducationalApplication\",\"operatingSystem\":\"Web\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"},\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\"}</script><header class=\"sticky top-0 z-50 border-b border-border/80 bg-background/85 backdrop-blur-md\"><div class=\"container-af flex h-14 items-center justify-between gap-4\"><div class=\"flex items-center gap-6\"><a class=\"flex items-center gap-2 font-bold tracking-tight\" href=\"/\"><span class=\"inline-flex h-7 w-7 items-center justify-center rounded-md bg-primary text-primary-foreground text-xs font-black\">AF</span><span class=\"hidden sm:inline\">AlgoForge</span></a><nav class=\"hidden lg:flex items-center gap-1\" aria-label=\"Main\"><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/problems\">Problems</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/topics\">Topics</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/patterns\">Patterns</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/roadmaps\">Roadmaps</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blind-75\">Blind 75</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/companies\">Companies</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blog\">Blog</a></nav></div><div class=\"flex items-center gap-1\"><a class=\"hidden sm:inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-1.5 text-sm text-muted-foreground hover:border-primary/40 transition-colors\" href=\"/search\"><span>Search…</span><kbd class=\"rounded border border-border bg-muted px-1.5 text-[10px] font-mono\">/</kbd></a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground\" href=\"/dashboard\">Progress</a><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 hover:bg-muted text-foreground h-9 w-9\" aria-label=\"Toggle theme\"></button></div></div></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Minimum Incompatibility\",\"item\":\"https://algoforge.dev/problems/minimum-incompatibility\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"C++\",\"item\":\"https://algoforge.dev/problems/minimum-incompatibility/cpp\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/minimum-incompatibility\">Minimum Incompatibility</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">C++</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\">Hard</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Minimum Incompatibility<!-- --> — <!-- -->C++</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/minimum-incompatibility\">Full explanation</a> · <!-- -->Time <!-- -->O(max(n * 2^n, 3^n))<!-- --> · Space <!-- -->O(2^n)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">C++</button><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code>// Time:  O(max(n * 2^n, 3^n))\n// Space: O(2^n)\n\nclass Solution {\npublic:\n    int minimumIncompatibility(vector&lt;int&gt;&amp; nums, int k) {\n        const vector&lt;int&gt; candidates = findCandidates(nums, k);  // Time: O(n * 2^n)\n        const int total = (1 &lt;&lt; size(nums)) - 1;\n        vector&lt;int&gt; dp(total + 1, numeric_limits&lt;int&gt;::max());\n        dp[0] = 0;\n        for (int mask = 0; mask &lt;= total; ++mask) {  // Time: O(3^n)\n            if (__builtin_popcount(mask) % (size(nums) / k) != 0) {\n                continue;\n            }\n            // submask enumeration:\n            // =&gt; sum(nCr(n, k) * 2^k for k in xrange(n+1)) = (1 + 2)^n = 3^n\n            // =&gt; Time: O(3^n), see https://cp-algorithms.com/algebra/all-submasks.html\n            for (int submask = mask; submask; submask = (submask - 1) &amp; mask) {\n                if (candidates[submask] == numeric_limits&lt;int&gt;::max() ||\n                    dp[mask - submask] == numeric_limits&lt;int&gt;::max()) {\n                    continue;\n                }\n                dp[mask] = min(dp[mask], dp[mask - submask] + candidates[submask]);\n            }\n        }\n        return dp.back() != numeric_limits&lt;int&gt;::max() ? dp.back() : -1;\n    }\n\nprivate:                        \n    vector&lt;int&gt; findCandidates(const vector&lt;int&gt;&amp; nums, int k) {\n        const int total = (1 &lt;&lt; size(nums)) - 1;\n        vector&lt;int&gt; result(total + 1, numeric_limits&lt;int&gt;::max());\n        for (int mask = 0; mask &lt;= total; ++mask) {\n            if (__builtin_popcount(mask) != size(nums) / k) {\n                continue;\n            }\n            int lookup = 0;\n            int mx = 0, mn = numeric_limits&lt;int&gt;::max();\n            bool duplicated = false;\n            for (int i = 0; i &lt; size(nums); ++i) {\n                if ((mask &amp; (1 &lt;&lt; i)) == 0) {\n                    continue;\n                }\n                if (lookup &amp; (1 &lt;&lt; nums[i])) {\n                    duplicated = true;\n                    break;\n                }\n                lookup |= (1 &lt;&lt; nums[i]);\n                mx = max(mx, nums[i]);\n                mn = min(mn, nums[i]);\n            }\n            if (duplicated) {\n                continue;\n            }\n            result[mask] = mx - mn;\n        }\n        return result;\n    }\n};\n\n// Time:  O(sum(i*d * nCr(i*d, d) * nCr(n, i*d) for i in xrange(1, k+1))) &lt; O(sum(n * 2^m * nCr(n, m) for m in xrange(n+1))) = O(n * 3^n)\n// Space: O(n * k)\nclass Solution_TLE {\npublic:\n    int minimumIncompatibility(vector&lt;int&gt;&amp; nums, int k) {\n        unordered_map&lt;string, int&gt; lookup;\n        int result = backtracking(nums, size(nums) / k, &amp;lookup);\n        return result != numeric_limits&lt;int&gt;::max() ? result : -1;\n    }\n\nprivate:\n    int backtracking(const vector&lt;int&gt;&amp; nums, int d, unordered_map&lt;string, int&gt; *lookup) {\n        if (empty(nums)) {\n            return 0;\n        }\n        string k = key(nums);\n        if (!lookup-&gt;count(k)) {\n            int ret = numeric_limits&lt;int&gt;::max();\n            combinations(size(nums), d,\n                         [this, &amp;nums, &amp;d, &amp;lookup, &amp;ret](const vector&lt;int&gt;&amp; idxs) {\n                             unordered_set&lt;int&gt; new_nums_set;\n                             for (const auto&amp; idx : idxs) {\n                                 new_nums_set.emplace(nums[idx]);\n                             }\n                             if (size(new_nums_set) &lt; d) {\n                                 return;\n                             }\n                             int mx = *max_element(cbegin(new_nums_set), cend(new_nums_set));\n                             int mn = *min_element(cbegin(new_nums_set), cend(new_nums_set));\n                             vector&lt;int&gt; left;\n                             for (const auto&amp; num : nums) {\n                                 if (new_nums_set.count(num)) {\n                                     new_nums_set.erase(num);\n                                     continue;\n                                 }\n                                 left.emplace_back(num);\n                             }\n                             int result = backtracking(left, d, lookup);\n                             if (result != numeric_limits&lt;int&gt;::max()) {\n                                 ret = min(ret, mx - mn + result);\n                             }\n                         });\n            (*lookup)[k] = ret;\n        }\n        return (*lookup)[k];\n    }\n\n    string key(const vector&lt;int&gt;&amp; nums) {\n        string result;\n        for (const auto&amp; num : nums) {\n            result += to_string(num);\n            result.push_back(&#x27;,&#x27;);\n        }\n        return result;\n    }\n\n    void combinations(int n, int k, const function&lt;void (const vector&lt;int&gt;&amp;)&gt;&amp; callback) {\n        static const auto&amp; next_pos =\n            [](const auto&amp; n, const auto&amp; k, const auto&amp; idxs) {\n                int i = k - 1;\n                for (; i &gt;= 0; --i) {\n                    if (idxs[i] != i + n - k) {\n                        break;\n                    }\n                }\n                return i;\n            };\n    \n        vector&lt;int&gt; idxs(k);\n        iota(begin(idxs), end(idxs), 0);\n        callback(idxs);\n        for (int i; (i = next_pos(n, k, idxs)) &gt;= 0;) {\n            ++idxs[i];\n            for (int j = i + 1; j &lt; k; ++j) {\n                idxs[j] = idxs[j - 1] + 1;\n            }\n            callback(idxs);\n        }\n    }\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// wrong with greedy solution\n// nums = [15, 9, 7, 10, 15, 14, 12, 2, 10, 8, 10, 13, 4, 11, 2]\n// k = 5\n// greedy  =&gt; [[2, 4, 7], [2, 8, 9], [10, 11, 12], [10, 13, 15], [10, 14, 15]] =&gt; 24\n// correct =&gt; [[2, 4, 7], [2, 8, 10], [9, 10, 11], [10, 12, 15], [13, 14, 15]] =&gt; 22\n// optimized from Solution_Wrong_Greedy\nclass Solution_Wrong_Greedy_Map {\npublic:\n    int minimumIncompatibility(vector&lt;int&gt;&amp; nums, int k) {\n        return min(greedy&lt;less&lt;int&gt;&gt;(nums, k), greedy&lt;greater&lt;int&gt;&gt;(nums, k));  // two possible minimas\n    }\n\nprivate:\n    template&lt;typename T&gt;\n    int greedy(const vector&lt;int&gt;&amp; nums, int k) {\n        map&lt;int, int, T&gt; count;\n        for (const auto&amp; num : nums) {\n            ++count[num];\n        }\n        unordered_map&lt;int, list&lt;int&gt;&gt; freq_to_nodes;\n        unordered_map&lt;int, list&lt;int&gt;::iterator&gt; key_to_nodeit;\n        for (const auto&amp; [x, cnt] : count) {\n            freq_to_nodes[cnt].emplace_back(x);\n            key_to_nodeit[x] = prev(end(freq_to_nodes[cnt]));\n            if (cnt &gt; k) {\n                return -1;\n            }\n        }\n        vector&lt;vector&lt;int&gt;&gt; stks(k);\n        int curr = 0;\n        while (!empty(count)) {  // the while loop runs O(k) times\n            if (freq_to_nodes.count(size(stks) - curr)) {  // fill the deterministic elements into the remaining subsets\n                for (const auto&amp; x : freq_to_nodes[size(stks) - curr]) {  // total time = O(n)\n                    for (int i = curr; i &lt; size(stks); ++i) {\n                        stks[i].emplace_back(x);\n                    }\n                    key_to_nodeit.erase(x);\n                    count.erase(x);\n                }\n                freq_to_nodes.erase(size(stks) - curr);\n            }\n            // greedily fill the contiguous ordered elements into the first vacant subset until it is full,\n            // otherwise, the result sum would get larger =&gt; in fact, this is wrong\n            vector&lt;int&gt; to_delete;\n            for (auto&amp; [x, cnt] : count) {\n                stks[curr].emplace_back(x);\n                freq_to_nodes[cnt].erase(key_to_nodeit[x]);\n                if (empty(freq_to_nodes[cnt])) {\n                    freq_to_nodes.erase(cnt);\n                }\n                --cnt;  // total time = O(n)\n                if (!cnt) {\n                    key_to_nodeit.erase(x);\n                    to_delete.emplace_back(x);\n                } else {\n                    freq_to_nodes[cnt].emplace_back(x);\n                    key_to_nodeit[x] = prev(end(freq_to_nodes[cnt]));\n                }\n                if (size(stks[curr]) == size(nums) / k) { \n                    ++curr;\n                    break;\n                }\n            }\n            for (const auto&amp; x : to_delete) {\n                count.erase(x);  // total time = O(nlogn)\n            }\n        }\n        return accumulate(cbegin(stks), cend(stks), 0,\n                          [](const auto&amp; a, const auto&amp; b) {\n                              return a + (*max_element(cbegin(b), cend(b)) - *min_element(cbegin(b), cend(b)));\n                          });\n    }\n};\n\n// Time:  O(nlogn + k * n)\n// Space: O(n)\n// wrong with greedy solution\n// nums = [15, 9, 7, 10, 15, 14, 12, 2, 10, 8, 10, 13, 4, 11, 2]\n// k = 5\n// greedy  =&gt; [[2, 4, 7], [2, 8, 9], [10, 11, 12], [10, 13, 15], [10, 14, 15]] =&gt; 24\n// correct =&gt; [[2, 4, 7], [2, 8, 10], [9, 10, 11], [10, 12, 15], [13, 14, 15]] =&gt; 22\nclass Solution_Wrong_Greedy {\npublic:\n    int minimumIncompatibility(vector&lt;int&gt;&amp; nums, int k) {\n        return min(greedy&lt;less&lt;int&gt;&gt;(nums, k), greedy&lt;greater&lt;int&gt;&gt;(nums, k));  // two possible minimas\n    }\n\nprivate:\n    template&lt;typename T&gt;\n    int greedy(const vector&lt;int&gt;&amp; nums, int k) {\n        map&lt;int, int, T&gt; count;\n        for (const auto&amp; num : nums) {\n            ++count[num];\n        }\n        for (const auto&amp; [_, cnt] : count) {\n            if (cnt &gt; k) {\n                return -1;\n            }\n        }\n        vector&lt;vector&lt;int&gt;&gt; stks(k);\n        int curr = 0;\n        int remain = size(nums);\n        while (remain) {  // the while loop runs O(k) times, and the inner loops runs O(n) times\n            for (auto&amp; [x, cnt] : count) {  // fill the deterministic elements into the remaining subsets\n                if (cnt != size(stks) - curr) {\n                    continue;\n                }\n                for (int i = curr; i &lt; size(stks); ++i) {\n                    stks[i].emplace_back(x);\n                }\n                remain -= cnt;\n                cnt = 0;\n            }\n            // greedily fill the contiguous ordered elements into the first vacant subset until it is full,\n            // otherwise, the result sum would get larger =&gt; in fact, this is wrong\n            for (auto&amp; [x, cnt] : count) {\n                if (!cnt) {\n                    continue;\n                }\n                stks[curr].emplace_back(x);\n                --remain;\n                --cnt;\n                if (size(stks[curr]) == size(nums) / k) { \n                    ++curr;\n                    break;\n                }\n            }\n        }\n        return accumulate(cbegin(stks), cend(stks), 0,\n                          [](const auto&amp; a, const auto&amp; b) {\n                              return a + (*max_element(cbegin(b), cend(b)) - *min_element(cbegin(b), cend(b)));\n                          });\n    }\n};\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">Learn</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/problems\">Problems</a></li><li><a class=\"hover:text-primary\" href=\"/patterns\">Patterns</a></li><li><a class=\"hover:text-primary\" href=\"/roadmaps\">Roadmaps</a></li><li><a class=\"hover:text-primary\" href=\"/blind-75\">Blind 75</a></li><li><a class=\"hover:text-primary\" href=\"/grind-169\">Grind 169</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">