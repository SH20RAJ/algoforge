.dev/problems/maximum-balanced-subsequence-sum/python\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:site_name\",\"content\":\"AlgoForge\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:image:alt\",\"content\":\"Maximum Balanced Subsequence Sum Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"13\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:title\",\"content\":\"Maximum Balanced Subsequence Sum Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"15\",{\"name\":\"twitter:description\",\"content\":\"Python solution for Maximum Balanced Subsequence Sum (LeetCode #2926). Time O(nlogn), space O(n).\"}],[\"$\",\"meta\",\"16\",{\"name\":\"twitter:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"link\",\"17\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.2vob68tjqpejf.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"link\",\"18\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\"}],[\"$\",\"$L21\",\"19\",{}]]\n","/problems/$d$slug/$d$lang/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[522016,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"\"]\n3:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n8:I[897367,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"OutletBoundary\"]\n9:\"$Sreact.suspense\"\n4:T1456,// Time:  O(nlogn)\n// Space: O(n)\n\n// bst, binary search, mono stack\nclass Solution {\npublic:\n    long long maxBalancedSubsequenceSum(vector<int>& nums) {\n        static const auto NEG_INF = numeric_limits<int64_t>::min();\n\n        const auto& query = [](const auto& bst, const auto& k) {\n            const auto it = bst.lower_bound(pair(k, 0));\n            return it != begin(bst) ? prev(it)->second : NEG_INF;\n        };\n\n        const auto& update = [](auto& bst, const auto& k, const auto& v) {\n            const auto it = bst.lower_bound(pair(k, 0));\n            if (it != end(bst) && it->first == k) {\n                if (!(it->second < v)) {\n                    return;\n                }\n                bst.erase(it);\n            } else if (!(it == begin(bst) || prev(it)->second < v)) {\n                return;\n            }\n            const auto [jt, _] = bst.emplace(k, v);\n            while (next(jt) != end(bst) && next(jt)->second <= jt->second) {\n                bst.erase(next(jt));\n            }\n        };\n\n        set<pair<int, int64_t>> bst;\n        for (int i = 0; i < size(nums); ++i) {\n            const auto val = max(query(bst, (nums[i] - i) + 1), static_cast<int64_t>(0)) + nums[i];\n            update(bst, nums[i] - i, val);\n        }\n        return rbegin(bst)->second;\n    }\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// bit, fenwick tree\nclass Solution2 {\npublic:\n    long long maxBalancedSubsequenceSum(vector<int>& nums) {\n        static const auto NEG_INF = numeric_limits<int64_t>::min();\n\n        unordered_set<int> vals_set;\n        for (int i = 0; i < size(nums); ++i) {\n            vals_set.emplace(nums[i] - i);\n        }\n        vector<int> sorted_vals(cbegin(vals_set), cend(vals_set));\n        sort(begin(sorted_vals), end(sorted_vals));\n        unordered_map<int, int> val_to_idx;\n        for (int i = 0; i < size(sorted_vals); ++i) {\n            val_to_idx[sorted_vals[i]] = i;\n        }\n        const auto& fn = [](const auto& a, const auto& b) {\n            return max(a, b);\n        };\n        BIT<int64_t> bit(size(val_to_idx), NEG_INF, fn);\n        for (int i = 0; i < size(nums); ++i) {\n            const auto val = max(bit.query(val_to_idx[nums[i] - i]), static_cast<int64_t>(0)) + nums[i];\n            bit.update(val_to_idx[nums[i] - i], val);\n        }\n        return bit.query(size(val_to_idx) - 1);\n    }\n\nprivate:\n    template<typename T>\n    class BIT {\n    public:\n        BIT(int n, T val, const function<T (T, T)> fn)\n          : bit_(n + 1, val),\n            fn_(fn) {  // 0-indexed\n        }\n        \n        void update(int i, T val) {\n            ++i;\n            for (; i < size(bit_); i += lower_bit(i)) {\n                bit_[i] = fn_(bit_[i], val);\n            }\n        }\n\n        T query(int i) const {\n            ++i;\n            auto total = bit_[0];\n            for (; i > 0; i -= lower_bit(i)) {\n                total = fn_(total, bit_[i]);\n            }\n            return total;\n        }\n    \n    private:\n        int lower_bit(int i) const {\n            return i & -i;\n        }\n        \n        vector<T> bit_;\n        const function<T (T, T)> fn_;\n    };\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// segment tree\nclass Solution3 {\npublic:\n    long long maxBalancedSubsequenceSum(vector<int>& nums) {\n        static const auto NEG_INF = numeric_limits<int64_t>::min();\n\n        unordered_set<int> vals_set;\n        for (int i = 0; i < size(nums); ++i) {\n            vals_set.emplace(nums[i] - i);\n        }\n        vector<int> sorted_vals(cbegin(vals_set), cend(vals_set));\n        sort(begin(sorted_vals), end(sorted_vals));\n        unordered_map<int, int> val_to_idx;\n        for (int i = 0; i < size(sorted_vals); ++i) {\n            val_to_idx[sorted_vals[i]] = i;\n        }\n        SegmentTree<int64_t> st(size(val_to_idx));\n        for (int i = 0; i < size(nums); ++i) {\n            const auto val = max(st.query(0, val_to_idx[nums[i] - i]), static_cast<int64_t>(0)) + nums[i];\n            st.update(val_to_idx[nums[i] - i], val);\n        }\n        return st.query(0, size(val_to_idx) - 1);\n    }\n\nprivate:\n    template<typename T>\n    class SegmentTree {\n    private:\n        const T NEG_INF = numeric_limits<T>::min();\n      \n    public:\n        explicit SegmentTree(int N)\n          : tree(N > 1 ? 1 << (__lg(N - 1) + 2) : 2, NEG_INF),\n            base(N > 1 ? 1 << (__lg(N - 1) + 1) : 1) {\n\n        }\n\n        void update(int i, T h) {\n            int x = base + i;\n            tree[x] = max(tree[x], h);\n            while (x > 1) {\n                x /= 2;\n                tree[x] = max(tree[x * 2], tree[x * 2 + 1]);\n            }\n        }\n\n        T query(int L, int R) {\n            T result = NEG_INF;\n            if (L > R) {\n                return result;\n            }\n            L += base;\n            R += base;\n            for (; L <= R; L /= 2, R /= 2) {\n                if (L & 1) {\n                    result = max(result, tree[L]);\n                    ++L;\n                }\n                if ((R & 1) == 0) {\n                    result = max(tree[R], result);\n                    --R;\n                }\n            }\n            return result;\n        }\n\n        vector<T> tree;\n        int base;\n    };\n};\n5:T1132,# Time:  O(nlogn)\n# Space: O(n)\n\nfrom sortedcontainers import SortedList\n\n\n# sorted list, binary search, mono stack\nclass Solution(object):\n    def maxBalancedSubsequenceSum(self, nums):\n        \"\"\"\n        :type nums: List[int]\n        :rtype: int\n        \"\"\"\n        NEG_INF = float(\"-inf\")\n        def query(sl, k):\n            j = sl.bisect_left((k,))\n            return sl[j-1][1] if j-1 >= 0 else NEG_INF\n    \n        def update(sl, k, v):\n            j = sl.bisect_left((k,))\n            if j < len(sl) and sl[j][0] == k:\n                if not (sl[j][1] < v):\n                    return\n                del sl[j]\n            elif not (j-1 < 0 or sl[j-1][1] < v):\n                return\n            sl.add((k, v))\n            while j+1 < len(sl) and sl[j+1][1] <= sl[j][1]:\n                del sl[j+1]\n\n        sl = SortedList()\n        for i, x in enumerate(nums):\n            v = max(query(sl, (x-i)+1), 0)+x\n            update(sl, x-i, v)\n        return sl[-1][1]\n\n\n# Time:  O(nlogn)\n# Space: O(n)\n# bit, fenwick tree\nclass Solution2(object):\n    def maxBalancedSubsequenceSum(self, nums):\n        \"\"\"\n        :type nums: List[int]\n        :rtype: int\n        \"\"\"\n        NEG_INF = float(\"-inf\")\n        class BIT(object):  # 0-indexed.\n            def __init__(self, n, default=0, fn=lambda x, y: x+y):\n                self.__bit = [NEG_INF]*(n+1)  # Extra one for dummy node.\n                self.__default = default\n                self.__fn = fn\n\n            def update(self, i, val):\n                i += 1  # Extra one for dummy node.\n                while i < len(self.__bit):\n                    self.__bit[i] = self.__fn(self.__bit[i], val)\n                    i += (i & -i)\n\n            def query(self, i):\n                i += 1  # Extra one for dummy node.\n                ret = self.__default\n                while i > 0:\n                    ret = self.__fn(ret, self.__bit[i])\n                    i -= (i & -i)\n                return ret\n\n        val_to_idx = {x:i for i, x in enumerate(sorted({x-i for i, x in enumerate(nums)}))}\n        bit = BIT(len(val_to_idx), default=NEG_INF, fn=max)\n        for i, x in enumerate(nums):\n            v = max(bit.query(val_to_idx[x-i]), 0)+x\n            bit.update(val_to_idx[x-i], v)\n        return bit.query(len(val_to_idx)-1)\n\n\n# Time:  O(nlogn)\n# Space: O(n)\n# segment tree\nclass Solution3(object):\n    def maxBalancedSubsequenceSum(self, nums):\n        \"\"\"\n        :type nums: List[int]\n        :rtype: int\n        \"\"\"\n        NEG_INF = float(\"-inf\")\n        # Range Maximum Query\n        class SegmentTree(object):\n            def __init__(self, N,\n                         build_fn=lambda _: None,\n                         query_fn=lambda x, y: max(x, y),\n                         update_fn=lambda x, y: max(x, y)):\n                self.tree = [None]*(2*2**((N-1).bit_length()))\n                self.base = len(self.tree)//2\n                self.query_fn = query_fn\n                self.update_fn = update_fn\n                for i in xrange(self.base, self.base+N):\n                    self.tree[i] = build_fn(i-self.base)\n                for i in reversed(xrange(1, self.base)):\n                    self.tree[i] = query_fn(self.tree[2*i], self.tree[2*i+1])\n\n            def update(self, i, h):\n                x = self.base+i\n                self.tree[x] = self.update_fn(self.tree[x], h)\n                while x > 1:\n                    x //= 2\n                    self.tree[x] = self.query_fn(self.tree[x*2], self.tree[x*2+1])\n\n            def query(self, L, R):\n                if L > R:\n                    return None\n                L += self.base\n                R += self.base\n                left = right = None\n                while L <= R:\n                    if L & 1:\n                        left = self.query_fn(left, self.tree[L])\n                        L += 1\n                    if R & 1 == 0:\n                        right = self.query_fn(self.tree[R], right)\n                        R -= 1\n                    L //= 2\n                    R //= 2\n                return self.query_fn(left, right)\n\n        val_to_idx = {x:i for i, x in enumerate(sorted({x-i for i, x in enumerate(nums)}))}\n        st = SegmentTree(len(val_to_idx))\n        for i, x in enumerate(nums):\n            v = max(st.query(0, val_to_idx[x-i]), 0)+x\n            st.update(val_to_idx[x-i], v)\n        return st.query(0, len(val_to_idx)-1)\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Maximum Balanced Subsequence Sum\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/maximum-balanced-subsequence-sum\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"Python\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/maximum-balanced-subsequence-sum/python\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L2\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L2\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/maximum-balanced-subsequence-sum\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L2\",null,{\"href\":\"/problems/maximum-balanced-subsequence-sum\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Maximum Balanced Subsequence Sum\"}]]}],[\"