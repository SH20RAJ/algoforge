{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/problems/layout,_N_T_/problems/[slug]/layout,_N_T_/problems/[slug]/page,_N_T_/problems/maximum-number-of-accepted-invitations"},"segmentPaths":["/_tree","/_full","/problems/$d$slug/__PAGE__","/problems/$d$slug","/problems","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/340fxer6uczx7.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/05kafvajig4wu.js\"/><script src=\"/_next/static/chunks/2o5-igl1ik8oj.js\" async=\"\"></script><script src=\"/_next/static/chunks/1uejzok0tpgy1.js\" async=\"\"></script><script src=\"/_next/static/chunks/3ujjz4ap-oopx.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3om3j4o09b7fr.js\" async=\"\"></script><script src=\"/_next/static/chunks/2fvm6eoqeukxu.js\" async=\"\"></script><script src=\"/_next/static/chunks/1ntn7efqc-iiw.js\" async=\"\"></script><script src=\"/_next/static/chunks/0plpm2axnqe9k.js\" async=\"\"></script><script src=\"/_next/static/chunks/259rkrk9l2f9c.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Maximum Number of Accepted Invitations Solution — Medium | AlgoForge</title><meta name=\"description\" content=\"Original Medium explanation for Maximum Number of Accepted Invitations (LeetCode #1820). Pattern: graph algorithms. Time O(m * n * sqrt(m + n)), space O(m + n). Multi-language solutions and interview tips.\"/><meta name=\"keywords\" content=\"Maximum Number of Accepted Invitations,Maximum Number of Accepted Invitations solution,Maximum Number of Accepted Invitations leetcode,graph,graph-algorithms,medium\"/><link rel=\"canonical\" href=\"https://algoforge.dev/problems/maximum-number-of-accepted-invitations\"/><meta property=\"og:title\" content=\"Maximum Number of Accepted Invitations Solution — Medium | AlgoForge\"/><meta property=\"og:description\" content=\"Original Medium explanation for Maximum Number of Accepted Invitations (LeetCode #1820). Pattern: graph algorithms. Time O(m * n * sqrt(m + n)), space O(m + n). Multi-language solutions and interview tips.\"/><meta property=\"og:url\" content=\"https://algoforge.dev/problems/maximum-number-of-accepted-invitations\"/><meta property=\"og:site_name\" content=\"AlgoForge\"/><meta property=\"og:image\" content=\"https://algoforge.dev/og-default.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"Maximum Number of Accepted Invitations Solution — Medium | AlgoForge\"/><meta property=\"og:type\" content=\"article\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Maximum Number of Accepted Invitations Solution — Medium | AlgoForge\"/><meta name=\"twitter:description\" content=\"Original Medium explanation for Maximum Number of Accepted Invitations (LeetCode #1820). Pattern: graph algorithms. Time O(m * n * sqrt(m + n)), space O(m + n). Multi-language solutions and interview tips.\"/><meta name=\"twitter:image\" content=\"https://algoforge.dev/og-default.png\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/favicon.ico\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"geist_deef94d5-module__Sms4YG__variable geist_mono_1bf8cbf6-module__FlyLvG__variable antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><script>((a,b,c,d,e,f,g,h)=>{let i=document.documentElement,j=[\"light\",\"dark\"];function k(b){var c;(Array.isArray(a)?a:[a]).forEach(a=>{let c=\"class\"===a,d=c&&f?e.map(a=>f[a]||a):e;c?(i.classList.remove(...d),i.classList.add(f&&f[b]?f[b]:b)):i.setAttribute(a,b)}),c=b,h&&j.includes(c)&&(i.style.colorScheme=c)}if(d)k(d);else try{let a=localStorage.getItem(b)||c,d=g&&\"system\"===a?window.matchMedia(\"(prefers-color-scheme: dark)\").matches?\"dark\":\"light\":a;k(d)}catch(a){}})(\"class\",\"theme\",\"system\",null,[\"light\",\"dark\"],null,true,true)</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"AlgoForge\",\"url\":\"https://algoforge.dev\",\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\"}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"AlgoForge\",\"url\":\"https://algoforge.dev\",\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://algoforge.dev/search?q={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"AlgoForge\",\"applicationCategory\":\"EducationalApplication\",\"operatingSystem\":\"Web\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"},\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\"}</script><header class=\"sticky top-0 z-50 border-b border-border/80 bg-background/85 backdrop-blur-md\"><div class=\"container-af flex h-14 items-center justify-between gap-4\"><div class=\"flex items-center gap-6\"><a class=\"flex items-center gap-2 font-bold tracking-tight\" href=\"/\"><span class=\"inline-flex h-7 w-7 items-center justify-center rounded-md bg-primary text-primary-foreground text-xs font-black\">AF</span><span class=\"hidden sm:inline\">AlgoForge</span></a><nav class=\"hidden lg:flex items-center gap-1\" aria-label=\"Main\"><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/problems\">Problems</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/topics\">Topics</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/patterns\">Patterns</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/roadmaps\">Roadmaps</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blind-75\">Blind 75</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/companies\">Companies</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blog\">Blog</a></nav></div><div class=\"flex items-center gap-1\"><a class=\"hidden sm:inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-1.5 text-sm text-muted-foreground hover:border-primary/40 transition-colors\" href=\"/search\"><span>Search…</span><kbd class=\"rounded border border-border bg-mut