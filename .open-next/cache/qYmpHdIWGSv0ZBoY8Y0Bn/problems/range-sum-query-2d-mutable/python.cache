rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 hover:bg-muted text-foreground h-9 w-9\" aria-label=\"Toggle theme\"></button></div></div></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Range Sum Query 2D - Mutable\",\"item\":\"https://algoforge.dev/problems/range-sum-query-2d-mutable\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Python\",\"item\":\"https://algoforge.dev/problems/range-sum-query-2d-mutable/python\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/range-sum-query-2d-mutable\">Range Sum Query 2D - Mutable</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">Python</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\">Hard</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Range Sum Query 2D - Mutable<!-- --> — <!-- -->Python</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/range-sum-query-2d-mutable\">Full explanation</a> · <!-- -->Time <!-- -->ctor: O(m * n), update: O(logm * logn), query: O(logm * logn)<!-- --> · Space <!-- -->O(m * n)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">C++</button><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code># Time:  ctor:   O(m * n)\n#        update: O(logm * logn)\n#        query:  O(logm * logn)\n# Space: O(m * n)\n\nclass NumMatrix(object):\n    def __init__(self, matrix):\n        &quot;&quot;&quot;\n        initialize your data structure here.\n        :type matrix: List[List[int]]\n        &quot;&quot;&quot;\n        if not matrix:\n            return\n        self.__matrix = matrix\n        self.__bit = [[0] * (len(self.__matrix[0]) + 1) \\\n                      for _ in xrange(len(self.__matrix) + 1)]\n        for i in xrange(1, len(self.__bit)):\n            for j in xrange(1, len(self.__bit[0])):\n                self.__bit[i][j] = matrix[i-1][j-1] + self.__bit[i-1][j] + \\\n                                   self.__bit[i][j-1] - self.__bit[i-1][j-1]\n        for i in reversed(xrange(1, len(self.__bit))):\n            for j in reversed(xrange(1, len(self.__bit[0]))):\n                last_i, last_j = i - (i &amp; -i), j - (j &amp; -j)\n                self.__bit[i][j] = self.__bit[i][j] - self.__bit[i][last_j] - \\\n                                   self.__bit[last_i][j] + self.__bit[last_i][last_j]\n\n    def update(self, row, col, val):\n        &quot;&quot;&quot;\n        update the element at matrix[row,col] to val.\n        :type row: int\n        :type col: int\n        :type val: int\n        :rtype: void\n        &quot;&quot;&quot;\n        if val - self.__matrix[row][col]:\n            self.__add(row, col, val - self.__matrix[row][col])\n            self.__matrix[row][col] = val\n\n    def sumRegion(self, row1, col1, row2, col2):\n        &quot;&quot;&quot;\n        sum of elements matrix[(row1,col1)..(row2,col2)], inclusive.\n        :type row1: int\n        :type col1: int\n        :type row2: int\n        :type col2: int\n        :rtype: int\n        &quot;&quot;&quot;\n        return self.__sum(row2, col2) - self.__sum(row2, col1 - 1) - \\\n               self.__sum(row1 - 1, col2) + self.__sum(row1 - 1, col1 - 1)\n\n    def __sum(self, row, col):\n        row += 1\n        col += 1\n        ret = 0\n        i = row\n        while i &gt; 0:\n            j = col\n            while j &gt; 0:\n                ret += self.__bit[i][j]\n                j -= (j &amp; -j)\n            i -= (i &amp; -i)\n        return ret\n\n    def __add(self, row, col, val):\n        row += 1\n        col += 1\n        i = row\n        while i &lt;= len(self.__matrix):\n            j = col\n            while j &lt;= len(self.__matrix[0]):\n                self.__bit[i][j] += val\n                j += (j &amp; -j)\n            i += (i &amp; -i)\n\n\n\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">Learn</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/problems\">Problems</a></li><li><a class=\"hover:text-primary\" href=\"/patterns\">Patterns</a></li><li><a class=\"hover:text-primary\" href=\"/roadmaps\">Roadmaps</a></li><li><a class=\"hover:text-primary\" href=\"/blind-75\">Blind 75</a></li><li><a class=\"hover:text-primary\" href=\"/grind-169\">Grind 169</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Interview</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/companies\">Companies</a></li><li><a class=\"hover:text-primary\" href=\"/interview-preparation\">Interview prep</a></li><li><a class=\"hover:text-primary\" href=\"/system-design\">System design</a></li><li><a class=\"hover:text-primary\" href=\"/glossary\">Glossary</a></li><li><a class=\"hover:text-primary\" href=\"/blog\">Blog</a></li></ul></div><div><p class=\"font-semibold text-sm mb-3\">Product</p><ul class=\"space-y-2 text-sm text-muted-foreground\"><li><a class=\"hover:text-primary\" href=\"/pricing\">Pricing</a></li><li><a class=\"hover:text-primary\" href=\"/about\">About</a></li><li><a class=\"hover:text-primary\" href=\"/about/attribution\">Attribution</a></li><li><a class=\"hover:text-primary\" href=\"/sitemap-html\">Sitemap</a></li></ul></div></div><div class=\"border-t border-border\"><div class=\"container-af py-4 flex flex-col sm:flex-row gap-2 justify-between text-xs text-muted-foreground\"><p>© <!-- -->2026<!-- --> <!-- -->AlgoForge<!-- -->. Educational use only.</p><p>Solution code sourced under MIT from<!-- --> <a href=\"https://github.com/kamyu104/LeetCode-Solutions\" class=\"underline hover:text-primary\" rel=\"noopener noreferrer\" target=\"_blank\">kamyu104/LeetCode-Solutions</a>. Explanations are original AlgoForge content.</p></div></div></footer><script src=\"/_next/static/chunks/05kafvajig4wu.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[427423,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\"],\\\"ThemeProvider\\\"]\\n3:I[522016,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\",\\\"/_next/static/chunks/0a2gmow1_jiq0.js\\\"],\\\"\\\"]\\n10:I[168027,[\\\"/_next/static/chunks/2fvm6eoqeukxu.js\\\",\\\"/_next/static/chunks/1ntn7efqc-iiw.js\\\",\\\"/_next/static/chunks/0plpm2axnqe9k.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/340fxer6uczx7.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"c\\\":[\\\"\\\",\\\"problems