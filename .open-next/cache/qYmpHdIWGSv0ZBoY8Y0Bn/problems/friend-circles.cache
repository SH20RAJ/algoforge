{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/problems/layout,_N_T_/problems/[slug]/layout,_N_T_/problems/[slug]/page,_N_T_/problems/friend-circles"},"segmentPaths":["/_tree","/_full","/problems/$d$slug/__PAGE__","/problems/$d$slug","/problems","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/340fxer6uczx7.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/05kafvajig4wu.js\"/><script src=\"/_next/static/chunks/2o5-igl1ik8oj.js\" async=\"\"></script><script src=\"/_next/static/chunks/1uejzok0tpgy1.js\" async=\"\"></script><script src=\"/_next/static/chunks/3ujjz4ap-oopx.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3om3j4o09b7fr.js\" async=\"\"></script><script src=\"/_next/static/chunks/2fvm6eoqeukxu.js\" async=\"\"></script><script src=\"/_next/static/chunks/1ntn7efqc-iiw.js\" async=\"\"></script><script src=\"/_next/static/chunks/0plpm2axnqe9k.js\" async=\"\"></script><script src=\"/_next/static/chunks/259rkrk9l2f9c.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Friend Circles Solution — Medium | AlgoForge</title><meta name=\"description\" content=\"Original Medium explanation for Friend Circles (LeetCode #547). Pattern: union find. Time O(n^2), space O(n). Multi-language solutions and interview tips.\"/><meta name=\"keywords\" content=\"Friend Circles,Friend Circles solution,Friend Circles leetcode,depth-first-search,un