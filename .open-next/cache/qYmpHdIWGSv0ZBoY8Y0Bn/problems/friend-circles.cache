t) {\\n                    set_[min(x_root, y_root)] = max(x_root, y_root);\\n                    --count_;\\n                }\\n            }\\n\\n            int size() const {\\n                return count_;\\n            }\\n\\n        private:\\n            vector\\u003cint\\u003e set_;\\n            int count_;\\n    };\\n};\\n\"])</script><script>self.__next_f.push([1,\"1f:[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-6 grid lg:grid-cols-[1fr_280px] gap-10\\\",\\\"children\\\":[[\\\"$\\\",\\\"article\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"header\\\",null,{\\\"className\\\":\\\"space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"flex flex-wrap items-center gap-2\\\",\\\"children\\\":[[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"text-sm text-muted-foreground tabular-nums\\\",\\\"children\\\":[\\\"#\\\",547]}],[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-medium/15 text-medium\\\",\\\"children\\\":\\\"Medium\\\"}],false,[\\\"$\\\",\\\"span\\\",null,{\\\"className\\\":\\\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\\\",\\\"children\\\":[\\\"~\\\",35,\\\" min\\\"]}]]}],[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"text-3xl md:text-4xl font-bold tracking-tight\\\",\\\"children\\\":\\\"Friend Circles\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-muted-foreground max-w-2xl\\\",\\\"children\\\":[\\\"Time \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"className\\\":\\\"text-foreground\\\",\\\"children\\\":\\\"O(n^2)\\\"}],\\\" · \\\",\\\"Space \\\",[\\\"$\\\",\\\"strong\\\",null,{\\\"className\\\":\\\"text-foreground\\\",\\\"children\\\":\\\"O(n)\\\"}],\\\" · \\\",[\\\"$\\\",\\\"a\\\",null,{\\\"href\\\":\\\"https://leetcode.com/problems/friend-circles/\\\",\\\"target\\\":\\\"_blank\\\",\\\"rel\\\":\\\"noopener noreferrer\\\",