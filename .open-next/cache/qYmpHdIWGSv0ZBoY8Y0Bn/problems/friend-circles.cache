\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"AlgoForge\\\"},\\\"datePublished\\\":\\\"2026-01-01\\\",\\\"dateModified\\\":\\\"2026-07-17\\\"}\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"FAQPage\\\",\\\"mainEntity\\\":[{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"What is the time complexity of Friend Circles?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"The reference solutions aim for O(n^2) time and O(n) space. Always re-derive complexity from the code you write in the interview.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"What pattern does Friend Circles use?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"It primarily maps to union find, within the broader topic of depth first search.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Is Friend Circles good for interviews?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Yes — as a Medium problem it is a solid practice target. Pair it with related problems in the same pattern family for spaced repetition.\\\"}},{\\\"@type\\\":\\\"Question\\\",\\\"name\\\":\\\"Where can I read the official statement?\\\",\\\"acceptedAnswer\\\":{\\\"@type\\\":\\\"Answer\\\",\\\"text\\\":\\\"Open the official LeetCode page for constraints and examples: https://leetcode.com/problems/friend-circles/\\\"}}]}\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"HowTo\\\",\\\"name\\\":\\\"How to solve Friend Circles\\\",\\\"description\\\":\\\"Original Medium explanation for Friend Circles (LeetCode #547). Pattern: union find. Time O(n^2), space O(n). Multi-language solutions and interview tips.\\\",\\\"step\\\":[{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":1,\\\"text\\\":\\\"Read the official problem statement on LeetCode\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":2,\\\"text\\\":\\\"Solve on paper / whiteboard first\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":3,\\\"text\\\":\\\"Implement the union find approach\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":4,\\\"text\\\":\\\"Verify edge cases from the checklist\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":5,\\\"text\\\":\\\"State time and space complexity aloud\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":6,\\\"text\\\":\\\"Compare with the AlgoForge reference solution\\\"},{\\\"@type\\\":\\\"HowToStep\\\",\\\"position\\\":7,\\\"text\\\":\\\"Schedule a revision session\\\"}]}\"}}],[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Friend Circles\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/friend-circles\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],\"$L1d\",\"$L1e\"]}]]}],\"$L1f\"]}]\n20:I[56303,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"BookmarkButton\"]\n21:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"CodeTabs\"]\n1d:[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}]\n1e:[\"$\",\"li\",\"/problems/friend-circles\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"Friend Circles\"}]]}]\n22:T4d2,// Time:  O(n^2)\n// Space: O(n)\n\nclass Solution {\npublic:\n    int findCircleNum(vector<vector<int>>& M) {\n        UnionFind circles(M.size());\n        for (int i = 0; i < M.size(); ++i) {\n            for (int j = 0; j < M[i].size(); ++j) {\n                if (M[i][j] && i != j) {\n                    circles.union_set(i, j);\n                }\n            }\n        }\n        return circles.size();\n    }\n\nprivate:\n    class UnionFind {\n        public:\n            UnionFind(const int n) : set_(n), count_(n) {\n                iota(set_.begin(), set_.end(), 0);\n            }\n\n            int find_set(const int x) {\n               if (set_[x] != x) {\n                   set_[x] = find_set(set_[x]);  // Path compression.\n               }\n               return set_[x];\n            }\n\n            void union_set(const int x, const int y) {\n                int x_root = find_set(x), y_root = find_set(y);\n                if (x_root != y_root) {\n                    set_[min(x_root, y_root)] = max(x_root, y_root);\n                    --count_;\n                }\n            }\n\n            int size() const {\n                return count_;\n            }\n\n        private:\n            vector<int> set_;\n            int count_;\n    };\n};\n1f:[\"$\",\"div\",null,{\"className\":\"mt-6 grid lg:grid-cols-[1fr_280px] gap-10\",\"children\":[[\"$\",\"article\",null,{\"children\":[[\"$\",\"header\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex flex-wrap items-center gap-2\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-sm text-muted-foreground tabular-nums\",\"children\":[\"#\",547]}],[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-medium/15 text-medium\",\"children\":\"Medium\"}],false,[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":[\"~\",35,\" min\"]}]]}],[\"$\",\"h1\",null,{\"className\":\"text-3xl md:text-4xl font-bold tracking-tight\",\"children\":\"Friend Circles\"}],[\"$\",\"p\",null,{\"className\":\"text-muted-foreground max-w-2xl\",\"children\":[\"Time \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O(n^2)\"}],\" · \",\"Space \",[\"$\",\"strong\",null,{\"className\":\"text-foreground\",\"children\":\"O(n)\"}],\" · \",[\"$\",\"a\",null,{\"href\":\"https://leetcode.com/problems/friend-circles/\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-primary underline-offset-2 hover:underline\",\"children\":\"Official statement on LeetCode\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[[\"$\",\"$L3\",\"depth-first-search\",{\"href\":\"/topics/depth-first-search\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-primary/15 text-primary\",\"children\":\"depth first search\"}]}]],[[\"$\",\"$L3\",\"union-find\",{\"href\":\"/patterns/union-find\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide border border-border text-muted-foreground\",\"children\":\"union find\"}]}]],[[\"$\",\"$L3\",\"google\",{\"href\":\"/companies/google\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-muted text-muted-foreground\",\"children\":\"google\"}]}],[\"$\",\"$L3\",\"amazon\",{\"href\":\"/companies/amazon\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-muted text-muted-foreground\",\"children\":\"amazon\"}]}],[\"$\",\"$L3\",\"bloomberg\",{\"href\":\"/companies/bloomberg\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-muted text-muted-foreground\",\"children\":\"bloomberg\"}]}]]]}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2 pt-1\",\"children\":[[\"$\",\"$L20\",null,{\"slug\":\"friend-circles\"}],[[\"$\",\"$L3\",\"cpp\",{\"href\":\"/problems/friend-circles/cpp\",\"className\":\"text-sm text-primary hover:underline\",\"children\":\"cpp\"}],[\"$\",\"$L3\",\"python\",{\"href\":\"/problems/friend-circles/python\",\"className\":\"text-sm text-primary hover:underline\",\"children\":\"python\"}]]]}]]}],[\"$\",\"section\",null,{\"className\":\"mt-10\",\"id\":\"solutions\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Solutions\"}],[\"$\",\"$L21\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"friend-circles.cpp\",\"code\":\"$22\",\"sourcePath\":\"C++/friend-circles.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"friend-circles.py\",\"code\":\"# Time:  O(n^2)\\n# Space: O(n)\\n\\nclass Solution(object):\\n    def findCircleNum(self, M):\\n        \\\"\\\"\\\"\\n        :type M: List[List[int]]\\n        :rtype: int\\n        \\\"\\\"\\\"\\n\\n        class UnionFind(object):\\n            def __init__(self, n):\\n                self.set = range(n)\\n                self.count = n\\n\\n            def find_set(self, x):\\n               if self.set[x] != x:\\n                   self.set[x] = self.find_set(self.set[x])  # path compression.\\n               return self.set[x]\\n\\n            def union_set(self, x, y):\\n                x_root, y_root = map(self.find_set, (x, y))\\n                if x_root != y_root:\\n                    self.set[min(x_root, y_root)] = max(x_root, y_root)\\n                    self.count -= 1\\n\\n        circles = UnionFind(len(M))\\n        for i in xrange(len(M)):\\n            for j in xrange(len(M)):\\n                if M[i][j] and i != j:\\n                    circles.union_set(i, j)\\n        return circles.count\\n\\n\\n\",\"sourcePath\":\"Python/friend-circles.py\"}}}]]}],[\"$L23\",\"$L24\",\"$L25\",\"$L26\",\"$L27\",\"$L28\",\"$L29\",\"$L2a\",\"$L2b\",\"$L2c\"],\"$L2d\",\"$L2e\",\"$L2f\",\"$L30\",\"$L31\",\"$L32\"]}],\"$L33\"]}]\n3b:I[203221,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/259rkrk9l2f9c.js\"],\"ConfidenceTracker\"]\n23:[\"$\",\"section\",\"beginner\",{\"id\":\"beginner\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Beginner Explanation\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>What is Friend Circles?</h2>\\n<p><strong>Friend Circles</strong> (LeetCode #547) is a <strong>Medium</strong> problem that primarily trains <strong>depth first search</strong>.</p>\\n<h3>How to think about it</h3>\\n<ol>\\n<li><strong>Restate the goal</strong> in your own words before coding.</li>\\n<li>Work a <strong>tiny example</strong> by hand so the invariant becomes obvious.</li>\\n<li>Identify the <strong>pattern</strong> — this problem aligns with <strong>union find</strong>.</li>\\n<li>Only then translate the idea into code.</li>\\n</ol>\\n<h3>Why this problem matters</h3>\\n<p>It sits in the sweet spot of interview difficulty: multiple valid approaches, clear trade-offs.\\nOfficial solution notes mention: Union Find.</p>\\n<blockquote>\\n<p>AlgoForge explanations are original teaching notes. Always open the <a href=\\\"https://leetcode.com/problems/friend-circles/\\\">official problem statement on LeetCode</a> for constraints and examples.</p>\\n</blockquote>\\n\"}}]]}]\n34:T4ad,<h2>Interview approach for Friend Circles</h2>\n<h3>Opening (30–60 seconds)</h3>\n<ul>\n<li>Clarify inputs/outputs and edge cases (empty input, single element, duplicates, overflow).</li>\n<li>State a <strong>brute force</strong> so the interviewer knows you can solve it naively.</li>\n<li>Propose the <strong>optimal direction</strong> tied to <strong>union find</strong>.</li>\n</ul>\n<h3>Core solution narrative</h3>\n<ol>\n<li>Define the <strong>state</strong> you track (pointers, DP cell, set membership, stack top, etc.).</li>\n<li>Explain the <strong>transition</strong> when you process the next element.</li>\n<li>Call out <strong>time</strong> (O(n^2)) and <strong>space</strong> (O(n)) before coding.</li>\n<li>Code cleanly; narrate variable names.</li>\n</ol>\n<h3>What interviewers listen for</h3>\n<ul>\n<li>Correctness on edge cases</li>\n<li>Complexity honesty</li>\n<li>Ability to discuss <strong>trade-offs</strong> (e.g., hash map space vs. sort + two pointers)</li>\n</ul>\n<h3>Follow-up questions they may ask</h3>\n<ul>\n<li>Can you solve it with less memory?</li>\n<li>What if the input stream is infinite / doesn't fit in RAM?</li>\n<li>How would tests look for adversarial inputs?</li>\n</ul>\n24:[\"$\",\"section\",\"interview\",{\"id\":\"interview\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Interview Walkthrough\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"$34\"}}]]}]\n25:[\"$\",\"section\",\"optimized\",{\"id\":\"optimized\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Optimized Approach\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Optimized solution notes</h2>\\n<p>The reference solutions on AlgoForge target <strong>O(n^2)</strong> time and <strong>O(n)</strong> space.</p>\\n<h3>Pattern focus: union find</h3>\\n<p>Use the pattern as a checklist:</p>\\n<ul>\\n<li><strong>union find</strong> — confirm the invariant holds after each step</li>\\n</ul>\\n<p>Multiple methods appear in the source solutions — compare them and explain when each is preferable.</p>\\n<h3>Implementation tips</h3>\\n<ul>\\n<li>Prefer readable names over micro-optimizations in interviews.</li>\\n<li>Extract helpers only when they clarify (e.g., expand-around-center, DFS visit).</li>\\n<li>After AC-level logic, re-scan for off-by-one and null checks.</li>\\n</ul>\\n\"}}]]}]\n26:[\"$\",\"section\",\"complexity\",{\"id\":\"complexity\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Complexity Analysis\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Complexity</h2>\\n<table>\\n<thead>\\n<tr>\\n<th>Measure</th>\\n<th>Bound</th>\\n</tr>\\n</thead>\\n<tbody>\\n<tr>\\n<td>Time</td>\\n<td><strong>O(n^2)</strong></td>\\n</tr>\\n<tr>\\n<td>Space</td>\\n<td><strong>O(n)</strong></td>\\n</tr>\\n</tbody>\\n</table>\\n<h3>How to justify this in an interview</h3>\\n<ul>\\n<li><strong>Time:</strong> count loops, map/set operations, and recursive branching; state average vs worst case if relevant.</li>\\n<li><strong>Space:</strong> include hash maps, recursion stack, and output allocation when the problem asks for it.</li>\\n</ul>\\n<p>If your implementation differs from the reference, re-derive big-O from <em>your</em> code — never memorize a complexity you cannot defend.</p>\\n\"}}]]}]\n27:[\"$\",\"section\",\"common-mistakes\",{\"id\":\"common-mistakes\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Common Mistakes\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Common mistakes on Friend Circles</h2>\\n<ol>\\n<li><strong>Skipping edge cases</strong> — empty collections, single-element inputs, max constraints.</li>\\n<li><strong>Wrong invariant</strong> for union find — updating state too early or too late.</li>\\n<li><strong>Mutating input unexpectedly</strong> when the problem forbids it.</li>\\n<li><strong>Off-by-one</strong> in windows, ranges, or binary search bounds.</li>\\n<li><strong>Ignoring overflow / precision</strong> for integer arithmetic problems.</li>\\n<li><strong>Overengineering</strong> — jumping to an advanced structure when a simpler approach works.</li>\\n</ol>\\n\"}}]]}]\n28:[\"$\",\"section\",\"alternatives\",{\"id\":\"alternatives\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Alternative Approaches\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Alternatives</h2>\\n<p>The source file includes more than one method. Compare:</p>\\n<ol>\\n<li><strong>Primary optimized path</strong> — best complexity for typical interviews.</li>\\n<li><strong>Secondary approach</strong> — often brute force, sorting-based, or space-optimized variant.</li>\\n</ol>\\n<p>Practice articulating <strong>when</strong> you would pick each (constraints, readability, follow-ups).</p>\\n\"}}]]}]\n29:[\"$\",\"section\",\"edge-cases\",{\"id\":\"edge-cases\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Edge Cases\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Edge cases checklist</h2>\\n<ul>\\n<li>Minimum input size</li>\\n<li>Maximum input size / time limits</li>\\n<li>Duplicates and already-sorted input</li>\\n<li>Negative numbers / zeros (if applicable)</li>\\n<li>Disconnected structures (graphs/trees)</li>\\n<li>Single path vs branching recursion depth</li>\\n</ul>\\n\"}}]]}]\n2a:[\"$\",\"section\",\"pattern-recognition\",{\"id\":\"pattern-recognition\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Pattern Recognition\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Spotting this pattern</h2>\\n<p>Signal phrases that point to <strong>union find</strong>:</p>\\n<ul>\\n<li>Sorted input or ability to sort without changing the answer class</li>\\n<li>Need for contiguous subarray / substring → consider sliding window</li>\\n<li>Need for O(1) membership → hash set/map</li>\\n<li>Optimal substructure + overlapping subproblems → DP</li>\\n<li>Connectivity / components → graph DFS/BFS or Union-Find</li>\\n</ul>\\n<p>Primary topics: <strong>depth first search</strong>.</p>\\n\"}}]]}]\n2b:[\"$\",\"section\",\"follow-ups\",{\"id\":\"follow-ups\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Follow-up Interview Questions\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>Follow-ups</h2>\\n<ol>\\n<li>How does the solution change if the input is a stream?</li>\\n<li>Can you solve it in-place?</li>\\n<li>What if duplicates must be handled differently?</li>\\n<li>How would you parallelize the approach?</li>\\n<li>Design tests that would break a buggy implementation.</li>\\n</ol>\\n\"}}]]}]\n2c:[\"$\",\"section\",\"practice\",{\"id\":\"practice\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-2 mb-3\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold\",\"children\":\"Practice Recommendations\"}],false]}],[\"$\",\"div\",null,{\"className\":\"prose-af\",\"dangerouslySetInnerHTML\":{\"__html\":\"<h2>What to practice next</h2>\\n<ol>\\n<li>Re-solve <strong>Friend Circles</strong> in a second language (cpp, python).</li>\\n<li>Drill 3–5 more problems tagged <strong>depth first search</strong>.</li>\\n<li>Teach the solution out loud in under 5 minutes.</li>\\n<li>Add this problem to your revision calendar in 3 days and 14 days.</li>\\n</ol>\\n\"}}]]}]\n2d:[\"$\",\"section\",null,{\"id\":\"visualization\",\"className\":\"mt-10 scroll-mt-24\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-xl font-bold mb-3\",\"children\":\"Visualization\"}],[\"$\",\"div\",null,{\"className\":\"rounded-xl border border-dashed border-border bg-muted/40 p-6 text-sm text-muted-foreground\",\"children\":\"Conceptual diagram for Friend Circles: show input structure (dep