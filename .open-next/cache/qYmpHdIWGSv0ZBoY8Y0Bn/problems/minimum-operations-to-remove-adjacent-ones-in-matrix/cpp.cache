a, int L, vector<vector<int>>& g, vector<int>& btoa, vector<int>& A, vector<int>& B) {\n    if (A[a] != L) return 0;\n    A[a] = -1;\n    for (int b : g[a]) if (B[b] == L + 1) {\n        B[b] = 0;\n        if (btoa[b] == -1 || dfs(btoa[b], L + 1, g, btoa, A, B))\n            return btoa[b] = a, 1;\n    }\n    return 0;\n}\n\nint hopcroftKarp(vector<vector<int>>& g, vector<int>& btoa) {\n    int res = 0;\n    vector<int> A(g.size()), B(btoa.size()), cur, next;\n    for (;;) {\n        fill(begin(A), end(A), 0);\n        fill(begin(B), end(B), 0);\n        /// Find the starting nodes for BFS (i.e. layer 0).\n        cur.clear();\n        for (int a : btoa) if(a != -1) A[a] = -1;\n        for (int a = 0; a < size(g); ++a) if(A[a] == 0) cur.push_back(a);\n        /// Find all layers using bfs.\n        for (int lay = 1;; lay++) {\n            bool islast = 0;\n            next.clear();\n            for (int a : cur) for (int b : g[a]) {\n                if (btoa[b] == -1) {\n                    B[b] = lay;\n                    islast = 1;\n                }\n                else if (btoa[b] != a && !B[b]) {\n                    B[b] = lay;\n                    next.push_back(btoa[b]);\n                }\n            }\n            if (islast) break;\n            if (next.empty()) return res;\n            for (int a : next) A[a] = lay;\n            cur.swap(next);\n        }\n        /// Use DFS to scan for augmenting paths.\n        for (int a = 0; a < size(g); ++a)\n            res += dfs(a, 0, g, btoa, A, B);\n    }\n}\n\nclass Solution {\npublic:\n    int minimumOperations(vector<vector<int>>& grid) {\n        vector<vector<int>> adj;\n        vector<unordered_map<int, int>> ids(2);\n        vector<vector<bool>> lookup(size(grid), vector<bool>(size(grid[0])));\n        for (int i = 0; i < size(grid); ++i) {\n            for (int j = 0; j < size(grid[0]); ++j) {\n                if (!grid[i][j]) {\n                    continue;\n                }\n                iter_dfs(grid, i, j, &lookup, &ids, &adj);\n            }\n        }\n        vector<int> b(size(ids[1]), -1);\n        return hopcroftKarp(adj, b);\n    }\n\nprivate:\n    void iter_dfs(const vector<vector<int>>& grid, int i, int j,\n                  vector<vector<bool>> *lookup,\n                  vector<unordered_map<int, int>> *ids,\n                  vector<vector<int>> *adj) {\n        static const vector<pair<int, int>> directions{{0, 1}, {1, 0}, {0, -1}, {-1, 0}};\n\n        if ((*lookup)[i][j]) {\n            return;\n        }\n        auto get_id = [&grid, &ids](int i, int j, int color) {\n            const int x = size(grid[0]) * i + j;\n            if (!(*ids)[color].count(x)) {\n                (*ids)[color][x] = size((*ids)[color]);\n            }\n            return (*ids)[color][x];\n        };\n\n        (*lookup)[i][j] = true;\n        vector<tuple<int, int, int>> stk = {{i, j, (i + j) % 2}};\n        while (!empty(stk)) {\n            const auto [i, j, color] = stk.back(); stk.pop_back();\n            for (const auto& [di, dj] : directions) {\n                const int ni = i + di, nj = j + dj;\n                if (!(0 <= ni && ni < size(grid) &&\n                      0 <= nj && nj < size(grid[0]) &&\n                      grid[ni][nj])) {\n                    continue;\n                }\n                if (!color) {\n                    const int x = get_id(i, j, color);\n                    const int y = get_id(ni, nj, color ^ 1);\n                    adj->resize(size((*ids)[0]));\n                    (*adj)[x].emplace_back(y);\n                }\n                if ((*lookup)[ni][nj]) {\n                    continue;\n                }\n                (*lookup)[ni][nj] = true;\n                stk.emplace_back(ni, nj, color ^ 1);\n            }\n        }\n    }\n};\n20:T15ed,# Time:  O(E * sqrt(V)) = O(m * n * sqrt(m * n))\n# Space: O(V) = O(m * n)\n\nfrom functools import partial\n\n# Time:  O(E * sqrt(V))\n# Space: O(V)\n# Source code from http://code.activestate.com/recipes/123641-hopcroft-karp-bipartite-matching/\n# Hopcroft-Karp bipartite max-cardinality matching and max independent set\n# David Eppstein, UC Irvine, 27 Apr 2002\ndef bipartiteMatch(graph):\n    '''Find maximum cardinality matching of a bipartite graph (U,V,E).\n    The input format is a dictionary mapping members of U to a list\n    of their neighbors in V.  The output is a triple (M,A,B) where M is a\n    dictionary mapping members of V to their matches in U, A is the part\n    of the maximum independent set in U, and B is the part of the MIS in V.\n    The same object may occur in both U and V, and is treated as two\n    distinct vertices if this happens.'''\n    \n    # initialize greedy matching (redundant, but faster than full search)\n    matching = {}\n    for u in graph:\n        for v in graph[u]:\n            if v not in matching:\n                matching[v] = u\n                break\n    \n    while 1:\n        # structure residual graph into layers\n        # pred[u] gives the neighbor in the previous layer for u in U\n        # preds[v] gives a list of neighbors in the previous layer for v in V\n        # unmatched gives a list of unmatched vertices in final layer of V,\n        # and is also used as a flag value for pred[u] when u is in the first layer\n        preds = {}\n        unmatched = []\n        pred = dict([(u,unmatched) for u in graph])\n        for v in matching:\n            del pred[matching[v]]\n        layer = list(pred)\n        \n        # repeatedly extend layering structure by another pair of layers\n        while layer and not unmatched:\n            newLayer = {}\n            for u in layer:\n                for v in graph[u]:\n                    if v not in preds:\n                        newLayer.setdefault(v,[]).append(u)\n            layer = []\n            for v in newLayer:\n                preds[v] = newLayer[v]\n                if v in matching:\n                    layer.append(matching[v])\n                    pred[matching[v]] = v\n                else:\n                    unmatched.append(v)\n        \n        # did we finish layering without finding any alternating paths?\n        if not unmatched:\n            unlayered = {}\n            for u in graph:\n                for v in graph[u]:\n                    if v not in preds:\n                        unlayered[v] = None\n            return (matching,list(pred),list(unlayered))\n\n        # recursively search backward through layers to find alternating paths\n        # recursion returns true if found path, false otherwise\n        def recurse(v):\n            if v in preds:\n                L = preds[v]\n                del preds[v]\n                for u in L:\n                    if u in pred:\n                        pu = pred[u]\n                        del pred[u]\n                        if pu is unmatched or recurse(pu):\n                            matching[v] = u\n                            return 1\n            return 0\n        \n        def recurse_iter(v):\n            def divide(v):\n                if v not in preds:\n                    return\n                L = preds[v]\n                del preds[v]\n                for u in L :\n                    if u in pred and pred[u] is unmatched:  # early return\n                        del pred[u]\n                        matching[v] = u\n                        ret[0] = True\n                        return\n                stk.append(partial(conquer, v, iter(L)))\n\n            def conquer(v, it):\n                for u in it:\n                    if u not in pred:\n                        continue\n                    pu = pred[u]\n                    del pred[u]\n                    stk.append(partial(postprocess, v, u, it))\n                    stk.append(partial(divide, pu))\n                    return\n\n            def postprocess(v, u, it):\n                if not ret[0]:\n                    stk.append(partial(conquer, v, it))\n                    return\n                matching[v] = u\n\n            ret, stk = [False], []\n            stk.append(partial(divide, v))\n            while stk:\n                stk.pop()()\n            return ret[0]\n\n        for v in unmatched: recurse_iter(v)\n\n\nimport collections\n\n\nclass Solution(object):\n    def minimumOperations(self, grid):\n        \"\"\"\n        :type grid: List[List[int]]\n        :rtype: int\n        \"\"\"\n        directions = [(0, 1), (1, 0), (0, -1), (-1, 0)]\n        def iter_dfs(grid, i, j, lookup, adj):\n            if lookup[i][j]:\n                return\n            lookup[i][j] = True\n            stk = [(i, j, (i+j)%2)]\n            while stk:\n                i, j, color = stk.pop()\n                for di, dj in directions:\n                    ni, nj = i+di, j+dj\n                    if not (0 <= ni < len(grid) and 0 <= nj < len(grid[0]) and grid[ni][nj]):\n                        continue\n                    if not color:\n                        adj[len(grid[0])*ni+nj].append(len(grid[0])*i+j)\n                    if lookup[ni][nj]:\n                        continue\n                    lookup[ni][nj] = True\n                    stk.append((ni, nj, color^1))\n\n        adj = collections.defaultdict(list)\n        lookup = [[False]*len(grid[0]) for _ in xrange(len(grid))]\n        for i in xrange(len(grid)):\n            for j in xrange(len(grid[0])):\n                if not grid[i][j]:\n                    continue\n                iter_dfs(grid, i, j, lookup, adj)\n        return len(bipartiteMatch(adj)[0])\n15:[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Minimum Operations to Remove Adjacent Ones in Matrix\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/minimum-operations-to-remove-adjacent-ones-in-matrix\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"C++\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/minimum-operations-to-remove-adjacent-ones-in-matrix/cpp\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/minimum-operations-to-remove-adjacent-ones-in-matrix\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems/minimum-operations-to-remove-adjacent-ones-in-matrix\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Minimum Operations to Remove Adjacent Ones in Matrix\"}]]}],[\"$\",\"li\",\"/problems/minimum-operations-to-remove-adjacent-ones-in-matrix/cpp\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"C++\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 flex flex-wrap items-center gap-2\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\",\"children\":\"Hard\"}]}],[\"$\",\"h1\",null,{\"className\":\"mt-3 text-3xl font-bold tracking-tight\",\"children\":[\"Minimum Operations to Remove Adjacent Ones in Matrix\",\" — \",\"C++\"]}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-muted-foreground\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/problems/minimum-operations-to-remove-adjacent-ones-in-matrix\",\"className\":\"text-primary hover:underline\",\"children\":\"Full explanation\"}],\" · \",\"Time \",\"O(m * n * sqrt(m * n))\",\" · Space \",\"O(m + n)\"]}],[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L1e\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"minimum-operations-to-remove-adjacent-ones-in-matrix.cpp\",\"code\":\"$1f\",\"sourcePath\":\"C++/minimum-operations-to-remove-adjacent-ones-in-matrix.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"minimum-operations-to-remove-adjacent-ones-in-matrix.py\",\"code\":\"$20\",\"sourcePath\":\"Python/minimum-operations-to-remove-adjacent-ones-in-matrix.py\"}},\"defaultLang\":\"cpp\"}]}]]}]\n1b:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n21:I[27201,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"IconMark\"]\n18:null\n1d:[[\"$\",\"title\",\"0\",{\"children\":\"Minimum Operations to Remove Adjacent Ones in Matrix C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"C++ solution for Minimum Operations to Remove Adjacent Ones in Matrix (LeetCode #2123). Time O(m * n * sqrt(m * n)), space O(m + n).\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"Minimum Operations to Remove Adjacent Ones in Matrix cpp,Minimum Operations to Remove Adjacent Ones in Matrix C++,cpp leetcode\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://algoforge.dev/problems/minimum-operations-to-remove-adjacent-ones-in-matrix/cpp\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"Minimum Operations to Remove Adjacent Ones in Matrix C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"C++ solution for Minimum Operations to Remove Adjacent Ones in Matrix (LeetCode #2123). Time O(m * n * sqrt(m * n)), space O(m + n).\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:url\",\"content\":\"https://algoforge.dev/problems/minimum-operations-to-remove-adjacent-ones-in-matrix/cpp\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:site_name\",\"content\":\"AlgoForge\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:image:alt\",\"content\":\"Minimum Operations to Remove Adjacent Ones in Matrix C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"13\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:title\",\"content\":\"Minimum Operations to Remove Adjacent Ones in Matrix C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"15\",{\"name\":\"twitter:description\",\"content\":\"C++ solution for Minimum Operations to Remove Adjacent Ones in Matrix (LeetCode #2123). Time O(m * n * sqrt(m * n)), space O(m + n).\"}],[\"$\",\"meta\",\"16\",{\"name\":\"twitter:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"link\",\"17\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.2vob68tjqpejf.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"link\",\"18\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\"}],[\"$\",\"$L21\",\"19\",{}]]\n","/problems/$d$slug/$d$lang/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[522016,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"\"]\n3:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n8:I[897367,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"OutletBoundary\"]\n9:\"$Sreact.suspense\"\n4:Tf31,// Time:  O(m * n * sqrt(m + n))\n// Space: O(m * n)\n\n// template from https://github.com/kth-competitive-programming/kactl/blob/main/content/graph/hopcroftKarp.h\nbool dfs(int a, int L, vector<vector<int>>& g, vector<int>& btoa, vector<int>& A, vector<int>& B) {\n    if (A[a] != L) return 0;\n    A[a] = -1;\n    for (int b : g[a]) if (B[b] == L + 1) {\n        B[b] = 0;\n        if (btoa[b] == -1 || dfs(btoa[b], L + 1, g, btoa, A, B))\n            return btoa[b] = a, 1;\n    }\n    return 0;\n}\n\nint hopcroftKarp(vector<vector<int>>& g, vector<int>& btoa) {\n    int res = 0;\n    vector<int> A(g.size()), B(btoa.size()), cur, next;\n    for (;;) {\n        fill(begin(A), end(A), 0);\n        fill(begin(B), end(B), 0);\n        /// Find the starting nodes for BFS (i.e. layer 0).\n        cur.clear();\n        for (int a : btoa) if(a != -1) A[a] = -1;\n        for (int a = 0; a < size(g); ++a) if(A[a] == 0) cur.push_back(a);\n        /// Find all layers using bfs.\n        for (int lay = 1;; lay++) {\n            bool islast = 0;\n            next.clear();\n            for (int a : cur) for (int b : g[a]) {\n                if (btoa[b] == -1) {\n                    B[b] = lay;\n                    islast = 1;\n                }\n                else if (btoa[b] != a && !B[b]) {\n                    B[b] = lay;\n                    next.push_back(btoa[b]);\n                }\n            }\n            if (islast) break;\n            if (next.empty()) return res;\n            for (int a : next) A[a] = lay;\n            cur.swap(next);\n        }\n        /// Use DFS to scan for augmenting paths.\n        for (int a = 0; a < size(g); ++a)\n            res += dfs(a, 0, g, btoa, A, B);\n    }\n}\n\nclass Solution {\npublic:\n    int minimumOperations(vector<vector<int>>& grid) {\n        vector<vector<int>> adj;\n        vector<unordered_map<int, int>> ids(2);\n        vector<vector<bool>> lookup(size(grid), vector<bool>(size(grid[0])));\n        for (int i = 0; i < size(grid); ++i) {\n            for (int j = 0; j < size(grid[0]); ++j) {\n                if (!grid[i][j]) {\n                    continue;\n                }\n                iter_dfs(grid, i, j, &lookup, &ids, &adj);\n            }\n        }\n        vector<int> b(size(ids[1]), -1);\n        return hopcroftKarp(adj, b);\n    }\n\nprivate:\n    void iter_dfs(const vector<vector<int>>& grid, int i, int j,\n                  vector<vector<bool>> *lookup,\n                  vector<unordered_map<int, int>> *ids,\n                  vector<vector<int>> *adj) {\n        static const vector<pair<int, int>> directions{{0, 1}, {1, 0}, {0, -1}, {-1, 0}};\n\n        if ((*lookup)[i][j]) {\n            return;\n        }\n        auto get_id = [&grid, &ids](int i, int j, int color) {\n            const int x = size(grid[0]) * i + j;\n            if (!(*ids)[color].count(x)) {\n                (*ids)[color][x] = size((*ids)[color]);\n            }\n            return (*ids)[color][x];\n        };\n\n        (*lookup)[i][j] = true;\n        vector<tuple<int, int, int>> stk = {{i, j, (i + j) % 2}};\n        while (!empty(stk)) {\n            const auto [i, j, color] = stk.back(); stk.pop_back();\n            for (const auto& [di, dj] : directions) {\n                const int ni = i + di, nj = j + dj;\n                if (!(0 <= ni && ni < size(grid) &&\n                      0 <= nj && nj < size(grid[0]) &&\n                      grid[ni][nj])) {\n                    continue;\n                }\n                if (!color) {\n                    const int x = get_id(i, j, color);\n                    const int y = get_id(ni, nj, color ^ 1);\n                    adj->resize(size((*ids)[0]));\n                    (*adj)[x].emplace_back(y);\n                }\n                if ((*lookup)[ni][nj]) {\n                    continue;\n                }\n                (*lookup)[ni][nj] = true;\n                stk.emplace_back(ni, nj, color ^ 1);\n            }\n        }\n    }\n};\n5:T15ed,# Time:  O(E * sqrt(V)) = O(m * n * sqrt(m * n))\n# Space: O(V) = O(m * n)\n\nfrom functools import partial\n\n# Time:  O(E * sqrt(V))\n# Space: O(V)\n# Source code from http://code.activestate.com/recipes/123641-hopcroft-karp-bipartite-matching/\n# Hopcroft-Karp bipartite max-cardinality matching and max independent set\n# David Eppstein, UC Irvine, 27 Apr 2002\ndef bipartiteMatch(graph):\n    '''Find maximum cardinality matching of a bipartite graph (U,V,E).\n    The input format is a dictionary mapping members of U to a list\n    of their neighbors in V.  The output is a triple (M,A,B) where M is a\n    dictionary mapping members of V to their matches in U, A is the part\n    of the maximum independent set in U, and B is the part of the MIS in V.\n    The same object may occur in both U and V, and is treated as two\n    distinct vertices if this happens.'''\n    \n    # initialize greedy matching (redundant, but faster than full search)\n    matching = {}\n    for u in graph:\n        for v in graph[u]:\n            if v not in matching:\n                matching[v] = u\n                break\n    \n    while 1:\n        # structure residual graph into layers\n        # pred[u] gives the neighbor in the previous layer for u in U\n        # preds[v] gives a list of neighbors in the previous layer for v in V\n        # unmatched gives a list of unmatched vertices in final layer of V,\n        # and is also used as a flag value for pred[u] when u is in the first layer\n        preds = {}\n        unmatched = []\n        pred = dict([(u,unmatched) for u in graph])\n        for v in matching:\n            del pred[matching[v]]\n        layer = list(pred)\n        \n        # repeatedly extend layering structure by another pair of layers\n        while layer and not unmatched:\n            newLayer = {}\n            for u in layer:\n                for v in graph[u]:\n                    if v not in preds:\n                        newLayer.setdefault(v,[]).append(u)\n            layer = []\n            for v in newLayer:\n                preds[v] = newLayer[v]\n                if v in matching:\n                    layer.append(matching[v])\n                    pred[matching[v]] = v\n                else:\n                    unmatched.append(v)\n        \n        # did we finish layering without finding any alternating paths?\n        if not unmatched:\n            unlayered = {}\n            for u in graph:\n                for v in graph[u]:\n                    if v not in preds:\n                        unlayered[v] = None\n            return (matching,list(pred),list(unlayered))\n\n        # recursively search backward through layers to find alternating paths\n        # recursion returns true if found path, false otherwise\n        def recurse(v):\n            if v in preds:\n                L = preds[v]\n                del preds[v]\n                for u in L:\n                    if u in pred:\n                        pu = pred[u]\n                        del pred[u]\n                        if pu is unmatched or recurse(pu):\n                            matching[v] = u\n                            return 1\n            return 0\n        \n        def recurse_iter(v):\n            def divide(v):\n                if v not in preds:\n                    return\n                L = preds[v]\n                del preds[v]\n                for u in L :\n                    if u in pred and pred[u] is unmatched:  # early return\n                        del pred[u]\n                        matching[v] = u\n                        ret[0] = True\n                        return\n                stk.append(partial(conquer, v, iter(L)))\n\n            def conquer(v, it):\n                for u in it:\n                    if u not in pred:\n                        continue\n                    pu = pred[u]\n                    del pred[u]\n                    stk.append(partial(postprocess, v, u, it))\n                    stk.append(partial(divide, pu))\n                    return\n\n            def postprocess(v, u, it):\n                if not ret[0]:\n                    stk.append(partial(conquer, v, it))\n                    return\n                matching[v] = u\n\n            ret, stk = [False], []\n            stk.append(partial(divide, v))\n            while stk:\n                stk.pop()()\n            return ret[0]\n\n        for v in unmatched: recurse_iter(v)\n\n\nimport collections\n\n\nclass Solution(object):\n    def minimumOperations(self, grid):\n        \"\"\"\n        :type grid: List[List[int]]\n        :rtype: int\n        \"\"\"\n        directions = [(0, 1), (1, 0), (0, -1), (-1, 0)]\n        def iter_dfs(grid, i, j, lookup, adj):\n            if lookup[i][j]:\n                return\n            lookup[i][j] = True\n            stk = [(i, j, (i+j)%2)]\n            while stk:\n                i, j, color = stk.pop()\n                for di, dj in directions:\n                    ni, nj = i+di, j+dj\n                    if not (0 <= ni < len(grid) and 0 <= nj < len(grid[0]) and grid[ni][nj]):\n                        continue\n                    if not color:\n                        adj[len(grid[0])*ni+nj].append(len(grid[0])*i+j)\n                    if lookup[ni][nj]:\n                        continue\n                    lookup[ni][nj] = True\n                    stk.append((ni, nj, color^1))\n\n        adj = collections.defaultdict(list)\n        lookup = [[False]*len(grid[0]) for _ in xrange(len(grid))]\n        for i in xrange(len(grid)):\n            for j in xrange(len(grid[0])):\n                if not grid[i][j]:\n                    continue\n                iter_dfs(grid, i, j, lookup, adj)\n        return len(bipartiteMatch(adj)[0])\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Minimum Operations to Remove Adjacent Ones in Matrix\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/minimum-operations-to-remove-adjacent-ones-in-matrix\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"C++\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/minimum-operations-to-remove-adjacent-ones-in-matrix/cpp\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"child