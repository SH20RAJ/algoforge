\",\"padding\":\"0 23px 0 0\",\"fontSize\":24,\"fontWeight\":500,\"verticalAlign\":\"top\",\"lineHeight\":\"49px\"},\"children\":404}],[\"$\",\"div\",null,{\"style\":{\"display\":\"inline-block\"},\"children\":[\"$\",\"h2\",null,{\"style\":{\"fontSize\":14,\"fontWeight\":400,\"lineHeight\":\"49px\",\"margin\":0},\"children\":\"This page could not be found.\"}]}]]}]}]],[]],\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}]\n9:[\"$\",\"footer\",null,{\"className\":\"mt-20 border-t border-border bg-sidebar\",\"children\":[[\"$\",\"div\",null,{\"className\":\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\",\"children\":[[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-lg\",\"children\":\"AlgoForge\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm text-muted-foreground max-w-xs\",\"children\":\"Master coding interviews with patterns, roadmaps, and solutions\"}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-sm mb-3\",\"children\":\"Learn\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary\",\"children\":\"Problems\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/patterns\",\"className\":\"hover:text-primary\",\"children\":\"Patterns\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/roadmaps\",\"className\":\"hover:text-primary\",\"children\":\"Roadmaps\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/blind-75\",\"className\":\"hover:text-primary\",\"children\":\"Blind 75\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/grind-169\",\"className\":\"hover:text-primary\",\"children\":\"Grind 169\"}]}]]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-sm mb-3\",\"children\":\"Interview\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/companies\",\"className\":\"hover:text-primary\",\"children\":\"Companies\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/interview-preparation\",\"className\":\"hover:text-primary\",\"children\":\"Interview prep\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/system-design\",\"className\":\"hover:text-primary\",\"children\":\"System design\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/glossary\",\"className\":\"hover:text-primary\",\"children\":\"Glossary\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/blog\",\"className\":\"hover:text-primary\",\"children\":\"Blog\"}]}]]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-sm mb-3\",\"children\":\"Product\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/pricing\",\"className\":\"hover:text-primary\",\"children\":\"Pricing\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/about\",\"className\":\"hover:text-primary\",\"children\":\"About\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/about/attribution\",\"className\":\"hover:text-primary\",\"children\":\"Attribution\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/sitemap-html\",\"className\":\"hover:text-primary\",\"children\":\"Sitemap\"}]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"border-t border-border\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-af py-4 flex flex-col sm:flex-row gap-2 justify-between text-xs text-muted-foreground\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"© \",2026,\" \",\"AlgoForge\",\". Educational use only.\"]}],[\"$\",\"p\",null,{\"children\":[\"Solution code sourced under MIT from\",\" \",[\"$\",\"a\",null,{\"href\":\"https://github.com/kamyu104/LeetCode-Solutions\",\"className\":\"underline hover:text-primary\",\"rel\":\"noopener noreferrer\",\"target\":\"_blank\",\"children\":\"kamyu104/LeetCode-Solutions\"}],\". Explanations are original AlgoForge content.\"]}]]}]}]]}]\na:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nb:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nc:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nd:[\"$\",\"$1\",\"c\",{\"children\":[\"$L15\",[[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0a2gmow1_jiq0.js\",\"async\":true,\"nonce\":\"$undefined\"}]],[\"$\",\"$L16\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@18\"}]}]]}]\n19:[]\ne:\"$W19\"\nf:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1a\",null,{\"children\":\"$L1b\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1d\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n11:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/340fxer6uczx7.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n1e:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n1f:T2446,// Time:  O(nlogn + mlogm)\n// Space: O(n + m)\n\n// dfs, centroid decomposition, prefix sum\nclass Solution {\npublic:\n    vector<int> maxTargetNodes(vector<vector<int>>& edges1, vector<vector<int>>& edges2, int k) {\n        const auto& centroid_decomposition = [](const auto& adj, int k) {\n            vector<int> result(size(adj));\n            vector<int> sizes(size(adj));\n            vector<bool> lookup(size(adj));\n            vector<vector<int>> prefix(size(adj));\n            vector<int> cnt;\n            vector<int> total, curr;\n\n            const function<void (int)> dfs = [&](int u) {\n                // https://usaco.guide/plat/centroid\n                const function<int (int, int)> find_subtree_size = [&](int u, int p) {\n                    sizes[u] = 1;\n                    for (const auto& v : adj[u]) {\n                        if (v == p || lookup[v]) {\n                            continue;\n                        }\n                        sizes[u] += find_subtree_size(v, u);\n                    }\n                    return sizes[u];\n                };\n\n                find_subtree_size(u, -1);\n                const int n = sizes[u];\n                const function<int (int, int)> find_centroid = [&](int u, int p) {\n                    for (const auto& v : adj[u]) {\n                        if (v == p || lookup[v]) {\n                            continue;\n                        }\n                        if (sizes[v] * 2 > n) {\n                            return find_centroid(v, u);\n                        }\n                    }\n                    return u;\n                };\n\n                const function<void (int, int, int)> count = [&](int u, int p, int d) {\n                    if (d > k) {\n                        return;\n                    }\n                    if (d - 1 == size(cnt)) {\n                        cnt.emplace_back(0);\n                    }\n                    ++cnt[d - 1];\n                    for (const auto& v : adj[u]) {\n                        if (v == p || lookup[v]) {\n                            continue;\n                        }\n                        count(v, u,  d + 1);\n                    }\n                };\n\n                const function<void (int, int, int)> update = [&](int u, int p, int d) {\n                    if (d > k) {\n                        return;\n                    }\n                    result[u] += total[min(k - d, static_cast<int>(size(total)) - 1)] - curr[min(k - d, static_cast<int>(size(curr)) - 1)];\n                    for (const auto& v : adj[u]) {\n                        if (v == p || lookup[v]) {\n                            continue;\n                        }\n                        update(v, u,  d + 1);\n                    }\n                };\n\n                u = find_centroid(u, -1);\n                lookup[u] = true;\n                int max_d = 0;\n                for (const auto& v : adj[u]) {\n                    if (lookup[v]) {\n                        continue;\n                    }\n                    cnt.clear();\n                    count(v, u, 0 + 1);\n                    prefix[v].emplace_back(0);\n                    for (int d = 0; d < size(cnt); ++d) {\n                        prefix[v].emplace_back(prefix[v].back() + cnt[d]);\n                    }\n                    max_d = max(max_d, static_cast<int>(size(cnt)));\n                }\n                total.assign(max_d + 1, 1);\n                for (const auto& v : adj[u]) {\n                    if (lookup[v]) {\n                        continue;\n                    }\n                    for (int d = 0; d < size(total); ++d) {\n                        total[d] += prefix[v][min(d, static_cast<int>(size(prefix[v])) - 1)];\n                    }\n                }\n                result[u] += total[min(k, static_cast<int>(size(total)) - 1)];\n                for (const auto& v : adj[u]) {\n                    if (lookup[v]) {\n                        continue;\n                    }\n                    curr = move(prefix[v]);\n                    update(v, u, 0 + 1);\n                }\n                for (const auto& v : adj[u]) {\n                    if (lookup[v]) {\n                        continue;\n                    }\n                    dfs(v);\n                }\n            };\n\n            if (k >= 0) {\n                dfs(0);\n            }\n            return result;\n        };\n\n        const auto& find_adj = [](const auto& edges) {\n            vector<vector<int>> adj(size(edges) + 1);\n            for (const auto& e : edges) {\n                adj[e[0]].emplace_back(e[1]);\n                adj[e[1]].emplace_back(e[0]);\n            }\n            return adj;\n        };\n\n        const auto& adj2 = find_adj(edges2);\n        int mx = ranges::max(centroid_decomposition(adj2, k - 1));\n        const auto& adj1 = find_adj(edges1);\n        vector<int> result(size(adj1));\n        const auto& ret = centroid_decomposition(adj1, k);\n        for (int u = 0; u < size(adj1); ++u) {\n            result[u] = mx + ret[u];\n        }\n        return result;\n    }\n};\n\n// Time:  O((n + m) * k)\n// Space: O((n + m) * k)\n// dfs, tree dp\nclass Solution2 {\npublic:\n    vector<int> maxTargetNodes(vector<vector<int>>& edges1, vector<vector<int>>& edges2, int k) {\n        const auto& tree_dp = [](const auto& adj, int k) {\n            vector<int> result(size(adj));\n            k = min(k, static_cast<int>(size(adj)) - 1);\n            if (k == -1) {\n                return result;\n            }\n            vector<vector<int>> dp(size(adj), vector<int>(k + 1));\n            const function<void (int, int)> dfs1 = [&](int u, int p) {\n                for (const auto& v : adj[u]) {\n                    if (v == p) {\n                        continue;\n                    }\n                    dfs1(v, u);\n                }\n                ++dp[u][0];\n                for (const auto& v : adj[u]) {\n                    if (v == p) {\n                        continue;\n                    }\n                    for (int d = 0; d < k; ++d) {\n                        dp[u][d + 1] += dp[v][d];\n                    }\n                }\n            };\n\n            const function<void(int, int, const vector<int>&)> dfs2 = [&](int u, int p, const auto& curr) {\n                const auto& update = [&](int v, int u, const auto& curr) {\n                    vector<int> new_curr(size(curr));\n                    for (int d = 0; d + 1 < size(new_curr); ++d) {\n                        new_curr[d + 1] = curr[d] + (dp[u][d] - (d - 1 >= 0 ? dp[v][d - 1] : 0));\n                    }\n                    return new_curr;\n                };\n\n                for (const auto& v : adj[u]) {\n                    if (v == p) {\n                        continue;\n                    }\n                    dfs2(v, u, update(v, u, curr));\n                }\n                for (int d = 0; d < size(curr); ++d) {\n                    result[u] += dp[u][d] + curr[d];\n                }\n            };\n\n            dfs1(0, -1);\n            dfs2(0, -1, vector<int>(k + 1));\n            return result;\n        };\n\n        const auto& find_adj = [](const auto& edges) {\n            vector<vector<int>> adj(size(edges) + 1);\n            for (const auto& e : edges) {\n                adj[e[0]].emplace_back(e[1]);\n                adj[e[1]].emplace_back(e[0]);\n            }\n            return adj;\n        };\n\n        const auto& adj2 = find_adj(edges2);\n        int mx = ranges::max(tree_dp(adj2, k - 1));\n        const auto& adj1 = find_adj(edges1);\n        vector<int> result(size(adj1));\n        const auto& ret = tree_dp(adj1, k);\n        for (int u = 0; u < size(adj1); ++u) {\n            result[u] = mx + ret[u];\n        }\n        return result;\n    }\n};\n\n// Time:  O(n^2 + m^2)\n// Space: O(n + m)\n// brute force, bfs\nclass Solution3 {\npublic:\n    vector<int> maxTargetNodes(vector<vector<int>>& edges1, vector<vector<int>>& edges2, int k) {\n        const auto& bfs = [](int u, const auto& adj, int k) {\n            int result = 0;\n            vector<pair<int, int>> q = {{u, -1}};\n            while (!empty(q)) {\n                if (k == -1) {\n                    break;\n                }\n                --k;\n                vector<pair<int, int>> new_q;\n                result += size(q);\n                for (const auto& [u, p] : q) {\n                    for (const auto& v : adj[u]) {\n                        if (v == p) {\n                            continue;\n                        }\n                        new_q.emplace_back(v, u);\n                    }\n                }\n                q = move(new_q);\n            }\n            return result;\n        };\n\n        const auto& find_adj = [](const auto& edges) {\n            vector<vector<int>> adj(size(edges) + 1);\n            for (const auto& e : edges) {\n                adj[e[0]].emplace_back(e[1]);\n                adj[e[1]].emplace_back(e[0]);\n            }\n            return adj;\n        };\n\n        const auto& adj2 = find_adj(edges2);\n        int mx = 0;\n        for (int u = 0; u < size(adj2); ++u) {\n            mx = max(mx, bfs(u, adj2, k - 1));\n        }\n        const auto& adj1 = find_adj(edges1);\n        vector<int> result(size(adj1));\n        for (int u = 0; u < size(adj1); ++u) {\n            result[u] = mx + bfs(u, adj1, k);\n        }\n        return result;\n    }\n};\n20:T1978,# Time:  O(nlogn + mlogm)\n# Space: O(n + m)\n\n# dfs, centroid decomposition, prefix sum\nclass Solution(object):\n    def maxTargetNodes(self, edges1, edges2, k):\n        \"\"\"\n        :type edges1: List[List[int]]\n        :type edges2: List[List[int]]\n        :type k: int\n        :rtype: List[int]\n        \"\"\"\n        def centroid_decomposition(adj, k):\n            def dfs(u):\n                # https://usaco.guide/plat/centroid\n                def find_subtree_size(u, p):\n                    sizes[u] = 1\n                    for v in adj[u]:\n                        if v == p or lookup[v]:\n                            continue\n                        sizes[u] += find_subtree_size(v, u)\n                    return sizes[u]\n\n                def find_centroid(u, p):\n                    for v in adj[u]:\n                        if v == p or lookup[v]:\n                            continue\n                        if sizes[v]*2 > n:\n                            return find_centroid(v, u)\n                    return u\n\n                def count(u, p, d):\n                    if d > k:\n                        return\n                    if d-1 == len(cnt):\n                        cnt.append(0)\n                    cnt[d-1] += 1\n                    for v in adj[u]:\n                        if v == p or lookup[v]:\n                            continue\n                        count(v, u, d+1)\n\n                def update(u, p, d):\n                    if d > k:\n                        return\n                    result[u] += total[min(k-d, len(total)-1)]-curr[min(k-d, len(curr)-1)]\n                    for v in adj[u]:\n                        if v == p or lookup[v]:\n                            continue\n                        update(v, u, d+1)\n\n                find_subtree_size(u, -1)\n                n = sizes[u]\n                u = find_centroid(u, -1)\n                lookup[u] = True\n                max_d = 0\n                for v in adj[u]:\n                    if lookup[v]:\n                        continue\n                    cnt = []\n                    count(v, u, 0+1)\n                    prefix[v].append(0)\n                    for d in xrange(len(cnt)):\n                        prefix[v].append(prefix[v][-1]+cnt[d])\n                    max_d = max(max_d, len(cnt))\n                total = [1]*(max_d+1)\n                for v in adj[u]:\n                    if lookup[v]:\n                        continue\n                    for d in xrange(len(total)):\n                        total[d] += prefix[v][min(d, len(prefix[v])-1)]\n                result[u] += total[min(k, len(total)-1)]\n                for v in adj[u]:\n                    if lookup[v]:\n                        continue\n                    curr, prefix[v] = prefix[v], []\n                    update(v, u, 0+1)\n                for v in adj[u]:\n                    if lookup[v]:\n                        continue\n                    dfs(v)\n\n            result = [0]*len(adj)\n            sizes = [0]*len(adj)\n            lookup = [False]*len(adj)\n            prefix = [[] for _ in xrange(len(adj))]\n            if k >= 0:\n                dfs(0)\n            return result\n\n        def find_adj(edges):\n            adj = [[] for _ in xrange(len(edges)+1)]\n            for u, v in edges:\n                adj[u].append(v)\n                adj[v].append(u)\n            return adj\n\n        adj2 = find_adj(edges2)\n        mx = max(centroid_decomposition(adj2, k-1))\n        adj1 = find_adj(edges1)\n        return [mx+x for x in centroid_decomposition(adj1, k)]\n\n\n# Time:  O((n + m) * k)\n# Space: O((n + m) * k)\n# dfs, tree dp\nclass Solution2(object):\n    def maxTargetNodes(self, edges1, edges2, k):\n        \"\"\"\n        :type edges1: List[List[int]]\n        :type edges2: List[List[int]]\n        :type k: int\n        :rtype: List[int]\n        \"\"\"\n        def tree_dp(adj, k):\n            def dfs1(u, p):\n                for v in adj[u]:\n                    if v == p:\n                        continue\n                    dfs1(v, u)\n                dp[u][0] += 1\n                for v in adj[u]:\n                    if v == p:\n                        continue\n                    for d in xrange(k):\n                        dp[u][d+1] += dp[v][d]\n            \n            def dfs2(u, p, curr):\n                def update(v, u, curr):\n                    new_curr = [0]*len(curr)\n                    for d in xrange(len(curr)-1):\n                        new_curr[d+1] = curr[d]+(dp[u][d]-(dp[v][d-1] if d-1 >= 0 else 0))\n                    return new_curr\n\n                for v in adj[u]:\n                    if v == p:\n                        continue\n                    dfs2(v, u, update(v, u, curr))\n                result[u] = sum(dp[u][i]+curr[i] for i in xrange(len(curr)))\n\n            result = [0]*len(adj)\n            k = min(k, len(adj)-1)\n            if k == -1:\n                return result\n            dp = [[0]*(k+1) for _ in xrange(len(adj))]\n            dfs1(0, -1)\n            dfs2(0, -1, [0]*(k+1))\n            return result\n\n        def find_adj(edges):\n            adj = [[] for _ in xrange(len(edges)+1)]\n            for u, v in edges:\n                adj[u].append(v)\n                adj[v].append(u)\n            return adj\n        \n        adj2 = find_adj(edges2)\n        mx = max(tree_dp(adj2, k-1))\n        adj1 = find_adj(edges1)\n        return [mx+x for x in tree_dp(adj1, k)]\n\n\n# Time:  O(n^2 + m^2)\n# Space: O(n + m)\n# brute force, bfs\nclass Solution3(object):\n    def maxTargetNodes(self, edges1, edges2, k):\n        \"\"\"\n        :type edges1: List[List[int]]\n        :type edges2: List[List[int]]\n        :type k: int\n        :rtype: List[int]\n        \"\"\"\n        def bfs(u, adj, k):\n            result = 0\n            q = [(u, -1)]\n            while q:\n                if k == -1:\n                    break\n                k -= 1\n                new_q = []\n                result += len(q)\n                for u, p in q:\n                    for v in adj[u]:\n                        if v == p:\n                            continue\n                        new_q.append((v, u))\n                q = new_q\n            return result\n    \n        def find_adj(edges):\n            adj = [[] for _ in xrange(len(edges)+1)]\n            for u, v in edges:\n                adj[u].append(v)\n                adj[v].append(u)\n            return adj\n\n        adj2 = find_adj(edges2)\n        mx = max(bfs(u, adj2, k-1) for u in xrange(len(adj2)))\n        adj1 = find_adj(edges1)\n        return [mx+bfs(u, adj1, k) for u in xrange(len(adj1))]\n15:[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Maximize the Number of Target Nodes After Connecting Trees I\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/maximize-the-number-of-target-nodes-after-connecting-trees-i\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"Python\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/maximize-the-number-of-target-nodes-after-connecting-trees-i/python\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap ite