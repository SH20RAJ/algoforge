y\",\"children\":\"Sitemap\"}]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"border-t border-border\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-af py-4 flex flex-col sm:flex-row gap-2 justify-between text-xs text-muted-foreground\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"© \",2026,\" \",\"AlgoForge\",\". Educational use only.\"]}],[\"$\",\"p\",null,{\"children\":[\"Solution code sourced under MIT from\",\" \",[\"$\",\"a\",null,{\"href\":\"https://github.com/kamyu104/LeetCode-Solutions\",\"className\":\"underline hover:text-primary\",\"rel\":\"noopener noreferrer\",\"target\":\"_blank\",\"children\":\"kamyu104/LeetCode-Solutions\"}],\". Explanations are original AlgoForge content.\"]}]]}]}]]}]\na:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nb:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nc:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nd:[\"$\",\"$1\",\"c\",{\"children\":[\"$L15\",[[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0a2gmow1_jiq0.js\",\"async\":true,\"nonce\":\"$undefined\"}]],[\"$\",\"$L16\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@18\"}]}]]}]\n19:[]\ne:\"$W19\"\nf:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1a\",null,{\"children\":\"$L1b\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1d\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n11:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/340fxer6uczx7.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n1e:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n1f:T1a8a,// Time:  O(nlogd)\n// Space: O(d)\n\n// fastest and less verbose\n// sliding window, heap\nclass Solution {\npublic:\n    long long minimumCost(vector<int>& nums, int k, int dist) {\n        static const int64_t INF = numeric_limits<int64_t>::max();\n\n        const auto& get_top = [](auto& heap, auto& total, const int d) {\n            while (-heap.top().second < d) {\n                heap.pop();\n                --total;\n            }\n            return heap.top();\n        };\n\n        priority_queue<pair<int, int>> max_heap;\n        priority_queue<pair<int, int>, vector<pair<int, int>>, greater<pair<int, int>>> min_heap;\n        int total1 = 0, total2 = 0;\n        int64_t mn = INF, curr = 0;\n        for (int i = 1; i < size(nums); ++i) {\n            max_heap.emplace(nums[i], -i);\n            curr += nums[i];\n            if (i > k - 1) {\n                const auto [x, idx] = get_top(max_heap, total1, i - (1 + dist)); max_heap.pop();\n                curr -= x;\n                min_heap.emplace(x, idx);\n            }\n            if (i > 1 + dist) {\n                if (get_top(min_heap, total2, i - (1 + dist)) <= pair(nums[i - (1 + dist)], -(i - (1 + dist)))) {\n                    lazy_delete(min_heap, total2, i - (1 + dist));\n                } else {\n                    lazy_delete(max_heap, total1, i - (1 + dist));                    \n                    curr -= nums[i - (1 + dist)] - min_heap.top().first;\n                    max_heap.emplace(min_heap.top()); min_heap.pop();\n                }\n            }\n            if (i >= k - 1) {\n                mn = min(mn, curr);\n            }\n        }\n        return nums[0] + mn;\n    }\n\nprivate:\n    template<typename T>\n    void lazy_delete(T& heap, int& total, const int d) {\n        ++total;\n        if (total <= size(heap) - total) {\n            return;\n        }\n        T new_heap;\n        while (!empty(heap)) {\n            const auto x = heap.top(); heap.pop();\n            if (-x.second <= d) {\n                --total;\n                continue;\n            }\n            new_heap.emplace(x);\n        }\n        heap = move(new_heap);\n    }\n};\n\n// Time:  O(nlogd)\n// Space: O(d)\n// faster but more verbose\n// sliding window, heap, freq table\nclass Solution2 {\npublic:\n    long long minimumCost(vector<int>& nums, int k, int dist) {\n        static const int64_t INF = numeric_limits<int64_t>::max();\n\n        const auto& get_top = [](auto& heap, auto& cnt, auto& total) {\n            while (cnt.count(heap.top())) {\n                const int x = heap.top(); heap.pop();\n                if (--cnt[x] == 0) {\n                    cnt.erase(x);\n                }\n                --total;\n            }\n            return heap.top();\n        };\n\n        priority_queue<int> max_heap;\n        priority_queue<int, vector<int>, greater<int>> min_heap;\n        unordered_map<int, int> cnt1, cnt2;\n        int total1 = 0, total2 = 0;\n        int64_t mn = INF, curr = 0;\n        for (int i = 1; i < size(nums); ++i) {\n            max_heap.emplace(nums[i]);\n            curr += nums[i];\n            if (size(max_heap) - total1 > k - 1) {\n                const int x = get_top(max_heap, cnt1, total1); max_heap.pop();\n                curr -= x;\n                min_heap.emplace(x);\n                \n            }\n            if ((size(max_heap) - total1) + (size(min_heap) - total2) > 1 + dist) {\n                if (get_top(min_heap, cnt2, total2) <= nums[i - (1 + dist)]) {\n                    lazy_delete(min_heap, cnt2, total2, nums[i - (1 + dist)]);\n                } else {\n                    lazy_delete(max_heap, cnt1, total1, nums[i - (1 + dist)]);\n                    curr -= nums[i - (1 + dist)] - min_heap.top();\n                    max_heap.emplace(min_heap.top()); min_heap.pop();\n                }\n            }\n            if (size(max_heap) - total1 == k - 1) {\n                mn = min(mn, curr);\n            }\n        }\n        return nums[0] + mn;\n    }\n\nprivate:\n    template<typename T>\n    void lazy_delete(T& heap, auto& cnt, int& total, int x) {\n        ++cnt[x];\n        ++total;\n        if (total <= size(heap) - total) {\n            return;\n        }\n        T new_heap;\n        while (!empty(heap)) {\n            const auto x = heap.top(); heap.pop();\n            if (cnt.count(x)) {\n                if (--cnt[x] == 0) {\n                    cnt.erase(x);\n                }\n                continue;\n            }\n            new_heap.emplace(x);\n        }\n        total = 0;\n        heap = move(new_heap);\n    }\n};\n\n// Time:  O(nlogd)\n// Space: O(d)\n// fast but verbose\n// sliding window, bst\nclass Solution3 {\npublic:\n    long long minimumCost(vector<int>& nums, int k, int dist) {\n        static const int64_t INF = numeric_limits<int64_t>::max();\n\n        multiset<int> bst1, bst2;\n        int64_t mn = INF, curr = 0;\n        for (int i = 1; i < size(nums); ++i) {\n            bst1.emplace(nums[i]);\n            curr += nums[i];\n            if (size(bst1) > k - 1) {\n                curr -= *rbegin(bst1);\n                bst2.emplace(*rbegin(bst1));\n                bst1.erase(prev(end(bst1)));\n            }\n            if (size(bst1) + size(bst2) > 1 + dist) {\n                if (*cbegin(bst2) <= nums[i - (1 + dist)]) {\n                    bst2.erase(bst2.find(nums[i - (1 + dist)]));\n                } else {\n                    bst1.erase(bst1.find(nums[i - (1 + dist)]));\n                    curr -= nums[i - (1 + dist)] - *cbegin(bst2);\n                    bst1.emplace(*cbegin(bst2));\n                    bst2.erase(begin(bst2));\n                }\n            }\n            if (size(bst1) == k - 1) {\n                mn = min(mn, curr);\n            }\n        }\n        return nums[0] + mn;\n    }\n};\n\n// Time:  O(nlogd)\n// Space: O(d)\n#include <ext/pb_ds/assoc_container.hpp>\n#include <ext/pb_ds/tree_policy.hpp>\nusing namespace __gnu_pbds;\n\n// concise but slow\n// sliding window, ordered set\nclass Solution4 {\npublic:\n    long long minimumCost(vector<int>& nums, int k, int dist) {\n        using ordered_set = tree<pair<int, int>, null_type, less<pair<int, int>>, rb_tree_tag, tree_order_statistics_node_update>;\n        ordered_set os;\n        for (int i = 1; i < 1 + (1 + dist); ++i) {\n            os.insert({nums[i], i});\n        }\n        int64_t curr = 0;\n        auto it = cbegin(os);\n        for (int i = 0; i < k - 1; ++i, ++it) {\n            curr += it->first;\n        }\n        int64_t mn = curr;\n        for (int i = 1 + (1 + dist); i < size(nums); ++i) {\n            os.insert({nums[i], i});\n            curr += min(nums[i] - os.find_by_order(k - 1)->first, 0);\n            curr -= min(nums[i - (1 + dist)] - os.find_by_order(k - 1)->first, 0);\n            os.erase({nums[i - (1 + dist)], i - (1 + dist)});\n            mn = min(mn, curr);\n        }\n        return nums[0] + mn;\n    }\n};\n20:T14e3,# Time:  O(nlogd)\n# Space: O(d)\n\nimport heapq\n\n\n# sliding window, heap\nclass Solution(object):\n    def minimumCost(self, nums, k, dist):\n        \"\"\"\n        :type nums: List[int]\n        :type k: int\n        :type dist: int\n        :rtype: int\n        \"\"\"\n        def get_top(heap, total):\n            while abs(heap[0][1]) < i-(1+dist):\n                heapq.heappop(heap)\n                total[0] -= 1\n            return heap[0]\n            \n        def lazy_delete(heap, total):\n            total[0] += 1\n            if total[0] <= len(heap)-total[0]:\n                return\n            heap[:] = [x for x in heap if abs(x[1]) > i-(1+dist)]\n            heapq.heapify(heap)\n            total[0] = 0\n\n        max_heap, min_heap = [], []\n        total1, total2 = [0], [0]\n        mn, curr = float(\"inf\"), 0\n        for i in xrange(1, len(nums)):\n            heapq.heappush(max_heap, (-nums[i], i))\n            curr += nums[i]\n            if i > k-1:\n                x, idx = get_top(max_heap, total1)\n                heapq.heappop(max_heap)\n                curr -= -x\n                heapq.heappush(min_heap, (-x, -idx))\n            if i > 1+dist:\n                x, idx = get_top(min_heap, total2)\n                if (x, idx) <= (nums[i-(1+dist)], -(i-(1+dist))):\n                    lazy_delete(min_heap, total2)\n                else:\n                    lazy_delete(max_heap, total1)\n                    heapq.heappop(min_heap)\n                    curr -= nums[i-(1+dist)]-x\n                    heapq.heappush(max_heap, (-x, -idx))\n            if i >= k-1:\n                mn = min(mn, curr)\n        return nums[0]+mn\n\n\n# Time:  O(nlogd)\n# Space: O(d)\nimport heapq\nimport collections\n\n\n# sliding window, heap, freq table\nclass Solution2(object):\n    def minimumCost(self, nums, k, dist):\n        \"\"\"\n        :type nums: List[int]\n        :type k: int\n        :type dist: int\n        :rtype: int\n        \"\"\"\n        def get_top(heap, cnt, total):\n            while heap[0] in cnt:\n                x = heapq.heappop(heap)\n                cnt[x] -= 1\n                if cnt[x] == 0:\n                    del cnt[x]\n                total[0] -= 1\n            return heap[0]\n\n        def lazy_delete(heap, cnt, total, x):\n            cnt[x] += 1\n            total[0] += 1\n            if total[0] <= len(heap)-total[0]:\n                return\n            new_heap = []\n            for x in heap:\n                if x not in cnt:\n                    new_heap.append(x)\n                    continue\n                cnt[x] -= 1\n                if cnt[x] == 0:\n                    del cnt[x]\n            total[0] = 0\n            heapq.heapify(new_heap)\n            heap[:] = new_heap\n\n        max_heap, min_heap = [], []\n        cnt1, cnt2 = collections.Counter(), collections.Counter()\n        total1, total2 = [0], [0]\n        mn, curr = float(\"inf\"), 0\n        for i in xrange(1, len(nums)):\n            heapq.heappush(max_heap, -nums[i])\n            curr += nums[i]\n            if (len(max_heap)-total1[0]) > k-1:\n                x = get_top(max_heap, cnt1, total1)\n                curr -= -x\n                heapq.heappush(min_heap, -heapq.heappop(max_heap))\n            if (len(max_heap)-total1[0])+(len(min_heap)-total2[0]) > 1+dist:\n                x = get_top(min_heap, cnt2, total2)\n                if x <= nums[i-(1+dist)]:\n                    lazy_delete(min_heap, cnt2, total2, nums[i-(1+dist)])\n                else:\n                    lazy_delete(max_heap, cnt1, total1, -nums[i-(1+dist)])\n                    heapq.heappop(min_heap)\n                    curr -= nums[i-(1+dist)]-x\n                    heapq.heappush(max_heap, -x)\n            if len(max_heap)-total1[0] == k-1:\n                mn = min(mn, curr)\n        return nums[0]+mn\n\n\n# Time:  O(nlogd)\n# Space: O(d)\nfrom sortedcontainers import SortedList\n\n\n# sliding window, sorted list\nclass Solution3(object):\n    def minimumCost(self, nums, k, dist):\n        \"\"\"\n        :type nums: List[int]\n        :type k: int\n        :type dist: int\n        :rtype: int\n        \"\"\"\n        sl1, sl2 = SortedList(), SortedList()\n        mn, curr = float(\"inf\"), 0\n        for i in xrange(1, len(nums)):\n            sl1.add(nums[i])\n            curr += nums[i]\n            if len(sl1) > k-1:\n                curr -= sl1[-1]\n                sl2.add(sl1.pop())\n            if len(sl1)+len(sl2) > 1+dist:\n                if sl2[0] <= nums[i-(1+dist)]:\n                    sl2.remove(nums[i-(1+dist)])\n                else:\n                    sl1.remove(nums[i-(1+dist)])\n                    curr -= nums[i-(1+dist)]-sl2[0]\n                    sl1.add(sl2.pop(0))\n            if len(sl1) == k-1:\n                mn = min(mn, curr)\n        return nums[0]+mn\n\n\n# Time:  O(nlogd)\n# Space: O(d)\nfrom sortedcontainers import SortedList\n\n\n# sliding window, sorted list\nclass Solution4(object):\n    def minimumCost(self, nums, k, dist):\n        \"\"\"\n        :type nums: List[int]\n        :type k: int\n        :type dist: int\n        :rtype: int\n        \"\"\"\n        sl = SortedList(nums[1:1+(1+dist)])\n        mn = curr = sum(sl[:k-1])\n        for i in xrange(1+(1+dist), len(nums)):\n            sl.add(nums[i])\n            curr += min(nums[i]-sl[k-1], 0)\n            curr -= min(nums[i-(1+dist)]-sl[k-1], 0)\n            sl.remove(nums[i-(1+dist)])\n            mn = min(mn, curr)\n        return nums[0]+mn\n15:[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Divide an Array Into Subarrays With Minimum Cost II\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/divide-an-array-into-subarrays-with-minimum-cost-ii\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"Python\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/divide-an-array-into-subarrays-with-minimum-cost-ii/python\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/divide-an-array-into-subarrays-with-minimum-cost-ii\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems/divide-an-array-into-subarrays-with-minimum-cost-ii\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Divide an Array Into Subarrays With Minimum Cost II\"}]]}],[\"$\",\"li\",\"/problems/divide-an-array-into-subarrays-with-minimum-cost-ii/python\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"Python\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 flex flex-wrap items-center gap-2\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-hard/15 text-hard\",\"children\":\"Hard\"}]}],[\"$\",\"h1\",null,{\"className\":\"mt-3 text-3xl font-bold tracking-tight\",\"children\":[\"Divide an Array Into Subarrays With Minimum Cost II\",\" — \",\"Python\"]}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-muted-foreground\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/problems/divide-an-array-into-subarrays-with-minimum-cost-ii\",\"className\":\"text-primary hover:underline\",\"children\":\"Full explanation\"}],\" · \",\"Time \",\"O(nlogd)\",\" · Space \",\"O(d)\"]}],[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L1e\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"divide-an-array-into-subarrays-with-minimum-cost-ii.cpp\",\"code\":\"$1f\",\"sourcePath\":\"C++/divide-an-array-into-subarrays-with-minimum-cost-ii.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"divide-an-array-into-subarrays-with-minimum-cost-ii.py\",\"code\":\"$20\",\"sourcePath\":\"Python/divide-an-array-into-subarrays-with-minimum-cost-ii.py\"}},\"defaultLang\":\"python\"}]}]]}]\n1b:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n21:I[27201,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"IconMark\"]\n18:null\n1d:[[\"$\",\"title\",\"0\",{\"children\":\"Divide an Array Into Subarrays With Minimum Cost II Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Python solution for Divide an Array Into Subarrays With Minimum Cost II (LeetCode #3013). Time O(nlogd), space O(d).\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"Divide an Array Into Subarrays With Minimum Cost II python,Divide an Array Into Subarrays With Minimum Cost II Python,python leetcode\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://algoforge.dev/problems/divide-an-array-into-subarrays-with-minimum-cost-ii/python\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"Divide an Array Into Subarrays With Minimum Cost II Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"Python solution for Divide an Array Into Subarrays With Minimum Cost II (LeetCode #3013). Time O(nlogd), space O(d).\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:url\",\"content\":\"https://algoforge.dev/problems/divide-an-array-into-subarrays-with-minimum-cost-ii/python\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:site_name\",\"content\":\"AlgoForge\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:image:alt\",\"content\":\"Divide an Array Into Subarrays With Minimum Cost II Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"13\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:title\",\"content\":\"Divide an Array Into Subarrays With Minimum Cost II Python Solution | AlgoForge\"}],[\"$\",\"meta\",\"15\",{\"name\":\"twitter:description\",\"content\":\"Python solution for Divide an Array Into Subarrays With Minimum Cost II (LeetCode #3013). Time O(nlogd), space O(d).\"}],[\"$\",\"meta\",\"16\",{\"name\":\"twitter:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"link\",\"17\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.2vob68tjqpejf.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"link\",\"18\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\"}],[\"$\",\"$L21\",\"19\",{}]]\n","/problems/$d$slug/$d$lang/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[522016,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"\"]\n3:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n8:I[897367,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"OutletBoundary\"]\n9:\"$Sreact.suspense\"\n4:T1a8a,// Time:  O(nlogd)\n// Space: O(d)\n\n// fastest and less verbose\n// sliding window, heap\nclass Solution {\npublic:\n    long long minimumCost(vector<int>& nums, int k, int dist) {\n        static const int64_t INF = numeric_limits<int64_t>::max();\n\n        const auto& get_top = [](auto& heap, auto& total, const int d) {\n            while (-heap.top().second < d) {\n                heap.pop();\n                --total;\n            }\n            return heap.top();\n        };\n\n        priority_queue<pair<int, int>> max_heap;\n        priority_queue<pair<int, int>, vector<pair<int, int>>, greater<pair<int, int>>> min_heap;\n        int total1 = 0, total2 = 0;\n        int64_t mn = INF, curr = 0;\n        for (int i = 1; i < size(nums); ++i) {\n            max_heap.emplace(nums[i], -i);\n            curr += nums[i];\n            if (i > k - 1) {\n                const auto [x, idx] = get_top(max_heap, total1, i - (1 + dist)); max_heap.pop();\n                curr -= x;\n                min_heap.emplace(x, idx);\n            }\n            if (i > 1 + dist) {\n                if (get_top(min_heap, total2, i - (1 + dist)) <= pair(nums[i - (1 + dist)], -(i - (1 + dist)))) {\n                    lazy_delete(min_heap, total2, i - (1 + dist));\n                } else {\n                    lazy_delete(max_heap, total1, i - (1 + dist));                    \n                    curr -= nums[i - (1 + dist)] - min_heap.top().first;\n                    max_heap.emplace(min_heap.top()); min_heap.pop();\n                }\n            }\n            if (i >= k - 1) {\n                mn = min(mn, curr);\n            }\n        }\n        return nums[0] + mn;\n    }\n\nprivate:\n    template<typename T>\n    void lazy_delete(T& heap, int& total, const int d) {\n        ++total;\n        if (total <= size(heap) - total) {\n            return;\n        }\n        T new_heap;\n        while (!empty(heap)) {\n            const auto x = heap.top(); heap.pop();\n            if (-x.second <= d) {\n                --total;\n                continue;\n            }\n            new_heap.emplace(x);\n        }\n        heap = move(new_heap);\n    }\n};\n\n// Time:  O(nlogd)\n// Space: O(d)\n// faster but more verbose\n// sliding window, heap, freq table\nclass Solution2 {\npublic:\n    long long minimumCost(vector<int>& nums, int k, int dist) {\n        static const int64_t INF = numeric_limits<int64_t>::max();\n\n        const auto& get_top = [](auto& heap, auto& cnt, auto& total) {\n            while (cnt.count(heap.top())) {\n                const int x = heap.top(); heap.pop();\n                if (--cnt[x] == 0) {\n                    cnt.erase(x);\n                }\n                --total;\n            }\n            return heap.top();\n        };\n\n        priority_queue<int> max_heap;\n        priority_queue<int, vector<int>, greater<int>> min_heap;\n        unordered_map<int, int> cnt1, cnt2;\n        int total1 = 0, total2 = 0;\n        int64_t mn = INF, curr = 0;\n        for (int i = 1; i < size(nums); ++i) {\n            max_heap.emplace(nums[i]);\n            curr += nums[i];\n            if (size(max_heap) - total1 > k - 1) {\n                const int x = get_top(max_heap, cnt1, total1); max_heap.pop();\n                curr -= x;\n                min_heap.emplace(x);\n                \n            }\n            if ((size(max_heap) - total1) + (size(min_heap) - total2) > 1 + dist) {\n                if (get_top(min_heap, cnt2, total2) <= nums[i - (1 + dist)]) {\n                    lazy_delete(min_heap, cnt2, total2, nums[i - (1 + dist)]);\n                } else {\n                    lazy_delete(max_heap, cnt1, total1, nums[i - (1 + dist)]);\n                    curr -= nums[i - (1 + dist)] - min_heap.top();\n                    max_heap.emplace(min_heap.top()); min_heap.pop();\n                }\n            }\n            if (size(max_heap) - total1 == k - 1) {\n                mn = min(mn, curr);\n            }\n        }\n        return nums[0] + mn;\n    }\n\nprivate:\n    template<typename T>\n    void lazy_delete(T& heap, auto& cnt, int& total, int x) {\n        ++cnt[x];\n        ++total;\n        if (total <= size(heap) - total) {\n            return;\n        }\n        T new_heap;\n        while (!empty(heap)) {\n            const auto x = heap.top(); heap.pop();\n            if (cnt.count(x)) {\n                if (--cnt[x] == 0) {\n                    cnt.erase(x);\n                }\n                continue;\n            }\n            new_heap.emplace(x);\n        }\n        total = 0;\n        heap = move(new_heap);\n    }\n};\n\n// Time:  O(nlogd)\n// Space: O(d)\n// fast but verbose\n// sliding window, bst\nclass Solution3 {\npublic:\n    long long minimumCost(vector<int>& nums, int k, int dist) {\n        static const int64_t INF = numeric_limits<int64_t>::max();\n\n        multiset<int> bst1, bst2;\n        int64_t mn = INF, curr = 0;\n        for (int i = 1; i < size(nums); ++i) {\n            bst1.emplace(nums[i]);\n            curr += nums[i];\n            if (size(bst1) > k - 1) {\n                curr -= *rbegin(bst1);\n                bst2.emplace(*rbegin(bst1));\n                bst1.erase(prev(end(bst1)));\n            }\n            if (size(bst1) + size(bst2) > 1 + dist) {\n                if (*cbegin(bst2) <= nums[i - (1 + dist)]) {\n                    bst2.erase(bst2.find(nums[i - (1 + dist)]));\n                } else {\n                    bst1.erase(bst1.find(nums[i - (1 + dist)]));\n                    curr -= nums[i - (1 + dist)] - *cbegin(bst2);\n                    bst1.emplace(*cbegin(bst2));\n                    bst2.erase(begin(bst2));\n                }\n            }\n            if (size(bst1) == k - 1) {\n                mn = min(mn, curr);\n            }\n        }\n        return nums[0] + mn;\n    }\n};\n\n// Time:  O(nlogd)\n// Space: O(d)\n#include <ext/pb_ds/assoc_container.hpp>\n#include <ext/pb_ds/tree_policy.hpp>\nusing namespace __gnu_pbds;\n\n// concise but slow\n// sliding window, ordered set\nclass Solution4 {\npublic:\n    long long minimumCost(vector<int>& nums, int k, int dist) {\n        using ordered_set = tree<pair<int, int>, null_type, less<pair<int, int>>, rb_tree_tag, tree_order_statistics_node_update>;\n        ordered_set os;\n        for (int i = 1; i < 1 + (1 + dist); ++i) {\n            os.insert({nums[i], i});\n        }\n        int64_t curr = 0;\n        auto it = cbegin(os);\n        for (int i = 0; i < k - 1; ++i, ++it) {\n            curr += it->first;\n        }\n        int64_t mn = curr;\n        for (int i = 1 + (1 + dist); i < size(nums); ++i) {\n            os.insert({nums[i], i});\n            curr += min(nums[i] - os.find_by_order(k - 1)->first, 0);\n            curr -= min(nums[i - (1 + dist)] - os.find_by_order(k - 1)->first, 0);\n            os.erase({nums[i - (1 + dist)], i - (1 + dist)});\n            mn = min(mn, curr);\n        }\n        return nums[0] + mn;\n    }\n};\n5:T14e3,# Time:  O(nlogd)\n# Space: O(d)\n\nimport heapq\n\n\n# sliding window, heap\nclass Solution(object):\n    def minimumCost(self, nums, k, dist):\n        \"\"\"\n        :type nums: List[int]\n        :type k: int\n        :type dist: int\n        :rtype: int\n        \"\"\"\n        def get_top(heap, total):\n            while abs(heap[0][1]) < i-(1+dist):\n                heapq.heappop(heap)\n                total[0] -= 1\n            return heap[0]\n            \n        def lazy_delete(heap, total):\n            total[0] += 1\n            if total[0] <= len(heap)-total[0]:\n                return\n            heap[:] = [x for x in heap if abs(x[1]) > i-(1+dist)]\n            heapq.heapify(heap)\n            total[0] = 0\n\n        max_heap, min_heap = [], []\n        total1, total2 = [0], [0]\n        mn, curr = float(\"inf\"), 0\n        for i in xrange(1, len(nums)):\n            heapq.heappush(max_heap, (-nums[i], i))\n            curr += nums[i]\n            if i > k-1:\n                x, idx = get_top(max_heap, total1)\n                heapq.heappop(max_heap)\n                curr -= -x\n                heapq.heappush(min_heap, (-x, -idx))\n            if i > 1+dist:\n                x, idx = get_top(min_heap, total2)\n                if (x, idx) <= (nums[i-(1+dist)], -(i-(1+dist))):\n                    lazy_delete(min_heap, total2)\n                else:\n                    lazy_delete(max_heap, total1)\n                    heapq.heappop(min_heap)\n                    curr -= nums[i-(1+dist)]-x\n                    heapq.heappush(max_heap, (-x, -idx))\n            if i >= k-1:\n                mn = min(mn, curr)\n        return nums[0]+mn\n\n\n# Time:  O(nlogd)\n# Space: O(d)\nimport heapq\nimport collections\n\n\n# sliding window, heap, freq table\nclass Solution2(object):\n    def minimumCost(self, nums, k, dist):\n        \"\"\"\n        :type nums: List[int]\n        :type k: int\n        :type dist: int\n        :rtype: int\n        \"\"\"\n        def get_top(heap, cnt, total):\n            while heap[0] in cnt:\n                x = heapq.heappop(heap)\n                cnt[x] -= 1\n                if cnt[x] == 0:\n                    del cnt[x]\n                total[0] -= 1\n            return heap[0]\n\n        def lazy_delete(heap, cnt, total, x):\n            cnt[x] += 1\n            total[0] += 1\n            if total[0] <= len(heap)-total[0]:\n                return\n            new_heap = []\n            for x in heap:\n                if x not in cnt:\n                    new_heap.append(x)\n                    continue\n                cnt[x] -= 1\n                if cnt[x] == 0:\n                    del cnt[x]\n            total[0] = 0\n            heapq.heapify(new_heap)\n            heap[:] = new_heap\n\n        max_heap, min_heap = [], []\n        cnt1, cnt2 = collections.Counter(), collections.Counter()\n        total1, total2 = [0], [0]\n        mn, curr = float(\"inf\"), 0\n        for i in xrange(1, len(nums)):\n            heapq.heappush(max_heap, -nums[i])\n            curr += nums[i]\n            if (len(max_heap)-total1[0]) > k-1:\n                x = get_top(max_heap, cnt1, total1)\n                curr -= -x\n                heapq.heappush(min_heap, -heapq.heappop(max_heap))\n            if (len(max_heap)-total1[0])+(len(min_heap)-total2[0]) > 1+dist:\n                x = get_top(min_heap, cnt2, total2)\n                if x <= nums[i-(1+dist)]:\n                    lazy_delete(min_heap, cnt2, total2, nums[i-(1+dist)])\n                else:\n                    lazy_delete(max_heap, cnt1, total1, -nums[i-(1+dist)])\n                    heapq.heappop(min_heap)\n                    curr -= nums[i-(1+dist)]-x\n                    heapq.heappush(max_heap, -x)\n            if len(max_heap)-total1[0] == k-1:\n                mn = min(mn, curr)\n        return nums[0]+mn\n\n\n# Time:  O(nlogd)\n# Space: O(d)\nfrom sortedcontainers import SortedList\n\n\n# sliding window, sorted list\nclass Solution3(object):\n    def minimumCost(self, nums, k, dist):\n        \"\"\"\n        :type nums: List[int]\n        :type k: int\n        :type dist: int\n        :rtype: int\n        \"\"\"\n        sl1, sl2 = SortedList(), SortedList()\n        mn, curr = float(\"inf\"), 0\n        for i in xrange(1, len(nums)):\n            sl1.add(nums[i])\n            curr += nums[i]\n            if len(sl1) > k-1:\n                curr -= sl1[-1]\n                sl2.add(sl1.pop())\n            if len(sl1)+len(sl2) > 1+dist:\n                if sl2[0] <= nums[i-(1+dist)]:\n                    sl2.remove(nums[i-(1+dist)])\n                else:\n                    sl1.remove(nums[i-(1+dist)])\n                    curr -= nums[i-(1+dist)]-sl2[0]\n                    sl1.add(sl2.pop(0))\n            if len(sl1) == k-1:\n                mn = min(mn, curr)\n        return nums[0]+mn\n\n\n# Time:  O(nlogd)\n# Space: O(d)\nfrom sortedcontainers import SortedList\n\n\n# sliding window, sorted list\nclass Solution4(object):\n    def minimumCost(self, nums, k, dist):\n        \"\"\"\n        :type nums: List[int]\n        :type k: int\n        :type dist: int\n        :rtype: int\n        \"\"\"\n        sl = SortedList(nums[1:1+(1+dist)])\n        mn = curr = sum(sl[:k-1])\n        for i in xrange(1+(1+dist), len(nums)):\n            sl.add(nums[i])\n            curr += min(nums[i]-sl[k-1], 0)\n            curr -= min(nums[i-(1+dist)]-sl[k-1], 0)\n            sl.remove(nums[i-(1+dist)])\n            mn = min(mn, curr)\n        return nums[0]+mn\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\"