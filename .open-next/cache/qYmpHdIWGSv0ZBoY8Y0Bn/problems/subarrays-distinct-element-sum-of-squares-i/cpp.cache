{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/problems/layout,_N_T_/problems/[slug]/layout,_N_T_/problems/[slug]/[lang]/layout,_N_T_/problems/[slug]/[lang]/page,_N_T_/problems/subarrays-distinct-element-sum-of-squares-i/cpp"},"segmentPaths":["/_tree","/_full","/problems/$d$slug/$d$lang/__PAGE__","/problems/$d$slug/$d$lang","/problems/$d$slug","/problems","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0r6juujl39pe6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/340fxer6uczx7.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/05kafvajig4wu.js\"/><script src=\"/_next/static/chunks/2o5-igl1ik8oj.js\" async=\"\"></script><script src=\"/_next/static/chunks/1uejzok0tpgy1.js\" async=\"\"></script><script src=\"/_next/static/chunks/3ujjz4ap-oopx.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3om3j4o09b7fr.js\" async=\"\"></script><script src=\"/_next/static/chunks/2fvm6eoqeukxu.js\" async=\"\"></script><script src=\"/_next/static/chunks/1ntn7efqc-iiw.js\" async=\"\"></script><script src=\"/_next/static/chunks/0plpm2axnqe9k.js\" async=\"\"></script><script src=\"/_next/static/chunks/0a2gmow1_jiq0.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Subarrays Distinct Element Sum of Squares I C++ Solution | AlgoForge</title><meta name=\"description\" content=\"C++ solution for Subarrays Distinct Element Sum of Squares I (LeetCode #2913). Time O(nlogn), space O(n).\"/><meta name=\"keywords\" content=\"Subarrays Distinct Element Sum of Squares I cpp,Subarrays Distinct Element Sum of Squares I C++,cpp leetcode\"/><link rel=\"canonical\" href=\"https://algoforge.dev/problems/subarrays-distinct-element-sum-of-squares-i/cpp\"/><meta property=\"og:title\" content=\"Subarrays Distinct Element Sum of Squares I C++ Solution | AlgoForge\"/><meta property=\"og:description\" content=\"C++ solution for Subarrays Distinct Element Sum of Squares I (LeetCode #2913). Time O(nlogn), space O(n).\"/><meta property=\"og:url\" content=\"https://algoforge.dev/problems/subarrays-distinct-element-sum-of-squares-i/cpp\"/><meta property=\"og:site_name\" content=\"AlgoForge\"/><meta property=\"og:image\" content=\"https://algoforge.dev/og-default.png\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"Subarrays Distinct Element Sum of Squares I C++ Solution | AlgoForge\"/><meta property=\"og:type\" content=\"article\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"Subarrays Distinct Element Sum of Squares I C++ Solution | AlgoForge\"/><meta name=\"twitter:description\" content=\"C++ solution for Subarrays Distinct Element Sum of Squares I (LeetCode #2913). Time O(nlogn), space O(n).\"/><meta name=\"twitter:image\" content=\"https://algoforge.dev/og-default.png\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><link rel=\"icon\" href=\"/favicon.ico\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"geist_deef94d5-module__Sms4YG__variable geist_mono_1bf8cbf6-module__FlyLvG__variable antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><script>((a,b,c,d,e,f,g,h)=>{let i=document.documentElement,j=[\"light\",\"dark\"];function k(b){var c;(Array.isArray(a)?a:[a]).forEach(a=>{let c=\"class\"===a,d=c&&f?e.map(a=>f[a]||a):e;c?(i.classList.remove(...d),i.classList.add(f&&f[b]?f[b]:b)):i.setAttribute(a,b)}),c=b,h&&j.includes(c)&&(i.style.colorScheme=c)}if(d)k(d);else try{let a=localStorage.getItem(b)||c,d=g&&\"system\"===a?window.matchMedia(\"(prefers-color-scheme: dark)\").matches?\"dark\":\"light\":a;k(d)}catch(a){}})(\"class\",\"theme\",\"system\",null,[\"light\",\"dark\"],null,true,true)</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"AlgoForge\",\"url\":\"https://algoforge.dev\",\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\"}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"AlgoForge\",\"url\":\"https://algoforge.dev\",\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":{\"@type\":\"EntryPoint\",\"urlTemplate\":\"https://algoforge.dev/search?q={search_term_string}\"},\"query-input\":\"required name=search_term_string\"}}</script><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"SoftwareApplication\",\"name\":\"AlgoForge\",\"applicationCategory\":\"EducationalApplication\",\"operatingSystem\":\"Web\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"},\"description\":\"AlgoForge is a free, SEO-first coding interview platform with pattern-based learning paths, curated collections (Blind 75, Grind 169), multi-language solutions, and original explanations.\"}</script><header class=\"sticky top-0 z-50 border-b border-border/80 bg-background/85 backdrop-blur-md\"><div class=\"container-af flex h-14 items-center justify-between gap-4\"><div class=\"flex items-center gap-6\"><a class=\"flex items-center gap-2 font-bold tracking-tight\" href=\"/\"><span class=\"inline-flex h-7 w-7 items-center justify-center rounded-md bg-primary text-primary-foreground text-xs font-black\">AF</span><span class=\"hidden sm:inline\">AlgoForge</span></a><nav class=\"hidden lg:flex items-center gap-1\" aria-label=\"Main\"><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/problems\">Problems</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/topics\">Topics</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/patterns\">Patterns</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/roadmaps\">Roadmaps</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blind-75\">Blind 75</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/companies\">Companies</a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors\" href=\"/blog\">Blog</a></nav></div><div class=\"flex items-center gap-1\"><a class=\"hidden sm:inline-flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-1.5 text-sm text-muted-foreground hover:border-primary/40 transition-colors\" href=\"/search\"><span>Search…</span><kbd class=\"rounded border border-border bg-muted px-1.5 text-[10px] font-mono\">/</kbd></a><a class=\"rounded-md px-2.5 py-1.5 text-sm text-muted-foreground hover:text-foreground\" href=\"/dashboard\">Progress</a><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 hover:bg-muted text-foreground h-9 w-9\" aria-label=\"Toggle theme\"></button></div></div></header><main id=\"main\" class=\"min-h-[70vh]\"><div class=\"container-af py-10\"><nav aria-label=\"Breadcrumb\" class=\"text-sm text-muted-foreground\"><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://algoforge.dev/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Problems\",\"item\":\"https://algoforge.dev/problems\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Subarrays Distinct Element Sum of Squares I\",\"item\":\"https://algoforge.dev/problems/subarrays-distinct-element-sum-of-squares-i\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"C++\",\"item\":\"https://algoforge.dev/problems/subarrays-distinct-element-sum-of-squares-i/cpp\"}]}</script><ol class=\"flex flex-wrap items-center gap-1.5\"><li class=\"flex items-center gap-1.5\"><a class=\"hover:text-primary transition-colors\" href=\"/\">Home</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems\">Problems</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><a class=\"hover:text-primary transition-colors\" href=\"/problems/subarrays-distinct-element-sum-of-squares-i\">Subarrays Distinct Element Sum of Squares I</a></li><li class=\"flex items-center gap-1.5\"><span aria-hidden=\"true\" class=\"text-border\">/</span><span class=\"text-foreground font-medium\" aria-current=\"page\">C++</span></li></ol></nav><div class=\"mt-4 flex flex-wrap items-center gap-2\"><span class=\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-easy/15 text-easy\">Easy</span></div><h1 class=\"mt-3 text-3xl font-bold tracking-tight\">Subarrays Distinct Element Sum of Squares I<!-- --> — <!-- -->C++</h1><p class=\"mt-2 text-muted-foreground\"><a class=\"text-primary hover:underline\" href=\"/problems/subarrays-distinct-element-sum-of-squares-i\">Full explanation</a> · <!-- -->Time <!-- -->O(nlogn)<!-- --> · Space <!-- -->O(n)</p><div class=\"mt-8\"><div class=\"rounded-xl border border-border overflow-hidden bg-code-bg text-slate-100\"><div class=\"flex flex-wrap items-center justify-between gap-2 border-b border-white/10 bg-black/30 px-2 py-1.5\"><div class=\"flex flex-wrap gap-1\" role=\"tablist\" aria-label=\"Language\"><button role=\"tab\" aria-selected=\"true\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors bg-white/15 text-white\">C++</button><button role=\"tab\" aria-selected=\"false\" class=\"rounded-md px-2.5 py-1 text-xs font-medium transition-colors text-slate-400 hover:text-white hover:bg-white/5\">Python</button></div><button class=\"inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 px-3 text-sm text-slate-300 hover:text-white hover:bg-white/10 h-8\" type=\"button\" aria-label=\"Copy code\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-copy h-3.5 w-3.5\" aria-hidden=\"true\"><rect width=\"14\" height=\"14\" x=\"8\" y=\"8\" rx=\"2\" ry=\"2\"></rect><path d=\"M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2\"></path></svg>Copy</button></div><pre class=\"overflow-x-auto p-4 text-[13px] leading-relaxed font-mono max-h-[32rem]\"><code>// Time:  O(nlogn)\n// Space: O(n)\n\n#include &lt;ext/pb_ds/assoc_container.hpp&gt;\n#include &lt;ext/pb_ds/tree_policy.hpp&gt;\nusing namespace __gnu_pbds;\n\n// bit, fenwick tree, ordered set, math\nclass Solution {\npublic:\n    int sumCounts(vector&lt;int&gt;&amp; nums) {\n        static const int MOD = 1e9 + 7;\n\n        using ordered_set = tree&lt;int, null_type, less&lt;int&gt;, rb_tree_tag, tree_order_statistics_node_update&gt;;\n        ordered_set os;\n        unordered_map&lt;int, vector&lt;int&gt;&gt; idxs;\n        for (int i = size(nums) - 1; i &gt;= 0; --i) {\n            idxs[nums[i]].emplace_back(i);\n        }\n        for (const auto&amp; [_, v] : idxs) {\n            os.insert(v.back());\n        }\n        int result = 0;\n        int accu = ((static_cast&lt;int64_t&gt;(size(nums)) * size(os)) % MOD) * size(os) % MOD;\n        for (int i = 0; i &lt; size(os); ++i) {\n            accu = ((accu - (static_cast&lt;int64_t&gt;(2 * i + 1) * *os.find_by_order(i) % MOD)) % MOD + MOD) % MOD;\n        }\n        BIT bit(size(nums));\n        for (const auto&amp; x : os) {\n            bit.add(x, x);\n        }\n\n        const auto&amp; update = [&amp;](int x, int accu, int d) {\n            const int i = os.order_of_key(idxs[x].back());\n            accu = ((accu + d * (static_cast&lt;int64_t&gt;(size(nums)) * (2 * static_cast&lt;int&gt;(size(os)) - 1)\n                                 - static_cast&lt;int64_t&gt;(2 * i + 1) * idxs[x].back()\n                                 - 2ll * (bit.query(size(nums) - 1) - bit.query(idxs[x].back())))) % MOD + MOD) % MOD;\n            bit.add(idxs[x].back(), d * idxs[x].back());\n            return accu;\n        };\n\n        for (const auto&amp; x : nums) {\n            result = (result + accu) % MOD;  // accu = sum(count(i, k) for k in range(i, len(nums)))\n            accu = update(x, accu, -1);\n            os.erase(idxs[x].back());\n            idxs[x].pop_back();\n            if (empty(idxs[x])) {\n                continue;\n            }\n            os.insert(idxs[x].back());\n            accu = update(x, accu, +1);\n        }\n        assert(accu == 0);\n        return result;\n    }\n\nprivate:\n    class BIT {\n    public:\n        BIT(int n) : bit_(n + 1) {  // 0-indexed\n        }\n        \n        void add(int i, int val) {\n            ++i;\n            for (; i &lt; size(bit_); i += lower_bit(i)) {\n                bit_[i] = (bit_[i] + val) % MOD;\n            }\n        }\n\n        int query(int i) const {\n            ++i;\n            int total = 0;\n            for (; i &gt; 0; i -= lower_bit(i)) {\n                total = (total + bit_[i]) % MOD;\n            }\n            return total;\n        }\n    \n    private:\n        int lower_bit(int i) const {\n            return i &amp; -i;\n        }\n        \n        vector&lt;int&gt; bit_;\n        static const int MOD = 1e9 + 7;\n    };\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// dp, segment tree, math\nclass Solution2 {\npublic:\n    int sumCounts(vector&lt;int&gt;&amp; nums) {\n        static const int MOD = 1e9 + 7;\n\n        int result = 0, accu = 0;\n        unordered_map&lt;int, int&gt; lookup;\n        SegmentTree st(size(nums));\n        for (int i = 0; i &lt; size(nums); ++i) {\n            const int j = lookup.count(nums[i]) ? lookup[nums[i]] : -1;\n            // sum(count(k, i)^2 for k in range(i+1)) - sum(count(k, i-1)^2 for k in range(i))\n            // = sum(2*count(k, i-1)+1 for k in range(j+1, i+1))\n            // = (i-j) + sum(2*count(k, i-1) for k in range(j+1, i+1))\n            accu = (accu + ((i - j) + 2ll * st.query(j + 1, i))) % MOD;\n            result = (result + accu) % MOD;\n            st.update(j + 1, i, 1);  // count(k, i) = count(k, i-1)+(1 if k &gt;= j+1 else 0) for k in range(i+1)\n            lookup[nums[i]] = i;\n        }\n        return result;\n    }\n\nprivate:\n    class SegmentTree {\n    private:\n        static const int MOD = 1e9 + 7;\n\n    public:\n        explicit SegmentTree(\n            int N)\n         :  base_(N &gt; 1 ? 1 &lt;&lt; (__lg(N - 1) + 1) : 1),\n            lazy_(base_),\n            tree_(N &gt; 1 ? 1 &lt;&lt; (__lg(N - 1) + 2) : 2),\n            count_(size(tree_), 1) {\n\n            for (int i = base_ - 1; i &gt;= 1; --i) { // added\n                count_[i] = count_[i &lt;&lt; 1] + count_[(i &lt;&lt; 1) + 1];\n            }\n        }\n\n        void update(int L, int R, const int val) {\n            L += base_;\n            R += base_;\n            // push(L);  // enable if range assignment\n            // push(R);  // enable if range assignment\n            int L0 = L, R0 = R;\n            for (; L &lt;= R; L &gt;&gt;= 1, R &gt;&gt;= 1) {\n                if ((L &amp; 1) == 1) {\n                    apply(L++, val);\n                }\n                if ((R &amp; 1) == 0) {\n                    apply(R--, val);\n                }\n            }\n            pull(L0);\n            pull(R0);\n        }\n\n        int query(int L, int R) {\n            if (L &gt; R) {\n                return 0;\n            }\n            L += base_;\n            R += base_;\n            push(L);\n            push(R);\n            int left = 0, right = 0;\n            for (; L &lt;= R; L &gt;&gt;= 1, R &gt;&gt;= 1) {\n                if ((L &amp; 1) == 1) {\n                    left = (left + tree_[L++]) % MOD;\n                }\n                if ((R &amp; 1) == 0) {\n                    right = (tree_[R--] + right) % MOD;\n                }\n            }\n            return (left + right) % MOD;\n        }\n\n    private:\n        void apply(int x, const int val) {\n            tree_[x] = (tree_[x] + static_cast&lt;int64_t&gt;(val) * count_[x]) % MOD;  // modified\n            if (x &lt; base_) {\n                lazy_[x] = (lazy_[x] + val) % MOD;\n            }\n        }\n\n        void pull(int x) {\n            while (x &gt; 1) {\n                x &gt;&gt;= 1;\n                tree_[x] = (tree_[x &lt;&lt; 1] + tree_[(x &lt;&lt; 1) + 1]) % MOD;\n                if (lazy_[x]) {\n                    tree_[x] = (tree_[x] + static_cast&lt;int64_t&gt;(lazy_[x]) * count_[x]) % MOD;  // modified\n                }\n            }\n        }\n\n        void push(int x) {\n            for (int h = __lg(x) - 1; h &gt; 0; --h) {\n                int y = x &gt;&gt; h;\n                if (lazy_[y]) {\n                    apply(y &lt;&lt; 1, lazy_[y]);\n                    apply((y &lt;&lt; 1) + 1, lazy_[y]);\n                    lazy_[y] = 0;\n                }\n            }\n        }\n\n        int base_;\n        vector&lt;int&gt; tree_;\n        vector&lt;int&gt; lazy_;\n        vector&lt;int&gt; count_;  // added\n    };\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// dp, segment tree, math\nclass Solution3 {\npublic:\n    int sumCounts(vector&lt;int&gt;&amp; nums) {\n        static const int MOD = 1e9 + 7;\n\n        const auto&amp; sum = [&amp;] (const auto&amp; x, const auto&amp; y) {\n            return (x + y) % MOD;\n        };\n\n        int result = 0, accu = 0;\n        unordered_map&lt;int, int&gt; lookup;\n        SegmentTree&lt;int&gt; st(size(nums), sum, sum);\n        for (int i = 0; i &lt; size(nums); ++i) {\n            const int j = lookup.count(nums[i]) ? lookup[nums[i]] : -1;\n            // sum(count(k, i)^2 for k in range(i+1)) - sum(count(k, i-1)^2 for k in range(i))\n            // = sum(2*count(k, i-1)+1 for k in range(j+1, i+1))\n            // = (i-j) + sum(2*count(k, i-1) for k in range(j+1, i+1))\n            accu = (accu + ((i - j) + 2ll * st.query(j + 1, i))) % MOD;\n            result = (result + accu) % MOD;\n            st.update(j + 1, i, 1);  // count(k, i) = count(k, i-1)+(1 if k &gt;= j+1 else 0) for k in range(i+1)\n            lookup[nums[i]] = i;\n        }\n        return result;\n    }\n\nprivate:\n    template &lt;typename T&gt;\n    class SegmentTree {\n    private:\n        static const int MOD = 1e9 + 7;\n\n    public:\n        explicit SegmentTree(\n            int N,\n            const function&lt;T(const T&amp;, const T&amp;)&gt;&amp; query_fn,\n            const function&lt;T(const T&amp;, const T&amp;)&gt;&amp; update_fn)\n         :  base_(N &gt; 1 ? 1 &lt;&lt; (__lg(N - 1) + 1) : 1),\n            lazy_(base_),\n            tree_(N &gt; 1 ? 1 &lt;&lt; (__lg(N - 1) + 2) : 2),\n            count_(size(tree_), 1),\n            query_fn_(query_fn),\n            update_fn_(update_fn) {\n\n            for (int i = base_ - 1; i &gt;= 1; --i) { // added\n                count_[i] = count_[i &lt;&lt; 1] + count_[(i &lt;&lt; 1) + 1];\n            }\n        }\n\n        void update(int L, int R, const T&amp; val) {\n            L += base_;\n            R += base_;\n            // push(L);  // enable if range assignment\n            // push(R);  // enable if range assignment\n            int L0 = L, R0 = R;\n            for (; L &lt;= R; L &gt;&gt;= 1, R &gt;&gt;= 1) {\n                if ((L &amp; 1) == 1) {\n                    apply(L++, val);\n                }\n                if ((R &amp; 1) == 0) {\n                    apply(R--, val);\n                }\n            }\n            pull(L0);\n            pull(R0);\n        }\n\n        T query(int L, int R) {\n            if (L &gt; R) {\n                return T{};\n            }\n            L += base_;\n            R += base_;\n            push(L);\n            push(R);\n            T left{}, right{};\n            for (; L &lt;= R; L &gt;&gt;= 1, R &gt;&gt;= 1) {\n                if ((L &amp; 1) == 1) {\n                    left = query_fn_(left, tree_[L++]);\n                }\n                if ((R &amp; 1) == 0) {\n                    right = query_fn_(tree_[R--], right);\n                }\n            }\n            return query_fn_(left, right);\n        }\n\n    private:\n        void apply(int x, const T val) {\n            tree_[x] = update_fn_(tree_[x], (static_cast&lt;int64_t&gt;(val) * count_[x]) % MOD);  // modified\n            if (x &lt; base_) {\n                lazy_[x] = update_fn_(lazy_[x], val);\n            }\n        }\n\n        void pull(int x) {\n            while (x &gt; 1) {\n                x &gt;&gt;= 1;\n                tree_[x] = query_fn_(tree_[x &lt;&lt; 1], tree_[(x &lt;&lt; 1) + 1]);\n                if (lazy_[x]) {\n                    tree_[x] = update_fn_(tree_[x], (static_cast&lt;int64_t&gt;(lazy_[x]) * count_[x]) % MOD);  // modified\n                }\n            }\n        }\n\n        void push(int x) {\n            for (int h = __lg(x) - 1; h &gt; 0; --h) {\n                int y = x &gt;&gt; h;\n                if (lazy_[y]) {\n                    apply(y &lt;&lt; 1, lazy_[y]);\n                    apply((y &lt;&lt; 1) + 1, lazy_[y]);\n                    lazy_[y] = 0;\n                }\n            }\n        }\n\n        int base_;\n        vector&lt;T&gt; tree_;\n        vector&lt;T&gt; lazy_;\n        vector&lt;T&gt; count_;  // added\n        const function&lt;T(const T&amp;, const T&amp;)&gt; query_fn_;\n        const function&lt;T(const T&amp;, const T&amp;)&gt; update_fn_;\n    };\n};\n\n// Time:  O(n^2)\n// Space: O(n)\n// hash table\nclass Solution4 {\npublic:\n    int sumCounts(vector&lt;int&gt;&amp; nums) {\n        static const int MOD = 1e9 + 7;\n\n        int result = 0;\n        for (int i = 0; i &lt; size(nums); ++i) {\n            unordered_set&lt;int&gt; lookup;\n            for (int j = i; j &gt;= 0; --j) {\n                lookup.emplace(nums[j]);\n                result = (result + (static_cast&lt;int64_t&gt;(size(lookup)) * size(lookup) % MOD)) % MOD;\n            }\n        }\n        return result;\n    }\n};\n</code></pre></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-border bg-sidebar\"><div class=\"container-af py-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4\"><div><p class=\"font-bold text-lg\">AlgoForge</p><p class=\"mt-2 text-sm text-muted-foreground max-w-xs\">Master coding interviews with patterns, roadmaps, and solutions</p></div><div><p class=\"font-semibold text-sm mb-3\">