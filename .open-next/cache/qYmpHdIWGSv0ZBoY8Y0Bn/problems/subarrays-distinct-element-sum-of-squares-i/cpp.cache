ll,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/blog\",\"className\":\"hover:text-primary\",\"children\":\"Blog\"}]}]]}]]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-semibold text-sm mb-3\",\"children\":\"Product\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-sm text-muted-foreground\",\"children\":[[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/pricing\",\"className\":\"hover:text-primary\",\"children\":\"Pricing\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/about\",\"className\":\"hover:text-primary\",\"children\":\"About\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/about/attribution\",\"className\":\"hover:text-primary\",\"children\":\"Attribution\"}]}],[\"$\",\"li\",null,{\"children\":[\"$\",\"$L3\",null,{\"href\":\"/sitemap-html\",\"className\":\"hover:text-primary\",\"children\":\"Sitemap\"}]}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"border-t border-border\",\"children\":[\"$\",\"div\",null,{\"className\":\"container-af py-4 flex flex-col sm:flex-row gap-2 justify-between text-xs text-muted-foreground\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"© \",2026,\" \",\"AlgoForge\",\". Educational use only.\"]}],[\"$\",\"p\",null,{\"children\":[\"Solution code sourced under MIT from\",\" \",[\"$\",\"a\",null,{\"href\":\"https://github.com/kamyu104/LeetCode-Solutions\",\"className\":\"underline hover:text-primary\",\"rel\":\"noopener noreferrer\",\"target\":\"_blank\",\"children\":\"kamyu104/LeetCode-Solutions\"}],\". Explanations are original AlgoForge content.\"]}]]}]}]]}]\na:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nb:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nc:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L13\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L14\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nd:[\"$\",\"$1\",\"c\",{\"children\":[\"$L15\",[[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0a2gmow1_jiq0.js\",\"async\":true,\"nonce\":\"$undefined\"}]],[\"$\",\"$L16\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@18\"}]}]]}]\n19:[]\ne:\"$W19\"\nf:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1a\",null,{\"children\":\"$L1b\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$17\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1d\"}]}]}],[\"$\",\"meta\",null,{\"name\":\"next-size-adjust\",\"content\":\"\"}]]}]\n11:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/340fxer6uczx7.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\n1e:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n1f:T29f3,// Time:  O(nlogn)\n// Space: O(n)\n\n#include <ext/pb_ds/assoc_container.hpp>\n#include <ext/pb_ds/tree_policy.hpp>\nusing namespace __gnu_pbds;\n\n// bit, fenwick tree, ordered set, math\nclass Solution {\npublic:\n    int sumCounts(vector<int>& nums) {\n        static const int MOD = 1e9 + 7;\n\n        using ordered_set = tree<int, null_type, less<int>, rb_tree_tag, tree_order_statistics_node_update>;\n        ordered_set os;\n        unordered_map<int, vector<int>> idxs;\n        for (int i = size(nums) - 1; i >= 0; --i) {\n            idxs[nums[i]].emplace_back(i);\n        }\n        for (const auto& [_, v] : idxs) {\n            os.insert(v.back());\n        }\n        int result = 0;\n        int accu = ((static_cast<int64_t>(size(nums)) * size(os)) % MOD) * size(os) % MOD;\n        for (int i = 0; i < size(os); ++i) {\n            accu = ((accu - (static_cast<int64_t>(2 * i + 1) * *os.find_by_order(i) % MOD)) % MOD + MOD) % MOD;\n        }\n        BIT bit(size(nums));\n        for (const auto& x : os) {\n            bit.add(x, x);\n        }\n\n        const auto& update = [&](int x, int accu, int d) {\n            const int i = os.order_of_key(idxs[x].back());\n            accu = ((accu + d * (static_cast<int64_t>(size(nums)) * (2 * static_cast<int>(size(os)) - 1)\n                                 - static_cast<int64_t>(2 * i + 1) * idxs[x].back()\n                                 - 2ll * (bit.query(size(nums) - 1) - bit.query(idxs[x].back())))) % MOD + MOD) % MOD;\n            bit.add(idxs[x].back(), d * idxs[x].back());\n            return accu;\n        };\n\n        for (const auto& x : nums) {\n            result = (result + accu) % MOD;  // accu = sum(count(i, k) for k in range(i, len(nums)))\n            accu = update(x, accu, -1);\n            os.erase(idxs[x].back());\n            idxs[x].pop_back();\n            if (empty(idxs[x])) {\n                continue;\n            }\n            os.insert(idxs[x].back());\n            accu = update(x, accu, +1);\n        }\n        assert(accu == 0);\n        return result;\n    }\n\nprivate:\n    class BIT {\n    public:\n        BIT(int n) : bit_(n + 1) {  // 0-indexed\n        }\n        \n        void add(int i, int val) {\n            ++i;\n            for (; i < size(bit_); i += lower_bit(i)) {\n                bit_[i] = (bit_[i] + val) % MOD;\n            }\n        }\n\n        int query(int i) const {\n            ++i;\n            int total = 0;\n            for (; i > 0; i -= lower_bit(i)) {\n                total = (total + bit_[i]) % MOD;\n            }\n            return total;\n        }\n    \n    private:\n        int lower_bit(int i) const {\n            return i & -i;\n        }\n        \n        vector<int> bit_;\n        static const int MOD = 1e9 + 7;\n    };\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// dp, segment tree, math\nclass Solution2 {\npublic:\n    int sumCounts(vector<int>& nums) {\n        static const int MOD = 1e9 + 7;\n\n        int result = 0, accu = 0;\n        unordered_map<int, int> lookup;\n        SegmentTree st(size(nums));\n        for (int i = 0; i < size(nums); ++i) {\n            const int j = lookup.count(nums[i]) ? lookup[nums[i]] : -1;\n            // sum(count(k, i)^2 for k in range(i+1)) - sum(count(k, i-1)^2 for k in range(i))\n            // = sum(2*count(k, i-1)+1 for k in range(j+1, i+1))\n            // = (i-j) + sum(2*count(k, i-1) for k in range(j+1, i+1))\n            accu = (accu + ((i - j) + 2ll * st.query(j + 1, i))) % MOD;\n            result = (result + accu) % MOD;\n            st.update(j + 1, i, 1);  // count(k, i) = count(k, i-1)+(1 if k >= j+1 else 0) for k in range(i+1)\n            lookup[nums[i]] = i;\n        }\n        return result;\n    }\n\nprivate:\n    class SegmentTree {\n    private:\n        static const int MOD = 1e9 + 7;\n\n    public:\n        explicit SegmentTree(\n            int N)\n         :  base_(N > 1 ? 1 << (__lg(N - 1) + 1) : 1),\n            lazy_(base_),\n            tree_(N > 1 ? 1 << (__lg(N - 1) + 2) : 2),\n            count_(size(tree_), 1) {\n\n            for (int i = base_ - 1; i >= 1; --i) { // added\n                count_[i] = count_[i << 1] + count_[(i << 1) + 1];\n            }\n        }\n\n        void update(int L, int R, const int val) {\n            L += base_;\n            R += base_;\n            // push(L);  // enable if range assignment\n            // push(R);  // enable if range assignment\n            int L0 = L, R0 = R;\n            for (; L <= R; L >>= 1, R >>= 1) {\n                if ((L & 1) == 1) {\n                    apply(L++, val);\n                }\n                if ((R & 1) == 0) {\n                    apply(R--, val);\n                }\n            }\n            pull(L0);\n            pull(R0);\n        }\n\n        int query(int L, int R) {\n            if (L > R) {\n                return 0;\n            }\n            L += base_;\n            R += base_;\n            push(L);\n            push(R);\n            int left = 0, right = 0;\n            for (; L <= R; L >>= 1, R >>= 1) {\n                if ((L & 1) == 1) {\n                    left = (left + tree_[L++]) % MOD;\n                }\n                if ((R & 1) == 0) {\n                    right = (tree_[R--] + right) % MOD;\n                }\n            }\n            return (left + right) % MOD;\n        }\n\n    private:\n        void apply(int x, const int val) {\n            tree_[x] = (tree_[x] + static_cast<int64_t>(val) * count_[x]) % MOD;  // modified\n            if (x < base_) {\n                lazy_[x] = (lazy_[x] + val) % MOD;\n            }\n        }\n\n        void pull(int x) {\n            while (x > 1) {\n                x >>= 1;\n                tree_[x] = (tree_[x << 1] + tree_[(x << 1) + 1]) % MOD;\n                if (lazy_[x]) {\n                    tree_[x] = (tree_[x] + static_cast<int64_t>(lazy_[x]) * count_[x]) % MOD;  // modified\n                }\n            }\n        }\n\n        void push(int x) {\n            for (int h = __lg(x) - 1; h > 0; --h) {\n                int y = x >> h;\n                if (lazy_[y]) {\n                    apply(y << 1, lazy_[y]);\n                    apply((y << 1) + 1, lazy_[y]);\n                    lazy_[y] = 0;\n                }\n            }\n        }\n\n        int base_;\n        vector<int> tree_;\n        vector<int> lazy_;\n        vector<int> count_;  // added\n    };\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// dp, segment tree, math\nclass Solution3 {\npublic:\n    int sumCounts(vector<int>& nums) {\n        static const int MOD = 1e9 + 7;\n\n        const auto& sum = [&] (const auto& x, const auto& y) {\n            return (x + y) % MOD;\n        };\n\n        int result = 0, accu = 0;\n        unordered_map<int, int> lookup;\n        SegmentTree<int> st(size(nums), sum, sum);\n        for (int i = 0; i < size(nums); ++i) {\n            const int j = lookup.count(nums[i]) ? lookup[nums[i]] : -1;\n            // sum(count(k, i)^2 for k in range(i+1)) - sum(count(k, i-1)^2 for k in range(i))\n            // = sum(2*count(k, i-1)+1 for k in range(j+1, i+1))\n            // = (i-j) + sum(2*count(k, i-1) for k in range(j+1, i+1))\n            accu = (accu + ((i - j) + 2ll * st.query(j + 1, i))) % MOD;\n            result = (result + accu) % MOD;\n            st.update(j + 1, i, 1);  // count(k, i) = count(k, i-1)+(1 if k >= j+1 else 0) for k in range(i+1)\n            lookup[nums[i]] = i;\n        }\n        return result;\n    }\n\nprivate:\n    template <typename T>\n    class SegmentTree {\n    private:\n        static const int MOD = 1e9 + 7;\n\n    public:\n        explicit SegmentTree(\n            int N,\n            const function<T(const T&, const T&)>& query_fn,\n            const function<T(const T&, const T&)>& update_fn)\n         :  base_(N > 1 ? 1 << (__lg(N - 1) + 1) : 1),\n            lazy_(base_),\n            tree_(N > 1 ? 1 << (__lg(N - 1) + 2) : 2),\n            count_(size(tree_), 1),\n            query_fn_(query_fn),\n            update_fn_(update_fn) {\n\n            for (int i = base_ - 1; i >= 1; --i) { // added\n                count_[i] = count_[i << 1] + count_[(i << 1) + 1];\n            }\n        }\n\n        void update(int L, int R, const T& val) {\n            L += base_;\n            R += base_;\n            // push(L);  // enable if range assignment\n            // push(R);  // enable if range assignment\n            int L0 = L, R0 = R;\n            for (; L <= R; L >>= 1, R >>= 1) {\n                if ((L & 1) == 1) {\n                    apply(L++, val);\n                }\n                if ((R & 1) == 0) {\n                    apply(R--, val);\n                }\n            }\n            pull(L0);\n            pull(R0);\n        }\n\n        T query(int L, int R) {\n            if (L > R) {\n                return T{};\n            }\n            L += base_;\n            R += base_;\n            push(L);\n            push(R);\n            T left{}, right{};\n            for (; L <= R; L >>= 1, R >>= 1) {\n                if ((L & 1) == 1) {\n                    left = query_fn_(left, tree_[L++]);\n                }\n                if ((R & 1) == 0) {\n                    right = query_fn_(tree_[R--], right);\n                }\n            }\n            return query_fn_(left, right);\n        }\n\n    private:\n        void apply(int x, const T val) {\n            tree_[x] = update_fn_(tree_[x], (static_cast<int64_t>(val) * count_[x]) % MOD);  // modified\n            if (x < base_) {\n                lazy_[x] = update_fn_(lazy_[x], val);\n            }\n        }\n\n        void pull(int x) {\n            while (x > 1) {\n                x >>= 1;\n                tree_[x] = query_fn_(tree_[x << 1], tree_[(x << 1) + 1]);\n                if (lazy_[x]) {\n                    tree_[x] = update_fn_(tree_[x], (static_cast<int64_t>(lazy_[x]) * count_[x]) % MOD);  // modified\n                }\n            }\n        }\n\n        void push(int x) {\n            for (int h = __lg(x) - 1; h > 0; --h) {\n                int y = x >> h;\n                if (lazy_[y]) {\n                    apply(y << 1, lazy_[y]);\n                    apply((y << 1) + 1, lazy_[y]);\n                    lazy_[y] = 0;\n                }\n            }\n        }\n\n        int base_;\n        vector<T> tree_;\n        vector<T> lazy_;\n        vector<T> count_;  // added\n        const function<T(const T&, const T&)> query_fn_;\n        const function<T(const T&, const T&)> update_fn_;\n    };\n};\n\n// Time:  O(n^2)\n// Space: O(n)\n// hash table\nclass Solution4 {\npublic:\n    int sumCounts(vector<int>& nums) {\n        static const int MOD = 1e9 + 7;\n\n        int result = 0;\n        for (int i = 0; i < size(nums); ++i) {\n            unordered_set<int> lookup;\n            for (int j = i; j >= 0; --j) {\n                lookup.emplace(nums[j]);\n                result = (result + (static_cast<int64_t>(size(lookup)) * size(lookup) % MOD)) % MOD;\n            }\n        }\n        return result;\n    }\n};\n20:T1a18,# Time:  O(nlogn)\n# Space: O(n)\n\nimport collections\nfrom sortedcontainers import SortedList\n\n\n# bit, fenwick tree, sorted list, math\nclass Solution(object):\n    def sumCounts(self, nums):\n        \"\"\"\n        :type nums: List[int]\n        :rtype: int\n        \"\"\"\n        MOD = 10**9+7\n        class BIT(object):  # 0-indexed.\n            def __init__(self, n):\n                self.__bit = [0]*(n+1)  # Extra one for dummy node.\n\n            def add(self, i, val):\n                i += 1  # Extra one for dummy node.\n                while i < len(self.__bit):\n                    self.__bit[i] = (self.__bit[i]+val) % MOD\n                    i += (i & -i)\n\n            def query(self, i):\n                i += 1  # Extra one for dummy node.\n                ret = 0\n                while i > 0:\n                    ret = (ret+self.__bit[i]) % MOD\n                    i -= (i & -i)\n                return ret\n\n        def update(accu, d):\n            i = sl.bisect_left(idxs[x][-1])\n            accu = (accu + d*(len(nums)*(2*len(sl)-1) - (2*i+1)*idxs[x][-1] - 2*(bit.query(len(nums)-1)-bit.query(idxs[x][-1])))) % MOD\n            bit.add(idxs[x][-1], d*idxs[x][-1])\n            return accu\n\n        idxs = collections.defaultdict(list)\n        for i in reversed(xrange(len(nums))):\n            idxs[nums[i]].append(i)\n        result = 0\n        sl = SortedList(idxs[x][-1] for x in idxs)\n        accu = (len(nums)*len(sl)**2) % MOD\n        for i, x in enumerate(sl):\n            accu = (accu-(2*i+1)*x) % MOD\n        bit = BIT(len(nums))\n        for x in sl:\n            bit.add(x, x)\n        for x in nums:\n            result = (result+accu) % MOD  # accu = sum(count(i, k) for k in range(i, len(nums)))\n            accu = update(accu, -1)\n            del sl[0]\n            idxs[x].pop()\n            if not idxs[x]:\n                continue\n            sl.add(idxs[x][-1])\n            accu = update(accu, +1)\n        assert(accu == 0)\n        return result\n\n\n# Time:  O(nlogn)\n# Space: O(n)\n# dp, segment tree, math\nclass Solution2(object):\n    def sumCounts(self, nums):\n        \"\"\"\n        :type nums: List[int]\n        :rtype: int\n        \"\"\"\n        MOD = 10**9+7\n        # Template:\n        # https://github.com/kamyu104/LeetCode-Solutions/blob/master/Python/longest-substring-of-one-repeating-character.py\n        class SegmentTree(object):\n            def __init__(self, N,\n                         build_fn=None,\n                         query_fn=lambda x, y: y if x is None else x if y is None else (x+y)%MOD,\n                         update_fn=lambda x, y: y if x is None else (x+y)%MOD):\n                self.tree = [None]*(1<<((N-1).bit_length()+1))\n                self.base = len(self.tree)>>1\n                self.lazy = [None]*self.base\n                self.query_fn = query_fn\n                self.update_fn = update_fn\n                if build_fn is not None:\n                    for i in xrange(self.base, self.base+N):\n                        self.tree[i] = build_fn(i-self.base)\n                    for i in reversed(xrange(1, self.base)):\n                        self.tree[i] = query_fn(self.tree[i<<1], self.tree[(i<<1)+1])\n                self.count = [1]*len(self.tree)  # added\n                for i in reversed(xrange(1, self.base)):  # added\n                    self.count[i] = self.count[i<<1] + self.count[(i<<1)+1]\n\n            def __apply(self, x, val):\n                self.tree[x] = self.update_fn(self.tree[x], val*self.count[x])  # modified\n                if x < self.base:\n                    self.lazy[x] = self.update_fn(self.lazy[x], val)\n\n            def __push(self, x):\n                for h in reversed(xrange(1, x.bit_length())):\n                    y = x>>h\n                    if self.lazy[y] is not None:\n                        self.__apply(y<<1, self.lazy[y])\n                        self.__apply((y<<1)+1, self.lazy[y])\n                        self.lazy[y] = None\n\n            def update(self, L, R, h):  # Time: O(logN), Space: O(N)\n                def pull(x):\n                    while x > 1:\n                        x >>= 1\n                        self.tree[x] = self.query_fn(self.tree[x<<1], self.tree[(x<<1)+1])\n                        if self.lazy[x] is not None:\n                            self.tree[x] = self.update_fn(self.tree[x], self.lazy[x]*self.count[x])  # modified\n\n                L += self.base\n                R += self.base\n                # self.__push(L)  # enable if range assignment\n                # self.__push(R)  # enable if range assignment\n                L0, R0 = L, R\n                while L <= R:\n                    if L & 1:  # is right child\n                        self.__apply(L, h)\n                        L += 1\n                    if R & 1 == 0:  # is left child\n                        self.__apply(R, h)\n                        R -= 1\n                    L >>= 1\n                    R >>= 1\n                pull(L0)\n                pull(R0)\n\n            def query(self, L, R):\n                if L > R:\n                    return None\n                L += self.base\n                R += self.base\n                self.__push(L)\n                self.__push(R)\n                left = right = None\n                while L <= R:\n                    if L & 1:\n                        left = self.query_fn(left, self.tree[L])\n                        L += 1\n                    if R & 1 == 0:\n                        right = self.query_fn(self.tree[R], right)\n                        R -= 1\n                    L >>= 1\n                    R >>= 1\n                return self.query_fn(left, right)\n\n        result = accu = 0\n        sl = {}\n        st = SegmentTree(len(nums))\n        for i in xrange(len(nums)):\n            j = sl[nums[i]] if nums[i] in sl else -1\n            # sum(count(k, i)^2 for k in range(i+1)) - sum(count(k, i-1)^2 for k in range(i))\n            # = sum(2*count(k, i-1)+1 for k in range(j+1, i+1))\n            # = (i-j) + sum(2*count(k, i-1) for k in range(j+1, i+1))\n            accu = (accu+((i-j)+2*max(st.query(j+1, i), 0)))%MOD\n            result = (result+accu)%MOD\n            st.update(j+1, i, 1)  # count(k, i) = count(k, i-1)+(1 if k >= j+1 else 0) for k in range(i+1)\n            sl[nums[i]] = i\n        return result\n\n\n# Time:  O(n^2)\n# Space: O(n)\n# hash table\nclass Solution3(object):\n    def sumCounts(self, nums):\n        \"\"\"\n        :type nums: List[int]\n        :rtype: int\n        \"\"\"\n        MOD = 10**9+7\n        result = 0\n        for i in xrange(len(nums)):\n            lookup = set()\n            for j in reversed(xrange(i+1)):\n                lookup.add(nums[j])\n                result = (result+len(lookup)**2) % MOD\n        return result\n15:[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Subarrays Distinct Element Sum of Squares I\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/subarrays-distinct-element-sum-of-squares-i\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"C++\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/subarrays-distinct-element-sum-of-squares-i/cpp\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[[\"$\",\"li\",\"/\",{\"className\":\"flex items-center gap-1.5\",\"children\":[false,[\"$\",\"$L3\",null,{\"href\":\"/\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Home\"}]]}],[\"$\",\"li\",\"/problems\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Problems\"}]]}],[\"$\",\"li\",\"/problems/subarrays-distinct-element-sum-of-squares-i\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"$L3\",null,{\"href\":\"/problems/subarrays-distinct-element-sum-of-squares-i\",\"className\":\"hover:text-primary transition-colors\",\"children\":\"Subarrays Distinct Element Sum of Squares I\"}]]}],[\"$\",\"li\",\"/problems/subarrays-distinct-element-sum-of-squares-i/cpp\",{\"className\":\"flex items-center gap-1.5\",\"children\":[[\"$\",\"span\",null,{\"aria-hidden\":true,\"className\":\"text-border\",\"children\":\"/\"}],[\"$\",\"span\",null,{\"className\":\"text-foreground font-medium\",\"aria-current\":\"page\",\"children\":\"C++\"}]]}]]}]]}],[\"$\",\"div\",null,{\"className\":\"mt-4 flex flex-wrap items-center gap-2\",\"children\":[\"$\",\"span\",null,{\"className\":\"inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold tracking-wide bg-easy/15 text-easy\",\"children\":\"Easy\"}]}],[\"$\",\"h1\",null,{\"className\":\"mt-3 text-3xl font-bold tracking-tight\",\"children\":[\"Subarrays Distinct Element Sum of Squares I\",\" — \",\"C++\"]}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-muted-foreground\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/problems/subarrays-distinct-element-sum-of-squares-i\",\"className\":\"text-primary hover:underline\",\"children\":\"Full explanation\"}],\" · \",\"Time \",\"O(nlogn)\",\" · Space \",\"O(n)\"]}],[\"$\",\"div\",null,{\"className\":\"mt-8\",\"children\":[\"$\",\"$L1e\",null,{\"solutions\":{\"cpp\":{\"language\":\"C++\",\"languageSlug\":\"cpp\",\"filename\":\"subarrays-distinct-element-sum-of-squares-i.cpp\",\"code\":\"$1f\",\"sourcePath\":\"C++/subarrays-distinct-element-sum-of-squares-i.cpp\"},\"python\":{\"language\":\"Python\",\"languageSlug\":\"python\",\"filename\":\"subarrays-distinct-element-sum-of-squares-i.py\",\"code\":\"$20\",\"sourcePath\":\"Python/subarrays-distinct-element-sum-of-squares-i.py\"}},\"defaultLang\":\"cpp\"}]}]]}]\n1b:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n21:I[27201,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"IconMark\"]\n18:null\n1d:[[\"$\",\"title\",\"0\",{\"children\":\"Subarrays Distinct Element Sum of Squares I C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"C++ solution for Subarrays Distinct Element Sum of Squares I (LeetCode #2913). Time O(nlogn), space O(n).\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"Subarrays Distinct Element Sum of Squares I cpp,Subarrays Distinct Element Sum of Squares I C++,cpp leetcode\"}],[\"$\",\"link\",\"3\",{\"rel\":\"canonical\",\"href\":\"https://algoforge.dev/problems/subarrays-distinct-element-sum-of-squares-i/cpp\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:title\",\"content\":\"Subarrays Distinct Element Sum of Squares I C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:description\",\"content\":\"C++ solution for Subarrays Distinct Element Sum of Squares I (LeetCode #2913). Time O(nlogn), space O(n).\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:url\",\"content\":\"https://algoforge.dev/problems/subarrays-distinct-element-sum-of-squares-i/cpp\"}],[\"$\",\"meta\",\"7\",{\"property\":\"og:site_name\",\"content\":\"AlgoForge\"}],[\"$\",\"meta\",\"8\",{\"property\":\"og:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:image:width\",\"content\":\"1200\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:image:height\",\"content\":\"630\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:image:alt\",\"content\":\"Subarrays Distinct Element Sum of Squares I C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"13\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:title\",\"content\":\"Subarrays Distinct Element Sum of Squares I C++ Solution | AlgoForge\"}],[\"$\",\"meta\",\"15\",{\"name\":\"twitter:description\",\"content\":\"C++ solution for Subarrays Distinct Element Sum of Squares I (LeetCode #2913). Time O(nlogn), space O(n).\"}],[\"$\",\"meta\",\"16\",{\"name\":\"twitter:image\",\"content\":\"https://algoforge.dev/og-default.png\"}],[\"$\",\"link\",\"17\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.2vob68tjqpejf.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"link\",\"18\",{\"rel\":\"icon\",\"href\":\"/favicon.ico\"}],[\"$\",\"$L21\",\"19\",{}]]\n","/problems/$d$slug/$d$lang/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[522016,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"\"]\n3:I[705747,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\",\"/_next/static/chunks/0a2gmow1_jiq0.js\"],\"CodeTabs\"]\n8:I[897367,[\"/_next/static/chunks/2fvm6eoqeukxu.js\",\"/_next/static/chunks/1ntn7efqc-iiw.js\",\"/_next/static/chunks/0plpm2axnqe9k.js\"],\"OutletBoundary\"]\n9:\"$Sreact.suspense\"\n4:T29f3,// Time:  O(nlogn)\n// Space: O(n)\n\n#include <ext/pb_ds/assoc_container.hpp>\n#include <ext/pb_ds/tree_policy.hpp>\nusing namespace __gnu_pbds;\n\n// bit, fenwick tree, ordered set, math\nclass Solution {\npublic:\n    int sumCounts(vector<int>& nums) {\n        static const int MOD = 1e9 + 7;\n\n        using ordered_set = tree<int, null_type, less<int>, rb_tree_tag, tree_order_statistics_node_update>;\n        ordered_set os;\n        unordered_map<int, vector<int>> idxs;\n        for (int i = size(nums) - 1; i >= 0; --i) {\n            idxs[nums[i]].emplace_back(i);\n        }\n        for (const auto& [_, v] : idxs) {\n            os.insert(v.back());\n        }\n        int result = 0;\n        int accu = ((static_cast<int64_t>(size(nums)) * size(os)) % MOD) * size(os) % MOD;\n        for (int i = 0; i < size(os); ++i) {\n            accu = ((accu - (static_cast<int64_t>(2 * i + 1) * *os.find_by_order(i) % MOD)) % MOD + MOD) % MOD;\n        }\n        BIT bit(size(nums));\n        for (const auto& x : os) {\n            bit.add(x, x);\n        }\n\n        const auto& update = [&](int x, int accu, int d) {\n            const int i = os.order_of_key(idxs[x].back());\n            accu = ((accu + d * (static_cast<int64_t>(size(nums)) * (2 * static_cast<int>(size(os)) - 1)\n                                 - static_cast<int64_t>(2 * i + 1) * idxs[x].back()\n                                 - 2ll * (bit.query(size(nums) - 1) - bit.query(idxs[x].back())))) % MOD + MOD) % MOD;\n            bit.add(idxs[x].back(), d * idxs[x].back());\n            return accu;\n        };\n\n        for (const auto& x : nums) {\n            result = (result + accu) % MOD;  // accu = sum(count(i, k) for k in range(i, len(nums)))\n            accu = update(x, accu, -1);\n            os.erase(idxs[x].back());\n            idxs[x].pop_back();\n            if (empty(idxs[x])) {\n                continue;\n            }\n            os.insert(idxs[x].back());\n            accu = update(x, accu, +1);\n        }\n        assert(accu == 0);\n        return result;\n    }\n\nprivate:\n    class BIT {\n    public:\n        BIT(int n) : bit_(n + 1) {  // 0-indexed\n        }\n        \n        void add(int i, int val) {\n            ++i;\n            for (; i < size(bit_); i += lower_bit(i)) {\n                bit_[i] = (bit_[i] + val) % MOD;\n            }\n        }\n\n        int query(int i) const {\n            ++i;\n            int total = 0;\n            for (; i > 0; i -= lower_bit(i)) {\n                total = (total + bit_[i]) % MOD;\n            }\n            return total;\n        }\n    \n    private:\n        int lower_bit(int i) const {\n            return i & -i;\n        }\n        \n        vector<int> bit_;\n        static const int MOD = 1e9 + 7;\n    };\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// dp, segment tree, math\nclass Solution2 {\npublic:\n    int sumCounts(vector<int>& nums) {\n        static const int MOD = 1e9 + 7;\n\n        int result = 0, accu = 0;\n        unordered_map<int, int> lookup;\n        SegmentTree st(size(nums));\n        for (int i = 0; i < size(nums); ++i) {\n            const int j = lookup.count(nums[i]) ? lookup[nums[i]] : -1;\n            // sum(count(k, i)^2 for k in range(i+1)) - sum(count(k, i-1)^2 for k in range(i))\n            // = sum(2*count(k, i-1)+1 for k in range(j+1, i+1))\n            // = (i-j) + sum(2*count(k, i-1) for k in range(j+1, i+1))\n            accu = (accu + ((i - j) + 2ll * st.query(j + 1, i))) % MOD;\n            result = (result + accu) % MOD;\n            st.update(j + 1, i, 1);  // count(k, i) = count(k, i-1)+(1 if k >= j+1 else 0) for k in range(i+1)\n            lookup[nums[i]] = i;\n        }\n        return result;\n    }\n\nprivate:\n    class SegmentTree {\n    private:\n        static const int MOD = 1e9 + 7;\n\n    public:\n        explicit SegmentTree(\n            int N)\n         :  base_(N > 1 ? 1 << (__lg(N - 1) + 1) : 1),\n            lazy_(base_),\n            tree_(N > 1 ? 1 << (__lg(N - 1) + 2) : 2),\n            count_(size(tree_), 1) {\n\n            for (int i = base_ - 1; i >= 1; --i) { // added\n                count_[i] = count_[i << 1] + count_[(i << 1) + 1];\n            }\n        }\n\n        void update(int L, int R, const int val) {\n            L += base_;\n            R += base_;\n            // push(L);  // enable if range assignment\n            // push(R);  // enable if range assignment\n            int L0 = L, R0 = R;\n            for (; L <= R; L >>= 1, R >>= 1) {\n                if ((L & 1) == 1) {\n                    apply(L++, val);\n                }\n                if ((R & 1) == 0) {\n                    apply(R--, val);\n                }\n            }\n            pull(L0);\n            pull(R0);\n        }\n\n        int query(int L, int R) {\n            if (L > R) {\n                return 0;\n            }\n            L += base_;\n            R += base_;\n            push(L);\n            push(R);\n            int left = 0, right = 0;\n            for (; L <= R; L >>= 1, R >>= 1) {\n                if ((L & 1) == 1) {\n                    left = (left + tree_[L++]) % MOD;\n                }\n                if ((R & 1) == 0) {\n                    right = (tree_[R--] + right) % MOD;\n                }\n            }\n            return (left + right) % MOD;\n        }\n\n    private:\n        void apply(int x, const int val) {\n            tree_[x] = (tree_[x] + static_cast<int64_t>(val) * count_[x]) % MOD;  // modified\n            if (x < base_) {\n                lazy_[x] = (lazy_[x] + val) % MOD;\n            }\n        }\n\n        void pull(int x) {\n            while (x > 1) {\n                x >>= 1;\n                tree_[x] = (tree_[x << 1] + tree_[(x << 1) + 1]) % MOD;\n                if (lazy_[x]) {\n                    tree_[x] = (tree_[x] + static_cast<int64_t>(lazy_[x]) * count_[x]) % MOD;  // modified\n                }\n            }\n        }\n\n        void push(int x) {\n            for (int h = __lg(x) - 1; h > 0; --h) {\n                int y = x >> h;\n                if (lazy_[y]) {\n                    apply(y << 1, lazy_[y]);\n                    apply((y << 1) + 1, lazy_[y]);\n                    lazy_[y] = 0;\n                }\n            }\n        }\n\n        int base_;\n        vector<int> tree_;\n        vector<int> lazy_;\n        vector<int> count_;  // added\n    };\n};\n\n// Time:  O(nlogn)\n// Space: O(n)\n// dp, segment tree, math\nclass Solution3 {\npublic:\n    int sumCounts(vector<int>& nums) {\n        static const int MOD = 1e9 + 7;\n\n        const auto& sum = [&] (const auto& x, const auto& y) {\n            return (x + y) % MOD;\n        };\n\n        int result = 0, accu = 0;\n        unordered_map<int, int> lookup;\n        SegmentTree<int> st(size(nums), sum, sum);\n        for (int i = 0; i < size(nums); ++i) {\n            const int j = lookup.count(nums[i]) ? lookup[nums[i]] : -1;\n            // sum(count(k, i)^2 for k in range(i+1)) - sum(count(k, i-1)^2 for k in range(i))\n            // = sum(2*count(k, i-1)+1 for k in range(j+1, i+1))\n            // = (i-j) + sum(2*count(k, i-1) for k in range(j+1, i+1))\n            accu = (accu + ((i - j) + 2ll * st.query(j + 1, i))) % MOD;\n            result = (result + accu) % MOD;\n            st.update(j + 1, i, 1);  // count(k, i) = count(k, i-1)+(1 if k >= j+1 else 0) for k in range(i+1)\n            lookup[nums[i]] = i;\n        }\n        return result;\n    }\n\nprivate:\n    template <typename T>\n    class SegmentTree {\n    private:\n        static const int MOD = 1e9 + 7;\n\n    public:\n        explicit SegmentTree(\n            int N,\n            const function<T(const T&, const T&)>& query_fn,\n            const function<T(const T&, const T&)>& update_fn)\n         :  base_(N > 1 ? 1 << (__lg(N - 1) + 1) : 1),\n            lazy_(base_),\n            tree_(N > 1 ? 1 << (__lg(N - 1) + 2) : 2),\n            count_(size(tree_), 1),\n            query_fn_(query_fn),\n            update_fn_(update_fn) {\n\n            for (int i = base_ - 1; i >= 1; --i) { // added\n                count_[i] = count_[i << 1] + count_[(i << 1) + 1];\n            }\n        }\n\n        void update(int L, int R, const T& val) {\n            L += base_;\n            R += base_;\n            // push(L);  // enable if range assignment\n            // push(R);  // enable if range assignment\n            int L0 = L, R0 = R;\n            for (; L <= R; L >>= 1, R >>= 1) {\n                if ((L & 1) == 1) {\n                    apply(L++, val);\n                }\n                if ((R & 1) == 0) {\n                    apply(R--, val);\n                }\n            }\n            pull(L0);\n            pull(R0);\n        }\n\n        T query(int L, int R) {\n            if (L > R) {\n                return T{};\n            }\n            L += base_;\n            R += base_;\n            push(L);\n            push(R);\n            T left{}, right{};\n            for (; L <= R; L >>= 1, R >>= 1) {\n                if ((L & 1) == 1) {\n                    left = query_fn_(left, tree_[L++]);\n                }\n                if ((R & 1) == 0) {\n                    right = query_fn_(tree_[R--], right);\n                }\n            }\n            return query_fn_(left, right);\n        }\n\n    private:\n        void apply(int x, const T val) {\n            tree_[x] = update_fn_(tree_[x], (static_cast<int64_t>(val) * count_[x]) % MOD);  // modified\n            if (x < base_) {\n                lazy_[x] = update_fn_(lazy_[x], val);\n            }\n        }\n\n        void pull(int x) {\n            while (x > 1) {\n                x >>= 1;\n                tree_[x] = query_fn_(tree_[x << 1], tree_[(x << 1) + 1]);\n                if (lazy_[x]) {\n                    tree_[x] = update_fn_(tree_[x], (static_cast<int64_t>(lazy_[x]) * count_[x]) % MOD);  // modified\n                }\n            }\n        }\n\n        void push(int x) {\n            for (int h = __lg(x) - 1; h > 0; --h) {\n                int y = x >> h;\n                if (lazy_[y]) {\n                    apply(y << 1, lazy_[y]);\n                    apply((y << 1) + 1, lazy_[y]);\n                    lazy_[y] = 0;\n                }\n            }\n        }\n\n        int base_;\n        vector<T> tree_;\n        vector<T> lazy_;\n        vector<T> count_;  // added\n        const function<T(const T&, const T&)> query_fn_;\n        const function<T(const T&, const T&)> update_fn_;\n    };\n};\n\n// Time:  O(n^2)\n// Space: O(n)\n// hash table\nclass Solution4 {\npublic:\n    int sumCounts(vector<int>& nums) {\n        static const int MOD = 1e9 + 7;\n\n        int result = 0;\n        for (int i = 0; i < size(nums); ++i) {\n            unordered_set<int> lookup;\n            for (int j = i; j >= 0; --j) {\n                lookup.emplace(nums[j]);\n                result = (result + (static_cast<int64_t>(size(lookup)) * size(lookup) % MOD)) % MOD;\n            }\n        }\n        return result;\n    }\n};\n5:T1a18,# Time:  O(nlogn)\n# Space: O(n)\n\nimport collections\nfrom sortedcontainers import SortedList\n\n\n# bit, fenwick tree, sorted list, math\nclass Solution(object):\n    def sumCounts(self, nums):\n        \"\"\"\n        :type nums: List[int]\n        :rtype: int\n        \"\"\"\n        MOD = 10**9+7\n        class BIT(object):  # 0-indexed.\n            def __init__(self, n):\n                self.__bit = [0]*(n+1)  # Extra one for dummy node.\n\n            def add(self, i, val):\n                i += 1  # Extra one for dummy node.\n                while i < len(self.__bit):\n                    self.__bit[i] = (self.__bit[i]+val) % MOD\n                    i += (i & -i)\n\n            def query(self, i):\n                i += 1  # Extra one for dummy node.\n                ret = 0\n                while i > 0:\n                    ret = (ret+self.__bit[i]) % MOD\n                    i -= (i & -i)\n                return ret\n\n        def update(accu, d):\n            i = sl.bisect_left(idxs[x][-1])\n            accu = (accu + d*(len(nums)*(2*len(sl)-1) - (2*i+1)*idxs[x][-1] - 2*(bit.query(len(nums)-1)-bit.query(idxs[x][-1])))) % MOD\n            bit.add(idxs[x][-1], d*idxs[x][-1])\n            return accu\n\n        idxs = collections.defaultdict(list)\n        for i in reversed(xrange(len(nums))):\n            idxs[nums[i]].append(i)\n        result = 0\n        sl = SortedList(idxs[x][-1] for x in idxs)\n        accu = (len(nums)*len(sl)**2) % MOD\n        for i, x in enumerate(sl):\n            accu = (accu-(2*i+1)*x) % MOD\n        bit = BIT(len(nums))\n        for x in sl:\n            bit.add(x, x)\n        for x in nums:\n            result = (result+accu) % MOD  # accu = sum(count(i, k) for k in range(i, len(nums)))\n            accu = update(accu, -1)\n            del sl[0]\n            idxs[x].pop()\n            if not idxs[x]:\n                continue\n            sl.add(idxs[x][-1])\n            accu = update(accu, +1)\n        assert(accu == 0)\n        return result\n\n\n# Time:  O(nlogn)\n# Space: O(n)\n# dp, segment tree, math\nclass Solution2(object):\n    def sumCounts(self, nums):\n        \"\"\"\n        :type nums: List[int]\n        :rtype: int\n        \"\"\"\n        MOD = 10**9+7\n        # Template:\n        # https://github.com/kamyu104/LeetCode-Solutions/blob/master/Python/longest-substring-of-one-repeating-character.py\n        class SegmentTree(object):\n            def __init__(self, N,\n                         build_fn=None,\n                         query_fn=lambda x, y: y if x is None else x if y is None else (x+y)%MOD,\n                         update_fn=lambda x, y: y if x is None else (x+y)%MOD):\n                self.tree = [None]*(1<<((N-1).bit_length()+1))\n                self.base = len(self.tree)>>1\n                self.lazy = [None]*self.base\n                self.query_fn = query_fn\n                self.update_fn = update_fn\n                if build_fn is not None:\n                    for i in xrange(self.base, self.base+N):\n                        self.tree[i] = build_fn(i-self.base)\n                    for i in reversed(xrange(1, self.base)):\n                        self.tree[i] = query_fn(self.tree[i<<1], self.tree[(i<<1)+1])\n                self.count = [1]*len(self.tree)  # added\n                for i in reversed(xrange(1, self.base)):  # added\n                    self.count[i] = self.count[i<<1] + self.count[(i<<1)+1]\n\n            def __apply(self, x, val):\n                self.tree[x] = self.update_fn(self.tree[x], val*self.count[x])  # modified\n                if x < self.base:\n                    self.lazy[x] = self.update_fn(self.lazy[x], val)\n\n            def __push(self, x):\n                for h in reversed(xrange(1, x.bit_length())):\n                    y = x>>h\n                    if self.lazy[y] is not None:\n                        self.__apply(y<<1, self.lazy[y])\n                        self.__apply((y<<1)+1, self.lazy[y])\n                        self.lazy[y] = None\n\n            def update(self, L, R, h):  # Time: O(logN), Space: O(N)\n                def pull(x):\n                    while x > 1:\n                        x >>= 1\n                        self.tree[x] = self.query_fn(self.tree[x<<1], self.tree[(x<<1)+1])\n                        if self.lazy[x] is not None:\n                            self.tree[x] = self.update_fn(self.tree[x], self.lazy[x]*self.count[x])  # modified\n\n                L += self.base\n                R += self.base\n                # self.__push(L)  # enable if range assignment\n                # self.__push(R)  # enable if range assignment\n                L0, R0 = L, R\n                while L <= R:\n                    if L & 1:  # is right child\n                        self.__apply(L, h)\n                        L += 1\n                    if R & 1 == 0:  # is left child\n                        self.__apply(R, h)\n                        R -= 1\n                    L >>= 1\n                    R >>= 1\n                pull(L0)\n                pull(R0)\n\n            def query(self, L, R):\n                if L > R:\n                    return None\n                L += self.base\n                R += self.base\n                self.__push(L)\n                self.__push(R)\n                left = right = None\n                while L <= R:\n                    if L & 1:\n                        left = self.query_fn(left, self.tree[L])\n                        L += 1\n                    if R & 1 == 0:\n                        right = self.query_fn(self.tree[R], right)\n                        R -= 1\n                    L >>= 1\n                    R >>= 1\n                return self.query_fn(left, right)\n\n        result = accu = 0\n        sl = {}\n        st = SegmentTree(len(nums))\n        for i in xrange(len(nums)):\n            j = sl[nums[i]] if nums[i] in sl else -1\n            # sum(count(k, i)^2 for k in range(i+1)) - sum(count(k, i-1)^2 for k in range(i))\n            # = sum(2*count(k, i-1)+1 for k in range(j+1, i+1))\n            # = (i-j) + sum(2*count(k, i-1) for k in range(j+1, i+1))\n            accu = (accu+((i-j)+2*max(st.query(j+1, i), 0)))%MOD\n            result = (result+accu)%MOD\n            st.update(j+1, i, 1)  # count(k, i) = count(k, i-1)+(1 if k >= j+1 else 0) for k in range(i+1)\n            sl[nums[i]] = i\n        return result\n\n\n# Time:  O(n^2)\n# Space: O(n)\n# hash table\nclass Solution3(object):\n    def sumCounts(self, nums):\n        \"\"\"\n        :type nums: List[int]\n        :rtype: int\n        \"\"\"\n        MOD = 10**9+7\n        result = 0\n        for i in xrange(len(nums)):\n            lookup = set()\n            for j in reversed(xrange(i+1)):\n                lookup.add(nums[j])\n                result = (result+len(lookup)**2) % MOD\n        return result\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"div\",null,{\"className\":\"container-af py-10\",\"children\":[[\"$\",\"nav\",null,{\"aria-label\":\"Breadcrumb\",\"className\":\"text-sm text-muted-foreground\",\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"BreadcrumbList\\\",\\\"itemListElement\\\":[{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":1,\\\"name\\\":\\\"Home\\\",\\\"item\\\":\\\"https://algoforge.dev/\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":2,\\\"name\\\":\\\"Problems\\\",\\\"item\\\":\\\"https://algoforge.dev/problems\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":3,\\\"name\\\":\\\"Subarrays Distinct Element Sum of Squares I\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/subarrays-distinct-element-sum-of-squares-i\\\"},{\\\"@type\\\":\\\"ListItem\\\",\\\"position\\\":4,\\\"name\\\":\\\"C++\\\",\\\"item\\\":\\\"https://algoforge.dev/problems/subarrays-distinct-element-sum-of-squares-i/cpp\\\"}]}\"}}],[\"$\",\"ol\",null,{\"className\":\"flex flex-wrap items-center gap-1.5\",\"children\":[